{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Clasp Benchmark Result",
  "type": "object",
  "required": [
    "taskId",
    "suite",
    "language",
    "harness",
    "model",
    "startedAt",
    "finishedAt",
    "durationMs",
    "humanInterventions",
    "tokenUsage",
    "verification"
  ],
  "properties": {
    "taskId": {
      "type": "string"
    },
    "suite": {
      "type": "string"
    },
    "language": {
      "type": "string"
    },
    "harness": {
      "type": "string"
    },
    "model": {
      "type": "string"
    },
    "startedAt": {
      "type": "string",
      "format": "date-time"
    },
    "finishedAt": {
      "type": "string",
      "format": "date-time"
    },
    "durationMs": {
      "type": "integer",
      "minimum": 0
    },
    "humanInterventions": {
      "type": "integer",
      "minimum": 0
    },
    "notes": {
      "type": "string"
    },
    "tokenUsage": {
      "type": "object",
      "required": [
        "prompt",
        "completion",
        "retry",
        "debug",
        "total"
      ],
      "properties": {
        "prompt": { "type": "integer", "minimum": 0 },
        "completion": { "type": "integer", "minimum": 0 },
        "retry": { "type": "integer", "minimum": 0 },
        "debug": { "type": "integer", "minimum": 0 },
        "total": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "harnessUsage": {
      "type": "object",
      "required": [
        "provider",
        "agentLogFile",
        "inputTokens",
        "cachedInputTokens",
        "outputTokens",
        "uncachedInputTokens",
        "uncachedTotal"
      ],
      "properties": {
        "provider": { "type": "string" },
        "agentLogFile": { "type": "string" },
        "inputTokens": { "type": "integer", "minimum": 0 },
        "cachedInputTokens": { "type": "integer", "minimum": 0 },
        "outputTokens": { "type": "integer", "minimum": 0 },
        "uncachedInputTokens": { "type": "integer", "minimum": 0 },
        "uncachedTotal": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "protocol": {
      "type": "object",
      "properties": {
        "schemaVersion": { "type": "integer", "minimum": 1 },
        "mode": {
          "type": "string",
          "enum": ["raw-repo", "file-hinted", "oracle"]
        },
        "workflowAssistance": {
          "type": "string"
        },
        "promptFile": { "type": "string" },
        "repeatedSamples": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "sampleIndex": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "runOrderPosition": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "randomizedOrderSeed": {
          "type": ["string", "null"]
        },
        "bundle": {
          "type": ["object", "null"],
          "properties": {
            "id": { "type": "string" },
            "manifestFile": { "type": "string" },
            "sha256": { "type": "string" }
          },
          "required": ["id", "manifestFile", "sha256"],
          "additionalProperties": false
        },
        "timingWindow": {
          "type": "object",
          "properties": {
            "startedAt": {
              "type": "string",
              "format": "date-time"
            },
            "finishedAt": {
              "type": "string",
              "format": "date-time"
            }
          },
          "required": ["startedAt", "finishedAt"],
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "phases": {
      "type": ["object", "null"],
      "properties": {
        "discoveryMs": { "type": "integer", "minimum": 0 },
        "firstEditMs": { "type": "integer", "minimum": 0 },
        "firstVerifyMs": { "type": "integer", "minimum": 0 },
        "timeToGreenMs": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "verification": {
      "type": "object",
      "required": [
        "passed",
        "command",
        "exitCode"
      ],
      "properties": {
        "passed": { "type": "boolean" },
        "command": {
          "type": "array",
          "items": { "type": "string" }
        },
        "exitCode": {
          "type": "integer"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
