{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Clasp Backend Benchmark Result",
  "type": "object",
  "required": [
    "schemaVersion",
    "generatedAt",
    "backendTarget",
    "mode",
    "compileBenchmarks",
    "runtimeBenchmarks"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 2
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "backendTarget": {
      "type": "string",
      "const": "native"
    },
    "mode": {
      "type": "string",
      "const": "native-only"
    },
    "environment": {
      "type": "object"
    },
    "compileBenchmarks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["workload", "input", "samples", "native"],
        "properties": {
          "workload": { "type": "string" },
          "input": { "type": "string" },
          "samples": { "type": "integer" },
          "native": {
            "type": "object",
            "required": ["command", "samplesMs", "medianMs"],
            "properties": {
              "command": { "type": "array", "items": { "type": "string" } },
              "samplesMs": { "type": "array", "items": { "type": "integer" } },
              "medianMs": { "type": "integer" }
            }
          }
        }
      }
    },
    "runtimeBenchmarks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["workload", "input", "iterations", "samples", "native"],
        "properties": {
          "workload": { "type": "string" },
          "input": { "type": "string" },
          "iterations": { "type": "integer" },
          "samples": { "type": "integer" },
          "native": {
            "type": "object",
            "required": ["command", "samplesMs", "medianMs", "checksum"],
            "properties": {
              "command": { "type": "array", "items": { "type": "string" } },
              "samplesMs": { "type": "array", "items": { "type": "integer" } },
              "medianMs": { "type": "integer" },
              "checksum": { "type": "integer" }
            }
          }
        }
      }
    }
  },
  "additionalProperties": true
}
