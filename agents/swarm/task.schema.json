{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clasp.dev/schemas/swarm-task.schema.json",
  "title": "Clasp Swarm Task Manifest",
  "description": "Schema for the parsed machine-readable manifest projected from a markdown swarm task file.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "taskId",
    "taskKey",
    "title",
    "goal",
    "why",
    "scope",
    "likelyFiles",
    "dependencies",
    "acceptance",
    "verification"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "taskId": {
      "type": "string",
      "pattern": "^[A-Z]{2,3}-[0-9]{3}(?:-[a-z0-9]+)*$"
    },
    "taskKey": {
      "type": "string",
      "pattern": "^[A-Z]{2,3}-[0-9]{3}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "why": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "likelyFiles": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z]{2,3}-[0-9]{3}$"
      }
    },
    "acceptance": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "shell",
        "command"
      ],
      "properties": {
        "shell": {
          "type": "string",
          "enum": [
            "sh",
            "bash"
          ]
        },
        "command": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
