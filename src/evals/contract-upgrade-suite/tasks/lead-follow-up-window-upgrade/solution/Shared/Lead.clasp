module Shared.Lead

type LeadPriority = Low | Medium | High

record Empty = {}

record LeadIntake = {
  company : Str,
  priority : LeadPriority
}

record LeadFollowUpDigest = {
  company : Str,
  priorityLabel : Str,
  followUpWindowDays : Int,
  escalationOwner : Str
}

record LeadPlaybookLookup = {
  followUpWindowDays : Int,
  escalationOwner : Str
}

record LeadPlaybook = {
  guidance : Str
}

record LeadFollowUpState = {
  digest : LeadFollowUpDigest
}
