module Shared.Lead

type LeadPriority = Low | Medium | High

record Empty = {}

record LeadIntake = {
  company : Str,
  priority : LeadPriority
}

record LeadDigest = {
  company : Str,
  priorityLabel : Str,
  owner : Str,
  needsFollowUp : Bool
}

record LeadPlaybookLookup = {
  owner : Str,
  needsFollowUp : Bool
}

record LeadPlaybook = {
  guidance : Str
}

record LeadFollowUpState = {
  digest : LeadDigest
}
