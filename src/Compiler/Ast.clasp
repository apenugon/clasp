appendMainDefinition : ParserState -> Str -> ParserState
appendMainDefinition state body = {
  let expr = parseExpr body;
  parserState (stateModuleName state) (stateImports state) (stateTypeDeclarations state) (stateRecordDeclarations state) (stateForeignDeclarations state) (appendDecl (stateDeclarations state) (hostedDeclAst "main" (statePendingAnnotation state) [] expr)) (stateGuideDeclarations state) (statePolicyDeclarations state) (stateAgentRoleDeclarations state) (stateAgentDeclarations state) (stateWorkflowDeclarations state) (stateHookDeclarations state) (stateToolServerDeclarations state) (stateToolDeclarations state) (stateVerifierDeclarations state) (stateMergeGateDeclarations state) missingAnnotation (expressionSummary expr)
}

stepParser : ParserState -> Str -> ParserState
stepParser state line = match textPrefix line "module " {
  Ok moduleName ->
    parserState moduleName (stateImports state) (stateTypeDeclarations state) (stateRecordDeclarations state) (stateForeignDeclarations state) (stateDeclarations state) (stateGuideDeclarations state) (statePolicyDeclarations state) (stateAgentRoleDeclarations state) (stateAgentDeclarations state) (stateWorkflowDeclarations state) (stateHookDeclarations state) (stateToolServerDeclarations state) (stateToolDeclarations state) (stateVerifierDeclarations state) (stateMergeGateDeclarations state) (statePendingAnnotation state) (stateMainExprSummary state),
  Err moduleMiss ->
    match textPrefix line "import " {
      Ok importName ->
        parserState (stateModuleName state) (appendRenderedText (stateImports state) importName) (stateTypeDeclarations state) (stateRecordDeclarations state) (stateForeignDeclarations state) (stateDeclarations state) (stateGuideDeclarations state) (statePolicyDeclarations state) (stateAgentRoleDeclarations state) (stateAgentDeclarations state) (stateWorkflowDeclarations state) (stateHookDeclarations state) (stateToolServerDeclarations state) (stateToolDeclarations state) (stateVerifierDeclarations state) (stateMergeGateDeclarations state) (statePendingAnnotation state) (stateMainExprSummary state),
      Err importMiss ->
        match textPrefix line "type " {
          Ok typeBody ->
            appendTypeDefinition state typeBody,
          Err notType ->
            match textPrefix line "record " {
              Ok recordBody ->
                appendRecordDefinition state recordBody,
              Err notRecord ->
                match textPrefix line "guide " {
                  Ok guideBody ->
                    appendGuideDefinition state guideBody,
                  Err notGuide ->
                    match textPrefix line "policy " {
                      Ok policyBody ->
                        appendPolicyDefinition state policyBody,
                      Err notPolicy ->
                        match textPrefix line "role " {
                          Ok roleBody ->
                            appendRoleDefinition state roleBody,
                          Err notRole ->
                            match textPrefix line "agent " {
                              Ok agentBody ->
                                appendAgentDefinition state agentBody,
                              Err notAgent ->
                                match textPrefix line "workflow " {
                                  Ok workflowBody ->
                                    appendWorkflowDefinition state workflowBody,
                                  Err notWorkflow ->
                                    match textPrefix line "hook " {
                                      Ok hookBody ->
                                        appendHookDefinition state hookBody,
                                      Err notHook ->
                                        match textPrefix line "toolserver " {
                                          Ok toolServerBody ->
                                            appendToolServerDefinition state toolServerBody,
                                          Err notToolServer ->
                                            match textPrefix line "tool " {
                                              Ok toolBody ->
                                                appendToolDefinition state toolBody,
                                              Err notTool ->
                                                match textPrefix line "verifier " {
                                                  Ok verifierBody ->
                                                    appendVerifierDefinition state verifierBody,
                                                  Err notVerifier ->
                                                    match textPrefix line "mergegate " {
                                                      Ok mergeGateBody ->
                                                        appendMergeGateDefinition state mergeGateBody,
                                                      Err notMergeGate ->
                                                        match textPrefix line "foreign " {
                                                          Ok foreignBody ->
                                                            appendForeignDefinition state foreignBody,
                                                          Err notForeign ->
                                                            match textPrefix line "hosted foreign-signature " {
                                                              Ok signatureBody ->
                                                                appendForeignSignatureDefinition state signatureBody,
                                                              Err notHostedSignature ->
                                                                {
                                                                  let words = splitWords line;
                                                                  match splitTokensAt ":" words {
                                                                    FoundTokenSplit lhsTokens rhsTokens ->
                                                                      if firstText (remainingTexts lhsTokens) == "" then parserState (stateModuleName state) (stateImports state) (stateTypeDeclarations state) (stateRecordDeclarations state) (stateForeignDeclarations state) (stateDeclarations state) (stateGuideDeclarations state) (statePolicyDeclarations state) (stateAgentRoleDeclarations state) (stateAgentDeclarations state) (stateWorkflowDeclarations state) (stateHookDeclarations state) (stateToolServerDeclarations state) (stateToolDeclarations state) (stateVerifierDeclarations state) (stateMergeGateDeclarations state) (presentAnnotation (parseHostedType (textJoin " " rhsTokens))) (stateMainExprSummary state) else match splitTokensAt "=" words {
                                                                        FoundTokenSplit definitionLhsTokens definitionRhsTokens ->
                                                                          if firstText definitionLhsTokens == "main" then appendMainDefinition state (textJoin " " definitionRhsTokens) else appendDefinition state (textJoin " " definitionLhsTokens) (textJoin " " definitionRhsTokens),
                                                                        MissingTokenSplit ->
                                                                          state
                                                                      },
                                                                    MissingTokenSplit ->
                                                                      match splitTokensAt "=" words {
                                                                        FoundTokenSplit definitionLhsTokens definitionRhsTokens ->
                                                                          if firstText definitionLhsTokens == "main" then appendMainDefinition state (textJoin " " definitionRhsTokens) else appendDefinition state (textJoin " " definitionLhsTokens) (textJoin " " definitionRhsTokens),
                                                                        MissingTokenSplit ->
                                                                          state
                                                                      }
                                                                  }
                                                                }
                                                            }
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

parseModuleAst : Str -> HostedModuleAst
parseModuleAst source = {
  let mut state = parserState "Main" [] [] [] [] [] [] [] [] [] [] [] [] [] [] [] missingAnnotation "<missing>";
  for line in logicalLines source {
    state = stepParser state line;
    state
  };
  hostedModuleAst (stateModuleName state) (stateImports state) (stateTypeDeclarations state) (stateRecordDeclarations state) (stateForeignDeclarations state) (stateDeclarations state) (stateGuideDeclarations state) (statePolicyDeclarations state) (stateAgentRoleDeclarations state) (stateAgentDeclarations state) (stateWorkflowDeclarations state) (stateHookDeclarations state) (stateToolServerDeclarations state) (stateToolDeclarations state) (stateVerifierDeclarations state) (stateMergeGateDeclarations state) (stateMainExprSummary state)
}

declNames : HostedModuleAst -> [Str]
declNames modl = {
  let mut names = [];
  for decl in moduleDeclarations modl {
    names = appendRenderedText names (declName decl);
    names
  };
  names
}

recordDeclNames : HostedModuleAst -> [Str]
recordDeclNames modl = {
  let mut names = [];
  for decl in moduleRecordDeclarations modl {
    names = appendRenderedText names (recordDeclName decl);
    names
  };
  names
}

firstRecordDecl : HostedModuleAst -> HostedRecordDeclAst
firstRecordDecl modl = {
  for decl in moduleRecordDeclarations modl {
    return decl
  };
  hostedRecordDeclAst "" []
}

typeDeclNames : HostedModuleAst -> [Str]
typeDeclNames modl = {
  let mut names = [];
  for decl in moduleTypeDeclarations modl {
    names = appendRenderedText names (typeDeclName decl);
    names
  };
  names
}

firstTypeDecl : HostedModuleAst -> HostedTypeDeclAst
firstTypeDecl modl = {
  for decl in moduleTypeDeclarations modl {
    return decl
  };
  hostedTypeDeclAst "" []
}

declAnnotationTextByName : HostedModuleAst -> Str -> Str
declAnnotationTextByName modl targetName = {
  for decl in moduleDeclarations modl {
    if declName decl == targetName then {
      return renderAnnotationAst (declAnnotation decl)
    } else {
      ""
    }
  };
  ""
}

renderMainExpr : HostedModuleAst -> Str
renderMainExpr modl = moduleMainExprSummary modl
