renderHostedTypeList : [HostedTypeAst] -> [Str]
renderHostedTypeList values = {
  let mut rendered = [];
  for value in values {
    rendered = appendRenderedText rendered (renderHostedType value);
    rendered
  };
  rendered
}

renderRecordFieldTypeSummaries : HostedRecordDeclAst -> [Str]
renderRecordFieldTypeSummaries decl = {
  let mut rendered = [];
  for field in recordDeclFields decl {
    rendered = appendRenderedText rendered (textConcat [recordFieldDeclName field, " : ", renderHostedType (recordFieldDeclType field)]);
    rendered
  };
  rendered
}

renderConstructorSummary : HostedConstructorDeclAst -> Str
renderConstructorSummary decl = {
  let name = constructorDeclName decl;
  let payloads = renderHostedTypeList (constructorDeclPayloadTypes decl);
  if firstText payloads == "" then name else textConcat [name, " ", textJoin " " payloads]
}

renderConstructorSummaries : HostedTypeDeclAst -> [Str]
renderConstructorSummaries decl = {
  let mut rendered = [];
  for constructorDecl in typeDeclConstructors decl {
    rendered = appendRenderedText rendered (renderConstructorSummary constructorDecl);
    rendered
  };
  rendered
}

hostedModuleAst : Str -> [Str] -> [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [HostedForeignDeclAst] -> [HostedDeclAst] -> [HostedGuideDeclAst] -> [HostedPolicyDeclAst] -> [HostedAgentRoleDeclAst] -> [HostedAgentDeclAst] -> [HostedWorkflowDeclAst] -> [HostedHookDeclAst] -> [HostedToolServerDeclAst] -> [HostedToolDeclAst] -> [HostedVerifierDeclAst] -> [HostedMergeGateDeclAst] -> Str -> HostedModuleAst
