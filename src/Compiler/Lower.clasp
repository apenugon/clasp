      HostedLessThanOrEqual left right ->
        LowerInvoke "filter" (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedGreaterThan left right ->
        LowerInvoke "filter" (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedGreaterThanOrEqual left right ->
        LowerInvoke "filter" (lowerExprs typeDecls recordDecls env localEnv fnContext args)
    }
  } else {
    LowerInvoke "filter" (lowerExprs typeDecls recordDecls env localEnv fnContext args)
  }
}

lowerAnyExpr : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [TypeBinding] -> [TypeBinding] -> ReturnContext -> [HostedExprAst] -> LowerExprText
lowerAnyExpr typeDecls recordDecls env localEnv fnContext args = {
  let functionExpr = firstHostedExpr args;
  let valuesExpr = firstHostedExpr (remainingHostedExprs args);
  let extraExpr = firstHostedExpr (remainingHostedExprs (remainingHostedExprs args));
  if expressionSummary functionExpr == "" then {
    LowerInvoke "any" (lowerExprs typeDecls recordDecls env localEnv fnContext args)
  } else if expressionSummary valuesExpr == "" then {
    LowerInvoke "any" (lowerExprs typeDecls recordDecls env localEnv fnContext args)
  } else if expressionSummary extraExpr == "" then {
    match functionExpr {
      HostedName functionName ->
        LowerListAny functionName (lowerExpr typeDecls recordDecls env localEnv fnContext valuesExpr),
      HostedString value ->
        LowerInvoke "any" (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedInt value ->
        LowerInvoke "any" (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedBool value ->
        LowerInvoke "any" (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedList values ->
