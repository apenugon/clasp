  }
}

lowerAllExpr : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [TypeBinding] -> [TypeBinding] -> ReturnContext -> [HostedExprAst] -> LowerExprText
lowerAllExpr typeDecls recordDecls env localEnv fnContext args = {
  let functionExpr = firstHostedExpr args;
  let valuesExpr = firstHostedExpr (remainingHostedExprs args);
  let extraExpr = firstHostedExpr (remainingHostedExprs (remainingHostedExprs args));
  if expressionSummary functionExpr == "" then {
    LowerInvoke "all" (lowerExprs typeDecls recordDecls env localEnv fnContext args)
  } else if expressionSummary valuesExpr == "" then {
    LowerInvoke "all" (lowerExprs typeDecls recordDecls env localEnv fnContext args)
  } else if expressionSummary extraExpr == "" then {
    match functionExpr {
      HostedName functionName ->
        LowerListAll functionName (lowerExpr typeDecls recordDecls env localEnv fnContext valuesExpr),
      HostedString value ->
        LowerInvoke "all" (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedInt value ->
