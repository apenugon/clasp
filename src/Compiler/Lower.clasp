    }
  } else {
    LowerInvoke "all" (lowerExprs typeDecls recordDecls env localEnv fnContext args)
  }
}

lowerFoldExpr : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [TypeBinding] -> [TypeBinding] -> ReturnContext -> [HostedExprAst] -> LowerExprText
lowerFoldExpr typeDecls recordDecls env localEnv fnContext args = {
  let functionExpr = firstHostedExpr args;
  let initialExpr = firstHostedExpr (remainingHostedExprs args);
  let valuesExpr = firstHostedExpr (remainingHostedExprs (remainingHostedExprs args));
  let extraExpr = firstHostedExpr (remainingHostedExprs (remainingHostedExprs (remainingHostedExprs args)));
  if expressionSummary functionExpr == "" then {
    LowerInvoke "fold" (lowerExprs typeDecls recordDecls env localEnv fnContext args)
  } else if expressionSummary initialExpr == "" then {
    LowerInvoke "fold" (lowerExprs typeDecls recordDecls env localEnv fnContext args)
  } else if expressionSummary valuesExpr == "" then {
    LowerInvoke "fold" (lowerExprs typeDecls recordDecls env localEnv fnContext args)
  } else if expressionSummary extraExpr == "" then {
    match functionExpr {
      HostedName functionName ->
        LowerListFold functionName (lowerExpr typeDecls recordDecls env localEnv fnContext initialExpr) (lowerExpr typeDecls recordDecls env localEnv fnContext valuesExpr),
      HostedString value ->
        LowerInvoke "fold" (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedInt value ->
        LowerInvoke "fold" (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedBool value ->
        LowerInvoke "fold" (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedList values ->
        LowerInvoke "fold" (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedCall callee values ->
        LowerInvoke "fold" (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedConstructor constructorName values ->
        LowerInvoke "fold" (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedMatch subject branches ->
        LowerInvoke "fold" (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedRecord recordName fields ->
        LowerInvoke "fold" (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedFieldAccess subject fieldName ->
        LowerInvoke "fold" (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedLet binder value body ->
        LowerInvoke "fold" (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedMutableLet binder value body ->
        LowerInvoke "fold" (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedAssign binder value body ->
        LowerInvoke "fold" (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedFor binder iterable loopBody body ->
        LowerInvoke "fold" (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedReturn value ->
        LowerInvoke "fold" (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedIf condition thenBranch elseBranch ->
        LowerInvoke "fold" (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedEqual left right ->
        LowerInvoke "fold" (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedNotEqual left right ->
        LowerInvoke "fold" (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedLessThan left right ->
        LowerInvoke "fold" (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedLessThanOrEqual left right ->
        LowerInvoke "fold" (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedGreaterThan left right ->
        LowerInvoke "fold" (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedGreaterThanOrEqual left right ->
        LowerInvoke "fold" (lowerExprs typeDecls recordDecls env localEnv fnContext args)
    }
  } else {
    LowerInvoke "fold" (lowerExprs typeDecls recordDecls env localEnv fnContext args)
  }
}

lowerEncodeExpr : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [TypeBinding] -> [TypeBinding] -> ReturnContext -> [HostedExprAst] -> LowerExprText
lowerEncodeExpr typeDecls recordDecls env localEnv fnContext args = {
  let value = firstHostedExpr args;
  let extra = firstHostedExpr (remainingHostedExprs args);
  if expressionSummary value == "" then {
    LowerInvoke "encode" (lowerExprs typeDecls recordDecls env localEnv fnContext args)
  } else if expressionSummary extra == "" then {
    LowerEncode (lowerExpr typeDecls recordDecls env localEnv fnContext value)
  } else {
    LowerInvoke "encode" (lowerExprs typeDecls recordDecls env localEnv fnContext args)
  }
}

lowerDecodeExpr : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [TypeBinding] -> [TypeBinding] -> ReturnContext -> [HostedExprAst] -> LowerExprText
lowerDecodeExpr typeDecls recordDecls env localEnv fnContext args = {
  let targetExpr = firstHostedExpr args;
  let rawExpr = firstHostedExpr (remainingHostedExprs args);
  let extraExpr = firstHostedExpr (remainingHostedExprs (remainingHostedExprs args));
  if expressionSummary targetExpr == "" then {
    LowerInvoke "decode" (lowerExprs typeDecls recordDecls env localEnv fnContext args)
  } else if expressionSummary rawExpr == "" then {
    LowerInvoke "decode" (lowerExprs typeDecls recordDecls env localEnv fnContext args)
  } else if expressionSummary extraExpr == "" then {
    match decodeTargetTypeFromExpr targetExpr {
      DecodeTargetType targetType ->
        LowerDecode targetType (lowerExpr typeDecls recordDecls env localEnv fnContext rawExpr),
      DecodeTargetTypeError message ->
        LowerInvoke "decode" (lowerExprs typeDecls recordDecls env localEnv fnContext args)
    }
  } else {
    LowerInvoke "decode" (lowerExprs typeDecls recordDecls env localEnv fnContext args)
  }
}

recordUpdateLowerTempName : Str
recordUpdateLowerTempName = "__clasp_record_update_subject__"

lowerRecordUpdateExpr : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [TypeBinding] -> [TypeBinding] -> ReturnContext -> [HostedExprAst] -> LowerExprText
lowerRecordUpdateExpr typeDecls recordDecls env localEnv fnContext args = {
  let subjectExpr = firstHostedExpr args;
  let overrideExpr = firstHostedExpr (remainingHostedExprs args);
  let extraExpr = firstHostedExpr (remainingHostedExprs (remainingHostedExprs args));
  if expressionSummary subjectExpr == "" then {
    LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args)
  } else if expressionSummary overrideExpr == "" then {
    LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args)
  } else if expressionSummary extraExpr == "" then {
    match overrideExpr {
      HostedRecord overrideName fields ->
        if overrideName == recordUpdatePlaceholderName then {
          match inferredExprType typeDecls recordDecls env localEnv fnContext subjectExpr {
            TNamed recordName ->
              match lookupRecordDecl recordDecls recordName {
                FoundRecord recordDecl -> {
                  let mut loweredFields = emptyLowerRecordFields;
                  for fieldDecl in recordDeclFields recordDecl {
                    let fieldName = recordFieldDeclName fieldDecl;
                    let loweredValue = match lookupRecordExprField fields fieldName {
                      FoundRecordExprField exprField ->
                        lowerExpr typeDecls recordDecls env localEnv fnContext (recordExprFieldValue exprField),
                      MissingRecordExprField missingField ->
                        LowerFieldAccess recordName (LowerName recordUpdateLowerTempName) fieldName
                    };
                    loweredFields = appendLowerRecordField loweredFields (LowerRecordFieldText fieldName loweredValue);
                    loweredFields
                  };
                  LowerLet recordUpdateLowerTempName (lowerExpr typeDecls recordDecls env localEnv fnContext subjectExpr) (LowerRecord recordName loweredFields)
                },
                MissingRecord missing ->
                  LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args)
              },
            TApply recordName typeArgs ->
              match lookupRecordDecl recordDecls recordName {
                FoundRecord recordDecl -> {
                  let mut loweredFields = emptyLowerRecordFields;
                  for fieldDecl in recordDeclFields recordDecl {
                    let fieldName = recordFieldDeclName fieldDecl;
                    let loweredValue = match lookupRecordExprField fields fieldName {
                      FoundRecordExprField exprField ->
                        lowerExpr typeDecls recordDecls env localEnv fnContext (recordExprFieldValue exprField),
                      MissingRecordExprField missingField ->
                        LowerFieldAccess recordName (LowerName recordUpdateLowerTempName) fieldName
                    };
                    loweredFields = appendLowerRecordField loweredFields (LowerRecordFieldText fieldName loweredValue);
                    loweredFields
                  };
                  LowerLet recordUpdateLowerTempName (lowerExpr typeDecls recordDecls env localEnv fnContext subjectExpr) (LowerRecord recordName loweredFields)
                },
                MissingRecord missing ->
                  LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args)
              },
            TInt ->
              LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
            TStr ->
              LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
            TBool ->
              LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
            TList itemType ->
              LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
            TFunction inputType resultType ->
              LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
            TVar label ->
              LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
            TUnknown label ->
              LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args)
          }
        } else {
          LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args)
        },
      HostedName name ->
        LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedString value ->
        LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedInt value ->
        LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedBool value ->
        LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedList values ->
        LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedCall callee values ->
        LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedConstructor constructorName values ->
        LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedMatch subject branches ->
        LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedFieldAccess subject fieldName ->
        LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedLet binder value body ->
        LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedMutableLet binder value body ->
        LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedAssign binder value body ->
        LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedFor binder iterable loopBody body ->
        LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedReturn value ->
        LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedIf condition thenBranch elseBranch ->
        LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedEqual left right ->
        LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedNotEqual left right ->
        LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedLessThan left right ->
        LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedLessThanOrEqual left right ->
        LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedGreaterThan left right ->
        LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedGreaterThanOrEqual left right ->
        LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args)
    }
  } else {
    LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args)
  }
}

lowerExpr : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [TypeBinding] -> [TypeBinding] -> ReturnContext -> HostedExprAst -> LowerExprText
lowerExpr typeDecls recordDecls env localEnv fnContext expr = match expr {
  HostedName name ->
    LowerName name,
  HostedString value ->
    LowerLiteral value,
  HostedInt value ->
    LowerInt value,
  HostedBool value ->
    LowerBool value,
  HostedList values ->
    LowerArray (lowerExprs typeDecls recordDecls env localEnv fnContext values),
  HostedCall callee args ->
    if callee == "append" then lowerAppendExpr typeDecls recordDecls env localEnv fnContext args else if callee == "prepend" then lowerPrependExpr typeDecls recordDecls env localEnv fnContext args else if callee == "reverse" then lowerReverseExpr typeDecls recordDecls env localEnv fnContext args else if callee == "length" then lowerLengthExpr typeDecls recordDecls env localEnv fnContext args else if callee == "map" then lowerMapExpr typeDecls recordDecls env localEnv fnContext args else if callee == "filter" then lowerFilterExpr typeDecls recordDecls env localEnv fnContext args else if callee == "any" then lowerAnyExpr typeDecls recordDecls env localEnv fnContext args else if callee == "all" then lowerAllExpr typeDecls recordDecls env localEnv fnContext args else if callee == "fold" then lowerFoldExpr typeDecls recordDecls env localEnv fnContext args else if callee == "decode" then lowerDecodeExpr typeDecls recordDecls env localEnv fnContext args else if callee == "encode" then lowerEncodeExpr typeDecls recordDecls env localEnv fnContext args else if callee == recordUpdateBuiltinName then lowerRecordUpdateExpr typeDecls recordDecls env localEnv fnContext args else LowerInvoke callee (lowerExprs typeDecls recordDecls env localEnv fnContext args),
  HostedConstructor constructorName args ->
    LowerConstructor constructorName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
  HostedMatch subject branches ->
    LowerMatch (lowerExpr typeDecls recordDecls env localEnv fnContext subject) (lowerMatchBranches typeDecls recordDecls env localEnv fnContext branches),
  HostedRecord recordName fields ->
    LowerRecord recordName (lowerRecordFields typeDecls recordDecls env localEnv fnContext fields),
  HostedFieldAccess subject fieldName ->
    LowerFieldAccess (recordNameForType (inferredExprType typeDecls recordDecls env localEnv fnContext subject)) (lowerExpr typeDecls recordDecls env localEnv fnContext subject) fieldName,
  HostedLet binder value body ->
    LowerLet binder (lowerExpr typeDecls recordDecls env localEnv fnContext value) (lowerExpr typeDecls recordDecls env (extendLowerLocalEnv typeDecls recordDecls env localEnv fnContext binder value) fnContext body),
  HostedMutableLet binder value body ->
    LowerMutableLet binder (lowerExpr typeDecls recordDecls env localEnv fnContext value) (lowerExpr typeDecls recordDecls env (extendLowerLocalEnv typeDecls recordDecls env localEnv fnContext binder value) fnContext body),
  HostedAssign binder value body ->
    LowerAssign binder (lowerExpr typeDecls recordDecls env localEnv fnContext value) (lowerExpr typeDecls recordDecls env localEnv fnContext body),
  HostedFor binder iterable loopBody body ->
    LowerFor binder (lowerExpr typeDecls recordDecls env localEnv fnContext iterable) (lowerExpr typeDecls recordDecls env (extendLowerLoopLocalEnv typeDecls recordDecls env localEnv fnContext binder iterable) fnContext loopBody) (lowerExpr typeDecls recordDecls env localEnv fnContext body),
  HostedReturn value ->
    LowerReturn (lowerExpr typeDecls recordDecls env localEnv fnContext value),
  HostedIf condition thenBranch elseBranch ->
    LowerIf (lowerExpr typeDecls recordDecls env localEnv fnContext condition) (lowerExpr typeDecls recordDecls env localEnv fnContext thenBranch) (lowerExpr typeDecls recordDecls env localEnv fnContext elseBranch),
  HostedEqual left right ->
    LowerEqual (lowerExpr typeDecls recordDecls env localEnv fnContext left) (lowerExpr typeDecls recordDecls env localEnv fnContext right),
  HostedNotEqual left right ->
    LowerNotEqual (lowerExpr typeDecls recordDecls env localEnv fnContext left) (lowerExpr typeDecls recordDecls env localEnv fnContext right),
  HostedLessThan left right ->
    LowerLessThan (lowerExpr typeDecls recordDecls env localEnv fnContext left) (lowerExpr typeDecls recordDecls env localEnv fnContext right),
  HostedLessThanOrEqual left right ->
    LowerLessThanOrEqual (lowerExpr typeDecls recordDecls env localEnv fnContext left) (lowerExpr typeDecls recordDecls env localEnv fnContext right),
  HostedGreaterThan left right ->
    LowerGreaterThan (lowerExpr typeDecls recordDecls env localEnv fnContext left) (lowerExpr typeDecls recordDecls env localEnv fnContext right),
  HostedGreaterThanOrEqual left right ->
    LowerGreaterThanOrEqual (lowerExpr typeDecls recordDecls env localEnv fnContext left) (lowerExpr typeDecls recordDecls env localEnv fnContext right)
}

lowerFunctionLocalEnv : HostedDeclAst -> [TypeBinding]
lowerFunctionLocalEnv decl = if hasAnnotationAst (declAnnotation decl) then {
  let declaredType = instantiateGenericType (textConcat ["decl:", declName decl]) (typeFromHostedTypeAst (annotationTypeAst (declAnnotation decl)));
  match bindFunctionParams decl declaredType {
    BindingParams localEnv expectedBodyType ->
      localEnv,
    BindingParamError message ->
      emptyTypeBindings
  }
} else {
  emptyTypeBindings
}

lowerFunctionFnContext : HostedDeclAst -> ReturnContext
lowerFunctionFnContext decl = if hasAnnotationAst (declAnnotation decl) then {
  let declaredType = instantiateGenericType (textConcat ["decl:", declName decl]) (typeFromHostedTypeAst (annotationTypeAst (declAnnotation decl)));
  match bindFunctionParams decl declaredType {
    BindingParams localEnv expectedBodyType ->
      InsideFunction expectedBodyType,
    BindingParamError message ->
      OutsideFunction
  }
} else {
  OutsideFunction
}

lowerDecl : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [TypeBinding] -> HostedDeclAst -> LowerDeclText
lowerDecl typeDecls recordDecls env decl = if hasLowerParams decl then LowerFn (declName decl) (declParams decl) (lowerExpr typeDecls recordDecls env (lowerFunctionLocalEnv decl) (lowerFunctionFnContext decl) (declBody decl)) else LowerConst (declName decl) (lowerExpr typeDecls recordDecls env emptyTypeBindings OutsideFunction (declBody decl))

lowerModule : HostedModuleAst -> [LowerDeclText]
lowerModule modl = {
  let typeDecls = effectiveModuleTypeDecls modl;
  let recordDecls = effectiveModuleRecordDecls modl;
  let env = lowerModuleEnv modl typeDecls;
  let mut lowered = emptyLowerDecls;
  for decl in moduleDeclarations modl {
    lowered = appendLowerDecl lowered (lowerDecl typeDecls recordDecls env decl);
    lowered
  };
  lowered
}

renderLowerExprs : [LowerExprText] -> [Str]
renderLowerExprs values = {
  let mut rendered = emptyRenderedTexts;
  for value in values {
    rendered = appendLowerRenderedText rendered (renderLowerExpr value);
    rendered
  };
  rendered
}

renderLowerRecordFields : [LowerRecordFieldText] -> [Str]
renderLowerRecordFields fields = {
  let mut rendered = emptyRenderedTexts;
  for field in fields {
    rendered = appendLowerRenderedText rendered (renderLowerRecordField field);
    rendered
  };
  rendered
}

renderLowerRecordField : LowerRecordFieldText -> Str
renderLowerRecordField field = match field {
  LowerRecordFieldText name value ->
    textConcat [name, " = ", renderLowerExpr value]
}

renderLowerMatchBranch : LowerMatchBranchText -> Str
renderLowerMatchBranch branch = match branch {
  LowerMatchBranchText constructorName binders body ->
    textConcat [constructorName, "(", textJoin ", " binders, ") -> ", renderLowerExpr body]
}

renderLowerMatchBranches : [LowerMatchBranchText] -> [Str]
renderLowerMatchBranches branches = {
  let mut rendered = emptyRenderedTexts;
  for branch in branches {
    rendered = appendLowerRenderedText rendered (renderLowerMatchBranch branch);
    rendered
  };
  rendered
}

renderLowerExpr : LowerExprText -> Str
renderLowerExpr expr = match expr {
  LowerName name ->
    textConcat ["name:", name],
  LowerLiteral value ->
    textConcat ["literal:", value],
  LowerInt value ->
    textConcat ["int:", value],
  LowerBool value ->
    textConcat ["bool:", if value then "true" else "false"],
  LowerArray values ->
    textConcat ["list:[", textJoin ", " (renderLowerExprs values), "]"],
  LowerListAppend left right ->
    textConcat ["list.append(", renderLowerExpr left, ", ", renderLowerExpr right, ")"],
  LowerListPrepend value values ->
    textConcat ["list.prepend(", renderLowerExpr value, ", ", renderLowerExpr values, ")"],
  LowerListReverse values ->
    textConcat ["list.reverse(", renderLowerExpr values, ")"],
  LowerLength value ->
    textConcat ["length(", renderLowerExpr value, ")"],
  LowerListMap callee values ->
    textConcat ["list.map(", callee, ", ", renderLowerExpr values, ")"],
  LowerListFilter callee values ->
    textConcat ["list.filter(", callee, ", ", renderLowerExpr values, ")"],
  LowerListAny callee values ->
    textConcat ["list.any(", callee, ", ", renderLowerExpr values, ")"],
  LowerListAll callee values ->
    textConcat ["list.all(", callee, ", ", renderLowerExpr values, ")"],
  LowerListFold callee initial values ->
    textConcat ["list.fold(", callee, ", ", renderLowerExpr initial, ", ", renderLowerExpr values, ")"],
  LowerViewAppend left right ->
    textConcat ["view.append(", renderLowerExpr left, ", ", renderLowerExpr right, ")"],
  LowerEncode value ->
    textConcat ["encode(", renderLowerExpr value, ")"],
  LowerDecode targetType value ->
    textConcat ["decode(", renderType targetType, ", ", renderLowerExpr value, ")"],
  LowerInvoke callee args ->
    textConcat ["call ", callee, "(", textJoin ", " (renderLowerExprs args), ")"],
  LowerConstructor constructorName args ->
    textConcat ["ctor ", constructorName, "(", textJoin ", " (renderLowerExprs args), ")"],
  LowerMatch subject branches ->
    textConcat ["match ", renderLowerExpr subject, " [", textJoin ", " (renderLowerMatchBranches branches), "]"],
  LowerRecord recordName fields ->
    textConcat ["record ", recordName, " {", textJoin ", " (renderLowerRecordFields fields), "}"],
  LowerFieldAccess recordName subject fieldName ->
    if recordName == "" then textConcat ["field(", renderLowerExpr subject, ", ", fieldName, ")"] else textConcat ["field(", recordName, ", ", renderLowerExpr subject, ", ", fieldName, ")"],
  LowerLet binder value body ->
    textConcat ["let ", binder, " = ", renderLowerExpr value, " in ", renderLowerExpr body],
  LowerMutableLet binder value body ->
    textConcat ["let mut ", binder, " = ", renderLowerExpr value, " in ", renderLowerExpr body],
  LowerAssign binder value body ->
    textConcat ["assign ", binder, " = ", renderLowerExpr value, " then ", renderLowerExpr body],
  LowerFor binder iterable loopBody body ->
    textConcat ["for ", binder, " in ", renderLowerExpr iterable, " do ", renderLowerExpr loopBody, " then ", renderLowerExpr body],
  LowerReturn value ->
    textConcat ["return ", renderLowerExpr value],
  LowerIf condition thenBranch elseBranch ->
    textConcat ["if ", renderLowerExpr condition, " then ", renderLowerExpr thenBranch, " else ", renderLowerExpr elseBranch],
  LowerEqual left right ->
    textConcat ["eq(", renderLowerExpr left, ", ", renderLowerExpr right, ")"],
  LowerNotEqual left right ->
    textConcat ["ne(", renderLowerExpr left, ", ", renderLowerExpr right, ")"],
  LowerLessThan left right ->
    textConcat ["lt(", renderLowerExpr left, ", ", renderLowerExpr right, ")"],
  LowerLessThanOrEqual left right ->
    textConcat ["le(", renderLowerExpr left, ", ", renderLowerExpr right, ")"],
  LowerGreaterThan left right ->
    textConcat ["gt(", renderLowerExpr left, ", ", renderLowerExpr right, ")"],
  LowerGreaterThanOrEqual left right ->
    textConcat ["ge(", renderLowerExpr left, ", ", renderLowerExpr right, ")"]
}

renderLowerDecl : LowerDeclText -> Str
renderLowerDecl decl = match decl {
  LowerConst name body ->
    textConcat ["const ", name, " = ", renderLowerExpr body],
  LowerFn name params body ->
    textConcat ["function ", name, "(", textJoin ", " params, ") = ", renderLowerExpr body]
}

renderLowerModuleSummary : [LowerDeclText] -> Str
renderLowerModuleSummary decls = {
  let mut rendered = emptyRenderedTexts;
  for decl in decls {
    rendered = appendLowerRenderedText rendered (renderLowerDecl decl);
    rendered
  };
  textJoin "\n" rendered
}

renderLowerDeclByName : [LowerDeclText] -> Str -> Str
renderLowerDeclByName decls targetName = {
  let mut rendered = textConcat ["<missing:", targetName, ">"];
  for decl in decls {
    rendered = if lowerDeclName decl == targetName then renderLowerDecl decl else rendered;
    rendered
  };
  rendered
}

lowerDeclName : LowerDeclText -> Str
lowerDeclName decl = match decl {
  LowerConst name body ->
    name,
  LowerFn name params body ->
    name
}
