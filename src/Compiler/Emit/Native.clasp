firstWorkflowDecl : HostedModuleAst -> HostedWorkflowDeclAst
firstWorkflowDecl modl = {
  for workflowDecl in moduleWorkflowDeclarations modl {
    return workflowDecl
  };
  hostedWorkflowDeclAst "" "" (HostedTypeName "")
}

hasExactlyOneWorkflowDecl : HostedModuleAst -> Bool
hasExactlyOneWorkflowDecl modl = {
  let mut seenOne = false;
  for workflowDecl in moduleWorkflowDeclarations modl {
    if seenOne then return false else {
      seenOne = true;
      seenOne
    }
  };
  seenOne
}

emitNativeMigrationStateTypeValue : HostedModuleAst -> Str
emitNativeMigrationStateTypeValue modl = if hasExactlyOneWorkflowDecl modl then encode (renderHostedType (workflowDeclStateTypeAst (firstWorkflowDecl modl))) else "null"

emitNativeMigrationSnapshotSymbolValue : HostedModuleAst -> Str
emitNativeMigrationSnapshotSymbolValue modl = if hasExactlyOneWorkflowDecl modl then encode (textConcat ["$encode_", workflowCodecSuffix (firstWorkflowDecl modl)]) else "null"

emitNativeMigrationHandoffSymbolValue : HostedModuleAst -> Str
emitNativeMigrationHandoffSymbolValue modl = if hasExactlyOneWorkflowDecl modl then encode (workflowHandoffSymbol (moduleNameOf modl) (firstWorkflowDecl modl)) else "null"

emitNativeJsonNumberList : [Str] -> [Str]
emitNativeJsonNumberList values = values

