emitHostedRuntimeMetadataImage : HostedModuleAst -> Str
emitHostedRuntimeMetadataImage modl =
  jsonObject [
    jsonFieldArray "guides" (emitHostedGuideMetadataImages modl),
    jsonFieldArray "policies" (emitHostedPolicyMetadataImages modl),
    jsonFieldArray "agentRoles" (emitHostedAgentRoleMetadataImages modl),
    jsonFieldArray "agents" (emitHostedAgentMetadataImages modl)
  ]

emitHostedBoundaryImages : Str -> HostedModuleAst -> [Str]
emitHostedBoundaryImages moduleName modl =
  append
    (append
      (append
        (append (emitHostedRouteBoundaryImages modl) (emitHostedHookBoundaryImages modl))
        (emitHostedToolServerBoundaryImages modl))
      (emitHostedToolBoundaryImages modl))
    (emitHostedWorkflowBoundaryImages moduleName modl)

emitHostedBoundaryTexts : Str -> HostedModuleAst -> [Str]
emitHostedBoundaryTexts moduleName modl =
  append
    (append
      (append
        (append (emitHostedRouteBoundaryTexts modl) (emitHostedHookBoundaryTexts modl))
        (emitHostedToolServerBoundaryTexts modl))
      (emitHostedToolBoundaryTexts modl))
    (emitHostedWorkflowBoundaryTexts moduleName modl)

emitHostedRouteServiceTransportImage : HostedRouteDeclAst -> Str
emitHostedRouteServiceTransportImage routeDecl =
  jsonObject [
    jsonFieldText "kind" "route",
    jsonFieldText "name" (routeDeclName routeDecl),
    jsonFieldText "id" (routeDeclIdentity routeDecl),
    jsonFieldText "mode" "request_response",
    jsonFieldText "request" (routeDeclRequestType routeDecl),
    jsonFieldText "requestEncode" (textConcat ["$encode_binary_", routeDeclRequestType routeDecl]),
    jsonFieldText "requestDecode" (textConcat ["$decode_binary_", routeDeclRequestType routeDecl]),
    jsonFieldText "response" (routeDeclResponseType routeDecl),
    jsonFieldText "responseEncode" (textConcat ["$encode_binary_", routeDeclResponseType routeDecl]),
    jsonFieldText "responseDecode" (textConcat ["$decode_binary_", routeDeclResponseType routeDecl]),
    jsonFieldText "framing" "length_prefixed"
  ]

