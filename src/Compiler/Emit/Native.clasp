    ", request_encode=$encode_binary_",
    routeDeclRequestType routeDecl,
    ", request_decode=$decode_binary_",
    routeDeclRequestType routeDecl,
    ", response=",
    routeDeclResponseType routeDecl,
    ", response_encode=$encode_binary_",
    routeDeclResponseType routeDecl,
    ", response_decode=$decode_binary_",
    routeDeclResponseType routeDecl,
