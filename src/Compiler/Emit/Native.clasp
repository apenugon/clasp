emitHostedToolBoundaryImage : HostedToolDeclAst -> Str
emitHostedToolBoundaryImage toolDecl =
  jsonObject [
    jsonFieldText "kind" "tool",
    jsonFieldText "name" (toolDeclName toolDecl),
    jsonFieldText "id" (textConcat ["tool:", toolDeclName toolDecl]),
    jsonFieldText "server" (toolDeclServerName toolDecl),
    jsonFieldText "operation" (toolDeclOperation toolDecl),
    jsonFieldText "request" (toolDeclRequestType toolDecl),
    jsonFieldText "response" (toolDeclResponseType toolDecl),
    jsonFieldText "encode" (textConcat ["$encode_", toolDeclResponseType toolDecl]),
    jsonFieldText "decode" (textConcat ["$decode_", toolDeclRequestType toolDecl])
  ]

emitHostedToolBoundaryImages : HostedModuleAst -> [Str]
emitHostedToolBoundaryImages modl = {
  let mut rendered = [];
  for toolDecl in moduleToolDeclarations modl {
