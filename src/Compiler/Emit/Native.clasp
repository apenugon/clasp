mage "fileExists" "fileExists" "Str -> Bool" else if name == "readFile" then emitRuntimeBindingImage "readFile" "readFile" "Str -> Result Str" else if name == "swarmBootstrapJson" then emitRuntimeBindingImage "swarmBootstrapJson" "swarmBootstrapJson" "Str -> Str -> Str -> Result Str" else if name == "swarmLeaseJson" then emitRuntimeBindingImage "swarmLeaseJson" "swarmLeaseJson" "Str -> Str -> Str -> Result Str" else if name == "swarmCompleteJson" then emitRuntimeBindingImage "swarmCompleteJson" "swarmCompleteJson" "Str -> Str -> Str -> Result Str" else if name == "swarmStatusJson" then emitRuntimeBindingImage "swarmStatusJson" "swarmStatusJson" "Str -> Str -> Result Str" else if name == "swarmSummaryJson" then emitRuntimeBindingImage "swarmSummaryJson" "swarmSummaryJson" "Str -> Result Str" else if name == "swarmReadyJson" then emitRuntimeBindingImage "swarmReadyJson" "swarmReadyJson" "Str -> Str -> Result Str" else if name == "swarmManagerNextJson" then emitRuntimeBindingImage "swarmManagerNextJson" "swarmManagerNextJson" "Str -> Str -> Result Str" else if name == "swarmObjectiveCreateJson" then emitRuntimeBindingImage "swarmObjectiveCreateJson" "swarmObjectiveCreateJson" "Str -> Str -> Str -> Int -> Int -> Result Str" else if name == "swarmObjectiveStatusJson" then emitRuntimeBindingImage "swarmObjectiveStatusJson" "swarmObjectiveStatusJson" "Str -> Str -> Result Str" else if name == "swarmTaskCreateJson" then emitRuntimeBindingImage "swarmTaskCreateJson" "swarmTaskCreateJson" "Str -> Str -> Str -> Str -> [Str] -> Int -> Int -> Result Str" else if name == "swarmPolicySetJson" then emitRuntimeBindingImage "swarmPolicySetJson" "swarmPolicySetJson" "Str -> Str -> Str -> [Str] -> [Str] -> Result Str" else if name == "swarmToolRunJson" then emitRuntimeBindingImage "swarmToolRunJson" "swarmToolRunJson" "Str -> Str -> Str -> Str -> [Str] -> Result Str" else if name == "swarmVerifierRunJson" then emitRuntimeBindingImage "swarmVerifierRunJson" "swarmVerifierRunJson" "Str -