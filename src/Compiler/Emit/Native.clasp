    jsonFieldText "response" (hookDeclResponseType hookDecl),
    jsonFieldText "handler" (hookDeclHandlerName hookDecl),
    jsonFieldText "encode" (textConcat ["$encode_", hookDeclResponseType hookDecl]),
    jsonFieldText "decode" (textConcat ["$decode_", hookDeclRequestType hookDecl])
  ]

