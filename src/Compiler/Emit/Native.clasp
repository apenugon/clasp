emitHostedHookBoundaryText hookDecl =
  textConcat [
    "hook ",
    hookDeclName hookDecl,
    "{id=hook:",
    hookDeclName hookDecl,
    ", event=",
    encode (hookDeclEvent hookDecl),
    ", request=",
    hookDeclRequestType hookDecl,
    ", response=",
    hookDeclResponseType hookDecl,
    ", handler=",
    hookDeclHandlerName hookDecl,
    ", encode=$encode_",
    hookDeclResponseType hookDecl,
    ", decode=$decode_",
    hookDeclRequestType hookDecl,
    "}"
