e=appendFile, symbol=clasp_rt_append_file, type=Str -> Str -> Result Str}" else if name == "mkdirAll" then "mkdirAll{runtime=mkdirAll, symbol=clasp_rt_mkdir_all, type=Str -> Result Str}" else ""

emitNativeRuntimeBindingImage : HostedForeignDeclAst -> Str
emitNativeRuntimeBindingImage foreignDecl =
  emitRuntimeBindingImage (foreignDeclName foreignDecl) (foreignDeclRuntimeName foreignDecl) (renderHostedType (foreignDeclTypeAst foreignDecl))

emitNativeRuntimeBindingText : HostedForeignDeclAst -> Str
emitNativeRuntimeBindingText foreignDecl =
  textConcat [foreignDeclName foreignDecl, "{runtime=", foreignDeclRuntimeName foreignDecl, ", symbol=", nativeRuntimeBindingSymbol (foreignDeclRuntimeName foreignDecl), ", type=", renderHostedType (foreignDeclTypeAst foreignDecl), "}"]

emitNativeBuiltinRuntimeBindingImages : [Str] -> [Str]
emitNativeBuiltinRuntimeBindingImages bindingNames = {
  let mut rendered = emptyRenderedTexts;
  for builtinName in ["textConcat", "textJoin", "textSplit", "textChars", "textFingerprint64Hex", "textPrefix", "textSplitFirst", "dictEmpty", "dictSet", "dictGet", "dictHas", "dictRemove", "dictKeys", "dictValues", "text", "element", "styled", "link", "form", "input", "submit", "systemPrompt", "assistantPrompt", "userPrompt", "appendPrompt", "promptText", "page", "redirect", "principal", "tenant", "resourceIdentity", "authSession", "argv", "timeUnixMs", "envVar", "pathJoin", "pathDirname", "pathBasename", "fileExists", "readFile", "swarmBootstrapJson", "swarmLeaseJson", "swarmCompleteJson", "swarmStatusJson", "swarmSummaryJson", "swarmReadyJson", "swarmManagerNextJson", "swarmObjectiveCreateJson", "swarmObjectiveStatusJson", "swarmTaskCreateJson", "swarmPolicySetJson", "swarmToolRunJson", "swarmVerifierRunJson", "swarmApproveJson", "swarmMergegateDecideJson", "swarmRunsJson", "swarmArtifactsJson", "runCommandJson", "writeFile", "appendFile", "mkdirAll"] {
    if containsText bindingNames builtinName then {
      rendered = appendNativeRenderedText rendered (emitBuiltinRuntimeBindingImage builtinName);
      rendered
    } else {
      rendered
    }
  };
  rendered
}

emitNativeBuiltinRuntimeBindingTexts : [Str] -> [Str]
emitNativeBuiltinRuntimeBindingTexts bindingNames = {
  let mut rendered = emptyRenderedTexts;
  for builtinName in ["textConcat", "textJoin", "textSplit", "textChars", "textFingerprint64Hex", "textPrefix", "textSplitFirst", "dictEmpty", "dictSet", "dictGet", "dictHas", "dictRemove", "dictKeys", "dictValues", "text", "element", "styled", "link", "form", "input", "submit", "systemPrompt", "assistantPrompt", "userPrompt", "appendPrompt", "promptText", "page", "redirect", "principal", "tenant", "resourceIdentity", "authSession", "argv", "timeUnixMs", "envVar", "pathJoin", "pathDirname", "pathBasename", "fileExists", "readFile", "swarmBootstrapJson", "swarmLeaseJson", "swarmCompleteJson", "swarmStatusJson", "swarmSummaryJson", "swarmReadyJson", "swarmManagerNextJson", "swarmObjectiveCreateJson", "swarmObjectiveStatusJson", "swarmTaskCreateJson", "swarmPolicySetJson", "swarmToolRunJson", "swarmVerifierRunJson", "swarmApproveJson", "swarmMergegateDecideJson", "swarmRunsJson", "swarmArtifactsJson", "runCommandJson", "writeFile", "appendFile", "mkdirAll"] {
    if containsText bindingNames builtinName then {
      rendered = appendNativeRenderedText rendered (emitBuiltinRuntimeBindingText builtinName);
      rendered
    } else {
      rendered
    }
  };
  rendered
}

emitNativeRuntimeBindingImages : HostedModuleAst -> [Str]
emitNativeRuntimeBindingImages modl = {
  let mut rendered = emitNativeBuiltinRuntimeBindingImages (collectModuleRuntimeBindingNames modl);
  for foreignDecl in moduleForeignDeclarations modl {
    rendered = appendNativeRenderedText rendered (emitNativeRuntimeBindingImage foreignDecl);
    rendered
  };
  rendered
}

emitNativeRuntimeBindingTexts : HostedModuleAst -> [Str]
emitNativeRuntimeBindingTexts modl = {
  let mut rendered = emitNativeBuiltinRuntimeBindingTexts (collectModuleRuntimeBindingNames modl);
  for foreignDecl in moduleForeignDeclarations modl {
    rendered = appendNativeRenderedText rendered (emitNativeRuntimeBindingText foreignDecl);
    rendered
  };
  rendered
}

nativeCodecSuffixForType : TypeText -> Str
nativeCodecSuffixForType typ = match typ {
  TInt ->
    "Int",
  TStr ->
    "Str",
  TBool ->
    "Bool",
  TList itemType ->
    textConcat ["List_", nativeCodecSuffixForType itemType],
  TNamed name ->
    name,
  TApply name args ->
    textConcat [name, "_Generic"],
  TFunction input result ->
    "Unsupported",
  TVar label ->
    textConcat ["Var_", label],
  TUnknown label ->
    label
}

emitNativeJsonCodecImage : TypeText -> Str
emitNativeJsonCodecImage typ = {
  let suffix = nativeCodecSuffixForType typ;
  jsonObject [jsonFieldText "type" (renderType typ), jsonFieldText "encode" (textConcat ["$encode_", suffix]), jsonFieldText "decode" (textConcat ["$decode_", suffix])]
}

emitNativeBinaryCodecImage : TypeText -> Str
emitNativeBinaryCodecImage typ = {
  let suffix = nativeCodecSuffixForType typ;
  jsonObject [jsonFieldText "type" (renderType typ), jsonFieldText "encode" (textConcat ["$encode_binary_", suffix]), jsonFieldText "decode" (textConcat ["$decode_binary_", suffix]), jsonFieldText "framing" "length_prefixed"]
}

emitNativeJsonCodecText : TypeText -> Str
emitNativeJsonCodecText typ = {
  let suffix = nativeCodecSuffixForType typ;
  textConcat [renderType typ, "{encode=$encode_", suffix, ", decode=$decode_", suffix, "}"]
}

emitNativeBinaryCodecText : TypeText -> Str
emitNativeBinaryCodecText typ = {
  let suffix = nativeCodecSuffixForType typ;
  textConcat [renderType typ, "{encode=$encode_binary_", suffix, ", decode=$decode_binary_", suffix, ", framing=length_prefixed}"]
}

emitNativeJsonCodecImagesFromTypes : [TypeText] -> [Str]
emitNativeJsonCodecImagesFromTypes codecTypes = {
  let mut rendered = emptyRenderedTexts;
  for codecType in codecTypes {
    rendered = appendNativeRenderedText rendered (emitNativeJsonCodecImage codecType);
    rendered
  };
  rendered
}

emitNativeJsonCodecTextsFromTypes : [TypeText] -> [Str]
emitNativeJsonCodecTextsFromTypes codecTypes = {
  let mut rendered = emptyRenderedTexts;
  for codecType in codecTypes {
    rendered = appendNativeRenderedText rendered (emitNativeJsonCodecText codecType);
    rendered
  };
  rendered
}

emitNativeBinaryCodecImagesFromTypes : [TypeText] -> [Str]
emitNativeBinaryCodecImagesFromTypes codecTypes = {
  let mut rendered = emptyRenderedTexts;
  for codecType in codecTypes {
    rendered = appendNativeRenderedText rendered (emitNativeBinaryCodecImage codecType);
    rendered
  };
  rendered
}

emitNativeBinaryCodecTextsFromTypes : [TypeText] -> [Str]
emitNativeBinaryCodecTextsFromTypes codecTypes = {
  let mut rendered = emptyRenderedTexts;
  for codecType in codecTypes {
    rendered = appendNativeRenderedText rendered (emitNativeBinaryCodecText codecType);
    rendered
  };
  rendered
}


emitNativeJsonNumberList : [Str] -> [Str]
emitNativeJsonNumberList values = values

emitNativeAbiAllocationImage : Str
