emitHostedToolServerBoundaryImage : HostedToolServerDeclAst -> Str
emitHostedToolServerBoundaryImage toolServerDecl =
  jsonObject [
    jsonFieldText "kind" "toolserver",
    jsonFieldText "name" (toolServerDeclName toolServerDecl),
    jsonFieldText "id" (textConcat ["toolserver:", toolServerDeclName toolServerDecl]),
    jsonFieldText "protocol" (toolServerDeclProtocol toolServerDecl),
    jsonFieldText "location" (toolServerDeclLocation toolServerDecl),
    jsonFieldText "policy" (toolServerDeclPolicyName toolServerDecl)
  ]

emitHostedToolServerBoundaryImages : HostedModuleAst -> [Str]
emitHostedToolServerBoundaryImages modl = {
  let mut rendered = [];
  for toolServerDecl in moduleToolServerDeclarations modl {
    rendered = appendNativeRenderedText rendered (emitHostedToolServerBoundaryImage toolServerDecl);
