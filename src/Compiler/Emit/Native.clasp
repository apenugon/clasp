emitHostedToolServerBoundaryText : HostedToolServerDeclAst -> Str
emitHostedToolServerBoundaryText toolServerDecl =
  textConcat [
    "toolserver ",
    toolServerDeclName toolServerDecl,
    "{id=toolserver:",
    toolServerDeclName toolServerDecl,
    ", protocol=",
    toolServerDeclProtocol toolServerDecl,
    ", location=",
    encode (toolServerDeclLocation toolServerDecl),
    ", policy=",
    toolServerDeclPolicyName toolServerDecl,
    "}"
  ]

emitHostedToolServerBoundaryTexts : HostedModuleAst -> [Str]
