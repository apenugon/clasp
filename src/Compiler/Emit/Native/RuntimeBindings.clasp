hasRuntimeBindingSpec : [NativeRuntimeBindingSpec] -> Str -> Bool
hasRuntimeBindingSpec specs name = {
  for spec in specs {
    if nativeRuntimeBindingSpecName spec == name then return true else false
  };
  false
}

builtinRuntimeBindingName : Str -> Bool
builtinRuntimeBindingName name = if hasRuntimeBindingSpec builtinCoreRuntimeBindingSpecs name then true else if hasRuntimeBindingSpec builtinUiRuntimeBindingSpecs name then true else if hasRuntimeBindingSpec builtinPromptRuntimeBindingSpecs name then true else if hasRuntimeBindingSpec builtinWebRuntimeBindingSpecs name then true else if hasRuntimeBindingSpec builtinSwarmRuntimeBindingSpecs name then true else if hasRuntimeBindingSpec builtinProcessRuntimeBindingSpecs name then true else hasRuntimeBindingSpec builtinDeadlineRuntimeBindingSpecs name

collectRuntimeBindingNamesFromExprList : [HostedExprAst] -> [Str]
collectRuntimeBindingNamesFromExprList exprs = {
  let mut collected = emptyRenderedTexts;
  for expr in exprs {
    collected = appendUniqueTextValues collected (collectRuntimeBindingNamesFromExpr expr);
    collected
  };
  collected
}

collectRuntimeBindingNamesFromRecordFields : [HostedRecordFieldExprAst] -> [Str]
collectRuntimeBindingNamesFromRecordFields fields = {
  let mut collected = emptyRenderedTexts;
  for field in fields {
    collected = appendUniqueTextValues collected (collectRuntimeBindingNamesFromExpr (recordExprFieldValue field));
    collected
  };
  collected
}

collectRuntimeBindingNamesFromBranches : [HostedMatchBranchAst] -> [Str]
collectRuntimeBindingNamesFromBranches branches = {
  let mut collected = emptyRenderedTexts;
  for branch in branches {
    collected = appendUniqueTextValues collected (collectRuntimeBindingNamesFromExpr (branchBodyExpr branch));
    collected
  };
  collected
}

collectRuntimeBindingNamesFromExpr : HostedExprAst -> [Str]
collectRuntimeBindingNamesFromExpr expr = match expr {
  HostedName name ->
    if builtinRuntimeBindingName name then [name] else emptyRenderedTexts,
  HostedString value ->
    emptyRenderedTexts,
  HostedInt value ->
    emptyRenderedTexts,
  HostedBool value ->
    emptyRenderedTexts,
  HostedList values ->
    collectRuntimeBindingNamesFromExprList values,
  HostedCall callee args -> {
    let argNames = collectRuntimeBindingNamesFromExprList args;
    if builtinRuntimeBindingName callee then appendUniqueTextValue argNames callee else argNames
  },
  HostedConstructor constructorName args ->
    collectRuntimeBindingNamesFromExprList args,
  HostedMatch subject branches -> {
    let subjectNames = collectRuntimeBindingNamesFromExpr subject;
    appendUniqueTextValues subjectNames (collectRuntimeBindingNamesFromBranches branches)
  },
  HostedRecord recordName fields ->
    collectRuntimeBindingNamesFromRecordFields fields,
  HostedFieldAccess subject fieldName ->
    collectRuntimeBindingNamesFromExpr subject,
  HostedLet binder value body -> {
    let valueNames = collectRuntimeBindingNamesFromExpr value;
    appendUniqueTextValues valueNames (collectRuntimeBindingNamesFromExpr body)
  },
  HostedMutableLet binder value body -> {
    let valueNames = collectRuntimeBindingNamesFromExpr value;
    appendUniqueTextValues valueNames (collectRuntimeBindingNamesFromExpr body)
  },
  HostedAssign binder value body -> {
    let valueNames = collectRuntimeBindingNamesFromExpr value;
    appendUniqueTextValues valueNames (collectRuntimeBindingNamesFromExpr body)
  },
  HostedFor binder iterable loopBody body -> {
    let iterableNames = collectRuntimeBindingNamesFromExpr iterable;
    let loopNames = collectRuntimeBindingNamesFromExpr loopBody;
    appendUniqueTextValues (appendUniqueTextValues iterableNames loopNames) (collectRuntimeBindingNamesFromExpr body)
  },
  HostedReturn value ->
    collectRuntimeBindingNamesFromExpr value,
  HostedIf condition thenBranch elseBranch -> {
    let conditionNames = collectRuntimeBindingNamesFromExpr condition;
    let thenNames = collectRuntimeBindingNamesFromExpr thenBranch;
    appendUniqueTextValues (appendUniqueTextValues conditionNames thenNames) (collectRuntimeBindingNamesFromExpr elseBranch)
  },
  HostedEqual left right -> {
    let leftNames = collectRuntimeBindingNamesFromExpr left;
    appendUniqueTextValues leftNames (collectRuntimeBindingNamesFromExpr right)
  },
  HostedNotEqual left right -> {
    let leftNames = collectRuntimeBindingNamesFromExpr left;
    appendUniqueTextValues leftNames (collectRuntimeBindingNamesFromExpr right)
  },
  HostedLessThan left right -> {
    let leftNames = collectRuntimeBindingNamesFromExpr left;
    appendUniqueTextValues leftNames (collectRuntimeBindingNamesFromExpr right)
  },
  HostedLessThanOrEqual left right -> {
    let leftNames = collectRuntimeBindingNamesFromExpr left;
    appendUniqueTextValues leftNames (collectRuntimeBindingNamesFromExpr right)
  },
  HostedGreaterThan left right -> {
    let leftNames = collectRuntimeBindingNamesFromExpr left;
    appendUniqueTextValues leftNames (collectRuntimeBindingNamesFromExpr right)
  },
  HostedGreaterThanOrEqual left right -> {
    let leftNames = collectRuntimeBindingNamesFromExpr left;
    appendUniqueTextValues leftNames (collectRuntimeBindingNamesFromExpr right)
  }
}

collectModuleRuntimeBindingNames : HostedModuleAst -> [Str]
collectModuleRuntimeBindingNames modl = {
  let mut collected = emptyRenderedTexts;
  for decl in moduleDeclarations modl {
    collected = appendUniqueTextValues collected (collectRuntimeBindingNamesFromExpr (declBody decl));
    collected
  };
  collected
}

lowercaseRuntimeChar : Str -> Str
lowercaseRuntimeChar value = if value == "A" then "a" else if value == "B" then "b" else if value == "C" then "c" else if value == "D" then "d" else if value == "E" then "e" else if value == "F" then "f" else if value == "G" then "g" else if value == "H" then "h" else if value == "I" then "i" else if value == "J" then "j" else if value == "K" then "k" else if value == "L" then "l" else if value == "M" then "m" else if value == "N" then "n" else if value == "O" then "o" else if value == "P" then "p" else if value == "Q" then "q" else if value == "R" then "r" else if value == "S" then "s" else if value == "T" then "t" else if value == "U" then "u" else if value == "V" then "v" else if value == "W" then "w" else if value == "X" then "x" else if value == "Y" then "y" else if value == "Z" then "z" else value

dropLastChar : Str -> Str
dropLastChar value = {
  let mut result = "";
  let mut previous = "";
  let mut seenChar = false;
  for char in textChars value {
    if seenChar then {
      result = appendChar result previous;
      previous = char;
      result
    } else {
      previous = char;
      seenChar = true;
      result
    }
  };
  result
}

normalizeRuntimeName : Str -> Str
normalizeRuntimeName value = {
  let mut normalized = "";
  let mut seenText = false;
  for char in textChars value {
    if char == "_" then {
      if seenText then {
        if lastCharText normalized == "_" then normalized else {
          normalized = appendChar normalized "_";
          normalized
        }
      } else {
        normalized
      }
    } else if isUppercaseChar char then {
      if seenText then {
        if lastCharText normalized == "_" then {
          normalized = appendChar normalized (lowercaseRuntimeChar char);
          normalized
        } else {
          normalized = textConcat [normalized, "_", lowercaseRuntimeChar char];
          normalized
        }
      } else {
        normalized = appendChar normalized (lowercaseRuntimeChar char);
        seenText = true;
        normalized
      }
    } else {
      normalized = appendChar normalized char;
      seenText = true;
      normalized
    }
  };
  if lastCharText normalized == "_" then dropLastChar normalized else normalized
}

nativeRuntimeBindingSymbol : Str -> Str
nativeRuntimeBindingSymbol runtimeName = textConcat ["clasp_rt_", normalizeRuntimeName runtimeName]

emitRuntimeBindingImage : Str -> Str -> Str -> Str
emitRuntimeBindingImage name runtimeName bindingType =
  jsonObject [
    jsonFieldText "name" name,
    jsonFieldText "runtime" runtimeName,
    jsonFieldText "symbol" (nativeRuntimeBindingSymbol runtimeName),
    jsonFieldText "type" bindingType
  ]

emitRuntimeBindingSpecImage : NativeRuntimeBindingSpec -> Str
emitRuntimeBindingSpecImage spec =
  emitRuntimeBindingImage (nativeRuntimeBindingSpecName spec) (nativeRuntimeBindingSpecRuntimeName spec) (nativeRuntimeBindingSpecType spec)

emitBuiltinRuntimeBindingImageFromSpecs : [NativeRuntimeBindingSpec] -> Str -> Str
emitBuiltinRuntimeBindingImageFromSpecs specs name = {
  for spec in specs {
    if nativeRuntimeBindingSpecName spec == name then return emitRuntimeBindingSpecImage spec else ""
  };
  jsonObject emptyJsonFields
}

emitBuiltinRuntimeBindingImage : Str -> Str
emitBuiltinRuntimeBindingImage name = {
  let core = emitBuiltinRuntimeBindingImageFromSpecs builtinCoreRuntimeBindingSpecs name;
  if core == jsonObject emptyJsonFields then {
    let ui = emitBuiltinRuntimeBindingImageFromSpecs builtinUiRuntimeBindingSpecs name;
    if ui == jsonObject emptyJsonFields then {
      let prompt = emitBuiltinRuntimeBindingImageFromSpecs builtinPromptRuntimeBindingSpecs name;
      if prompt == jsonObject emptyJsonFields then {
        let web = emitBuiltinRuntimeBindingImageFromSpecs builtinWebRuntimeBindingSpecs name;
        if web == jsonObject emptyJsonFields then {
          let swarm = emitBuiltinRuntimeBindingImageFromSpecs builtinSwarmRuntimeBindingSpecs name;
          if swarm == jsonObject emptyJsonFields then {
            let process = emitBuiltinRuntimeBindingImageFromSpecs builtinProcessRuntimeBindingSpecs name;
            if process == jsonObject emptyJsonFields then emitBuiltinRuntimeBindingImageFromSpecs builtinDeadlineRuntimeBindingSpecs name else process
          } else swarm
        } else web
      } else prompt
    } else ui
  } else core
}

emitRuntimeBindingSpecText : NativeRuntimeBindingSpec -> Str
emitRuntimeBindingSpecText spec =
  textConcat [
    nativeRuntimeBindingSpecName spec,
    "{runtime=",
    nativeRuntimeBindingSpecRuntimeName spec,
    ", symbol=",
    nativeRuntimeBindingSymbol (nativeRuntimeBindingSpecRuntimeName spec),
    ", type=",
    nativeRuntimeBindingSpecType spec,
    "}"
  ]

emitBuiltinRuntimeBindingTextFromSpecs : [NativeRuntimeBindingSpec] -> Str -> Str
emitBuiltinRuntimeBindingTextFromSpecs specs name = {
  for spec in specs {
    if nativeRuntimeBindingSpecName spec == name then return emitRuntimeBindingSpecText spec else ""
  };
  ""
}

emitBuiltinRuntimeBindingText : Str -> Str
emitBuiltinRuntimeBindingText name = {
  let core = emitBuiltinRuntimeBindingTextFromSpecs builtinCoreRuntimeBindingSpecs name;
  if core == "" then {
    let ui = emitBuiltinRuntimeBindingTextFromSpecs builtinUiRuntimeBindingSpecs name;
    if ui == "" then {
      let prompt = emitBuiltinRuntimeBindingTextFromSpecs builtinPromptRuntimeBindingSpecs name;
      if prompt == "" then {
        let web = emitBuiltinRuntimeBindingTextFromSpecs builtinWebRuntimeBindingSpecs name;
        if web == "" then {
          let swarm = emitBuiltinRuntimeBindingTextFromSpecs builtinSwarmRuntimeBindingSpecs name;
          if swarm == "" then {
            let process = emitBuiltinRuntimeBindingTextFromSpecs builtinProcessRuntimeBindingSpecs name;
            if process == "" then emitBuiltinRuntimeBindingTextFromSpecs builtinDeadlineRuntimeBindingSpecs name else process
          } else swarm
        } else web
      } else prompt
    } else ui
  } else core
}

emitNativeRuntimeBindingImage : HostedForeignDeclAst -> Str
emitNativeRuntimeBindingImage foreignDecl =
  emitRuntimeBindingImage (foreignDeclName foreignDecl) (foreignDeclRuntimeName foreignDecl) (renderHostedType (foreignDeclTypeAst foreignDecl))

emitNativeMetadataField : Str -> Str -> Str
emitNativeMetadataField name value = textConcat [name, "=", encode value]

emitNativeRuntimeBindingText : HostedForeignDeclAst -> Str
emitNativeRuntimeBindingText foreignDecl =
  textConcat [
    "runtimeBinding{",
    emitNativeMetadataField "name" (foreignDeclName foreignDecl),
    ", ",
    emitNativeMetadataField "runtime" (foreignDeclRuntimeName foreignDecl),
    ", ",
    emitNativeMetadataField "symbol" (nativeRuntimeBindingSymbol (foreignDeclRuntimeName foreignDecl)),
    ", ",
    emitNativeMetadataField "type" (renderHostedType (foreignDeclTypeAst foreignDecl)),
    "}"
  ]

appendRuntimeBindingSpecImages : [Str] -> [Str] -> [NativeRuntimeBindingSpec] -> [Str]
appendRuntimeBindingSpecImages rendered bindingNames specs = {
  let mut next = rendered;
  for spec in specs {
    if containsText bindingNames (nativeRuntimeBindingSpecName spec) then {
      next = appendNativeRenderedText next (emitRuntimeBindingSpecImage spec);
      next
    } else {
      next
    }
  };
  next
}

appendRuntimeBindingSpecTexts : [Str] -> [Str] -> [NativeRuntimeBindingSpec] -> [Str]
appendRuntimeBindingSpecTexts rendered bindingNames specs = {
  let mut next = rendered;
  for spec in specs {
    if containsText bindingNames (nativeRuntimeBindingSpecName spec) then {
      next = appendNativeRenderedText next (emitRuntimeBindingSpecText spec);
      next
    } else {
      next
    }
  };
  next
}

emitNativeBuiltinRuntimeBindingImages : [Str] -> [Str]
emitNativeBuiltinRuntimeBindingImages bindingNames = {
  let mut rendered = emptyRenderedTexts;
  rendered = appendRuntimeBindingSpecImages rendered bindingNames builtinCoreRuntimeBindingSpecs;
  rendered = appendRuntimeBindingSpecImages rendered bindingNames builtinUiRuntimeBindingSpecs;
  rendered = appendRuntimeBindingSpecImages rendered bindingNames builtinPromptRuntimeBindingSpecs;
  rendered = appendRuntimeBindingSpecImages rendered bindingNames builtinWebRuntimeBindingSpecs;
  rendered = appendRuntimeBindingSpecImages rendered bindingNames builtinSwarmRuntimeBindingSpecs;
  rendered = appendRuntimeBindingSpecImages rendered bindingNames builtinProcessRuntimeBindingSpecs;
  rendered = appendRuntimeBindingSpecImages rendered bindingNames builtinDeadlineRuntimeBindingSpecs;
  rendered
}

emitNativeBuiltinRuntimeBindingTexts : [Str] -> [Str]
emitNativeBuiltinRuntimeBindingTexts bindingNames = {
  let mut rendered = emptyRenderedTexts;
  rendered = appendRuntimeBindingSpecTexts rendered bindingNames builtinCoreRuntimeBindingSpecs;
  rendered = appendRuntimeBindingSpecTexts rendered bindingNames builtinUiRuntimeBindingSpecs;
  rendered = appendRuntimeBindingSpecTexts rendered bindingNames builtinPromptRuntimeBindingSpecs;
  rendered = appendRuntimeBindingSpecTexts rendered bindingNames builtinWebRuntimeBindingSpecs;
  rendered = appendRuntimeBindingSpecTexts rendered bindingNames builtinSwarmRuntimeBindingSpecs;
  rendered = appendRuntimeBindingSpecTexts rendered bindingNames builtinProcessRuntimeBindingSpecs;
  rendered = appendRuntimeBindingSpecTexts rendered bindingNames builtinDeadlineRuntimeBindingSpecs;
  rendered
}

emitNativeRuntimeBindingImages : HostedModuleAst -> [Str]
emitNativeRuntimeBindingImages modl = {
  let mut rendered = emitNativeBuiltinRuntimeBindingImages (collectModuleRuntimeBindingNames modl);
  for foreignDecl in moduleForeignDeclarations modl {
    rendered = appendNativeRenderedText rendered (emitNativeRuntimeBindingImage foreignDecl);
    rendered
  };
  rendered
}

emitNativeRuntimeBindingTexts : HostedModuleAst -> [Str]
emitNativeRuntimeBindingTexts modl = {
  let mut rendered = emitNativeBuiltinRuntimeBindingTexts (collectModuleRuntimeBindingNames modl);
  for foreignDecl in moduleForeignDeclarations modl {
    rendered = appendNativeRenderedText rendered (emitNativeRuntimeBindingText foreignDecl);
    rendered
  };
  rendered
}
