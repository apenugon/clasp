module Compiler.Emit.Native.RuntimeBindings

import Compiler.Ast
import Compiler.Emit.Native.Core
import Compiler.Json

type NativeRuntimeBindingSpec = NativeRuntimeBindingSpec Str Str Str

nativeRuntimeBindingSpecName : NativeRuntimeBindingSpec -> Str
nativeRuntimeBindingSpecName spec = match spec {
  NativeRuntimeBindingSpec name runtimeName bindingType ->
    name
}

nativeRuntimeBindingSpecRuntimeName : NativeRuntimeBindingSpec -> Str
nativeRuntimeBindingSpecRuntimeName spec = match spec {
  NativeRuntimeBindingSpec name runtimeName bindingType ->
    runtimeName
}

nativeRuntimeBindingSpecType : NativeRuntimeBindingSpec -> Str
nativeRuntimeBindingSpecType spec = match spec {
  NativeRuntimeBindingSpec name runtimeName bindingType ->
    bindingType
}

appendUniqueTextValue : [Str] -> Str -> [Str]
appendUniqueTextValue values value = if containsText values value then values else append values [value]

appendUniqueTextValues : [Str] -> [Str] -> [Str]
appendUniqueTextValues existing additions = {
  let mut merged = existing;
  for value in additions {
    merged = appendUniqueTextValue merged value;
    merged
  };
  merged
}

