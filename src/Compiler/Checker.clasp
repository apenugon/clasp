builtinResultTypeDecl : HostedTypeDeclAst
builtinResultTypeDecl =
  hostedTypeDeclAstWithParams
    resultBuiltinTypeName
    ["a"]
    [ hostedConstructorDeclAst resultOkConstructorName [HostedTypeVar "a"]
    , hostedConstructorDeclAst resultErrConstructorName [HostedTypeName "Str"]
    ]

principalBuiltinRecordDecl : HostedRecordDeclAst
principalBuiltinRecordDecl =
  hostedRecordDeclAst "Principal" [hostedRecordFieldDeclAst "id" (HostedTypeName "Str")]

tenantBuiltinRecordDecl : HostedRecordDeclAst
tenantBuiltinRecordDecl =
  hostedRecordDeclAst "Tenant" [hostedRecordFieldDeclAst "id" (HostedTypeName "Str")]

resourceIdentityBuiltinRecordDecl : HostedRecordDeclAst
resourceIdentityBuiltinRecordDecl =
  hostedRecordDeclAst
    "ResourceIdentity"
    [ hostedRecordFieldDeclAst "resourceType" (HostedTypeName "Str")
    , hostedRecordFieldDeclAst "resourceId" (HostedTypeName "Str")
    ]

authSessionBuiltinRecordDecl : HostedRecordDeclAst
authSessionBuiltinRecordDecl =
  hostedRecordDeclAst
    "AuthSession"
    [ hostedRecordFieldDeclAst "sessionId" (HostedTypeName "Str")
    , hostedRecordFieldDeclAst "principal" (HostedTypeName "Principal")
    , hostedRecordFieldDeclAst "tenant" (HostedTypeName "Tenant")
    , hostedRecordFieldDeclAst "resource" (HostedTypeName "ResourceIdentity")
    ]

effectiveModuleRecordDecls : HostedModuleAst -> [HostedRecordDeclAst]
effectiveModuleRecordDecls modl =
  append
    [principalBuiltinRecordDecl, tenantBuiltinRecordDecl, resourceIdentityBuiltinRecordDecl, authSessionBuiltinRecordDecl]
    (moduleRecordDeclarations modl)

effectiveModuleTypeDecls : HostedModuleAst -> [HostedTypeDeclAst]
effectiveModuleTypeDecls modl = append [builtinResultTypeDecl] (moduleTypeDeclarations modl)

