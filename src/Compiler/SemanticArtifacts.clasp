semanticContextSurfaceIndexForeignBoundaries : [HostedForeignDeclAst] -> [Str]
semanticContextSurfaceIndexForeignBoundaries foreignDecls = {
  let mut entries = emptyRenderedTexts;
  for foreignDecl in foreignDecls {
    entries =
      appendRenderedText
        entries
        (jsonObject
          [ jsonFieldText "id" (semanticForeignNodeId foreignDecl)
          , jsonFieldText "name" (foreignDeclName foreignDecl)
          , jsonFieldText "runtimeName" (foreignDeclRuntimeName foreignDecl)
          , jsonFieldText "type" (renderHostedType (foreignDeclTypeAst foreignDecl))
          ]);
