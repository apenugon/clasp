semanticContainsText : [Str] -> Str -> Bool
semanticContainsText values target = containsText values target

semanticNonEmptyContainsText : [Str] -> Str -> Bool
semanticNonEmptyContainsText values target =
  if target == "" then false else semanticContainsText values target

semanticAppendUniqueText : [Str] -> Str -> [Str]
semanticAppendUniqueText values value =
  if semanticContainsText values value then values else appendRenderedText values value

semanticAppendNamedTargetEdge : [Str] -> [Str] -> Str -> Str -> Str -> Str -> [Str]
semanticAppendNamedTargetEdge edges availableNames targetName fromId targetPrefix kind =
  if semanticNonEmptyContainsText availableNames targetName then
    appendRenderedText edges (semanticJsonEdge fromId (textConcat [targetPrefix, targetName]) kind)
  else
    edges

semanticDeclUseTargetNodeId : HostedModuleAst -> Str -> Str
semanticDeclUseTargetNodeId modl target =
  if semanticContainsText (semanticDeclNames modl) target then
    textConcat ["decl:", target]
  else if semanticContainsText (semanticForeignNames modl) target then
    textConcat ["foreign:", target]
  else if semanticContainsText (semanticRecordNames modl) target then
    textConcat ["schema:", target]
  else
    ""

semanticAppendDeclUseTarget : HostedModuleAst -> [Str] -> Str -> [Str]
semanticAppendDeclUseTarget modl targetIds target = {
  let targetId = semanticDeclUseTargetNodeId modl target;
  if targetId == "" then targetIds else semanticAppendUniqueText targetIds targetId
}

semanticExprListUseTargetNodeIds : HostedModuleAst -> [HostedExprAst] -> [Str]
semanticExprListUseTargetNodeIds modl values = {
  let mut targetIds = emptyRenderedTexts;
  for value in values {
    targetIds = append targetIds (semanticExprUseTargetNodeIds modl value);
    targetIds
  };
  targetIds
}

semanticRecordFieldUseTargetNodeIds : HostedModuleAst -> HostedRecordFieldExprAst -> [Str]
semanticRecordFieldUseTargetNodeIds modl field =
  semanticExprUseTargetNodeIds modl (recordExprFieldValue field)

semanticRecordFieldsUseTargetNodeIds : HostedModuleAst -> [HostedRecordFieldExprAst] -> [Str]
semanticRecordFieldsUseTargetNodeIds modl fields = {
  let mut targetIds = emptyRenderedTexts;
  for field in fields {
    targetIds = append targetIds (semanticRecordFieldUseTargetNodeIds modl field);
    targetIds
  };
  targetIds
}

semanticMatchBranchUseTargetNodeIds : HostedModuleAst -> HostedMatchBranchAst -> [Str]
semanticMatchBranchUseTargetNodeIds modl branch =
  semanticExprUseTargetNodeIds modl (branchBodyExpr branch)

semanticMatchBranchesUseTargetNodeIds : HostedModuleAst -> [HostedMatchBranchAst] -> [Str]
semanticMatchBranchesUseTargetNodeIds modl branches = {
  let mut targetIds = emptyRenderedTexts;
  for branch in branches {
    targetIds = append targetIds (semanticMatchBranchUseTargetNodeIds modl branch);
    targetIds
  };
  targetIds
}

semanticExprUseTargetNodeIds : HostedModuleAst -> HostedExprAst -> [Str]
semanticExprUseTargetNodeIds modl expr = match expr {
  HostedName name ->
    semanticAppendDeclUseTarget modl emptyRenderedTexts name,
  HostedString value ->
    emptyRenderedTexts,
  HostedInt value ->
    emptyRenderedTexts,
  HostedBool value ->
    emptyRenderedTexts,
  HostedList values ->
    semanticExprListUseTargetNodeIds modl values,
  HostedCall callee args -> {
    let mut targetIds = semanticAppendDeclUseTarget modl emptyRenderedTexts callee;
    targetIds = append targetIds (semanticExprListUseTargetNodeIds modl args);
    targetIds
  },
  HostedConstructor constructorName args -> {
    let mut targetIds = semanticAppendDeclUseTarget modl emptyRenderedTexts constructorName;
    targetIds = append targetIds (semanticExprListUseTargetNodeIds modl args);
    targetIds
  },
  HostedMatch subject branches -> {
    let mut targetIds = semanticExprUseTargetNodeIds modl subject;
    targetIds = append targetIds (semanticMatchBranchesUseTargetNodeIds modl branches);
    targetIds
  },
  HostedRecord recordName fields -> {
    let mut targetIds = semanticAppendDeclUseTarget modl emptyRenderedTexts recordName;
    targetIds = append targetIds (semanticRecordFieldsUseTargetNodeIds modl fields);
    targetIds
  },
  HostedFieldAccess subject fieldName ->
    semanticExprUseTargetNodeIds modl subject,
  HostedLet binder value body ->
    append (semanticExprUseTargetNodeIds modl value) (semanticExprUseTargetNodeIds modl body),
  HostedMutableLet binder value body ->
    append (semanticExprUseTargetNodeIds modl value) (semanticExprUseTargetNodeIds modl body),
  HostedAssign binder value body ->
    append (semanticExprUseTargetNodeIds modl value) (semanticExprUseTargetNodeIds modl body),
  HostedFor binder iterable loopBody body -> {
    let mut targetIds = semanticExprUseTargetNodeIds modl iterable;
    targetIds = append targetIds (semanticExprUseTargetNodeIds modl loopBody);
    targetIds = append targetIds (semanticExprUseTargetNodeIds modl body);
    targetIds
  },
  HostedReturn value ->
    semanticExprUseTargetNodeIds modl value,
  HostedIf condition thenBranch elseBranch -> {
    let mut targetIds = semanticExprUseTargetNodeIds modl condition;
    targetIds = append targetIds (semanticExprUseTargetNodeIds modl thenBranch);
    targetIds = append targetIds (semanticExprUseTargetNodeIds modl elseBranch);
    targetIds
  },
  HostedEqual left right ->
    append (semanticExprUseTargetNodeIds modl left) (semanticExprUseTargetNodeIds modl right),
  HostedNotEqual left right ->
    append (semanticExprUseTargetNodeIds modl left) (semanticExprUseTargetNodeIds modl right),
  HostedLessThan left right ->
    append (semanticExprUseTargetNodeIds modl left) (semanticExprUseTargetNodeIds modl right),
  HostedLessThanOrEqual left right ->
    append (semanticExprUseTargetNodeIds modl left) (semanticExprUseTargetNodeIds modl right),
  HostedGreaterThan left right ->
    append (semanticExprUseTargetNodeIds modl left) (semanticExprUseTargetNodeIds modl right),
  HostedGreaterThanOrEqual left right ->
    append (semanticExprUseTargetNodeIds modl left) (semanticExprUseTargetNodeIds modl right)
}

semanticDeclUseTargetNodeIds : HostedModuleAst -> HostedDeclAst -> [Str]
semanticDeclUseTargetNodeIds modl decl =
  semanticExprUseTargetNodeIds modl (declBody decl)

semanticDeclUseEdges : HostedModuleAst -> [Str]
semanticDeclUseEdges modl = {
  let mut edges = emptyRenderedTexts;
  for decl in moduleDeclarations modl {
    for targetId in semanticDeclUseTargetNodeIds modl decl {
      if targetId != semanticDeclNodeId decl then {
        edges = appendRenderedText edges (semanticJsonEdge (semanticDeclNodeId decl) targetId "uses");
        edges
      } else {
        edges
      }
    };
    edges
  };
  edges
}

semanticAppendNonEmptyUniqueText : [Str] -> Str -> [Str]
semanticAppendNonEmptyUniqueText values value =
  if value == "" then values else semanticAppendUniqueText values value

semanticAppendUniqueTexts : [Str] -> [Str] -> [Str]
semanticAppendUniqueTexts values additions = {
  let mut result = values;
  for value in additions {
    result = semanticAppendNonEmptyUniqueText result value;
    result
  };
  result
}

semanticTextHasPrefix : Str -> Str -> Bool
semanticTextHasPrefix value prefix = match textPrefix value prefix {
  Ok tail ->
    true,
  Err notMatching ->
    false
}

semanticSurfaceIdsWithPrefix : [Str] -> Str -> [Str]
semanticSurfaceIdsWithPrefix surfaces prefix = {
  let mut matches = emptyRenderedTexts;
  for surface in surfaces {
    if semanticTextHasPrefix surface prefix then {
      matches = semanticAppendNonEmptyUniqueText matches surface;
      matches
    } else {
      matches
    }
  };
  matches
}

semanticHostedTypeUsesName : HostedTypeAst -> Str -> Bool
semanticHostedTypeUsesName typ targetName = match typ {
  HostedTypeName name ->
    name == targetName,
  HostedTypeApply name args ->
    if name == targetName then true else semanticHostedTypesUseName args targetName,
  HostedTypeVar name ->
    false,
  HostedTypeList itemType ->
    semanticHostedTypeUsesName itemType targetName,
  HostedTypeFunction input result ->
    if semanticHostedTypeUsesName input targetName then true else semanticHostedTypeUsesName result targetName
}

semanticHostedTypesUseName : [HostedTypeAst] -> Str -> Bool
semanticHostedTypesUseName types targetName = {
  for typ in types {
    if semanticHostedTypeUsesName typ targetName then return true else false
  };
  false
}

semanticHostedTypeOwnSurfaceId : HostedModuleAst -> Str -> Str
semanticHostedTypeOwnSurfaceId modl name =
  if semanticContainsText (semanticRecordNames modl) name then
    textConcat ["schema:", name]
  else if semanticContainsText (semanticTypeNames modl) name then
    textConcat ["type:", name]
  else
    ""

semanticAppendHostedTypeOwnSurfaceId : HostedModuleAst -> [Str] -> Str -> [Str]
semanticAppendHostedTypeOwnSurfaceId modl surfaces name =
  semanticAppendNonEmptyUniqueText surfaces (semanticHostedTypeOwnSurfaceId modl name)

semanticHostedTypeSurfaceIds : HostedModuleAst -> HostedTypeAst -> [Str]
semanticHostedTypeSurfaceIds modl typ = match typ {
  HostedTypeName name ->
    semanticAppendHostedTypeOwnSurfaceId modl emptyRenderedTexts name,
  HostedTypeApply name args -> {
    let mut surfaces = semanticAppendHostedTypeOwnSurfaceId modl emptyRenderedTexts name;
    for arg in args {
      surfaces = semanticAppendUniqueTexts surfaces (semanticHostedTypeSurfaceIds modl arg);
      surfaces
    };
    surfaces
  },
  HostedTypeVar name ->
    emptyRenderedTexts,
  HostedTypeList itemType ->
    semanticHostedTypeSurfaceIds modl itemType,
  HostedTypeFunction input result ->
    semanticAppendUniqueTexts (semanticHostedTypeSurfaceIds modl input) (semanticHostedTypeSurfaceIds modl result)
}

semanticHostedTypesSurfaceIds : HostedModuleAst -> [HostedTypeAst] -> [Str]
semanticHostedTypesSurfaceIds modl types = {
  let mut surfaces = emptyRenderedTexts;
  for typ in types {
    surfaces = semanticAppendUniqueTexts surfaces (semanticHostedTypeSurfaceIds modl typ);
    surfaces
  };
  surfaces
}

semanticRecordDeclUsesTypeName : HostedRecordDeclAst -> Str -> Bool
semanticRecordDeclUsesTypeName recordDecl typeName = {
  for field in recordDeclFields recordDecl {
    if semanticHostedTypeUsesName (recordFieldDeclType field) typeName then return true else false
  };
  false
}

semanticSchemaIdsForTypeName : HostedModuleAst -> Str -> [Str]
semanticSchemaIdsForTypeName modl typeName = {
  let mut nodeIds = emptyRenderedTexts;
  for recordDecl in moduleRecordDeclarations modl {
    if semanticRecordDeclUsesTypeName recordDecl typeName then {
      nodeIds = semanticAppendNonEmptyUniqueText nodeIds (semanticSchemaNodeId recordDecl);
      nodeIds
    } else {
      nodeIds
    }
  };
  nodeIds
}

semanticSchemaFieldIdsForTypeName : HostedModuleAst -> Str -> [Str]
semanticSchemaFieldIdsForTypeName modl typeName = {
  let mut nodeIds = emptyRenderedTexts;
  for recordDecl in moduleRecordDeclarations modl {
    for field in recordDeclFields recordDecl {
      if semanticHostedTypeUsesName (recordFieldDeclType field) typeName then {
        nodeIds = semanticAppendNonEmptyUniqueText nodeIds (semanticSchemaFieldNodeId (recordDeclName recordDecl) field);
        nodeIds
      } else {
        nodeIds
      }
    };
    nodeIds
  };
  nodeIds
}

semanticSchemaNodeIds : HostedModuleAst -> [Str]
semanticSchemaNodeIds modl = {
  let mut nodeIds = emptyRenderedTexts;
  for recordDecl in moduleRecordDeclarations modl {
    nodeIds = appendRenderedText nodeIds (semanticSchemaNodeId recordDecl);
    nodeIds
  };
  nodeIds
}

semanticDeclNodeIds : HostedModuleAst -> [Str]
semanticDeclNodeIds modl = {
  let mut nodeIds = emptyRenderedTexts;
  for decl in moduleDeclarations modl {
    nodeIds = appendRenderedText nodeIds (semanticDeclNodeId decl);
    nodeIds
  };
  nodeIds
}

semanticForeignNodeIds : HostedModuleAst -> [Str]
semanticForeignNodeIds modl = {
  let mut nodeIds = emptyRenderedTexts;
  for foreignDecl in moduleForeignDeclarations modl {
    nodeIds = appendRenderedText nodeIds (semanticForeignNodeId foreignDecl);
    nodeIds
  };
  nodeIds
}

semanticTypeNodeIds : HostedModuleAst -> [Str]
semanticTypeNodeIds modl = {
  let mut nodeIds = emptyRenderedTexts;
  for typeDecl in moduleTypeDeclarations modl {
    nodeIds = appendRenderedText nodeIds (semanticTypeNodeId typeDecl);
    nodeIds
  };
  nodeIds
}

semanticRouteNodeIds : HostedModuleAst -> [Str]
semanticRouteNodeIds modl = {
  let mut nodeIds = emptyRenderedTexts;
  for routeDecl in moduleRouteDeclarations modl {
    nodeIds = appendRenderedText nodeIds (semanticRouteNodeId routeDecl);
    nodeIds
  };
  nodeIds
}

semanticSchemaFieldNodeIds : HostedRecordDeclAst -> [Str]
semanticSchemaFieldNodeIds recordDecl = {
  let mut nodeIds = emptyRenderedTexts;
  for field in recordDeclFields recordDecl {
    nodeIds = appendRenderedText nodeIds (semanticSchemaFieldNodeId (recordDeclName recordDecl) field);
    nodeIds
  };
  nodeIds
}

semanticSchemaFieldNodeIdsByName : HostedModuleAst -> Str -> [Str]
semanticSchemaFieldNodeIdsByName modl schemaName = {
  let mut nodeIds = emptyRenderedTexts;
  for recordDecl in moduleRecordDeclarations modl {
    if recordDeclName recordDecl == schemaName then {
      nodeIds = semanticAppendUniqueTexts nodeIds (semanticSchemaFieldNodeIds recordDecl);
      nodeIds
    } else {
      nodeIds
    }
  };
  nodeIds
}

semanticAppendSchemaImpactSurface : HostedModuleAst -> [Str] -> Str -> [Str]
semanticAppendSchemaImpactSurface modl surfaces schemaName = {
  let mut result = surfaces;
  if semanticNonEmptyContainsText (semanticRecordNames modl) schemaName then {
    result = semanticAppendNonEmptyUniqueText result (textConcat ["schema:", schemaName]);
    result = semanticAppendUniqueTexts result (semanticSchemaFieldNodeIdsByName modl schemaName);
    result
  } else {
    result
  }
}

semanticAppendToolServerImpactSurface : HostedModuleAst -> [Str] -> Str -> [Str]
semanticAppendToolServerImpactSurface modl surfaces serverName =
  if semanticNonEmptyContainsText (semanticToolServerNames modl) serverName then semanticAppendNonEmptyUniqueText surfaces (textConcat ["toolserver:", serverName]) else surfaces

semanticDeclIdsUsingTarget : HostedModuleAst -> Str -> [Str]
semanticDeclIdsUsingTarget modl targetId = {
  let mut nodeIds = emptyRenderedTexts;
  for decl in moduleDeclarations modl {
    if semanticContainsText (semanticDeclUseTargetNodeIds modl decl) targetId then {
      nodeIds = semanticAppendNonEmptyUniqueText nodeIds (semanticDeclNodeId decl);
      nodeIds
    } else {
      nodeIds
    }
  };
  nodeIds
}

semanticDeclDirectDependencySurfaces : HostedModuleAst -> HostedDeclAst -> [Str]
semanticDeclDirectDependencySurfaces modl decl = {
  let mut surfaces = [semanticDeclNodeId decl];
  surfaces = semanticAppendUniqueTexts surfaces (semanticDeclUseTargetNodeIds modl decl);
  surfaces
}

semanticDeclDirectDependencySurfacesByName : HostedModuleAst -> Str -> [Str]
semanticDeclDirectDependencySurfacesByName modl declNameText = {
  let mut surfaces = emptyRenderedTexts;
  for decl in moduleDeclarations modl {
    if declName decl == declNameText then {
      surfaces = semanticAppendUniqueTexts surfaces (semanticDeclDirectDependencySurfaces modl decl);
      surfaces
    } else {
      surfaces
    }
  };
  surfaces
}

semanticAppendNestedDeclDependencySurfaces : HostedModuleAst -> [Str] -> Str -> [Str]
semanticAppendNestedDeclDependencySurfaces modl surfaces targetId =
  match textPrefix targetId "decl:" {
    Ok declNameText ->
      semanticAppendUniqueTexts surfaces (semanticDeclDirectDependencySurfacesByName modl declNameText),
    Err notDeclTarget ->
      surfaces
  }

semanticDeclDependencySurfaces : HostedModuleAst -> HostedDeclAst -> [Str]
semanticDeclDependencySurfaces modl decl = {
  let directSurfaces = semanticDeclDirectDependencySurfaces modl decl;
  let mut surfaces = directSurfaces;
  for targetId in directSurfaces {
    surfaces = semanticAppendNestedDeclDependencySurfaces modl surfaces targetId;
    surfaces
  };
  surfaces
}

semanticDeclDependencySurfacesByName : HostedModuleAst -> Str -> [Str]
semanticDeclDependencySurfacesByName modl declNameText = {
  let mut surfaces = emptyRenderedTexts;
  for decl in moduleDeclarations modl {
    if declName decl == declNameText then {
      surfaces = semanticAppendUniqueTexts surfaces (semanticDeclDependencySurfaces modl decl);
      surfaces
    } else {
      surfaces
    }
  };
  surfaces
}

semanticRouteAffectedSurfaces : HostedModuleAst -> HostedRouteDeclAst -> [Str]
semanticRouteAffectedSurfaces modl routeDecl = {
  let mut surfaces = [semanticRouteNodeId routeDecl];
  surfaces = semanticAppendUniqueTexts surfaces (semanticDeclDependencySurfacesByName modl (routeDeclHandlerName routeDecl));
  surfaces = semanticAppendSchemaImpactSurface modl surfaces (routeDeclRequestType routeDecl);
  surfaces = semanticAppendSchemaImpactSurface modl surfaces (routeDeclResponseType routeDecl);
  surfaces
}

semanticHookAffectedSurfaces : HostedModuleAst -> HostedHookDeclAst -> [Str]
semanticHookAffectedSurfaces modl hookDecl = {
  let mut surfaces = [semanticHookNodeId hookDecl];
  surfaces = semanticAppendUniqueTexts surfaces (semanticDeclDependencySurfacesByName modl (hookDeclHandlerName hookDecl));
  surfaces = semanticAppendSchemaImpactSurface modl surfaces (hookDeclRequestType hookDecl);
  surfaces = semanticAppendSchemaImpactSurface modl surfaces (hookDeclResponseType hookDecl);
  surfaces
}

semanticToolAffectedSurfaces : HostedModuleAst -> HostedToolDeclAst -> [Str]
semanticToolAffectedSurfaces modl toolDecl = {
  let mut surfaces = [semanticToolNodeId toolDecl];
  surfaces = semanticAppendToolServerImpactSurface modl surfaces (toolDeclServerName toolDecl);
  surfaces = semanticAppendSchemaImpactSurface modl surfaces (toolDeclRequestType toolDecl);
  surfaces = semanticAppendSchemaImpactSurface modl surfaces (toolDeclResponseType toolDecl);
  surfaces
}

semanticToolAffectedSurfacesByName : HostedModuleAst -> Str -> [Str]
semanticToolAffectedSurfacesByName modl toolName = {
  let mut surfaces = emptyRenderedTexts;
  for toolDecl in moduleToolDeclarations modl {
    if toolDeclName toolDecl == toolName then {
      surfaces = semanticAppendUniqueTexts surfaces (semanticToolAffectedSurfaces modl toolDecl);
      surfaces
    } else {
      surfaces
    }
  };
  surfaces
}

semanticToolsAffectedSurfacesByNames : HostedModuleAst -> [Str] -> [Str]
semanticToolsAffectedSurfacesByNames modl toolNames = {
  let mut surfaces = emptyRenderedTexts;
  for toolName in toolNames {
    surfaces = semanticAppendUniqueTexts surfaces (semanticToolAffectedSurfacesByName modl toolName);
    surfaces
  };
  surfaces
}

semanticWorkflowAffectedSurfaces : HostedModuleAst -> HostedWorkflowDeclAst -> [Str]
semanticWorkflowAffectedSurfaces modl workflowDecl = {
  let mut surfaces = [semanticWorkflowNodeId workflowDecl];
  surfaces = semanticAppendSchemaImpactSurface modl surfaces (renderHostedType (workflowDeclStateTypeAst workflowDecl));
  surfaces
}

semanticProjectionAffectedSurfaces : HostedModuleAst -> HostedProjectionDeclAst -> [Str]
semanticProjectionAffectedSurfaces modl projectionDecl = {
  let mut surfaces = [semanticProjectionNodeId projectionDecl];
  surfaces = semanticAppendSchemaImpactSurface modl surfaces (projectionDeclSourceRecordName projectionDecl);
  surfaces = semanticAppendNonEmptyUniqueText surfaces (textConcat ["policy:", projectionDeclPolicyName projectionDecl]);
  surfaces = semanticAppendUniqueTexts surfaces (semanticProjectionFieldNodeIds projectionDecl);
  surfaces
}

semanticRouteIdsForSchemaName : HostedModuleAst -> Str -> [Str]
semanticRouteIdsForSchemaName modl schemaName = {
  let mut nodeIds = emptyRenderedTexts;
  for routeDecl in moduleRouteDeclarations modl {
    if routeDeclRequestType routeDecl == schemaName then {
      nodeIds = semanticAppendNonEmptyUniqueText nodeIds (semanticRouteNodeId routeDecl);
      nodeIds
    } else if routeDeclResponseType routeDecl == schemaName then {
      nodeIds = semanticAppendNonEmptyUniqueText nodeIds (semanticRouteNodeId routeDecl);
      nodeIds
    } else {
      nodeIds
    }
  };
  nodeIds
}

semanticHookIdsForSchemaName : HostedModuleAst -> Str -> [Str]
semanticHookIdsForSchemaName modl schemaName = {
  let mut nodeIds = emptyRenderedTexts;
  for hookDecl in moduleHookDeclarations modl {
    if hookDeclRequestType hookDecl == schemaName then {
      nodeIds = semanticAppendNonEmptyUniqueText nodeIds (semanticHookNodeId hookDecl);
      nodeIds
    } else if hookDeclResponseType hookDecl == schemaName then {
      nodeIds = semanticAppendNonEmptyUniqueText nodeIds (semanticHookNodeId hookDecl);
      nodeIds
    } else {
      nodeIds
    }
  };
  nodeIds
}

semanticToolIdsForSchemaName : HostedModuleAst -> Str -> [Str]
semanticToolIdsForSchemaName modl schemaName = {
  let mut nodeIds = emptyRenderedTexts;
  for toolDecl in moduleToolDeclarations modl {
    if toolDeclRequestType toolDecl == schemaName then {
      nodeIds = semanticAppendNonEmptyUniqueText nodeIds (semanticToolNodeId toolDecl);
      nodeIds
    } else if toolDeclResponseType toolDecl == schemaName then {
      nodeIds = semanticAppendNonEmptyUniqueText nodeIds (semanticToolNodeId toolDecl);
      nodeIds
    } else {
      nodeIds
    }
  };
  nodeIds
}

semanticForeignIdsForTypeName : HostedModuleAst -> Str -> [Str]
semanticForeignIdsForTypeName modl typeName = {
  let mut nodeIds = emptyRenderedTexts;
  for foreignDecl in moduleForeignDeclarations modl {
    if semanticHostedTypeUsesName (foreignDeclTypeAst foreignDecl) typeName then {
      nodeIds = semanticAppendNonEmptyUniqueText nodeIds (semanticForeignNodeId foreignDecl);
      nodeIds
    } else {
      nodeIds
    }
  };
  nodeIds
}

semanticForeignIdsForSchemaName : HostedModuleAst -> Str -> [Str]
semanticForeignIdsForSchemaName modl schemaName =
  semanticForeignIdsForTypeName modl schemaName

semanticToolNamesForSchemaName : HostedModuleAst -> Str -> [Str]
semanticToolNamesForSchemaName modl schemaName = {
  let mut names = emptyRenderedTexts;
  for toolDecl in moduleToolDeclarations modl {
    if toolDeclRequestType toolDecl == schemaName then {
      names = semanticAppendNonEmptyUniqueText names (toolDeclName toolDecl);
      names
    } else if toolDeclResponseType toolDecl == schemaName then {
      names = semanticAppendNonEmptyUniqueText names (toolDeclName toolDecl);
      names
    } else {
      names
    }
  };
  names
}

semanticWorkflowIdsForSchemaName : HostedModuleAst -> Str -> [Str]
semanticWorkflowIdsForSchemaName modl schemaName = {
  let mut nodeIds = emptyRenderedTexts;
  for workflowDecl in moduleWorkflowDeclarations modl {
    if renderHostedType (workflowDeclStateTypeAst workflowDecl) == schemaName then {
      nodeIds = semanticAppendNonEmptyUniqueText nodeIds (semanticWorkflowNodeId workflowDecl);
      nodeIds
    } else {
      nodeIds
    }
  };
  nodeIds
}

semanticProjectionSurfacesForSchemaName : HostedModuleAst -> Str -> [Str]
semanticProjectionSurfacesForSchemaName modl schemaName = {
  let mut surfaces = emptyRenderedTexts;
  for projectionDecl in moduleProjectionDeclarations modl {
    if projectionDeclSourceRecordName projectionDecl == schemaName then {
      surfaces = semanticAppendUniqueTexts surfaces (semanticProjectionAffectedSurfaces modl projectionDecl);
      surfaces
    } else {
      surfaces
    }
  };
  surfaces
}

semanticSchemaAffectedSurfaces : HostedModuleAst -> HostedRecordDeclAst -> [Str]
semanticSchemaAffectedSurfaces modl recordDecl = {
  let schemaName = recordDeclName recordDecl;
  let schemaId = semanticSchemaNodeId recordDecl;
  let mut surfaces = emptyRenderedTexts;
  surfaces = semanticAppendSchemaImpactSurface modl surfaces schemaName;
  surfaces = semanticAppendUniqueTexts surfaces (semanticDeclIdsUsingTarget modl schemaId);
  surfaces = semanticAppendUniqueTexts surfaces (semanticRouteIdsForSchemaName modl schemaName);
  surfaces = semanticAppendUniqueTexts surfaces (semanticHookIdsForSchemaName modl schemaName);
  surfaces = semanticAppendUniqueTexts surfaces (semanticToolIdsForSchemaName modl schemaName);
  surfaces = semanticAppendUniqueTexts surfaces (semanticForeignIdsForSchemaName modl schemaName);
  surfaces = semanticAppendUniqueTexts surfaces (semanticWorkflowIdsForSchemaName modl schemaName);
  surfaces = semanticAppendUniqueTexts surfaces (semanticProjectionSurfacesForSchemaName modl schemaName);
  surfaces
}

semanticRouteAffectedSurfacesByHandlerName : HostedModuleAst -> Str -> [Str]
semanticRouteAffectedSurfacesByHandlerName modl handlerName = {
  let mut surfaces = emptyRenderedTexts;
  for routeDecl in moduleRouteDeclarations modl {
    if routeDeclHandlerName routeDecl == handlerName then {
      surfaces = semanticAppendUniqueTexts surfaces (semanticRouteAffectedSurfaces modl routeDecl);
      surfaces
    } else {
      surfaces
    }
  };
  surfaces
}

semanticHookAffectedSurfacesByHandlerName : HostedModuleAst -> Str -> [Str]
semanticHookAffectedSurfacesByHandlerName modl handlerName = {
  let mut surfaces = emptyRenderedTexts;
  for hookDecl in moduleHookDeclarations modl {
    if hookDeclHandlerName hookDecl == handlerName then {
      surfaces = semanticAppendUniqueTexts surfaces (semanticHookAffectedSurfaces modl hookDecl);
      surfaces
    } else {
      surfaces
    }
  };
  surfaces
}

semanticDeclAffectedSurfaces : HostedModuleAst -> HostedDeclAst -> [Str]
semanticDeclAffectedSurfaces modl decl = {
  let declId = semanticDeclNodeId decl;
  let mut surfaces = semanticDeclDependencySurfaces modl decl;
  surfaces = semanticAppendUniqueTexts surfaces (semanticDeclIdsUsingTarget modl declId);
  surfaces = semanticAppendUniqueTexts surfaces (semanticRouteAffectedSurfacesByHandlerName modl (declName decl));
  surfaces = semanticAppendUniqueTexts surfaces (semanticHookAffectedSurfacesByHandlerName modl (declName decl));
  surfaces
}

semanticForeignAffectedSurfaces : HostedModuleAst -> HostedForeignDeclAst -> [Str]
semanticForeignAffectedSurfaces modl foreignDecl = {
  let foreignId = semanticForeignNodeId foreignDecl;
  let mut surfaces = [foreignId];
  for decl in moduleDeclarations modl {
    if semanticContainsText (semanticDeclUseTargetNodeIds modl decl) foreignId then {
      surfaces = semanticAppendUniqueTexts surfaces (semanticDeclAffectedSurfaces modl decl);
      surfaces
    } else {
      surfaces
    }
  };
  surfaces
}

semanticVerifierNamesForToolName : HostedModuleAst -> Str -> [Str]
semanticVerifierNamesForToolName modl toolName = {
  let mut names = emptyRenderedTexts;
  for verifierDecl in moduleVerifierDeclarations modl {
    if verifierDeclToolName verifierDecl == toolName then {
      names = semanticAppendNonEmptyUniqueText names (verifierDeclName verifierDecl);
      names
    } else {
      names
    }
  };
  names
}

semanticVerifierNamesForToolNames : HostedModuleAst -> [Str] -> [Str]
semanticVerifierNamesForToolNames modl toolNames = {
  let mut names = emptyRenderedTexts;
  for toolName in toolNames {
    names = semanticAppendUniqueTexts names (semanticVerifierNamesForToolName modl toolName);
    names
  };
  names
}

semanticVerifierIdsForNames : HostedModuleAst -> [Str] -> [Str]
semanticVerifierIdsForNames modl verifierNames = {
  let mut nodeIds = emptyRenderedTexts;
  for verifierDecl in moduleVerifierDeclarations modl {
    if semanticContainsText verifierNames (verifierDeclName verifierDecl) then {
      nodeIds = semanticAppendNonEmptyUniqueText nodeIds (semanticVerifierNodeId verifierDecl);
      nodeIds
    } else {
      nodeIds
    }
  };
  nodeIds
}

semanticMergeGateIdsForVerifierName : HostedModuleAst -> Str -> [Str]
semanticMergeGateIdsForVerifierName modl verifierName = {
  let mut nodeIds = emptyRenderedTexts;
  for mergeGateDecl in moduleMergeGateDeclarations modl {
    if semanticContainsText (mergeGateDeclVerifierNames mergeGateDecl) verifierName then {
      nodeIds = semanticAppendNonEmptyUniqueText nodeIds (semanticMergeGateNodeId mergeGateDecl);
      nodeIds
    } else {
      nodeIds
    }
  };
  nodeIds
}

semanticMergeGateIdsForVerifierNames : HostedModuleAst -> [Str] -> [Str]
semanticMergeGateIdsForVerifierNames modl verifierNames = {
  let mut nodeIds = emptyRenderedTexts;
  for verifierName in verifierNames {
    nodeIds = semanticAppendUniqueTexts nodeIds (semanticMergeGateIdsForVerifierName modl verifierName);
    nodeIds
  };
  nodeIds
}

semanticToolNamesForVerifierNames : HostedModuleAst -> [Str] -> [Str]
semanticToolNamesForVerifierNames modl verifierNames = {
  let mut toolNames = emptyRenderedTexts;
  for verifierDecl in moduleVerifierDeclarations modl {
    if semanticContainsText verifierNames (verifierDeclName verifierDecl) then {
      toolNames = semanticAppendNonEmptyUniqueText toolNames (verifierDeclToolName verifierDecl);
      toolNames
    } else {
      toolNames
    }
  };
  toolNames
}

semanticToolServerNamesForPolicyName : HostedModuleAst -> Str -> [Str]
semanticToolServerNamesForPolicyName modl policyName = {
  let mut names = emptyRenderedTexts;
  for toolServerDecl in moduleToolServerDeclarations modl {
    if toolServerDeclPolicyName toolServerDecl == policyName then {
      names = semanticAppendNonEmptyUniqueText names (toolServerDeclName toolServerDecl);
      names
    } else {
      names
    }
  };
  names
}

semanticToolNamesForServerNames : HostedModuleAst -> [Str] -> [Str]
semanticToolNamesForServerNames modl serverNames = {
  let mut names = emptyRenderedTexts;
  for toolDecl in moduleToolDeclarations modl {
    if semanticContainsText serverNames (toolDeclServerName toolDecl) then {
      names = semanticAppendNonEmptyUniqueText names (toolDeclName toolDecl);
      names
    } else {
      names
    }
  };
  names
}

semanticPolicyAffectedSurfaces : HostedModuleAst -> HostedPolicyDeclAst -> [Str]
semanticPolicyAffectedSurfaces modl policyDecl = {
  let policyName = policyDeclName policyDecl;
  let mut roleNames = emptyRenderedTexts;
  let mut serverNames = emptyRenderedTexts;
  let mut surfaces = [semanticPolicyNodeId policyDecl];
  for projectionDecl in moduleProjectionDeclarations modl {
    if projectionDeclPolicyName projectionDecl == policyName then {
      surfaces = semanticAppendUniqueTexts surfaces (semanticProjectionAffectedSurfaces modl projectionDecl);
      surfaces
    } else {
      surfaces
    }
  };
  for roleDecl in moduleAgentRoleDeclarations modl {
    if agentRoleDeclPolicyName roleDecl == policyName then {
      roleNames = semanticAppendNonEmptyUniqueText roleNames (agentRoleDeclName roleDecl);
      surfaces = semanticAppendNonEmptyUniqueText surfaces (semanticAgentRoleNodeId roleDecl);
      surfaces
    } else {
      surfaces
    }
  };
  for agentDecl in moduleAgentDeclarations modl {
    if semanticContainsText roleNames (agentDeclRoleName agentDecl) then {
      surfaces = semanticAppendNonEmptyUniqueText surfaces (semanticAgentNodeId agentDecl);
      surfaces
    } else {
      surfaces
    }
  };
  for toolServerDecl in moduleToolServerDeclarations modl {
    if toolServerDeclPolicyName toolServerDecl == policyName then {
      serverNames = semanticAppendNonEmptyUniqueText serverNames (toolServerDeclName toolServerDecl);
      surfaces = semanticAppendNonEmptyUniqueText surfaces (semanticToolServerNodeId toolServerDecl);
      surfaces
    } else {
      surfaces
    }
  };
  surfaces = semanticAppendUniqueTexts surfaces (semanticToolsAffectedSurfacesByNames modl (semanticToolNamesForServerNames modl serverNames));
  surfaces
}

semanticToolNamesForPolicyName : HostedModuleAst -> Str -> [Str]
semanticToolNamesForPolicyName modl policyName =
  semanticToolNamesForServerNames modl (semanticToolServerNamesForPolicyName modl policyName)

semanticVerifierAffectedSurfaces : HostedModuleAst -> HostedVerifierDeclAst -> [Str]
semanticVerifierAffectedSurfaces modl verifierDecl = {
  let mut surfaces = [semanticVerifierNodeId verifierDecl];
  surfaces = semanticAppendUniqueTexts surfaces (semanticToolAffectedSurfacesByName modl (verifierDeclToolName verifierDecl));
  surfaces
}

semanticMergeGateAffectedSurfaces : HostedModuleAst -> HostedMergeGateDeclAst -> [Str]
semanticMergeGateAffectedSurfaces modl mergeGateDecl = {
  let verifierNames = mergeGateDeclVerifierNames mergeGateDecl;
  let mut surfaces = [semanticMergeGateNodeId mergeGateDecl];
  surfaces = semanticAppendUniqueTexts surfaces (semanticVerifierIdsForNames modl verifierNames);
  surfaces = semanticAppendUniqueTexts surfaces (semanticToolsAffectedSurfacesByNames modl (semanticToolNamesForVerifierNames modl verifierNames));
  surfaces
}

semanticImpactEntry : Str -> Str -> Str -> [Str] -> [Str] -> [Str] -> Str
semanticImpactEntry sourceId sourceKind sourceName affectedSurfaces relevantVerifiers relevantMergeGates =
  jsonObject
    [ jsonFieldText "sourceId" sourceId
    , jsonFieldText "sourceKind" sourceKind
    , jsonFieldText "name" sourceName
    , jsonFieldRaw "affectedSurfaces" (semanticJsonTextArray affectedSurfaces)
    , jsonFieldRaw "relevantVerifiers" (semanticJsonTextArray relevantVerifiers)
    , jsonFieldRaw "relevantMergeGates" (semanticJsonTextArray relevantMergeGates)
    ]

semanticContextImpactIndexSchemas : HostedModuleAst -> [Str]
semanticContextImpactIndexSchemas modl = {
  let mut entries = emptyRenderedTexts;
  for recordDecl in moduleRecordDeclarations modl {
    let toolNames = semanticToolNamesForSchemaName modl (recordDeclName recordDecl);
    let verifierNames = semanticVerifierNamesForToolNames modl toolNames;
    entries =
      appendRenderedText
        entries
        (semanticImpactEntry
          (semanticSchemaNodeId recordDecl)
          "schema"
          (recordDeclName recordDecl)
          (semanticSchemaAffectedSurfaces modl recordDecl)
          (semanticVerifierIdsForNames modl verifierNames)
          (semanticMergeGateIdsForVerifierNames modl verifierNames));
    entries
  };
  entries
}

semanticContextImpactIndexDecls : HostedModuleAst -> [Str]
semanticContextImpactIndexDecls modl = {
  let mut entries = emptyRenderedTexts;
  for decl in moduleDeclarations modl {
    entries =
      appendRenderedText
        entries
        (semanticImpactEntry
          (semanticDeclNodeId decl)
          "declaration"
          (declName decl)
          (semanticDeclAffectedSurfaces modl decl)
          emptyRenderedTexts
          emptyRenderedTexts);
    entries
  };
  entries
}

semanticContextImpactIndexRoutes : HostedModuleAst -> [Str]
semanticContextImpactIndexRoutes modl = {
  let mut entries = emptyRenderedTexts;
  for routeDecl in moduleRouteDeclarations modl {
    entries =
      appendRenderedText
        entries
        (semanticImpactEntry
          (semanticRouteNodeId routeDecl)
          "route"
          (routeDeclName routeDecl)
          (semanticRouteAffectedSurfaces modl routeDecl)
          emptyRenderedTexts
          emptyRenderedTexts);
    entries
  };
  entries
}

semanticContextImpactIndexTools : HostedModuleAst -> [Str]
semanticContextImpactIndexTools modl = {
  let mut entries = emptyRenderedTexts;
  for toolDecl in moduleToolDeclarations modl {
    let verifierNames = semanticVerifierNamesForToolName modl (toolDeclName toolDecl);
    entries =
      appendRenderedText
        entries
        (semanticImpactEntry
          (semanticToolNodeId toolDecl)
          "tool"
          (toolDeclName toolDecl)
          (semanticToolAffectedSurfaces modl toolDecl)
          (semanticVerifierIdsForNames modl verifierNames)
          (semanticMergeGateIdsForVerifierNames modl verifierNames));
    entries
  };
  entries
}

semanticContextImpactIndexWorkflows : HostedModuleAst -> [Str]
semanticContextImpactIndexWorkflows modl = {
  let mut entries = emptyRenderedTexts;
  for workflowDecl in moduleWorkflowDeclarations modl {
    entries =
      appendRenderedText
        entries
        (semanticImpactEntry
          (semanticWorkflowNodeId workflowDecl)
          "workflow"
          (workflowDeclName workflowDecl)
          (semanticWorkflowAffectedSurfaces modl workflowDecl)
          emptyRenderedTexts
          emptyRenderedTexts);
    entries
  };
  entries
}

semanticContextImpactIndexPolicies : HostedModuleAst -> [Str]
semanticContextImpactIndexPolicies modl = {
  let mut entries = emptyRenderedTexts;
  for policyDecl in modulePolicyDeclarations modl {
    let verifierNames = semanticVerifierNamesForToolNames modl (semanticToolNamesForPolicyName modl (policyDeclName policyDecl));
    entries =
      appendRenderedText
        entries
        (semanticImpactEntry
          (semanticPolicyNodeId policyDecl)
          "policy"
          (policyDeclName policyDecl)
          (semanticPolicyAffectedSurfaces modl policyDecl)
          (semanticVerifierIdsForNames modl verifierNames)
          (semanticMergeGateIdsForVerifierNames modl verifierNames));
    entries
  };
  entries
}

semanticContextImpactIndexVerifiers : HostedModuleAst -> [Str]
semanticContextImpactIndexVerifiers modl = {
  let mut entries = emptyRenderedTexts;
  for verifierDecl in moduleVerifierDeclarations modl {
    let verifierNames = [verifierDeclName verifierDecl];
    entries =
      appendRenderedText
        entries
        (semanticImpactEntry
          (semanticVerifierNodeId verifierDecl)
          "verifier"
          (verifierDeclName verifierDecl)
          (semanticVerifierAffectedSurfaces modl verifierDecl)
          (semanticVerifierIdsForNames modl verifierNames)
          (semanticMergeGateIdsForVerifierNames modl verifierNames));
    entries
  };
  entries
}

semanticContextImpactIndexMergeGates : HostedModuleAst -> [Str]
semanticContextImpactIndexMergeGates modl = {
  let mut entries = emptyRenderedTexts;
  for mergeGateDecl in moduleMergeGateDeclarations modl {
    entries =
      appendRenderedText
        entries
        (semanticImpactEntry
          (semanticMergeGateNodeId mergeGateDecl)
          "mergeGate"
          (mergeGateDeclName mergeGateDecl)
          (semanticMergeGateAffectedSurfaces modl mergeGateDecl)
          (semanticVerifierIdsForNames modl (mergeGateDeclVerifierNames mergeGateDecl))
          [semanticMergeGateNodeId mergeGateDecl]);
    entries
  };
  entries
}

semanticContextImpactIndex : HostedModuleAst -> Str
semanticContextImpactIndex modl =
  jsonObject
    [ jsonFieldRaw "schemas" (jsonArray (semanticContextImpactIndexSchemas modl))
    , jsonFieldRaw "declarations" (jsonArray (semanticContextImpactIndexDecls modl))
    , jsonFieldRaw "routes" (jsonArray (semanticContextImpactIndexRoutes modl))
    , jsonFieldRaw "tools" (jsonArray (semanticContextImpactIndexTools modl))
    , jsonFieldRaw "workflows" (jsonArray (semanticContextImpactIndexWorkflows modl))
    , jsonFieldRaw "policies" (jsonArray (semanticContextImpactIndexPolicies modl))
    , jsonFieldRaw "verifiers" (jsonArray (semanticContextImpactIndexVerifiers modl))
    , jsonFieldRaw "mergeGates" (jsonArray (semanticContextImpactIndexMergeGates modl))
    ]

semanticContextVerificationGuidance : Str
semanticContextVerificationGuidance =
  jsonObject
    [ jsonFieldRaw "focusedCommands" (semanticJsonTextArray ["bash scripts/verify-affected.sh --changed-file <source.clasp>", "bash scripts/test-selfhost.sh"])
    , jsonFieldRaw "scenarioCommands" (semanticJsonTextArray ["bash examples/lead-app/scripts/verify.sh"])
    , jsonFieldText "fullCommand" "bash scripts/verify-all.sh"
    , jsonFieldRaw "requiresFullBeforeDone" "true"
    ]

semanticRouteVerificationGuidance : HostedRouteDeclAst -> [Str] -> Str
semanticRouteVerificationGuidance routeDecl affectedSurfaces =
  jsonObject
    [ jsonFieldText "scope" "route"
    , jsonFieldText "routeId" (semanticRouteNodeId routeDecl)
    , jsonFieldRaw "requiredSurfaces" (semanticJsonTextArray affectedSurfaces)
    , jsonFieldRaw "focusedCommands" (semanticJsonTextArray ["bash scripts/verify-affected.sh --changed-file <source.clasp>", "bash scripts/test-selfhost.sh"])
    , jsonFieldRaw "scenarioCommands" (semanticJsonTextArray ["bash examples/lead-app/scripts/verify.sh"])
    , jsonFieldText "fullCommand" "bash scripts/verify-all.sh"
    , jsonFieldRaw "requiresFullBeforeDone" "true"
    ]

semanticContextSurfaceIndexSchemaFieldEntry : HostedModuleAst -> Str -> HostedRecordFieldDeclAst -> Str
semanticContextSurfaceIndexSchemaFieldEntry modl schemaName field = {
  let referencedSurfaces = semanticHostedTypeSurfaceIds modl (recordFieldDeclType field);
  jsonObject
    [ jsonFieldText "id" (semanticSchemaFieldNodeId schemaName field)
    , jsonFieldText "name" (recordFieldDeclName field)
    , jsonFieldText "schema" schemaName
    , jsonFieldText "schemaId" (textConcat ["schema:", schemaName])
    , jsonFieldText "type" (renderHostedType (recordFieldDeclType field))
    , jsonFieldText "classification" (recordFieldDeclClassification field)
    , jsonFieldRaw "referencedSurfaces" (semanticJsonTextArray referencedSurfaces)
    , jsonFieldRaw "referencedSchemas" (semanticJsonTextArray (semanticSurfaceIdsWithPrefix referencedSurfaces "schema:"))
    , jsonFieldRaw "referencedTypes" (semanticJsonTextArray (semanticSurfaceIdsWithPrefix referencedSurfaces "type:"))
    ]
}

semanticContextSurfaceIndexSchemaFieldsForRecord : HostedModuleAst -> HostedRecordDeclAst -> [Str]
semanticContextSurfaceIndexSchemaFieldsForRecord modl recordDecl = {
  let mut entries = emptyRenderedTexts;
  for field in recordDeclFields recordDecl {
    entries = appendRenderedText entries (semanticContextSurfaceIndexSchemaFieldEntry modl (recordDeclName recordDecl) field);
    entries
  };
  entries
}

semanticContextSurfaceIndexSchemas : HostedModuleAst -> [Str]
semanticContextSurfaceIndexSchemas modl = {
  let mut entries = emptyRenderedTexts;
  for recordDecl in moduleRecordDeclarations modl {
    let affectedSurfaces = semanticSchemaAffectedSurfaces modl recordDecl;
    entries =
      appendRenderedText
        entries
        (jsonObject
          [ jsonFieldText "id" (semanticSchemaNodeId recordDecl)
          , jsonFieldText "name" (recordDeclName recordDecl)
          , jsonFieldText "kind" "record"
          , jsonFieldRaw "params" (semanticJsonTextArray (recordDeclParams recordDecl))
          , jsonFieldRaw "fieldIds" (semanticJsonTextArray (semanticSchemaFieldNodeIds recordDecl))
          , jsonFieldRaw "fields" (jsonArray (semanticContextSurfaceIndexSchemaFieldsForRecord modl recordDecl))
          , jsonFieldRaw "affectedSurfaces" (semanticJsonTextArray affectedSurfaces)
          , jsonFieldRaw "affectedRoutes" (semanticJsonTextArray (semanticSurfaceIdsWithPrefix affectedSurfaces "route:"))
          , jsonFieldRaw "affectedTools" (semanticJsonTextArray (semanticSurfaceIdsWithPrefix affectedSurfaces "tool:"))
          , jsonFieldRaw "affectedForeignBoundaries" (semanticJsonTextArray (semanticSurfaceIdsWithPrefix affectedSurfaces "foreign:"))
          , jsonFieldRaw "affectedDeclarations" (semanticJsonTextArray (semanticSurfaceIdsWithPrefix affectedSurfaces "decl:"))
          ]);
    entries
  };
  entries
}

semanticContextSurfaceIndexSchemaFields : HostedModuleAst -> [Str]
semanticContextSurfaceIndexSchemaFields modl = {
  let mut entries = emptyRenderedTexts;
  for recordDecl in moduleRecordDeclarations modl {
    entries = append entries (semanticContextSurfaceIndexSchemaFieldsForRecord modl recordDecl);
    entries
  };
  entries
}

semanticContextSurfaceIndexConstructorEntry : HostedModuleAst -> Str -> HostedConstructorDeclAst -> Str
semanticContextSurfaceIndexConstructorEntry modl typeName constructorDecl = {
  let payloadSurfaces = semanticHostedTypesSurfaceIds modl (constructorDeclPayloadTypes constructorDecl);
  jsonObject
    [ jsonFieldText "id" (semanticConstructorNodeId typeName constructorDecl)
    , jsonFieldText "name" (constructorDeclName constructorDecl)
    , jsonFieldText "type" typeName
    , jsonFieldText "typeId" (textConcat ["type:", typeName])
    , jsonFieldText "wireName" (constructorDeclName constructorDecl)
    , jsonFieldRaw "payloadTypes" (semanticJsonTextArray (renderHostedTypeList (constructorDeclPayloadTypes constructorDecl)))
    , jsonFieldRaw "payloadSurfaces" (semanticJsonTextArray payloadSurfaces)
    , jsonFieldRaw "payloadSchemas" (semanticJsonTextArray (semanticSurfaceIdsWithPrefix payloadSurfaces "schema:"))
    , jsonFieldRaw "payloadTypeSurfaces" (semanticJsonTextArray (semanticSurfaceIdsWithPrefix payloadSurfaces "type:"))
    ]
}

semanticContextSurfaceIndexTypeConstructors : HostedModuleAst -> HostedTypeDeclAst -> [Str]
semanticContextSurfaceIndexTypeConstructors modl typeDecl = {
  let mut entries = emptyRenderedTexts;
  for constructorDecl in typeDeclConstructors typeDecl {
    entries = appendRenderedText entries (semanticContextSurfaceIndexConstructorEntry modl (typeDeclName typeDecl) constructorDecl);
    entries
  };
  entries
}

semanticConstructorWireNames : HostedTypeDeclAst -> [Str]
semanticConstructorWireNames typeDecl = {
  let mut names = emptyRenderedTexts;
  for constructorDecl in typeDeclConstructors typeDecl {
    names = appendRenderedText names (constructorDeclName constructorDecl);
    names
  };
  names
}

semanticTypeAffectedSurfaces : HostedModuleAst -> HostedTypeDeclAst -> [Str]
semanticTypeAffectedSurfaces modl typeDecl = {
  let typeName = typeDeclName typeDecl;
  let mut surfaces = [semanticTypeNodeId typeDecl];
  surfaces = semanticAppendUniqueTexts surfaces (semanticConstructorNodeIds typeDecl);
  for recordDecl in moduleRecordDeclarations modl {
    if semanticRecordDeclUsesTypeName recordDecl typeName then {
      surfaces = semanticAppendUniqueTexts surfaces (semanticSchemaAffectedSurfaces modl recordDecl);
      surfaces
    } else {
      surfaces
    }
  };
  surfaces = semanticAppendUniqueTexts surfaces (semanticRouteIdsForSchemaName modl typeName);
  surfaces = semanticAppendUniqueTexts surfaces (semanticHookIdsForSchemaName modl typeName);
  surfaces = semanticAppendUniqueTexts surfaces (semanticToolIdsForSchemaName modl typeName);
  surfaces = semanticAppendUniqueTexts surfaces (semanticForeignIdsForTypeName modl typeName);
  surfaces = semanticAppendUniqueTexts surfaces (semanticWorkflowIdsForSchemaName modl typeName);
  surfaces
}

semanticContextSurfaceIndexTypes : HostedModuleAst -> [Str]
semanticContextSurfaceIndexTypes modl = {
  let mut entries = emptyRenderedTexts;
  for typeDecl in moduleTypeDeclarations modl {
    let affectedSurfaces = semanticTypeAffectedSurfaces modl typeDecl;
    entries =
      appendRenderedText
        entries
        (jsonObject
          [ jsonFieldText "id" (semanticTypeNodeId typeDecl)
          , jsonFieldText "name" (typeDeclName typeDecl)
          , jsonFieldText "kind" "type"
          , jsonFieldRaw "params" (semanticJsonTextArray (typeDeclParams typeDecl))
          , jsonFieldRaw "constructorIds" (semanticJsonTextArray (semanticConstructorNodeIds typeDecl))
          , jsonFieldRaw "wireConstructorNames" (semanticJsonTextArray (semanticConstructorWireNames typeDecl))
          , jsonFieldRaw "constructors" (jsonArray (semanticContextSurfaceIndexTypeConstructors modl typeDecl))
          , jsonFieldRaw "affectedSurfaces" (semanticJsonTextArray affectedSurfaces)
          , jsonFieldRaw "affectedSchemas" (semanticJsonTextArray (semanticSurfaceIdsWithPrefix affectedSurfaces "schema:"))
          , jsonFieldRaw "affectedSchemaFields" (semanticJsonTextArray (semanticSurfaceIdsWithPrefix affectedSurfaces "schema-field:"))
          , jsonFieldRaw "affectedRoutes" (semanticJsonTextArray (semanticSurfaceIdsWithPrefix affectedSurfaces "route:"))
          , jsonFieldRaw "affectedTools" (semanticJsonTextArray (semanticSurfaceIdsWithPrefix affectedSurfaces "tool:"))
          , jsonFieldRaw "affectedForeignBoundaries" (semanticJsonTextArray (semanticSurfaceIdsWithPrefix affectedSurfaces "foreign:"))
          ]);
    entries
  };
  entries
}

semanticContextSurfaceIndexRoutes : HostedModuleAst -> [Str]
semanticContextSurfaceIndexRoutes modl = {
  let mut entries = emptyRenderedTexts;
  for routeDecl in moduleRouteDeclarations modl {
    let affectedSurfaces = semanticRouteAffectedSurfaces modl routeDecl;
    entries =
      appendRenderedText
        entries
        (jsonObject
          [ jsonFieldText "id" (semanticRouteNodeId routeDecl)
          , jsonFieldText "name" (routeDeclName routeDecl)
          , jsonFieldText "identity" (routeDeclIdentity routeDecl)
          , jsonFieldText "method" (routeDeclMethod routeDecl)
          , jsonFieldText "path" (routeDeclPath routeDecl)
          , jsonFieldText "requestType" (routeDeclRequestType routeDecl)
          , jsonFieldText "responseType" (routeDeclResponseType routeDecl)
          , jsonFieldText "responseKind" (semanticRouteResponseKind (routeDeclResponseType routeDecl))
          , jsonFieldText "handler" (routeDeclHandlerName routeDecl)
          , jsonFieldText "requestSchemaId" (textConcat ["schema:", routeDeclRequestType routeDecl])
          , jsonFieldText "responseSchemaId" (textConcat ["schema:", routeDeclResponseType routeDecl])
          , jsonFieldText "handlerId" (textConcat ["decl:", routeDeclHandlerName routeDecl])
          , jsonFieldRaw "affectedSurfaces" (semanticJsonTextArray affectedSurfaces)
          , jsonFieldRaw "affectedRoutes" (semanticJsonTextArray (semanticSurfaceIdsWithPrefix affectedSurfaces "route:"))
          , jsonFieldRaw "affectedSchemas" (semanticJsonTextArray (semanticSurfaceIdsWithPrefix affectedSurfaces "schema:"))
          , jsonFieldRaw "affectedDeclarations" (semanticJsonTextArray (semanticSurfaceIdsWithPrefix affectedSurfaces "decl:"))
          , jsonFieldRaw "affectedForeignBoundaries" (semanticJsonTextArray (semanticSurfaceIdsWithPrefix affectedSurfaces "foreign:"))
          , jsonFieldRaw "verificationGuidance" (semanticRouteVerificationGuidance routeDecl affectedSurfaces)
          ]);
    entries
  };
  entries
}

semanticContextSurfaceIndexWorkflows : [HostedWorkflowDeclAst] -> [Str]
semanticContextSurfaceIndexWorkflows workflowDecls = {
  let mut entries = emptyRenderedTexts;
  for workflowDecl in workflowDecls {
    entries =
      appendRenderedText
        entries
        (jsonObject
          [ jsonFieldText "id" (semanticWorkflowNodeId workflowDecl)
          , jsonFieldText "name" (workflowDeclName workflowDecl)
          , jsonFieldText "identity" (workflowDeclIdentity workflowDecl)
          , jsonFieldText "stateType" (renderHostedType (workflowDeclStateTypeAst workflowDecl))
          ]);
    entries
  };
  entries
}

semanticContextSurfaceIndexTools : [HostedToolDeclAst] -> [Str]
semanticContextSurfaceIndexTools toolDecls = {
