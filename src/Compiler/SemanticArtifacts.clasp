semanticAirRootIds : HostedModuleAst -> [Str]
semanticAirRootIds modl = {
  let mut rootIds = [textConcat ["module:", moduleNameOf modl]];
  for typeDecl in moduleTypeDeclarations modl {
    rootIds = appendRenderedText rootIds (semanticTypeNodeId typeDecl);
    rootIds
  };
  for recordDecl in moduleRecordDeclarations modl {
    rootIds = appendRenderedText rootIds (semanticRecordNodeId recordDecl);
    rootIds
  };
  for foreignDecl in moduleForeignDeclarations modl {
    rootIds = appendRenderedText rootIds (semanticForeignNodeId foreignDecl);
    rootIds
  };
  for decl in moduleDeclarations modl {
    rootIds = appendRenderedText rootIds (semanticDeclNodeId decl);
    rootIds
  };
  for guideDecl in moduleGuideDeclarations modl {
    rootIds = appendRenderedText rootIds (semanticGuideNodeId guideDecl);
    rootIds
  };
  for policyDecl in modulePolicyDeclarations modl {
    rootIds = appendRenderedText rootIds (semanticPolicyNodeId policyDecl);
    rootIds
  };
  for projectionDecl in moduleProjectionDeclarations modl {
    rootIds = appendRenderedText rootIds (semanticProjectionNodeId projectionDecl);
    rootIds
  };
  for roleDecl in moduleAgentRoleDeclarations modl {
    rootIds = appendRenderedText rootIds (semanticAgentRoleNodeId roleDecl);
    rootIds
  };
  for agentDecl in moduleAgentDeclarations modl {
    rootIds = appendRenderedText rootIds (semanticAgentNodeId agentDecl);
    rootIds
  };
  for workflowDecl in moduleWorkflowDeclarations modl {
    rootIds = appendRenderedText rootIds (semanticWorkflowNodeId workflowDecl);
    rootIds
  };
  for routeDecl in moduleRouteDeclarations modl {
    rootIds = appendRenderedText rootIds (semanticRouteNodeId routeDecl);
    rootIds
  };
  for hookDecl in moduleHookDeclarations modl {
    rootIds = appendRenderedText rootIds (semanticHookNodeId hookDecl);
    rootIds
  };
  for toolServerDecl in moduleToolServerDeclarations modl {
    rootIds = appendRenderedText rootIds (semanticToolServerNodeId toolServerDecl);
    rootIds
  };
  for toolDecl in moduleToolDeclarations modl {
    rootIds = appendRenderedText rootIds (semanticToolNodeId toolDecl);
    rootIds
  };
  for verifierDecl in moduleVerifierDeclarations modl {
    rootIds = appendRenderedText rootIds (semanticVerifierNodeId verifierDecl);
    rootIds
  };
  for mergeGateDecl in moduleMergeGateDeclarations modl {
    rootIds = appendRenderedText rootIds (semanticMergeGateNodeId mergeGateDecl);
    rootIds
  };
  rootIds
}

semanticAirNodes : HostedModuleAst -> [Str]
semanticAirNodes modl = {
  let mut nodes = [semanticAirModuleNode modl];
  nodes = append nodes (semanticAirImportNodes (moduleImports modl));
  nodes = append nodes (semanticAirTypeNodes (moduleTypeDeclarations modl));
  nodes = append nodes (semanticAirRecordNodes (moduleRecordDeclarations modl));
  nodes = append nodes (semanticAirForeignNodes (moduleForeignDeclarations modl));
  nodes = append nodes (semanticAirDeclNodes (moduleDeclarations modl));
  nodes = append nodes (semanticAirGuideNodes (moduleGuideDeclarations modl));
  nodes = append nodes (semanticAirPolicyNodes (modulePolicyDeclarations modl));
  nodes = append nodes (semanticAirProjectionNodes (moduleProjectionDeclarations modl));
  nodes = append nodes (semanticAirAgentRoleNodes (moduleAgentRoleDeclarations modl));
  nodes = append nodes (semanticAirAgentNodes (moduleAgentDeclarations modl));
  nodes = append nodes (semanticAirWorkflowNodes (moduleWorkflowDeclarations modl));
  nodes = append nodes (semanticAirRouteNodes (moduleRouteDeclarations modl));
  nodes = append nodes (semanticAirHookNodes (moduleHookDeclarations modl));
  nodes = append nodes (semanticAirToolServerNodes (moduleToolServerDeclarations modl));
  nodes = append nodes (semanticAirToolNodes (moduleToolDeclarations modl));
  nodes = append nodes (semanticAirVerifierNodes (moduleVerifierDeclarations modl));
  nodes = append nodes (semanticAirMergeGateNodes (moduleMergeGateDeclarations modl));
  nodes
}

renderAirModuleJson : HostedModuleAst -> Str
renderAirModuleJson modl =
  jsonObject
    [ jsonFieldText "format" "clasp-air-v1"
    , jsonFieldText "module" (moduleNameOf modl)
    , jsonFieldRaw "roots" (semanticJsonTextArray (semanticAirRootIds modl))
    , jsonFieldRaw "nodes" (jsonArray (semanticAirNodes modl))
    ]

semanticRecordNames : HostedModuleAst -> [Str]
semanticRecordNames modl = recordDeclNames modl

semanticTypeNames : HostedModuleAst -> [Str]
semanticTypeNames modl = typeDeclNames modl

semanticDeclNames : HostedModuleAst -> [Str]
