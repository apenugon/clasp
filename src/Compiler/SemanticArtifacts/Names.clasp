semanticContainsText : [Str] -> Str -> Bool
semanticContainsText values target = containsText values target

semanticNonEmptyContainsText : [Str] -> Str -> Bool
semanticNonEmptyContainsText values target =
  if target == "" then false else semanticContainsText values target

semanticAppendUniqueText : [Str] -> Str -> [Str]
semanticAppendUniqueText values value =
  if semanticContainsText values value then values else appendRenderedText values value

semanticAppendNamedTargetEdge : [Str] -> [Str] -> Str -> Str -> Str -> Str -> [Str]
semanticAppendNamedTargetEdge edges availableNames targetName fromId targetPrefix kind =
  if semanticNonEmptyContainsText availableNames targetName then
    appendRenderedText edges (semanticJsonEdge fromId (textConcat [targetPrefix, targetName]) kind)
  else
    edges
