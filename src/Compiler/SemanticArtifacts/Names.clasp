module Compiler.SemanticArtifacts.Names

import Compiler.Ast
import Compiler.Checker
import Compiler.Checker.Types
import Compiler.Json
import Compiler.Project
import Compiler.SemanticArtifacts.Base

semanticRecordNames : HostedModuleAst -> [Str]
semanticRecordNames modl = recordDeclNames modl

semanticTypeNames : HostedModuleAst -> [Str]
semanticTypeNames modl = typeDeclNames modl

semanticDeclNames : HostedModuleAst -> [Str]
semanticDeclNames modl = declNames modl

semanticForeignNames : HostedModuleAst -> [Str]
semanticForeignNames modl = {
  let mut names = emptyRenderedTexts;
  for foreignDecl in moduleForeignDeclarations modl {
    names = appendRenderedText names (foreignDeclName foreignDecl);
    names
  };
  names
}

