semanticContextImpactIndexPolicies : HostedModuleAst -> [Str]
semanticContextImpactIndexPolicies modl = {
  let mut entries = emptyRenderedTexts;
  for policyDecl in modulePolicyDeclarations modl {
    let verifierNames = semanticVerifierNamesForToolNames modl (semanticToolNamesForPolicyName modl (policyDeclName policyDecl));
    entries =
      appendRenderedText
        entries
        (semanticImpactEntry
          (semanticPolicyNodeId policyDecl)
          "policy"
          (policyDeclName policyDecl)
          (semanticPolicyAffectedSurfaces modl policyDecl)
          (semanticVerifierIdsForNames modl verifierNames)
          (semanticMergeGateIdsForVerifierNames modl verifierNames));
    entries
  };
  entries
}

semanticContextImpactIndexVerifiers : HostedModuleAst -> [Str]
semanticContextImpactIndexVerifiers modl = {
  let mut entries = emptyRenderedTexts;
  for verifierDecl in moduleVerifierDeclarations modl {
    let verifierNames = [verifierDeclName verifierDecl];
    entries =
      appendRenderedText
        entries
        (semanticImpactEntry
          (semanticVerifierNodeId verifierDecl)
          "verifier"
          (verifierDeclName verifierDecl)
          (semanticVerifierAffectedSurfaces modl verifierDecl)
          (semanticVerifierIdsForNames modl verifierNames)
          (semanticMergeGateIdsForVerifierNames modl verifierNames));
    entries
  };
  entries
}

semanticContextImpactIndexMergeGates : HostedModuleAst -> [Str]
semanticContextImpactIndexMergeGates modl = {
  let mut entries = emptyRenderedTexts;
  for mergeGateDecl in moduleMergeGateDeclarations modl {
    entries =
      appendRenderedText
        entries
        (semanticImpactEntry
          (semanticMergeGateNodeId mergeGateDecl)
          "mergeGate"
          (mergeGateDeclName mergeGateDecl)
          (semanticMergeGateAffectedSurfaces modl mergeGateDecl)
          (semanticVerifierIdsForNames modl (mergeGateDeclVerifierNames mergeGateDecl))
          [semanticMergeGateNodeId mergeGateDecl]);
    entries
  };
  entries
}

semanticContextImpactIndex : HostedModuleAst -> Str
semanticContextImpactIndex modl =
  jsonObject
    [ jsonFieldRaw "schemas" (jsonArray (semanticContextImpactIndexSchemas modl))
    , jsonFieldRaw "declarations" (jsonArray (semanticContextImpactIndexDecls modl))
    , jsonFieldRaw "routes" (jsonArray (semanticContextImpactIndexRoutes modl))
    , jsonFieldRaw "tools" (jsonArray (semanticContextImpactIndexTools modl))
    , jsonFieldRaw "workflows" (jsonArray (semanticContextImpactIndexWorkflows modl))
    , jsonFieldRaw "policies" (jsonArray (semanticContextImpactIndexPolicies modl))
    , jsonFieldRaw "verifiers" (jsonArray (semanticContextImpactIndexVerifiers modl))
    , jsonFieldRaw "mergeGates" (jsonArray (semanticContextImpactIndexMergeGates modl))
    ]
