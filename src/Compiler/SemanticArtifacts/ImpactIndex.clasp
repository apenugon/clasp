semanticContextImpactIndexWorkflows modl = {
  let mut entries = emptyRenderedTexts;
  for workflowDecl in moduleWorkflowDeclarations modl {
    entries =
      appendRenderedText
        entries
        (semanticImpactEntry
          (semanticWorkflowNodeId workflowDecl)
          "workflow"
          (workflowDeclName workflowDecl)
          (semanticWorkflowAffectedSurfaces modl workflowDecl)
