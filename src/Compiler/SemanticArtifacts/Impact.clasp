}

semanticToolNamesForVerifierNames : HostedModuleAst -> [Str] -> [Str]
semanticToolNamesForVerifierNames modl verifierNames = {
  let mut toolNames = emptyRenderedTexts;
  for verifierDecl in moduleVerifierDeclarations modl {
    if semanticContainsText verifierNames (verifierDeclName verifierDecl) then {
      toolNames = semanticAppendNonEmptyUniqueText toolNames (verifierDeclToolName verifierDecl);
      toolNames
    } else {
