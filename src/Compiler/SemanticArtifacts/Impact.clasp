semanticMergeGateIdsForVerifierName modl verifierName = {
  let mut nodeIds = emptyRenderedTexts;
  for mergeGateDecl in moduleMergeGateDeclarations modl {
    if semanticContainsText (mergeGateDeclVerifierNames mergeGateDecl) verifierName then {
