semanticForeignIdsForSchemaName : HostedModuleAst -> Str -> [Str]
semanticForeignIdsForSchemaName modl schemaName =
  semanticForeignIdsForTypeName modl schemaName

semanticToolNamesForSchemaName : HostedModuleAst -> Str -> [Str]
semanticToolNamesForSchemaName modl schemaName = {
  let mut names = emptyRenderedTexts;
  for toolDecl in moduleToolDeclarations modl {
    if toolDeclRequestType toolDecl == schemaName then {
      names = semanticAppendNonEmptyUniqueText names (toolDeclName toolDecl);
      names
    } else if toolDeclResponseType toolDecl == schemaName then {
      names = semanticAppendNonEmptyUniqueText names (toolDeclName toolDecl);
      names
    } else {
      names
    }
  };
  names
}

semanticWorkflowIdsForSchemaName : HostedModuleAst -> Str -> [Str]
semanticWorkflowIdsForSchemaName modl schemaName = {
  let mut nodeIds = emptyRenderedTexts;
  for workflowDecl in moduleWorkflowDeclarations modl {
    if renderHostedType (workflowDeclStateTypeAst workflowDecl) == schemaName then {
      nodeIds = semanticAppendNonEmptyUniqueText nodeIds (semanticWorkflowNodeId workflowDecl);
      nodeIds
    } else {
      nodeIds
    }
