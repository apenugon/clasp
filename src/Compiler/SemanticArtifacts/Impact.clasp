semanticForeignIdsForTypeName modl typeName = {
  let mut nodeIds = emptyRenderedTexts;
  for foreignDecl in moduleForeignDeclarations modl {
    if semanticHostedTypeUsesName (foreignDeclTypeAst foreignDecl) typeName then {
