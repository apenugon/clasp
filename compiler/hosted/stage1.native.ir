runtime {
  profile compiler_backend_minimal
  artifacts ["runtime/native/clasp_runtime.h", "runtime/native/clasp_runtime.rs"]
  memory_symbols [clasp_rt_init, clasp_rt_register_static_root, clasp_rt_alloc_object, clasp_rt_retain, clasp_rt_release, clasp_rt_string_from_utf8, clasp_rt_bytes_new, clasp_rt_string_list_new, clasp_rt_result_ok_string, clasp_rt_result_err_string, clasp_rt_json_from_string, clasp_rt_json_to_string, clasp_rt_binary_from_json, clasp_rt_json_from_binary, clasp_rt_transport_frame, clasp_rt_transport_unframe]
  bindings [textConcat{runtime=textConcat, symbol=clasp_rt_text_concat, type=[Str] -> Str}, textJoin{runtime=textJoin, symbol=clasp_rt_text_join, type=Str -> [Str] -> Str}, textSplit{runtime=textSplit, symbol=clasp_rt_text_split, type=Str -> Str -> [Str]}, textChars{runtime=textChars, symbol=clasp_rt_text_chars, type=Str -> [Str]}, textFingerprint64Hex{runtime=textFingerprint64Hex, symbol=clasp_rt_text_fingerprint64_hex, type=Str -> Str}, textPrefix{runtime=textPrefix, symbol=clasp_rt_text_prefix, type=Str -> Str -> Result}, textSplitFirst{runtime=textSplitFirst, symbol=clasp_rt_text_split_first, type=Str -> Str -> Result}]
  json_codecs [Str{encode=$encode_Str, decode=$decode_Str}, HostedCompilerSnapshot{encode=$encode_HostedCompilerSnapshot, decode=$decode_HostedCompilerSnapshot}]
  binary_codecs [Str{encode=$encode_binary_Str, decode=$decode_binary_Str, framing=length_prefixed}, HostedCompilerSnapshot{encode=$encode_binary_HostedCompilerSnapshot, decode=$decode_binary_HostedCompilerSnapshot, framing=length_prefixed}]
  boundaries []
  service_transports []
}

