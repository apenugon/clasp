abi {
  version clasp-native-v1
  word_bytes 8
  memory_strategy reference_counting
  allocation { immediate = stack, handle = heap, global = static }
  ownership_rules [caller_owns_returns, callee_borrows_arguments, aggregates_retain_handle_fields, globals_are_static_roots]
  root_discovery_rules [static_globals, stack_handle_slots, heap_object_layouts]
  lifetime_invariants [layout_and_retain_headers, declared_root_offsets_only, release_children_before_free, borrowed_handles_do_not_retain]
  builtin_layout Int { storage = immediate, words = 1 }
  builtin_layout Bool { storage = immediate, words = 1 }
  builtin_layout Str { storage = handle, words = 1 }
  builtin_layout List { storage = handle, words = 1 }
  builtin_layout Page { storage = handle, words = 1 }
  builtin_layout Redirect { storage = handle, words = 1 }
  builtin_layout View { storage = handle, words = 1 }
  builtin_layout Prompt { storage = handle, words = 1 }
  record_layout Principal { words = 1, fields = [id:Str@word0/handle] }
  record_layout Tenant { words = 1, fields = [id:Str@word0/handle] }
  record_layout ResourceIdentity { words = 2, fields = [resourceType:Str@word0/handle, resourceId:Str@word1/handle] }
  record_layout AuditActor { words = 2, fields = [actorType:Str@word0/handle, actorId:Str@word1/handle] }
  record_layout AuditAction { words = 2, fields = [actionType:Str@word0/handle, summary:Str@word1/handle] }
  record_layout AuditProvenance { words = 3, fields = [source:Str@word0/handle, requestId:Str@word1/handle, traceId:Str@word2/handle] }
  record_layout SqliteConnection { words = 4, fields = [id:Str@word0/handle, databasePath:Str@word1/handle, readOnly:Bool@word2/immediate, memory:Bool@word3/immediate] }
