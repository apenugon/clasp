moduleForeignDeclarations modl = match modl {
  HostedModuleAst moduleName imports typeDeclarations recordDeclarations foreignDeclarations declarations mainExprSummary -> foreignDeclarations
}
moduleDeclarations : HostedModuleAst -> [HostedDeclAst]
moduleDeclarations modl = match modl {
  HostedModuleAst moduleName imports typeDeclarations recordDeclarations foreignDeclarations declarations mainExprSummary -> declarations
