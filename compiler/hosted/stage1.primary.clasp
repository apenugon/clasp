record HostedCompilerSnapshot = { loweredValue: Str, loweredFunction: Str, loweredModule: Str, checkedValueType: Str, checkedFunctionType: Str, checkedModule: Str, explainModule: Str, mismatchDiagnostic: Str, emittedModule: Str, emittedNativeModule: Str, emittedNativeImageModule: Str, parsedSampleModuleName: Str, parsedSampleImports: [Str], parsedSampleDeclNames: [Str], parsedSampleMainExpr: Str, secondaryParsedModuleName: Str, secondaryParsedDeclNames: [Str], secondaryCheckedModule: Str, secondaryLoweredModule: Str, secondaryEmittedModule: Str, tertiaryParsedModuleName: Str, tertiaryParsedDeclNames: [Str], tertiaryCheckedModule: Str, tertiaryLoweredModule: Str, tertiaryEmittedModule: Str, quaternaryParsedModuleName: Str, quaternaryParsedDeclNames: [Str], quaternaryCheckedModule: Str, quaternaryLoweredModule: Str, quaternaryEmittedModule: Str, quinaryParsedModuleName: Str, quinaryParsedRecordNames: [Str], quinaryParsedRecordFieldTypes: [Str], quinaryParsedDeclNames: [Str], quinaryCheckedModule: Str, quinaryLoweredModule: Str, quinaryEmittedModule: Str, senaryParsedModuleName: Str, senaryParsedTypeNames: [Str], senaryParsedConstructorSummaries: [Str], senaryChooseAnnotation: Str, senaryParsedDeclNames: [Str], senaryCheckedModule: Str, senaryLoweredModule: Str, senaryEmittedModule: Str, septenaryParsedModuleName: Str, septenaryParsedDeclNames: [Str], septenaryCheckedModule: Str, septenaryLoweredModule: Str, septenaryEmittedModule: Str }

renderStringLiteral : Str -> Str
renderStringLiteral value = encode value
renderHostedAtomicType : HostedTypeAst -> Str
renderHostedAtomicType typeAst = match typeAst {
  HostedTypeFunction input result -> textConcat ["(", renderHostedType typeAst, ")"],
  HostedTypeList itemType -> textConcat ["[", renderHostedType itemType, "]"],
  HostedTypeName name -> name
}
renderHostedType : HostedTypeAst -> Str
renderHostedType typeAst = match typeAst {
  HostedTypeName name -> name,
  HostedTypeList itemType -> textConcat ["[", renderHostedType itemType, "]"],
  HostedTypeFunction input result -> textConcat [renderHostedAtomicType input, " -> ", renderHostedType result]
}
missingAnnotation : HostedAnnotationAst
missingAnnotation = MissingAnnotation
presentAnnotation : HostedTypeAst -> HostedAnnotationAst
presentAnnotation typeAst = PresentAnnotation typeAst
annotationTypeAst : HostedAnnotationAst -> HostedTypeAst
annotationTypeAst annotation = match annotation {
  MissingAnnotation -> HostedTypeName "",
  PresentAnnotation typeAst -> typeAst
}
hasAnnotationAst : HostedAnnotationAst -> Bool
hasAnnotationAst annotation = match annotation {
  MissingAnnotation -> false,
  PresentAnnotation typeAst -> true
}
renderAnnotationAst : HostedAnnotationAst -> Str
renderAnnotationAst annotation = match annotation {
  MissingAnnotation -> "",
  PresentAnnotation typeAst -> renderHostedType typeAst
}
