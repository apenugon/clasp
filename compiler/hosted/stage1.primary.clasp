parserState moduleName imports typeDeclarations recordDeclarations foreignDeclarations declarations pendingAnnotation mainExprSummary = ParserState moduleName imports typeDeclarations recordDeclarations foreignDeclarations declarations pendingAnnotation mainExprSummary
stateModuleName : ParserState -> Str
stateModuleName state = match state {
  ParserState moduleName imports typeDeclarations recordDeclarations foreignDeclarations declarations pendingAnnotation mainExprSummary -> moduleName
}
