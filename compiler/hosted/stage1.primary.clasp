hostedModuleAst moduleName imports typeDeclarations recordDeclarations foreignDeclarations declarations mainExprSummary = HostedModuleAst moduleName imports typeDeclarations recordDeclarations foreignDeclarations declarations mainExprSummary
moduleNameOf : HostedModuleAst -> Str
moduleNameOf modl = match modl {
