  ]

emitHostedRecordFieldLayoutImage : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> Str -> HostedRecordFieldDeclAst -> Str
emitHostedRecordFieldLayoutImage typeDecls recordDecls wordOffset fieldDecl =
  jsonObject [
    jsonFieldText "name" (recordFieldDeclName fieldDecl),
    jsonFieldText "type" (renderHostedType (recordFieldDeclType fieldDecl)),
    jsonFieldText "storage" (nativeLayoutStorageForType typeDecls recordDecls (recordFieldDeclType fieldDecl)),
    jsonFieldRaw "wordOffset" wordOffset,
    jsonFieldRaw "wordCount" "1"
  ]

emitHostedRecordFieldLayoutImages : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [HostedRecordFieldDeclAst] -> [Str]
emitHostedRecordFieldLayoutImages typeDecls recordDecls fields = {
  let mut rendered = [];
  let mut wordOffset = "0";
  for fieldDecl in fields {
    rendered = appendNativeRenderedText rendered (emitHostedRecordFieldLayoutImage typeDecls recordDecls wordOffset fieldDecl);
    wordOffset = incrementNativeNumber wordOffset;
    rendered
  };
  rendered
}

emitHostedRecordLayoutImages : HostedModuleAst -> [Str]
emitHostedRecordLayoutImages modl = {
  let typeDecls = effectiveModuleTypeDecls modl;
  let recordDecls = moduleRecordDeclarations modl;
  let mut rendered = [];
  for recordDecl in recordDecls {
    rendered = appendNativeRenderedText rendered (jsonObject [
      jsonFieldText "name" (recordDeclName recordDecl),
      jsonFieldRaw "words" (countHostedRecordFields (recordDeclFields recordDecl)),
      jsonFieldArray "fields" (emitHostedRecordFieldLayoutImages typeDecls recordDecls (recordDeclFields recordDecl))
    ]);
    rendered
  };
  rendered
}

emitHostedPayloadLayoutImage : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> Str -> HostedTypeAst -> Str
emitHostedPayloadLayoutImage typeDecls recordDecls wordOffset payloadType =
  jsonObject [
    jsonFieldText "name" (textConcat ["$", decrementNativeNumber wordOffset]),
    jsonFieldText "type" (renderHostedType payloadType),
    jsonFieldText "storage" (nativeLayoutStorageForType typeDecls recordDecls payloadType),
    jsonFieldRaw "wordOffset" wordOffset,
    jsonFieldRaw "wordCount" "1"
  ]

emitHostedPayloadLayoutImages : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [HostedTypeAst] -> [Str]
emitHostedPayloadLayoutImages typeDecls recordDecls payloadTypes = {
  let mut rendered = [];
  let mut wordOffset = "1";
  for payloadType in payloadTypes {
    rendered = appendNativeRenderedText rendered (emitHostedPayloadLayoutImage typeDecls recordDecls wordOffset payloadType);
    wordOffset = incrementNativeNumber wordOffset;
    rendered
  };
  rendered
}

emitHostedConstructorLayoutImage : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> HostedConstructorDeclAst -> Str
emitHostedConstructorLayoutImage typeDecls recordDecls constructorDecl = {
  let payloadTypes = constructorDeclPayloadTypes constructorDecl;
  let payloadWords = countHostedTypes payloadTypes;
  let totalWords = incrementNativeNumber payloadWords;
  jsonObject [
    jsonFieldText "name" (constructorDeclName constructorDecl),
    jsonFieldRaw "tagWord" "0",
    jsonFieldRaw "payloadWords" payloadWords,
    jsonFieldRaw "words" totalWords,
    jsonFieldArray "payloads" (emitHostedPayloadLayoutImages typeDecls recordDecls payloadTypes)
  ]
}

emitHostedVariantLayoutImages : HostedModuleAst -> [Str]
emitHostedVariantLayoutImages modl = {
  let typeDecls = effectiveModuleTypeDecls modl;
  let emittedTypeDecls = nativeEmittedTypeDecls modl;
  let recordDecls = moduleRecordDeclarations modl;
  let mut rendered = [];
  for typeDecl in emittedTypeDecls {
    let maxPayloadWords = countHostedTypes (maxConstructorPayloadTypes typeDecl);
    let mut constructorLayouts = [];
    for constructorDecl in typeDeclConstructors typeDecl {
      constructorLayouts = appendNativeRenderedText constructorLayouts (emitHostedConstructorLayoutImage typeDecls recordDecls constructorDecl);
      constructorLayouts
    };
    rendered = appendNativeRenderedText rendered (jsonObject [
      jsonFieldText "name" (typeDeclName typeDecl),
      jsonFieldRaw "tagWord" "0",
      jsonFieldRaw "maxPayloadWords" maxPayloadWords,
      jsonFieldRaw "words" (incrementNativeNumber maxPayloadWords),
      jsonFieldArray "constructors" constructorLayouts
    ]);
    rendered
  };
  rendered
}

emitHostedRecordObjectLayoutImages : HostedModuleAst -> [Str]
emitHostedRecordObjectLayoutImages modl = {
  let typeDecls = effectiveModuleTypeDecls modl;
  let recordDecls = moduleRecordDeclarations modl;
  let mut rendered = [];
  for recordDecl in recordDecls {
    let fieldCount = countHostedRecordFields (recordDeclFields recordDecl);
    rendered = appendNativeRenderedText rendered (jsonObject [
      jsonFieldText "name" (recordDeclName recordDecl),
      jsonFieldText "kind" "record",
      jsonFieldRaw "headerWords" "2",
      jsonFieldRaw "words" (headerAdjustedOffset fieldCount),
      jsonFieldArray "roots" (emitNativeJsonNumberList (emitHostedRecordRootOffsets typeDecls recordDecls (recordDeclFields recordDecl)))
    ]);
    rendered
  };
  rendered
}

emitHostedVariantObjectLayoutImages : HostedModuleAst -> [Str]
emitHostedVariantObjectLayoutImages modl = {
  let typeDecls = effectiveModuleTypeDecls modl;
  let emittedTypeDecls = nativeEmittedTypeDecls modl;
  let recordDecls = moduleRecordDeclarations modl;
  let mut rendered = [];
  for typeDecl in emittedTypeDecls {
    for constructorDecl in typeDeclConstructors typeDecl {
      let payloadTypes = constructorDeclPayloadTypes constructorDecl;
      let totalWords = incrementNativeNumber (countHostedTypes payloadTypes);
      rendered = appendNativeRenderedText rendered (jsonObject [
        jsonFieldText "name" (textConcat [typeDeclName typeDecl, ".", constructorDeclName constructorDecl]),
        jsonFieldText "kind" "variant",
        jsonFieldRaw "headerWords" "2",
        jsonFieldRaw "words" (headerAdjustedOffset totalWords),
        jsonFieldArray "roots" (emitNativeJsonNumberList (emitHostedVariantRootOffsets typeDecls recordDecls payloadTypes))
      ]);
      rendered
    };
    rendered
  };
  rendered
}

emitNativeCompatibilitySurfaceImage : HostedModuleAst -> [LowerDeclText] -> Str
emitNativeCompatibilitySurfaceImage modl decls = {
  let moduleName = moduleNameOf modl;
  let exports = collectNativeExportNames modl decls;
  let entrypoints = append (emitNativeConstructorEntrypointJsons moduleName modl) (emitNativeEntrypointJsons moduleName decls);
  jsonObject [
    jsonFieldText "module" moduleName,
    jsonFieldArray "exports" (emitNativeJsonStringList exports),
    jsonFieldArray "entrypoints" entrypoints,
    jsonFieldRaw "abi" (emitNativeAbiImage modl),
    jsonFieldRaw "runtime" (emitNativeRuntimeImage modl)
  ]
}

nativeModuleSymbolPrefix : Str -> Str
nativeModuleSymbolPrefix moduleName = textConcat ["clasp_native__", textJoin "__" (textSplit moduleName ".")]

nativeEntrypointSymbol : Str -> Str -> Str
nativeEntrypointSymbol moduleName declName = textConcat [nativeModuleSymbolPrefix moduleName, "__", declName]

emitNativeEntrypoint : Str -> LowerDeclText -> Str
emitNativeEntrypoint moduleName decl = match decl {
  LowerConst name body ->
    textConcat [name, "{symbol=", nativeEntrypointSymbol moduleName name, ", kind=global, arity=0}"],
  LowerFn name params body ->
    textConcat [name, "{symbol=", nativeEntrypointSymbol moduleName name, ", kind=function, arity=", renderNativeArity params, "}"]
}

emitNativeEntrypoints : Str -> [LowerDeclText] -> [Str]
emitNativeEntrypoints moduleName decls = {
  let mut rendered = [];
  for decl in decls {
    rendered = appendNativeRenderedText rendered (emitNativeEntrypoint moduleName decl);
    rendered
  };
  rendered
}

emitNativeConstructorParams : [HostedTypeAst] -> [Str]
emitNativeConstructorParams payloadTypes = {
  let mut rendered = [];
  let mut index = "0";
  for payloadType in payloadTypes {
    let ignored = payloadType;
    rendered = appendNativeRenderedText rendered (textConcat ["$", index]);
    index = incrementNativeNumber index;
    rendered
  };
  rendered
}

emitNativeConstructorArgExprs : [Str] -> [Str]
emitNativeConstructorArgExprs params = {
  let mut rendered = [];
  for param in params {
    rendered = appendNativeRenderedText rendered (textConcat ["local(", param, ")"]);
    rendered
  };
  rendered
}

emitNativeConstructorDecl : HostedConstructorDeclAst -> Str
emitNativeConstructorDecl constructorDecl = {
  let params = emitNativeConstructorParams (constructorDeclPayloadTypes constructorDecl);
  if hasHostedTypeValues (constructorDeclPayloadTypes constructorDecl) then textConcat ["function ", constructorDeclName constructorDecl, "(", textJoin ", " params, ") = construct ", constructorDeclName constructorDecl, "(", textJoin ", " (emitNativeConstructorArgExprs params), ")"] else textConcat ["global ", constructorDeclName constructorDecl, " = construct ", constructorDeclName constructorDecl, "()"]
}

emitNativeConstructorDecls : HostedModuleAst -> [Str]
emitNativeConstructorDecls modl = {
  let mut rendered = [];
  for typeDecl in nativeEmittedTypeDecls modl {
    for constructorDecl in typeDeclConstructors typeDecl {
      rendered = appendNativeRenderedText rendered (emitNativeConstructorDecl constructorDecl);
      rendered
    };
    rendered
  };
  rendered
}

emitNativeConstructorEntrypoint : Str -> HostedConstructorDeclAst -> Str
emitNativeConstructorEntrypoint moduleName constructorDecl = {
  let payloadTypes = constructorDeclPayloadTypes constructorDecl;
  if hasHostedTypeValues payloadTypes then textConcat [constructorDeclName constructorDecl, "{symbol=", nativeEntrypointSymbol moduleName (constructorDeclName constructorDecl), ", kind=function, arity=", countHostedTypes payloadTypes, "}"] else textConcat [constructorDeclName constructorDecl, "{symbol=", nativeEntrypointSymbol moduleName (constructorDeclName constructorDecl), ", kind=global, arity=0}"]
}

emitNativeConstructorEntrypoints : Str -> HostedModuleAst -> [Str]
emitNativeConstructorEntrypoints moduleName modl = {
  let mut rendered = [];
  for typeDecl in nativeEmittedTypeDecls modl {
    for constructorDecl in typeDeclConstructors typeDecl {
      rendered = appendNativeRenderedText rendered (emitNativeConstructorEntrypoint moduleName constructorDecl);
      rendered
    };
    rendered
  };
  rendered
}

collectNativeExportNames : HostedModuleAst -> [LowerDeclText] -> [Str]
collectNativeExportNames modl decls = {
  let mut names = [];
  for typeDecl in nativeEmittedTypeDecls modl {
    for constructorDecl in typeDeclConstructors typeDecl {
      names = appendNativeRenderedText names (constructorDeclName constructorDecl);
      names
    };
    names
  };
  for decl in decls {
    names = appendNativeRenderedText names (nativeDeclName decl);
    names
  };
  names
}

nativeDeclName : LowerDeclText -> Str
nativeDeclName decl = match decl {
  LowerConst name body ->
    name,
  LowerFn name params body ->
    name
}

renderNativeDecls : [LowerDeclText] -> [Str]
renderNativeDecls decls = {
  let mut rendered = [];
  for decl in decls {
    rendered = appendNativeRenderedText rendered (emitNativeDecl decl);
    rendered
  };
  rendered
}

nativeAbiRecordLayoutLines : [Str]
nativeAbiRecordLayoutLines = {
  let mut lines = [];
  lines = appendNativeRenderedText lines "  record_layout Principal { words = 1, fields = [id:Str@word0/handle] }";
  lines = appendNativeRenderedText lines "  record_layout Tenant { words = 1, fields = [id:Str@word0/handle] }";
  lines = appendNativeRenderedText lines "  record_layout ResourceIdentity { words = 2, fields = [resourceType:Str@word0/handle, resourceId:Str@word1/handle] }";
  lines = appendNativeRenderedText lines "  record_layout AuditActor { words = 2, fields = [actorType:Str@word0/handle, actorId:Str@word1/handle] }";
  lines = appendNativeRenderedText lines "  record_layout AuditAction { words = 2, fields = [actionType:Str@word0/handle, summary:Str@word1/handle] }";
  lines = appendNativeRenderedText lines "  record_layout AuditProvenance { words = 3, fields = [source:Str@word0/handle, requestId:Str@word1/handle, traceId:Str@word2/handle] }";
  lines = appendNativeRenderedText lines "  record_layout SqliteConnection { words = 4, fields = [id:Str@word0/handle, databasePath:Str@word1/handle, readOnly:Bool@word2/immediate, memory:Bool@word3/immediate] }";
  lines = appendNativeRenderedText lines "  record_layout AuthSession { words = 4, fields = [sessionId:Str@word0/handle, principal:Principal@word1/handle, tenant:Tenant@word2/handle, resource:ResourceIdentity@word3/handle] }";
  lines = appendNativeRenderedText lines "  record_layout StandardAuditEnvelope { words = 5, fields = [actor:AuditActor@word0/handle, resource:ResourceIdentity@word1/handle, action:AuditAction@word2/handle, timestamp:Int@word3/immediate, provenance:AuditProvenance@word4/handle] }";
  lines
}

nativeAbiObjectLayoutLines : [Str]
nativeAbiObjectLayoutLines = {
  let mut lines = [];
  lines = appendNativeRenderedText lines "  object_layout Principal { kind = record, header_words = 2, words = 3, roots = [2] }";
  lines = appendNativeRenderedText lines "  object_layout Tenant { kind = record, header_words = 2, words = 3, roots = [2] }";
  lines = appendNativeRenderedText lines "  object_layout ResourceIdentity { kind = record, header_words = 2, words = 4, roots = [2, 3] }";
  lines = appendNativeRenderedText lines "  object_layout AuditActor { kind = record, header_words = 2, words = 4, roots = [2, 3] }";
  lines = appendNativeRenderedText lines "  object_layout AuditAction { kind = record, header_words = 2, words = 4, roots = [2, 3] }";
  lines = appendNativeRenderedText lines "  object_layout AuditProvenance { kind = record, header_words = 2, words = 5, roots = [2, 3, 4] }";
  lines = appendNativeRenderedText lines "  object_layout SqliteConnection { kind = record, header_words = 2, words = 6, roots = [2, 3] }";
  lines = appendNativeRenderedText lines "  object_layout AuthSession { kind = record, header_words = 2, words = 6, roots = [2, 3, 4, 5] }";
  lines = appendNativeRenderedText lines "  object_layout StandardAuditEnvelope { kind = record, header_words = 2, words = 7, roots = [2, 3, 4, 6] }";
  lines
}

typeDeclAllNullary : HostedTypeDeclAst -> Bool
typeDeclAllNullary typeDecl = {
  for constructorDecl in typeDeclConstructors typeDecl {
    if hasHostedTypeValues (constructorDeclPayloadTypes constructorDecl) then return false else true
  };
  true
}

nativeLayoutStorageForType : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> HostedTypeAst -> Str
nativeLayoutStorageForType typeDecls recordDecls typ = match typ {
  HostedTypeName name ->
    if name == "Int" then "immediate" else if name == "Bool" then "immediate" else if name == "Str" then "handle" else if name == "Page" then "handle" else if name == "Redirect" then "handle" else if name == "View" then "handle" else if name == "Prompt" then "handle" else match lookupRecordDecl recordDecls name {
      FoundRecord recordDecl ->
        "handle",
      MissingRecord missingRecord ->
        match lookupTypeDecl typeDecls name {
          FoundTypeDecl typeDecl ->
            if typeDeclAllNullary typeDecl then "immediate" else "handle",
          MissingTypeDecl missingType ->
            "handle"
        }
    },
  HostedTypeList itemType ->
    "handle",
  HostedTypeFunction input result ->
    "handle"
}

emitHostedRecordFieldLayout : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> Str -> HostedRecordFieldDeclAst -> Str
emitHostedRecordFieldLayout typeDecls recordDecls wordOffset fieldDecl = textConcat [recordFieldDeclName fieldDecl, ":", renderHostedType (recordFieldDeclType fieldDecl), "@word", wordOffset, "/", nativeLayoutStorageForType typeDecls recordDecls (recordFieldDeclType fieldDecl)]

emitHostedRecordFieldLayouts : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [HostedRecordFieldDeclAst] -> [Str]
emitHostedRecordFieldLayouts typeDecls recordDecls fields = {
  let mut rendered = [];
  let mut wordOffset = "0";
  for fieldDecl in fields {
    rendered = appendNativeRenderedText rendered (emitHostedRecordFieldLayout typeDecls recordDecls wordOffset fieldDecl);
    wordOffset = incrementNativeNumber wordOffset;
    rendered
  };
  rendered
}

emitHostedRecordRootOffsets : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [HostedRecordFieldDeclAst] -> [Str]
emitHostedRecordRootOffsets typeDecls recordDecls fields = {
  let mut rendered = [];
  let mut wordOffset = "0";
  for fieldDecl in fields {
    rendered = if nativeLayoutStorageForType typeDecls recordDecls (recordFieldDeclType fieldDecl) == "handle" then appendNativeRenderedText rendered (headerAdjustedOffset wordOffset) else rendered;
    wordOffset = incrementNativeNumber wordOffset;
    rendered
  };
  rendered
}

emitHostedRecordLayoutLines : HostedModuleAst -> [Str]
emitHostedRecordLayoutLines modl = {
  let typeDecls = effectiveModuleTypeDecls modl;
  let recordDecls = moduleRecordDeclarations modl;
  let mut rendered = [];
  for recordDecl in recordDecls {
    rendered = appendNativeRenderedText rendered (textConcat ["  record_layout ", recordDeclName recordDecl, " { words = ", countHostedRecordFields (recordDeclFields recordDecl), ", fields = [", textJoin ", " (emitHostedRecordFieldLayouts typeDecls recordDecls (recordDeclFields recordDecl)), "] }"]);
    rendered
  };
  rendered
}

emitHostedRecordObjectLayoutLines : HostedModuleAst -> [Str]
emitHostedRecordObjectLayoutLines modl = {
  let typeDecls = effectiveModuleTypeDecls modl;
  let recordDecls = moduleRecordDeclarations modl;
  let mut rendered = [];
  for recordDecl in recordDecls {
    let fieldCount = countHostedRecordFields (recordDeclFields recordDecl);
    rendered = appendNativeRenderedText rendered (textConcat ["  object_layout ", recordDeclName recordDecl, " { kind = record, header_words = 2, words = ", headerAdjustedOffset fieldCount, ", roots = [", textJoin ", " (emitHostedRecordRootOffsets typeDecls recordDecls (recordDeclFields recordDecl)), "] }"]);
    rendered
  };
  rendered
}

maxConstructorPayloadTypes : HostedTypeDeclAst -> [HostedTypeAst]
maxConstructorPayloadTypes typeDecl = {
  let mut payloadTypes = [];
  for constructorDecl in typeDeclConstructors typeDecl {
    payloadTypes = maxHostedTypeList payloadTypes (constructorDeclPayloadTypes constructorDecl);
    payloadTypes
  };
  payloadTypes
}

emitHostedPayloadLayouts : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [HostedTypeAst] -> [Str]
emitHostedPayloadLayouts typeDecls recordDecls payloadTypes = {
  let mut rendered = [];
  let mut wordOffset = "1";
  for payloadType in payloadTypes {
    rendered = appendNativeRenderedText rendered (textConcat ["$", decrementNativeNumber wordOffset, ":", renderHostedType payloadType, "@word", wordOffset, "/", nativeLayoutStorageForType typeDecls recordDecls payloadType]);
    wordOffset = incrementNativeNumber wordOffset;
    rendered
  };
  rendered
}

emitHostedConstructorLayout : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> HostedConstructorDeclAst -> Str
emitHostedConstructorLayout typeDecls recordDecls constructorDecl = {
  let payloadTypes = constructorDeclPayloadTypes constructorDecl;
  let payloadWords = countHostedTypes payloadTypes;
  let totalWords = incrementNativeNumber payloadWords;
  textConcat [constructorDeclName constructorDecl, "{tag_word=0, payload_words=", payloadWords, ", words=", totalWords, ", payloads=[", textJoin ", " (emitHostedPayloadLayouts typeDecls recordDecls payloadTypes), "]}"]
}

emitHostedVariantLayoutLines : HostedModuleAst -> [Str]
emitHostedVariantLayoutLines modl = {
  let typeDecls = effectiveModuleTypeDecls modl;
  let emittedTypeDecls = nativeEmittedTypeDecls modl;
  let recordDecls = moduleRecordDeclarations modl;
  let mut rendered = [];
  for typeDecl in emittedTypeDecls {
    let maxPayloadTypes = maxConstructorPayloadTypes typeDecl;
    let maxPayloadWords = countHostedTypes maxPayloadTypes;
    let mut constructorLayouts = [];
    for constructorDecl in typeDeclConstructors typeDecl {
      constructorLayouts = appendNativeRenderedText constructorLayouts (emitHostedConstructorLayout typeDecls recordDecls constructorDecl);
      constructorLayouts
    };
    rendered = appendNativeRenderedText rendered (textConcat ["  variant_layout ", typeDeclName typeDecl, " { tag_word = 0, max_payload_words = ", maxPayloadWords, ", words = ", incrementNativeNumber maxPayloadWords, ", constructors = [", textJoin ", " constructorLayouts, "] }"]);
    rendered
  };
  rendered
}

emitHostedVariantRootOffsets : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [HostedTypeAst] -> [Str]
emitHostedVariantRootOffsets typeDecls recordDecls payloadTypes = {
  let mut rendered = [];
  let mut wordOffset = "1";
  for payloadType in payloadTypes {
    rendered = if nativeLayoutStorageForType typeDecls recordDecls payloadType == "handle" then appendNativeRenderedText rendered (headerAdjustedOffset wordOffset) else rendered;
    wordOffset = incrementNativeNumber wordOffset;
    rendered
  };
  rendered
}

emitHostedVariantObjectLayoutLines : HostedModuleAst -> [Str]
emitHostedVariantObjectLayoutLines modl = {
  let typeDecls = effectiveModuleTypeDecls modl;
  let emittedTypeDecls = nativeEmittedTypeDecls modl;
  let recordDecls = moduleRecordDeclarations modl;
  let mut rendered = [];
  for typeDecl in emittedTypeDecls {
    for constructorDecl in typeDeclConstructors typeDecl {
      let payloadTypes = constructorDeclPayloadTypes constructorDecl;
      let totalWords = incrementNativeNumber (countHostedTypes payloadTypes);
      rendered = appendNativeRenderedText rendered (textConcat ["  object_layout ", typeDeclName typeDecl, ".", constructorDeclName constructorDecl, " { kind = variant, header_words = 2, words = ", headerAdjustedOffset totalWords, ", roots = [", textJoin ", " (emitHostedVariantRootOffsets typeDecls recordDecls payloadTypes), "] }"]);
      rendered
    };
    rendered
  };
  rendered
}

nativeAbiLines : HostedModuleAst -> [Str]
nativeAbiLines modl = {
  let mut lines = [];
  lines = appendNativeRenderedText lines "abi {";
  lines = appendNativeRenderedText lines "  version clasp-native-v1";
  lines = appendNativeRenderedText lines "  word_bytes 8";
  lines = appendNativeRenderedText lines "  memory_strategy reference_counting";
  lines = appendNativeRenderedText lines "  allocation { immediate = stack, handle = heap, global = static }";
  lines = appendNativeRenderedText lines "  ownership_rules [caller_owns_returns, callee_borrows_arguments, aggregates_retain_handle_fields, globals_are_static_roots]";
  lines = appendNativeRenderedText lines "  root_discovery_rules [static_globals, stack_handle_slots, heap_object_layouts]";
  lines = appendNativeRenderedText lines "  lifetime_invariants [layout_and_retain_headers, declared_root_offsets_only, release_children_before_free, borrowed_handles_do_not_retain]";
  lines = appendNativeRenderedText lines "  builtin_layout Int { storage = immediate, words = 1 }";
  lines = appendNativeRenderedText lines "  builtin_layout Bool { storage = immediate, words = 1 }";
  lines = appendNativeRenderedText lines "  builtin_layout Str { storage = handle, words = 1 }";
  lines = appendNativeRenderedText lines "  builtin_layout List { storage = handle, words = 1 }";
  lines = appendNativeRenderedText lines "  builtin_layout Page { storage = handle, words = 1 }";
  lines = appendNativeRenderedText lines "  builtin_layout Redirect { storage = handle, words = 1 }";
  lines = appendNativeRenderedText lines "  builtin_layout View { storage = handle, words = 1 }";
  lines = appendNativeRenderedText lines "  builtin_layout Prompt { storage = handle, words = 1 }";
  lines = append lines nativeAbiRecordLayoutLines;
  lines = append lines (emitHostedRecordLayoutLines modl);
  lines = append lines (emitHostedVariantLayoutLines modl);
  lines = append lines nativeAbiObjectLayoutLines;
  lines = append lines (emitHostedRecordObjectLayoutLines modl);
  lines = append lines (emitHostedVariantObjectLayoutLines modl);
  lines = appendNativeRenderedText lines "}";
  lines
}

nativeRuntimeLines : [Str]
nativeRuntimeLines = {
  let mut lines = [];
  lines = appendNativeRenderedText lines "runtime {";
  lines = appendNativeRenderedText lines "  profile compiler_backend_minimal";
  lines = appendNativeRenderedText lines "  artifacts [\"runtime/native/clasp_runtime.h\", \"runtime/native/clasp_runtime.rs\"]";
  lines = appendNativeRenderedText lines "  memory_symbols [clasp_rt_init, clasp_rt_register_static_root, clasp_rt_alloc_object, clasp_rt_retain, clasp_rt_release, clasp_rt_string_from_utf8, clasp_rt_bytes_new, clasp_rt_string_list_new, clasp_rt_result_ok_string, clasp_rt_result_err_string, clasp_rt_json_from_string, clasp_rt_json_to_string, clasp_rt_binary_from_json, clasp_rt_json_from_binary, clasp_rt_transport_frame, clasp_rt_transport_unframe]";
  lines = appendNativeRenderedText lines "  bindings []";
  lines = appendNativeRenderedText lines "  json_codecs []";
  lines = appendNativeRenderedText lines "  binary_codecs []";
  lines = appendNativeRenderedText lines "  boundaries []";
  lines = appendNativeRenderedText lines "  service_transports []";
  lines = appendNativeRenderedText lines "}";
  lines
}

emitNativeHeaderSection : HostedModuleAst -> [LowerDeclText] -> Str
emitNativeHeaderSection modl decls = {
  let moduleName = moduleNameOf modl;
  let mut lines = [];
  lines = appendNativeRenderedText lines "format clasp-native-ir-v1";
  lines = appendNativeRenderedText lines (textConcat ["module ", moduleName]);
  lines = appendNativeRenderedText lines (textConcat ["exports [", textJoin ", " (collectNativeExportNames modl decls), "]"]);
  lines = appendNativeRenderedText lines (textConcat ["entrypoints [", textJoin ", " (append (emitNativeConstructorEntrypoints moduleName modl) (emitNativeEntrypoints moduleName decls)), "]"]);
  textJoin "\n" lines
}

emitNativeAbiSection : HostedModuleAst -> Str
emitNativeAbiSection modl = textJoin "\n" (nativeAbiLines modl)

emitNativeRuntimeSection : Str
emitNativeRuntimeSection = textJoin "\n" nativeRuntimeLines

emitNativeDeclSection : [LowerDeclText] -> Str
emitNativeDeclSection decls = textJoin "\n\n" (renderNativeDecls decls)

emitNativeModule : HostedModuleAst -> [LowerDeclText] -> Str
emitNativeModule modl decls = {
  let mut sections = [];
  let allDeclLines = append (emitNativeConstructorDecls modl) (renderNativeDecls decls);
  sections = appendNativeRenderedText sections (emitNativeHeaderSection modl decls);
  sections = appendNativeRenderedText sections (emitNativeAbiSection modl);
  sections = appendNativeRenderedText sections emitNativeRuntimeSection;
  sections = appendNativeRenderedText sections (textJoin "\n\n" allDeclLines);
  textConcat [textJoin "\n\n" sections, "\n\n"]
}

emitNativeJsonStringList : [Str] -> [Str]
emitNativeJsonStringList values = {
  let mut rendered = [];
  for value in values {
    rendered = appendNativeRenderedText rendered (encode value);
    rendered
  };
  rendered
}

emitNativeJsonExprList : [LowerExprText] -> [Str]
emitNativeJsonExprList exprs = {
  let mut rendered = [];
  for expr in exprs {
    rendered = appendNativeRenderedText rendered (emitNativeExprJson expr);
    rendered
  };
  rendered
}

emitNativeJsonRecordFieldList : [LowerRecordFieldText] -> [Str]
emitNativeJsonRecordFieldList fields = {
  let mut rendered = [];
  for field in fields {
    rendered = appendNativeRenderedText rendered (emitNativeRecordFieldJson field);
    rendered
  };
  rendered
}

emitNativeJsonMatchBranchList : [LowerMatchBranchText] -> [Str]
emitNativeJsonMatchBranchList branches = {
  let mut rendered = [];
  for branch in branches {
    rendered = appendNativeRenderedText rendered (emitNativeMatchBranchJson branch);
    rendered
  };
  rendered
}

emitNativeCompareOpJson : LowerExprText -> LowerExprText -> Str -> Str
emitNativeCompareOpJson left right kindName =
  renderJsonObject [renderJsonField "kind" (encode "compare"), renderJsonField "op" (encode kindName), renderJsonField "left" (emitNativeExprJson left), renderJsonField "right" (emitNativeExprJson right)]

emitNativeExprJson : LowerExprText -> Str
emitNativeExprJson expr = match expr {
  LowerName name ->
    renderJsonObject [renderJsonField "kind" (encode "local"), renderJsonField "name" (encode name)],
  LowerLiteral value ->
    renderJsonObject [renderJsonField "kind" (encode "string"), renderJsonField "value" (encode value)],
  LowerInt value ->
    renderJsonObject [renderJsonField "kind" (encode "int"), renderJsonField "value" value],
  LowerBool value ->
    renderJsonObject [renderJsonField "kind" (encode "bool"), renderJsonField "value" (if value then "true" else "false")],
  LowerArray values ->
    renderJsonObject [renderJsonField "kind" (encode "list"), renderJsonField "items" (renderJsonArray (emitNativeJsonExprList values))],
  LowerListAppend left right ->
    renderJsonObject [renderJsonField "kind" (encode "intrinsic"), renderJsonField "name" (encode "list.append"), renderJsonField "left" (emitNativeExprJson left), renderJsonField "right" (emitNativeExprJson right)],
  LowerEncode value ->
    renderJsonObject [renderJsonField "kind" (encode "intrinsic"), renderJsonField "name" (encode "encode"), renderJsonField "value" (emitNativeExprJson value)],
  LowerIf condition thenBranch elseBranch ->
    renderJsonObject [renderJsonField "kind" (encode "if"), renderJsonField "condition" (emitNativeExprJson condition), renderJsonField "thenBranch" (emitNativeExprJson thenBranch), renderJsonField "elseBranch" (emitNativeExprJson elseBranch)],
  LowerEqual left right ->
    emitNativeCompareOpJson left right "eq",
  LowerNotEqual left right ->
    emitNativeCompareOpJson left right "ne",
  LowerLessThan left right ->
    emitNativeCompareOpJson left right "lt",
  LowerLessThanOrEqual left right ->
    emitNativeCompareOpJson left right "le",
  LowerGreaterThan left right ->
    emitNativeCompareOpJson left right "gt",
  LowerGreaterThanOrEqual left right ->
    emitNativeCompareOpJson left right "ge",
  LowerInvoke callee args ->
    renderJsonObject [renderJsonField "kind" (encode "call"), renderJsonField "callee" (renderJsonObject [renderJsonField "kind" (encode "local"), renderJsonField "name" (encode callee)]), renderJsonField "args" (renderJsonArray (emitNativeJsonExprList args))],
  LowerConstructor constructorName args ->
    renderJsonObject [renderJsonField "kind" (encode "construct"), renderJsonField "name" (encode constructorName), renderJsonField "args" (renderJsonArray (emitNativeJsonExprList args))],
  LowerMatch subject branches ->
    renderJsonObject [renderJsonField "kind" (encode "match"), renderJsonField "scrutinee" (emitNativeExprJson subject), renderJsonField "branches" (renderJsonArray (emitNativeJsonMatchBranchList branches))],
  LowerRecord recordName fields ->
    renderJsonObject [renderJsonField "kind" (encode "record"), renderJsonField "recordName" (encode recordName), renderJsonField "fields" (renderJsonArray (emitNativeJsonRecordFieldList fields))],
  LowerFieldAccess recordName subject fieldName ->
    renderJsonObject [renderJsonField "kind" (encode "field_access"), renderJsonField "recordName" (encode recordName), renderJsonField "target" (emitNativeExprJson subject), renderJsonField "fieldName" (encode fieldName)],
  LowerLet binder value body ->
    renderJsonObject [renderJsonField "kind" (encode "let"), renderJsonField "mutability" (encode "immutable"), renderJsonField "name" (encode binder), renderJsonField "value" (emitNativeExprJson value), renderJsonField "body" (emitNativeExprJson body)],
  LowerMutableLet binder value body ->
    renderJsonObject [renderJsonField "kind" (encode "let"), renderJsonField "mutability" (encode "mutable"), renderJsonField "name" (encode binder), renderJsonField "value" (emitNativeExprJson value), renderJsonField "body" (emitNativeExprJson body)],
  LowerAssign binder value body ->
    renderJsonObject [renderJsonField "kind" (encode "assign"), renderJsonField "name" (encode binder), renderJsonField "value" (emitNativeExprJson value), renderJsonField "body" (emitNativeExprJson body)],
  LowerFor binder iterable loopBody body ->
    renderJsonObject [renderJsonField "kind" (encode "for_each"), renderJsonField "name" (encode binder), renderJsonField "iterable" (emitNativeExprJson iterable), renderJsonField "loopBody" (emitNativeExprJson loopBody), renderJsonField "body" (emitNativeExprJson body)],
  LowerReturn value ->
    renderJsonObject [renderJsonField "kind" (encode "return"), renderJsonField "value" (emitNativeExprJson value)]
}

emitNativeRecordFieldJson : LowerRecordFieldText -> Str
emitNativeRecordFieldJson field = match field {
  LowerRecordFieldText name value ->
    renderJsonObject [renderJsonField "name" (encode name), renderJsonField "value" (emitNativeExprJson value)]
}

emitNativeMatchBranchJson : LowerMatchBranchText -> Str
emitNativeMatchBranchJson branch = match branch {
  LowerMatchBranchText constructorName binders body ->
    renderJsonObject [renderJsonField "tag" (encode constructorName), renderJsonField "binders" (renderJsonArray (emitNativeJsonStringList binders)), renderJsonField "body" (emitNativeExprJson body)]
}

emitNativeConstructorBodyJson : HostedConstructorDeclAst -> Str
emitNativeConstructorBodyJson constructorDecl = {
  let params = emitNativeConstructorParams (constructorDeclPayloadTypes constructorDecl);
  let mut args = [];
  for param in params {
    args = appendNativeRenderedText args (renderJsonObject [renderJsonField "kind" (encode "local"), renderJsonField "name" (encode param)]);
    args
  };
  renderJsonObject [renderJsonField "kind" (encode "construct"), renderJsonField "name" (encode (constructorDeclName constructorDecl)), renderJsonField "args" (renderJsonArray args)]
}

emitNativeConstructorDeclJson : HostedConstructorDeclAst -> Str
emitNativeConstructorDeclJson constructorDecl = {
  let params = emitNativeConstructorParams (constructorDeclPayloadTypes constructorDecl);
  let bodyJson = emitNativeConstructorBodyJson constructorDecl;
  if hasHostedTypeValues (constructorDeclPayloadTypes constructorDecl) then renderJsonObject [renderJsonField "kind" (encode "function"), renderJsonField "name" (encode (constructorDeclName constructorDecl)), renderJsonField "params" (renderJsonArray (emitNativeJsonStringList params)), renderJsonField "body" bodyJson] else renderJsonObject [renderJsonField "kind" (encode "global"), renderJsonField "name" (encode (constructorDeclName constructorDecl)), renderJsonField "body" bodyJson]
}

emitNativeConstructorDeclJsons : HostedModuleAst -> [Str]
emitNativeConstructorDeclJsons modl = {
  let mut rendered = [];
  for typeDecl in nativeEmittedTypeDecls modl {
    for constructorDecl in typeDeclConstructors typeDecl {
      rendered = appendNativeRenderedText rendered (emitNativeConstructorDeclJson constructorDecl);
      rendered
    };
    rendered
  };
  rendered
}

emitNativeDeclJson : LowerDeclText -> Str
emitNativeDeclJson decl = match decl {
  LowerConst name body ->
    renderJsonObject [renderJsonField "kind" (encode "global"), renderJsonField "name" (encode name), renderJsonField "body" (emitNativeExprJson body)],
  LowerFn name params body ->
    renderJsonObject [renderJsonField "kind" (encode "function"), renderJsonField "name" (encode name), renderJsonField "params" (renderJsonArray (emitNativeJsonStringList params)), renderJsonField "body" (emitNativeExprJson body)]
}

emitNativeDeclJsons : [LowerDeclText] -> [Str]
emitNativeDeclJsons decls = {
  let mut rendered = [];
  for decl in decls {
    rendered = appendNativeRenderedText rendered (emitNativeDeclJson decl);
    rendered
  };
  rendered
}

emitNativeEntrypointJson : Str -> LowerDeclText -> Str
emitNativeEntrypointJson moduleName decl = match decl {
  LowerConst name body ->
    renderJsonObject [renderJsonField "name" (encode name), renderJsonField "symbol" (encode (nativeEntrypointSymbol moduleName name)), renderJsonField "kind" (encode "global"), renderJsonField "arity" "0"],
  LowerFn name params body ->
    renderJsonObject [renderJsonField "name" (encode name), renderJsonField "symbol" (encode (nativeEntrypointSymbol moduleName name)), renderJsonField "kind" (encode "function"), renderJsonField "arity" (renderNativeArity params)]
}

emitNativeEntrypointJsons : Str -> [LowerDeclText] -> [Str]
emitNativeEntrypointJsons moduleName decls = {
  let mut rendered = [];
  for decl in decls {
    rendered = appendNativeRenderedText rendered (emitNativeEntrypointJson moduleName decl);
    rendered
  };
  rendered
}

emitNativeConstructorEntrypointJson : Str -> HostedConstructorDeclAst -> Str
emitNativeConstructorEntrypointJson moduleName constructorDecl = {
  let payloadTypes = constructorDeclPayloadTypes constructorDecl;
  renderJsonObject [renderJsonField "name" (encode (constructorDeclName constructorDecl)), renderJsonField "symbol" (encode (nativeEntrypointSymbol moduleName (constructorDeclName constructorDecl))), renderJsonField "kind" (encode (if hasHostedTypeValues payloadTypes then "function" else "global")), renderJsonField "arity" (if hasHostedTypeValues payloadTypes then countHostedTypes payloadTypes else "0")]
}

emitNativeConstructorEntrypointJsons : Str -> HostedModuleAst -> [Str]
emitNativeConstructorEntrypointJsons moduleName modl = {
  let mut rendered = [];
  for typeDecl in nativeEmittedTypeDecls modl {
    for constructorDecl in typeDeclConstructors typeDecl {
      rendered = appendNativeRenderedText rendered (emitNativeConstructorEntrypointJson moduleName constructorDecl);
      rendered
    };
    rendered
  };
  rendered
}

emitNativeCompatibilityFingerprint : HostedModuleAst -> [LowerDeclText] -> Str
emitNativeCompatibilityFingerprint modl decls =
  textConcat ["native-compat:", textFingerprint64Hex (emitNativeCompatibilitySurfaceImage modl decls)]

emitNativeAbiImage : HostedModuleAst -> Str
emitNativeAbiImage modl =
  jsonObject [
    jsonFieldText "version" "clasp-native-v1",
    jsonFieldRaw "wordBytes" "8",
    jsonFieldText "memoryStrategy" "reference_counting",
    jsonFieldRaw "allocation" emitNativeAbiAllocationImage,
    jsonFieldArray "ownershipRules" (emitNativeJsonStringList ["caller_owns_returns", "callee_borrows_arguments", "aggregates_retain_handle_fields", "globals_are_static_roots"]),
    jsonFieldArray "rootDiscoveryRules" (emitNativeJsonStringList ["static_globals", "stack_handle_slots", "heap_object_layouts"]),
    jsonFieldArray "lifetimeInvariants" (emitNativeJsonStringList ["layout_and_retain_headers", "declared_root_offsets_only", "release_children_before_free", "borrowed_handles_do_not_retain"]),
    jsonFieldArray "builtinLayouts" emitNativeBuiltinLayoutImages,
    jsonFieldArray "recordLayouts" (append emitNativeStaticRecordLayoutImages (emitHostedRecordLayoutImages modl)),
    jsonFieldArray "variantLayouts" (emitHostedVariantLayoutImages modl),
    jsonFieldArray "objectLayouts" (append (append emitNativeStaticObjectLayoutImages (emitHostedRecordObjectLayoutImages modl)) (emitHostedVariantObjectLayoutImages modl))
  ]

emitNativeRuntimeImage : HostedModuleAst -> Str
emitNativeRuntimeImage modl = {
  let runtimeBindingImages = emitNativeRuntimeBindingImages modl;
  let codecTypes = collectModuleRuntimeCodecTypes modl;
  jsonObject [
    jsonFieldText "profile" "compiler_backend_minimal",
    jsonFieldArray "artifacts" (emitNativeJsonStringList ["runtime/native/clasp_runtime.h", "runtime/native/clasp_runtime.rs"]),
    jsonFieldArray "memorySymbols" (emitNativeJsonStringList ["clasp_rt_init", "clasp_rt_register_static_root", "clasp_rt_alloc_object", "clasp_rt_retain", "clasp_rt_release", "clasp_rt_string_from_utf8", "clasp_rt_bytes_new", "clasp_rt_string_list_new", "clasp_rt_result_ok_string", "clasp_rt_result_err_string", "clasp_rt_json_from_string", "clasp_rt_json_to_string", "clasp_rt_binary_from_json", "clasp_rt_json_from_binary", "clasp_rt_transport_frame", "clasp_rt_transport_unframe"]),
    jsonFieldArray "bindings" runtimeBindingImages,
    jsonFieldArray "jsonCodecs" (emitNativeJsonCodecImagesFromTypes codecTypes),
    jsonFieldArray "binaryCodecs" (emitNativeBinaryCodecImagesFromTypes codecTypes),
    jsonFieldArray "boundaries" [],
    jsonFieldArray "serviceTransports" []
  ]
}

emitNativeCompatibilityImage : HostedModuleAst -> [LowerDeclText] -> Str
emitNativeCompatibilityImage modl decls = {
  let fingerprint = emitNativeCompatibilityFingerprint modl decls;
  jsonObject [
    jsonFieldText "kind" "clasp-native-compatibility-v1",
    jsonFieldText "interfaceFingerprint" fingerprint,
    jsonFieldArray "acceptedPreviousFingerprints" [encode fingerprint],
    jsonFieldRaw "migration" (jsonObject [
      jsonFieldText "kind" "clasp-native-migration-v1",
      jsonFieldText "strategy" "exact-interface-only",
      jsonFieldRaw "stateType" "null",
      jsonFieldRaw "snapshotSymbol" "null",
      jsonFieldRaw "handoffSymbol" "null"
    ])
  ]
}

emitNativeModuleImage : HostedModuleAst -> [LowerDeclText] -> Str
emitNativeModuleImage modl decls = {
  let moduleName = moduleNameOf modl;
  let exports = collectNativeExportNames modl decls;
  let entrypoints = append (emitNativeConstructorEntrypointJsons moduleName modl) (emitNativeEntrypointJsons moduleName decls);
  let declsJson = append (emitNativeConstructorDeclJsons modl) (emitNativeDeclJsons decls);
  jsonObject [
    jsonFieldText "format" "clasp-native-image-v1",
    jsonFieldText "irFormat" "clasp-native-ir-v1",
    jsonFieldText "module" moduleName,
    jsonFieldArray "exports" (emitNativeJsonStringList exports),
    jsonFieldArray "entrypoints" entrypoints,
    jsonFieldRaw "abi" (emitNativeAbiImage modl),
    jsonFieldRaw "runtime" (emitNativeRuntimeImage modl),
    jsonFieldRaw "compatibility" (emitNativeCompatibilityImage modl decls),
    jsonFieldArray "decls" declsJson
  ]
}
