module Compiler.Emit.Native

import Compiler.Ast
import Compiler.Checker
import Compiler.CheckedCore
import Compiler.Lower

appendNativeRenderedText : [Str] -> Str -> [Str]
appendNativeRenderedText values value = append values [value]

emitNativeExprs : [LowerExprText] -> [Str]
emitNativeExprs exprs = {
  let mut rendered = [];
  for expr in exprs {
    rendered = appendNativeRenderedText rendered (emitNativeExpr expr);
    rendered
  };
  rendered
}

emitNativeRecordFields : [LowerRecordFieldText] -> [Str]
emitNativeRecordFields fields = {
  let mut rendered = [];
  for field in fields {
    rendered = appendNativeRenderedText rendered (emitNativeRecordField field);
    rendered
  };
  rendered
}

emitNativeRecordField : LowerRecordFieldText -> Str
emitNativeRecordField field = match field {
  LowerRecordFieldText name value ->
    textConcat [name, " = ", emitNativeExpr value]
}

emitNativeMatchBranch : LowerMatchBranchText -> Str
emitNativeMatchBranch branch = match branch {
  LowerMatchBranchText constructorName binders body ->
    textConcat [constructorName, "(", textJoin ", " binders, ") -> ", emitNativeExpr body]
}

emitNativeMatchBranches : [LowerMatchBranchText] -> [Str]
emitNativeMatchBranches branches = {
  let mut rendered = [];
  for branch in branches {
    rendered = appendNativeRenderedText rendered (emitNativeMatchBranch branch);
    rendered
  };
  rendered
}

emitNativeExpr : LowerExprText -> Str
emitNativeExpr expr = match expr {
  LowerName name ->
    textConcat ["local(", name, ")"],
  LowerLiteral value ->
    textConcat ["string(\"", value, "\")"],
  LowerInt value ->
    textConcat ["int(", value, ")"],
  LowerBool value ->
    textConcat ["bool(", if value then "true" else "false", ")"],
  LowerArray values ->
    textConcat ["list([", textJoin ", " (emitNativeExprs values), "])"],
  LowerListAppend left right ->
    textConcat ["intrinsic.list.append(", emitNativeExpr left, ", ", emitNativeExpr right, ")"],
  LowerEncode value ->
    textConcat ["intrinsic.encode(", emitNativeExpr value, ")"],
  LowerIf condition thenBranch elseBranch ->
    textConcat ["if ", emitNativeExpr condition, " then ", emitNativeExpr thenBranch, " else ", emitNativeExpr elseBranch],
  LowerEqual left right ->
    textConcat ["compare.eq(", emitNativeExpr left, ", ", emitNativeExpr right, ")"],
  LowerNotEqual left right ->
    textConcat ["compare.ne(", emitNativeExpr left, ", ", emitNativeExpr right, ")"],
  LowerLessThan left right ->
    textConcat ["compare.lt(", emitNativeExpr left, ", ", emitNativeExpr right, ")"],
  LowerLessThanOrEqual left right ->
    textConcat ["compare.le(", emitNativeExpr left, ", ", emitNativeExpr right, ")"],
  LowerGreaterThan left right ->
    textConcat ["compare.gt(", emitNativeExpr left, ", ", emitNativeExpr right, ")"],
  LowerGreaterThanOrEqual left right ->
    textConcat ["compare.ge(", emitNativeExpr left, ", ", emitNativeExpr right, ")"],
  LowerInvoke callee args ->
    textConcat ["call(local(", callee, "), [", textJoin ", " (emitNativeExprs args), "])"],
  LowerConstructor constructorName args ->
    textConcat ["call(local(", constructorName, "), [", textJoin ", " (emitNativeExprs args), "])"],
  LowerMatch subject branches ->
    textConcat ["match ", emitNativeExpr subject, " [", textJoin ", " (emitNativeMatchBranches branches), "]"],
  LowerRecord recordName fields ->
    textConcat ["record ", recordName, " {", textJoin ", " (emitNativeRecordFields fields), "}"],
  LowerFieldAccess recordName subject fieldName ->
    if recordName == "" then textConcat ["field(", emitNativeExpr subject, ", ", fieldName, ")"] else textConcat ["field(", recordName, ", ", emitNativeExpr subject, ", ", fieldName, ")"],
  LowerLet binder value body ->
    textConcat ["let.immutable ", binder, " = ", emitNativeExpr value, " in ", emitNativeExpr body],
  LowerMutableLet binder value body ->
    textConcat ["let.mutable ", binder, " = ", emitNativeExpr value, " in ", emitNativeExpr body],
  LowerAssign binder value body ->
    textConcat ["assign ", binder, " = ", emitNativeExpr value, " then ", emitNativeExpr body],
  LowerFor binder iterable loopBody body ->
    textConcat ["for_each ", binder, " in ", emitNativeExpr iterable, " do ", emitNativeExpr loopBody, " then ", emitNativeExpr body],
  LowerReturn value ->
    textConcat ["return(", emitNativeExpr value, ")"]
}

emitNativeDecl : LowerDeclText -> Str
emitNativeDecl decl = match decl {
  LowerConst name body ->
    textConcat ["global ", name, " = ", emitNativeExpr body],
  LowerFn name params body ->
    textConcat ["function ", name, "(", textJoin ", " params, ") = ", emitNativeExpr body]
}

collectLowerDeclNames : [LowerDeclText] -> [Str]
collectLowerDeclNames decls = {
  let mut names = [];
  for decl in decls {
    names = append names [nativeDeclName decl];
    names
  };
  names
}

incrementNativeNumber : Str -> Str
incrementNativeNumber value = { if value == "0" then "1" else if value == "1" then "2" else if value == "2" then "3" else if value == "3" then "4" else if value == "4" then "5" else if value == "5" then "6" else if value == "6" then "7" else if value == "7" then "8" else if value == "8" then "9" else if value == "9" then "10" else if value == "10" then "11" else if value == "11" then "12" else if value == "12" then "13" else if value == "13" then "14" else if value == "14" then "15" else if value == "15" then "16" else if value == "16" then "17" else if value == "17" then "18" else if value == "18" then "19" else if value == "19" then "20" else if value == "20" then "21" else if value == "21" then "22" else if value == "22" then "23" else if value == "23" then "24" else if value == "24" then "25" else if value == "25" then "26" else if value == "26" then "27" else if value == "27" then "28" else if value == "28" then "29" else if value == "29" then "30" else if value == "30" then "31" else if value == "31" then "32" else if value == "32" then "33" else if value == "33" then "34" else if value == "34" then "35" else if value == "35" then "36" else if value == "36" then "37" else if value == "37" then "38" else if value == "38" then "39" else if value == "39" then "40" else value }

decrementNativeNumber : Str -> Str
decrementNativeNumber value = { if value == "1" then "0" else if value == "2" then "1" else if value == "3" then "2" else if value == "4" then "3" else if value == "5" then "4" else if value == "6" then "5" else if value == "7" then "6" else if value == "8" then "7" else if value == "9" then "8" else if value == "10" then "9" else if value == "11" then "10" else if value == "12" then "11" else if value == "13" then "12" else if value == "14" then "13" else if value == "15" then "14" else if value == "16" then "15" else if value == "17" then "16" else if value == "18" then "17" else if value == "19" then "18" else if value == "20" then "19" else if value == "21" then "20" else if value == "22" then "21" else if value == "23" then "22" else if value == "24" then "23" else if value == "25" then "24" else if value == "26" then "25" else if value == "27" then "26" else if value == "28" then "27" else if value == "29" then "28" else if value == "30" then "29" else if value == "31" then "30" else if value == "32" then "31" else if value == "33" then "32" else if value == "34" then "33" else if value == "35" then "34" else if value == "36" then "35" else if value == "37" then "36" else if value == "38" then "37" else if value == "39" then "38" else if value == "40" then "39" else value }

renderNativeArity : [Str] -> Str
renderNativeArity params = {
  let mut count = "0";
  for param in params {
    let ignored = param;
    count = incrementNativeNumber count;
    count
  };
  count
}

countHostedTypes : [HostedTypeAst] -> Str
countHostedTypes values = {
  let mut count = "0";
  for value in values {
    let ignored = value;
    count = incrementNativeNumber count;
    count
  };
  count
}

countHostedRecordFields : [HostedRecordFieldDeclAst] -> Str
countHostedRecordFields fields = {
  let mut count = "0";
  for field in fields {
    let ignored = field;
    count = incrementNativeNumber count;
    count
  };
  count
}

hasHostedTypeValues : [HostedTypeAst] -> Bool
hasHostedTypeValues values = {
  for value in values {
    return true
  };
  false
}

maxHostedTypeList : [HostedTypeAst] -> [HostedTypeAst] -> [HostedTypeAst]
maxHostedTypeList left right = if hasHostedTypeValues left then { if hasHostedTypeValues right then maxHostedTypeList (remainingHostedTypes left) (remainingHostedTypes right) else left } else right

headerAdjustedOffset : Str -> Str
headerAdjustedOffset value = incrementNativeNumber (incrementNativeNumber value)

hostedTypeUsesNamedType : HostedTypeAst -> Str -> Bool
hostedTypeUsesNamedType typeAst targetName = match typeAst {
  HostedTypeName name ->
    name == targetName,
  HostedTypeList itemType ->
    hostedTypeUsesNamedType itemType targetName,
  HostedTypeFunction input result ->
    if hostedTypeUsesNamedType input targetName then true else hostedTypeUsesNamedType result targetName
}

recordDeclUsesNamedType : HostedRecordDeclAst -> Str -> Bool
recordDeclUsesNamedType recordDecl targetName = {
  for fieldDecl in recordDeclFields recordDecl {
    if hostedTypeUsesNamedType (recordFieldDeclType fieldDecl) targetName then return true else false
  };
  false
}

constructorDeclUsesNamedType : HostedConstructorDeclAst -> Str -> Bool
constructorDeclUsesNamedType constructorDecl targetName = {
  for payloadType in constructorDeclPayloadTypes constructorDecl {
    if hostedTypeUsesNamedType payloadType targetName then return true else false
  };
  false
}

typeDeclUsesNamedType : HostedTypeDeclAst -> Str -> Bool
typeDeclUsesNamedType typeDecl targetName = {
  if typeDeclName typeDecl == targetName then true else {
    for constructorDecl in typeDeclConstructors typeDecl {
      if constructorDeclUsesNamedType constructorDecl targetName then return true else false
    };
    false
  }
}

annotationUsesNamedType : HostedAnnotationAst -> Str -> Bool
annotationUsesNamedType annotation targetName = if hasAnnotationAst annotation then hostedTypeUsesNamedType (annotationTypeAst annotation) targetName else false

exprUsesBuiltinResultRuntime : HostedExprAst -> Bool
exprUsesBuiltinResultRuntime expr = match expr {
  HostedName name ->
    false,
  HostedString value ->
    false,
  HostedInt value ->
    false,
  HostedBool value ->
    false,
  HostedList values ->
    exprListUsesBuiltinResultRuntime values,
  HostedCall callee args ->
    if callee == "textPrefix" then true else if callee == "textSplitFirst" then true else if callee == "readFile" then true else exprListUsesBuiltinResultRuntime args,
  HostedConstructor constructorName args ->
    exprListUsesBuiltinResultRuntime args,
  HostedMatch subject branches ->
    if exprUsesBuiltinResultRuntime subject then true else branchListUsesBuiltinResultRuntime branches,
  HostedRecord recordName fields ->
    recordFieldExprListUsesBuiltinResultRuntime fields,
  HostedFieldAccess subject fieldName ->
    exprUsesBuiltinResultRuntime subject,
  HostedLet binder value body ->
    if exprUsesBuiltinResultRuntime value then true else exprUsesBuiltinResultRuntime body,
  HostedMutableLet binder value body ->
    if exprUsesBuiltinResultRuntime value then true else exprUsesBuiltinResultRuntime body,
  HostedAssign binder value body ->
    if exprUsesBuiltinResultRuntime value then true else exprUsesBuiltinResultRuntime body,
  HostedFor binder iterable loopBody body ->
    if exprUsesBuiltinResultRuntime iterable then true else if exprUsesBuiltinResultRuntime loopBody then true else exprUsesBuiltinResultRuntime body,
  HostedReturn value ->
    exprUsesBuiltinResultRuntime value,
  HostedIf condition thenBranch elseBranch ->
    if exprUsesBuiltinResultRuntime condition then true else if exprUsesBuiltinResultRuntime thenBranch then true else exprUsesBuiltinResultRuntime elseBranch,
  HostedEqual left right ->
    if exprUsesBuiltinResultRuntime left then true else exprUsesBuiltinResultRuntime right,
  HostedNotEqual left right ->
    if exprUsesBuiltinResultRuntime left then true else exprUsesBuiltinResultRuntime right,
  HostedLessThan left right ->
    if exprUsesBuiltinResultRuntime left then true else exprUsesBuiltinResultRuntime right,
  HostedLessThanOrEqual left right ->
    if exprUsesBuiltinResultRuntime left then true else exprUsesBuiltinResultRuntime right,
  HostedGreaterThan left right ->
    if exprUsesBuiltinResultRuntime left then true else exprUsesBuiltinResultRuntime right,
  HostedGreaterThanOrEqual left right ->
    if exprUsesBuiltinResultRuntime left then true else exprUsesBuiltinResultRuntime right
}

exprListUsesBuiltinResultRuntime : [HostedExprAst] -> Bool
exprListUsesBuiltinResultRuntime exprs = {
  for expr in exprs {
    if exprUsesBuiltinResultRuntime expr then return true else false
  };
  false
}

recordFieldExprListUsesBuiltinResultRuntime : [HostedRecordFieldExprAst] -> Bool
recordFieldExprListUsesBuiltinResultRuntime fields = {
  for field in fields {
    if exprUsesBuiltinResultRuntime (recordExprFieldValue field) then return true else false
  };
  false
}

branchUsesBuiltinResultRuntime : HostedMatchBranchAst -> Bool
branchUsesBuiltinResultRuntime branch = exprUsesBuiltinResultRuntime (branchBodyExpr branch)

branchListUsesBuiltinResultRuntime : [HostedMatchBranchAst] -> Bool
branchListUsesBuiltinResultRuntime branches = {
  for branch in branches {
    if branchUsesBuiltinResultRuntime branch then return true else false
  };
  false
}

declUsesBuiltinResult : HostedDeclAst -> Bool
declUsesBuiltinResult decl = if annotationUsesNamedType (declAnnotation decl) resultBuiltinTypeName then true else exprUsesBuiltinResultRuntime (declBody decl)

foreignDeclUsesBuiltinResult : HostedForeignDeclAst -> Bool
foreignDeclUsesBuiltinResult foreignDecl = hostedTypeUsesNamedType (foreignDeclTypeAst foreignDecl) resultBuiltinTypeName

moduleDeclaresBuiltinResult : HostedModuleAst -> Bool
moduleDeclaresBuiltinResult modl = {
  for typeDecl in moduleTypeDeclarations modl {
    if typeDeclName typeDecl == resultBuiltinTypeName then return true else false
  };
  false
}

moduleUsesBuiltinResult : HostedModuleAst -> Bool
moduleUsesBuiltinResult modl = {
  if moduleDeclaresBuiltinResult modl then true else {
    for typeDecl in moduleTypeDeclarations modl {
      if typeDeclUsesNamedType typeDecl resultBuiltinTypeName then return true else false
    };
    for recordDecl in moduleRecordDeclarations modl {
      if recordDeclUsesNamedType recordDecl resultBuiltinTypeName then return true else false
    };
    for foreignDecl in moduleForeignDeclarations modl {
      if foreignDeclUsesBuiltinResult foreignDecl then return true else false
    };
    for decl in moduleDeclarations modl {
      if declUsesBuiltinResult decl then return true else false
    };
    false
  }
}

nativeEmittedTypeDecls : HostedModuleAst -> [HostedTypeDeclAst]
nativeEmittedTypeDecls modl = if moduleUsesBuiltinResult modl then effectiveModuleTypeDecls modl else moduleTypeDeclarations modl

renderTypeTextList : [TypeText] -> [Str]
renderTypeTextList types = {
  let mut rendered = [];
  for typ in types {
    rendered = appendNativeRenderedText rendered (renderType typ);
    rendered
  };
  rendered
}

supportsRuntimeCodecType : TypeText -> Bool
supportsRuntimeCodecType typ = match typ {
  TInt ->
    true,
  TStr ->
    true,
  TBool ->
    true,
  TList itemType ->
    supportsRuntimeCodecType itemType,
  TNamed name ->
    true,
  TFunction input result ->
    false,
  TUnknown label ->
    false
}

appendUniqueRuntimeCodecType : [TypeText] -> TypeText -> [TypeText]
appendUniqueRuntimeCodecType types typ = if supportsRuntimeCodecType typ then {
  if containsText (renderTypeTextList types) (renderType typ) then types else append types [typ]
} else {
  types
}

appendUniqueRuntimeCodecTypes : [TypeText] -> [TypeText] -> [TypeText]
appendUniqueRuntimeCodecTypes existing additions = {
  let mut merged = existing;
  for typ in additions {
    merged = appendUniqueRuntimeCodecType merged typ;
    merged
  };
  merged
}

collectRuntimeCodecTypesFromExprList : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [TypeBinding] -> [TypeBinding] -> ReturnContext -> [HostedExprAst] -> [TypeText]
collectRuntimeCodecTypesFromExprList typeDecls recordDecls env localEnv fnContext exprs = {
  let mut collected = [];
  for expr in exprs {
    collected = appendUniqueRuntimeCodecTypes collected (collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext expr);
    collected
  };
  collected
}

collectRuntimeCodecTypesFromRecordFields : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [TypeBinding] -> [TypeBinding] -> ReturnContext -> [HostedRecordFieldExprAst] -> [TypeText]
collectRuntimeCodecTypesFromRecordFields typeDecls recordDecls env localEnv fnContext fields = {
  let mut collected = [];
  for field in fields {
    collected = appendUniqueRuntimeCodecTypes collected (collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext (recordExprFieldValue field));
    collected
  };
  collected
}

collectRuntimeCodecTypesFromBranches : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [TypeBinding] -> [TypeBinding] -> ReturnContext -> [HostedMatchBranchAst] -> [TypeText]
collectRuntimeCodecTypesFromBranches typeDecls recordDecls env localEnv fnContext branches = {
  let mut collected = [];
  for branch in branches {
    collected = appendUniqueRuntimeCodecTypes collected (collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext (branchBodyExpr branch));
    collected
  };
  collected
}

collectRuntimeCodecTypesFromExpr : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [TypeBinding] -> [TypeBinding] -> ReturnContext -> HostedExprAst -> [TypeText]
collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext expr = match expr {
  HostedName name ->
    [],
  HostedString value ->
    [],
  HostedInt value ->
    [],
  HostedBool value ->
    [],
  HostedList values ->
    collectRuntimeCodecTypesFromExprList typeDecls recordDecls env localEnv fnContext values,
  HostedCall callee args -> {
    let argTypes = collectRuntimeCodecTypesFromExprList typeDecls recordDecls env localEnv fnContext args;
    if callee == "encode" then {
      appendUniqueRuntimeCodecType argTypes (inferredExprType typeDecls recordDecls env localEnv fnContext (firstHostedExpr args))
    } else {
      argTypes
    }
  },
  HostedConstructor constructorName args ->
    collectRuntimeCodecTypesFromExprList typeDecls recordDecls env localEnv fnContext args,
  HostedMatch subject branches -> {
    let subjectTypes = collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext subject;
    appendUniqueRuntimeCodecTypes subjectTypes (collectRuntimeCodecTypesFromBranches typeDecls recordDecls env localEnv fnContext branches)
  },
  HostedRecord recordName fields ->
    collectRuntimeCodecTypesFromRecordFields typeDecls recordDecls env localEnv fnContext fields,
  HostedFieldAccess subject fieldName ->
    collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext subject,
  HostedLet binder value body -> {
    let valueTypes = collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext value;
    let extendedLocalEnv = extendLowerLocalEnv typeDecls recordDecls env localEnv fnContext binder value;
    appendUniqueRuntimeCodecTypes valueTypes (collectRuntimeCodecTypesFromExpr typeDecls recordDecls env extendedLocalEnv fnContext body)
  },
  HostedMutableLet binder value body -> {
    let valueTypes = collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext value;
    let extendedLocalEnv = extendLowerLocalEnv typeDecls recordDecls env localEnv fnContext binder value;
    appendUniqueRuntimeCodecTypes valueTypes (collectRuntimeCodecTypesFromExpr typeDecls recordDecls env extendedLocalEnv fnContext body)
  },
  HostedAssign binder value body -> {
    let valueTypes = collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext value;
    appendUniqueRuntimeCodecTypes valueTypes (collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext body)
  },
  HostedFor binder iterable loopBody body -> {
    let iterableTypes = collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext iterable;
    let loopLocalEnv = extendLowerLoopLocalEnv typeDecls recordDecls env localEnv fnContext binder iterable;
    let loopTypes = collectRuntimeCodecTypesFromExpr typeDecls recordDecls env loopLocalEnv fnContext loopBody;
    appendUniqueRuntimeCodecTypes (appendUniqueRuntimeCodecTypes iterableTypes loopTypes) (collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext body)
  },
  HostedReturn value ->
    collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext value,
  HostedIf condition thenBranch elseBranch -> {
    let conditionTypes = collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext condition;
    let thenTypes = collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext thenBranch;
    appendUniqueRuntimeCodecTypes (appendUniqueRuntimeCodecTypes conditionTypes thenTypes) (collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext elseBranch)
  },
  HostedEqual left right -> {
    let leftTypes = collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext left;
    appendUniqueRuntimeCodecTypes leftTypes (collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext right)
  },
  HostedNotEqual left right -> {
    let leftTypes = collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext left;
    appendUniqueRuntimeCodecTypes leftTypes (collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext right)
  },
  HostedLessThan left right -> {
    let leftTypes = collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext left;
    appendUniqueRuntimeCodecTypes leftTypes (collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext right)
  },
  HostedLessThanOrEqual left right -> {
    let leftTypes = collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext left;
    appendUniqueRuntimeCodecTypes leftTypes (collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext right)
  },
  HostedGreaterThan left right -> {
    let leftTypes = collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext left;
    appendUniqueRuntimeCodecTypes leftTypes (collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext right)
  },
  HostedGreaterThanOrEqual left right -> {
    let leftTypes = collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext left;
    appendUniqueRuntimeCodecTypes leftTypes (collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext right)
  }
}

collectModuleRuntimeCodecTypes : HostedModuleAst -> [TypeText]
collectModuleRuntimeCodecTypes modl = {
  let typeDecls = effectiveModuleTypeDecls modl;
  let recordDecls = moduleRecordDeclarations modl;
  let env = lowerModuleEnv modl typeDecls;
  let mut collected = [];
  for decl in moduleDeclarations modl {
    let declCodecTypes = if hasLowerParams decl then collectRuntimeCodecTypesFromExpr typeDecls recordDecls env (lowerFunctionLocalEnv decl) (lowerFunctionFnContext decl) (declBody decl) else collectRuntimeCodecTypesFromExpr typeDecls recordDecls env emptyTypeBindings OutsideFunction (declBody decl);
    collected = appendUniqueRuntimeCodecTypes collected declCodecTypes;
    collected
  };
  collected
}

appendUniqueTextValue : [Str] -> Str -> [Str]
appendUniqueTextValue values value = if containsText values value then values else append values [value]

appendUniqueTextValues : [Str] -> [Str] -> [Str]
appendUniqueTextValues existing additions = {
  let mut merged = existing;
  for value in additions {
    merged = appendUniqueTextValue merged value;
    merged
  };
  merged
}

builtinRuntimeBindingName : Str -> Bool
builtinRuntimeBindingName name = if name == "textConcat" then true else if name == "textJoin" then true else if name == "textSplit" then true else if name == "textChars" then true else if name == "textFingerprint64Hex" then true else if name == "textPrefix" then true else if name == "textSplitFirst" then true else if name == "pathJoin" then true else if name == "pathDirname" then true else if name == "pathBasename" then true else if name == "fileExists" then true else if name == "readFile" then true else false

collectRuntimeBindingNamesFromExprList : [HostedExprAst] -> [Str]
collectRuntimeBindingNamesFromExprList exprs = {
  let mut collected = [];
  for expr in exprs {
    collected = appendUniqueTextValues collected (collectRuntimeBindingNamesFromExpr expr);
    collected
  };
  collected
}

collectRuntimeBindingNamesFromRecordFields : [HostedRecordFieldExprAst] -> [Str]
collectRuntimeBindingNamesFromRecordFields fields = {
  let mut collected = [];
  for field in fields {
    collected = appendUniqueTextValues collected (collectRuntimeBindingNamesFromExpr (recordExprFieldValue field));
    collected
  };
  collected
}

collectRuntimeBindingNamesFromBranches : [HostedMatchBranchAst] -> [Str]
collectRuntimeBindingNamesFromBranches branches = {
  let mut collected = [];
  for branch in branches {
    collected = appendUniqueTextValues collected (collectRuntimeBindingNamesFromExpr (branchBodyExpr branch));
    collected
  };
  collected
}

collectRuntimeBindingNamesFromExpr : HostedExprAst -> [Str]
collectRuntimeBindingNamesFromExpr expr = match expr {
  HostedName name ->
    [],
  HostedString value ->
    [],
  HostedInt value ->
    [],
  HostedBool value ->
    [],
  HostedList values ->
    collectRuntimeBindingNamesFromExprList values,
  HostedCall callee args -> {
    let argNames = collectRuntimeBindingNamesFromExprList args;
    if builtinRuntimeBindingName callee then appendUniqueTextValue argNames callee else argNames
  },
  HostedConstructor constructorName args ->
    collectRuntimeBindingNamesFromExprList args,
  HostedMatch subject branches -> {
    let subjectNames = collectRuntimeBindingNamesFromExpr subject;
    appendUniqueTextValues subjectNames (collectRuntimeBindingNamesFromBranches branches)
  },
  HostedRecord recordName fields ->
    collectRuntimeBindingNamesFromRecordFields fields,
  HostedFieldAccess subject fieldName ->
    collectRuntimeBindingNamesFromExpr subject,
  HostedLet binder value body -> {
    let valueNames = collectRuntimeBindingNamesFromExpr value;
    appendUniqueTextValues valueNames (collectRuntimeBindingNamesFromExpr body)
  },
  HostedMutableLet binder value body -> {
    let valueNames = collectRuntimeBindingNamesFromExpr value;
    appendUniqueTextValues valueNames (collectRuntimeBindingNamesFromExpr body)
  },
  HostedAssign binder value body -> {
    let valueNames = collectRuntimeBindingNamesFromExpr value;
    appendUniqueTextValues valueNames (collectRuntimeBindingNamesFromExpr body)
  },
  HostedFor binder iterable loopBody body -> {
    let iterableNames = collectRuntimeBindingNamesFromExpr iterable;
    let loopNames = collectRuntimeBindingNamesFromExpr loopBody;
    appendUniqueTextValues (appendUniqueTextValues iterableNames loopNames) (collectRuntimeBindingNamesFromExpr body)
  },
  HostedReturn value ->
    collectRuntimeBindingNamesFromExpr value,
  HostedIf condition thenBranch elseBranch -> {
    let conditionNames = collectRuntimeBindingNamesFromExpr condition;
    let thenNames = collectRuntimeBindingNamesFromExpr thenBranch;
    appendUniqueTextValues (appendUniqueTextValues conditionNames thenNames) (collectRuntimeBindingNamesFromExpr elseBranch)
  },
  HostedEqual left right -> {
    let leftNames = collectRuntimeBindingNamesFromExpr left;
    appendUniqueTextValues leftNames (collectRuntimeBindingNamesFromExpr right)
  },
  HostedNotEqual left right -> {
    let leftNames = collectRuntimeBindingNamesFromExpr left;
    appendUniqueTextValues leftNames (collectRuntimeBindingNamesFromExpr right)
  },
  HostedLessThan left right -> {
    let leftNames = collectRuntimeBindingNamesFromExpr left;
    appendUniqueTextValues leftNames (collectRuntimeBindingNamesFromExpr right)
  },
  HostedLessThanOrEqual left right -> {
    let leftNames = collectRuntimeBindingNamesFromExpr left;
    appendUniqueTextValues leftNames (collectRuntimeBindingNamesFromExpr right)
  },
  HostedGreaterThan left right -> {
    let leftNames = collectRuntimeBindingNamesFromExpr left;
    appendUniqueTextValues leftNames (collectRuntimeBindingNamesFromExpr right)
  },
  HostedGreaterThanOrEqual left right -> {
    let leftNames = collectRuntimeBindingNamesFromExpr left;
    appendUniqueTextValues leftNames (collectRuntimeBindingNamesFromExpr right)
  }
}

collectModuleRuntimeBindingNames : HostedModuleAst -> [Str]
collectModuleRuntimeBindingNames modl = {
  let mut collected = [];
  for decl in moduleDeclarations modl {
    collected = appendUniqueTextValues collected (collectRuntimeBindingNamesFromExpr (declBody decl));
    collected
  };
  collected
}

lowercaseRuntimeChar : Str -> Str
lowercaseRuntimeChar value = if value == "A" then "a" else if value == "B" then "b" else if value == "C" then "c" else if value == "D" then "d" else if value == "E" then "e" else if value == "F" then "f" else if value == "G" then "g" else if value == "H" then "h" else if value == "I" then "i" else if value == "J" then "j" else if value == "K" then "k" else if value == "L" then "l" else if value == "M" then "m" else if value == "N" then "n" else if value == "O" then "o" else if value == "P" then "p" else if value == "Q" then "q" else if value == "R" then "r" else if value == "S" then "s" else if value == "T" then "t" else if value == "U" then "u" else if value == "V" then "v" else if value == "W" then "w" else if value == "X" then "x" else if value == "Y" then "y" else if value == "Z" then "z" else value

dropLastChar : Str -> Str
dropLastChar value = {
  let mut result = "";
  let mut previous = "";
  let mut seenChar = false;
  for char in textChars value {
    if seenChar then {
      result = appendChar result previous;
      previous = char;
      result
    } else {
      previous = char;
      seenChar = true;
      result
    }
  };
  result
}

normalizeRuntimeName : Str -> Str
normalizeRuntimeName value = {
  let mut normalized = "";
  let mut seenText = false;
  for char in textChars value {
    if char == "_" then {
      if seenText then {
        if lastCharText normalized == "_" then normalized else {
          normalized = appendChar normalized "_";
          normalized
        }
      } else {
        normalized
      }
    } else if isUppercaseChar char then {
      if seenText then {
        if lastCharText normalized == "_" then {
          normalized = appendChar normalized (lowercaseRuntimeChar char);
          normalized
        } else {
          normalized = textConcat [normalized, "_", lowercaseRuntimeChar char];
          normalized
        }
      } else {
        normalized = appendChar normalized (lowercaseRuntimeChar char);
        seenText = true;
        normalized
      }
    } else {
      normalized = appendChar normalized char;
      seenText = true;
      normalized
    }
  };
  if lastCharText normalized == "_" then dropLastChar normalized else normalized
}

nativeRuntimeBindingSymbol : Str -> Str
nativeRuntimeBindingSymbol runtimeName = textConcat ["clasp_rt_", normalizeRuntimeName runtimeName]

emitBuiltinRuntimeBindingImage : Str -> Str
emitBuiltinRuntimeBindingImage name = if name == "textConcat" then renderJsonObject [renderJsonField "name" (encode "textConcat"), renderJsonField "runtime" (encode "textConcat"), renderJsonField "symbol" (encode (nativeRuntimeBindingSymbol "textConcat")), renderJsonField "type" (encode "[Str] -> Str")] else if name == "textJoin" then renderJsonObject [renderJsonField "name" (encode "textJoin"), renderJsonField "runtime" (encode "textJoin"), renderJsonField "symbol" (encode (nativeRuntimeBindingSymbol "textJoin")), renderJsonField "type" (encode "Str -> [Str] -> Str")] else if name == "textSplit" then renderJsonObject [renderJsonField "name" (encode "textSplit"), renderJsonField "runtime" (encode "textSplit"), renderJsonField "symbol" (encode (nativeRuntimeBindingSymbol "textSplit")), renderJsonField "type" (encode "Str -> Str -> [Str]")] else if name == "textChars" then renderJsonObject [renderJsonField "name" (encode "textChars"), renderJsonField "runtime" (encode "textChars"), renderJsonField "symbol" (encode (nativeRuntimeBindingSymbol "textChars")), renderJsonField "type" (encode "Str -> [Str]")] else if name == "textFingerprint64Hex" then renderJsonObject [renderJsonField "name" (encode "textFingerprint64Hex"), renderJsonField "runtime" (encode "textFingerprint64Hex"), renderJsonField "symbol" (encode (nativeRuntimeBindingSymbol "textFingerprint64Hex")), renderJsonField "type" (encode "Str -> Str")] else if name == "textPrefix" then renderJsonObject [renderJsonField "name" (encode "textPrefix"), renderJsonField "runtime" (encode "textPrefix"), renderJsonField "symbol" (encode (nativeRuntimeBindingSymbol "textPrefix")), renderJsonField "type" (encode "Str -> Str -> Result")] else if name == "textSplitFirst" then renderJsonObject [renderJsonField "name" (encode "textSplitFirst"), renderJsonField "runtime" (encode "textSplitFirst"), renderJsonField "symbol" (encode (nativeRuntimeBindingSymbol "textSplitFirst")), renderJsonField "type" (encode "Str -> Str -> Result")] else if name == "pathJoin" then renderJsonObject [renderJsonField "name" (encode "pathJoin"), renderJsonField "runtime" (encode "pathJoin"), renderJsonField "symbol" (encode (nativeRuntimeBindingSymbol "pathJoin")), renderJsonField "type" (encode "[Str] -> Str")] else if name == "pathDirname" then renderJsonObject [renderJsonField "name" (encode "pathDirname"), renderJsonField "runtime" (encode "pathDirname"), renderJsonField "symbol" (encode (nativeRuntimeBindingSymbol "pathDirname")), renderJsonField "type" (encode "Str -> Str")] else if name == "pathBasename" then renderJsonObject [renderJsonField "name" (encode "pathBasename"), renderJsonField "runtime" (encode "pathBasename"), renderJsonField "symbol" (encode (nativeRuntimeBindingSymbol "pathBasename")), renderJsonField "type" (encode "Str -> Str")] else if name == "fileExists" then renderJsonObject [renderJsonField "name" (encode "fileExists"), renderJsonField "runtime" (encode "fileExists"), renderJsonField "symbol" (encode (nativeRuntimeBindingSymbol "fileExists")), renderJsonField "type" (encode "Str -> Bool")] else if name == "readFile" then renderJsonObject [renderJsonField "name" (encode "readFile"), renderJsonField "runtime" (encode "readFile"), renderJsonField "symbol" (encode (nativeRuntimeBindingSymbol "readFile")), renderJsonField "type" (encode "Str -> Result")] else renderJsonObject []

emitNativeRuntimeBindingImage : HostedForeignDeclAst -> Str
emitNativeRuntimeBindingImage foreignDecl =
  renderJsonObject [renderJsonField "name" (encode (foreignDeclName foreignDecl)), renderJsonField "runtime" (encode (foreignDeclRuntimeName foreignDecl)), renderJsonField "symbol" (encode (nativeRuntimeBindingSymbol (foreignDeclRuntimeName foreignDecl))), renderJsonField "type" (encode (renderHostedType (foreignDeclTypeAst foreignDecl)))]

emitNativeBuiltinRuntimeBindingImages : [Str] -> [Str]
emitNativeBuiltinRuntimeBindingImages bindingNames = {
  let mut rendered = [];
  for builtinName in ["textConcat", "textJoin", "textSplit", "textChars", "textFingerprint64Hex", "textPrefix", "textSplitFirst", "pathJoin", "pathDirname", "pathBasename", "fileExists", "readFile"] {
    if containsText bindingNames builtinName then {
      rendered = appendNativeRenderedText rendered (emitBuiltinRuntimeBindingImage builtinName);
      rendered
    } else {
      rendered
    }
  };
  rendered
}

emitNativeRuntimeBindingImages : HostedModuleAst -> [Str]
emitNativeRuntimeBindingImages modl = {
  let mut rendered = emitNativeBuiltinRuntimeBindingImages (collectModuleRuntimeBindingNames modl);
  for foreignDecl in moduleForeignDeclarations modl {
    rendered = appendNativeRenderedText rendered (emitNativeRuntimeBindingImage foreignDecl);
    rendered
  };
  rendered
}

nativeCodecSuffixForType : TypeText -> Str
nativeCodecSuffixForType typ = match typ {
  TInt ->
    "Int",
  TStr ->
    "Str",
  TBool ->
    "Bool",
  TList itemType ->
    textConcat ["List_", nativeCodecSuffixForType itemType],
  TNamed name ->
    name,
  TFunction input result ->
    "Unsupported",
  TUnknown label ->
    label
}

emitNativeJsonCodecImage : TypeText -> Str
emitNativeJsonCodecImage typ = {
  let suffix = nativeCodecSuffixForType typ;
  renderJsonObject [renderJsonField "type" (encode (renderType typ)), renderJsonField "encode" (encode (textConcat ["$encode_", suffix])), renderJsonField "decode" (encode (textConcat ["$decode_", suffix]))]
}

emitNativeBinaryCodecImage : TypeText -> Str
emitNativeBinaryCodecImage typ = {
  let suffix = nativeCodecSuffixForType typ;
  renderJsonObject [renderJsonField "type" (encode (renderType typ)), renderJsonField "encode" (encode (textConcat ["$encode_binary_", suffix])), renderJsonField "decode" (encode (textConcat ["$decode_binary_", suffix])), renderJsonField "framing" (encode "length_prefixed")]
}

emitNativeJsonCodecImagesFromTypes : [TypeText] -> [Str]
emitNativeJsonCodecImagesFromTypes codecTypes = {
  let mut rendered = [];
  for codecType in codecTypes {
    rendered = appendNativeRenderedText rendered (emitNativeJsonCodecImage codecType);
    rendered
  };
  rendered
}

emitNativeBinaryCodecImagesFromTypes : [TypeText] -> [Str]
emitNativeBinaryCodecImagesFromTypes codecTypes = {
  let mut rendered = [];
  for codecType in codecTypes {
    rendered = appendNativeRenderedText rendered (emitNativeBinaryCodecImage codecType);
    rendered
  };
  rendered
}

emitNativeJsonNumberList : [Str] -> [Str]
emitNativeJsonNumberList values = values

emitNativeAbiAllocationImage : Str
emitNativeAbiAllocationImage =
  jsonObject [
    jsonFieldText "immediate" "stack",
    jsonFieldText "handle" "heap",
    jsonFieldText "global" "static"
  ]

emitNativeBuiltinLayoutImage : Str -> Str -> Str -> Str
