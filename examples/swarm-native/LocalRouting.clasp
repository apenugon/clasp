  else if localRouteTextIncludes prompt "required_available_memory_mb" then
    true
  else if localRouteTextIncludes prompt "memory reserve unmet" then
    true
  else if localRouteTextIncludes prompt "external agent reserve unmet" then
    true
  else if localRouteTextIncludes prompt "external agent reserve" then
    localRouteTextIncludes prompt "memory"
  else if localRouteTextIncludes prompt "Planner resource health:" then
    if localRouteTextIncludes prompt "memory:" then
      if localRouteTextIncludes prompt "status=blocked" then
        true
      else if localRouteTextIncludes prompt "reserveMet=false" then
        true
      else
        localRouteTextIncludes prompt "headroomMet=false"
    else
      false
  else
    false

localRouteHasPlannerDiskResourcePressure : Str -> Bool
localRouteHasPlannerDiskResourcePressure prompt =
  if localRouteTextIncludes prompt "resource-pressure-kind=disk" then
    true
  else if localRouteTextIncludes prompt "disk-exceeded" then
    true
  else if localRouteTextIncludes prompt "available_disk_mb" then
    true
  else if localRouteTextIncludes prompt "required_available_disk_mb" then
    true
  else if localRouteTextIncludes prompt "disk_headroom" then
    true
  else if localRouteTextIncludes prompt "GeneratedStateCleanupPlan" then
    true
  else if localRouteTextIncludes prompt "generated-state cleanup" then
    true
  else if localRouteTextIncludes prompt "CLASP_GENERATED_STATE_APPLY_JSON" then
    true
  else if localRouteTextIncludes prompt "Planner resource health:" then
    localRouteTextIncludes prompt "disk:"
  else
    false

localRouteHasAnyPlannerResourcePressure : Str -> Bool
localRouteHasAnyPlannerResourcePressure prompt =
  if localRouteHasPlannerResourcePressure prompt then
    true
  else if localRouteHasPlannerMemoryResourcePressure prompt then
    true
  else
    localRouteHasPlannerDiskResourcePressure prompt

localRouteResourcePressureKindForPrompt : Str -> Str
localRouteResourcePressureKindForPrompt prompt =
  if localRouteHasPlannerMemoryResourcePressure prompt then
    localRouteResourcePressureKindMemory
  else if localRouteHasPlannerDiskResourcePressure prompt then
    localRouteResourcePressureKindDisk
  else if localRouteHasPlannerResourcePressure prompt then
    localRouteTaskKindResourcePressure
  else
    localRouteResourcePressureKindGeneric

localRouteHasAffectedVerificationLaunchPolicy : Str -> Bool
localRouteHasAffectedVerificationLaunchPolicy prompt =
  if localRouteTextIncludes prompt "affectedVerificationLaunchPolicy" then
    true
  else if localRouteTextIncludes prompt "affected-launch-mode=" then
    true
  else if localRouteTextIncludes prompt "affected-verification-launch:" then
    true
  else if localRouteTextIncludes prompt "affected_verification_plan" then
    localRouteTextIncludes prompt "affected-verification-plan"
  else
    false

localRouteAffectedVerificationTouchesCompilerState : Str -> Bool
localRouteAffectedVerificationTouchesCompilerState prompt =
  if localRouteTextIncludes prompt "affected-launch-mode=direct-compiler-state-access" then
    true
  else if localRouteTextIncludes prompt "\"mode\":\"direct-compiler-state-access\"" then
    true
  else if localRouteTextIncludes prompt "\"mode\": \"direct-compiler-state-access\"" then
    true
  else if localRouteTextIncludes prompt "affected verifier plan touches compiler/cache state before launch" then
    true
  else
    localRouteTextIncludes prompt "affected-verification-plan:safe-direct-compiler-state-access"

localRouteAffectedVerificationRequiresManaged : Str -> Bool
localRouteAffectedVerificationRequiresManaged prompt =
  if localRouteTextIncludes prompt "affected-launch-mode=heavy-managed" then
    true
  else if localRouteTextIncludes prompt "affected-launch-mode=focused-managed" then
    true
  else if localRouteTextIncludes prompt "\"mode\":\"heavy-managed\"" then
    true
  else if localRouteTextIncludes prompt "\"mode\":\"focused-managed\"" then
    true
  else if localRouteTextIncludes prompt "\"mode\": \"heavy-managed\"" then
    true
  else if localRouteTextIncludes prompt "\"mode\": \"focused-managed\"" then
    true
  else if localRouteTextIncludes prompt "affected-verification-launch:managed-" then
    true
  else if localRouteTextIncludes prompt "affected verifier plan requires managed" then
    true
  else
    localRouteTextIncludes prompt "affected-verification-plan:run-managed"

localRouteFocusedVerificationPlanRequiresManaged : Str -> Bool
localRouteFocusedVerificationPlanRequiresManaged prompt =
  if localRouteTextIncludes prompt "focused-verification-plan-safe-direct:false" then
    true
  else if localRouteTextIncludes prompt "focused-verification-launch-mode=managed-required" then
    true
  else if localRouteTextIncludes prompt "focused-verification-launch-policy-mode:managed-required" then
    true
  else if localRouteTextIncludes prompt "focused-verification-launch:managed-required" then
    true
  else if localRouteTextIncludes prompt "focused-verification-launch-mode=invalid-plan" then
    true
  else if localRouteTextIncludes prompt "focused-verification-launch-policy-mode:invalid-plan" then
    true
  else if localRouteTextIncludes prompt "focused-verification-launch:repair-plan-section" then
    true
  else if localRouteTextIncludes prompt "Focused verification launch policy JSON:" then
    if localRouteTextIncludes prompt "\"mode\":\"managed-required\"" then
      true
    else if localRouteTextIncludes prompt "\"mode\": \"managed-required\"" then
      true
    else if localRouteTextIncludes prompt "\"mode\":\"invalid-plan\"" then
      true
    else if localRouteTextIncludes prompt "\"mode\": \"invalid-plan\"" then
      true
    else if localRouteTextIncludes prompt "\"ready\":false" then
      true
    else
      localRouteTextIncludes prompt "\"ready\": false"
  else if localRouteTextIncludes prompt "focused-verification-safe-direct=false" then
    true
  else if localRouteTextIncludes prompt "focused-verification-plan-managed-required:true" then
    true
  else if localRouteTextIncludes prompt "focused-verification-managed-required=true" then
    true
  else if localRouteTextIncludes prompt "capability-gap=focused_verification_plan:" then
    true
  else if localRouteTextIncludes prompt "capability-gap=focused_verification_launch_policy:" then
    true
  else if localRouteTextIncludes prompt "focused verification plan requires managed launch" then
    true
  else if localRouteTextIncludes prompt "unmanaged heavy focused plans" then
    true
  else
    localRouteTextIncludes prompt "focusedVerificationPlan:managed-required"

localRouteHasAffectedVerificationLaunchGap : Str -> Bool
localRouteHasAffectedVerificationLaunchGap prompt =
  if localRouteFocusedVerificationPlanRequiresManaged prompt then
    true
  else if localRouteHasAffectedVerificationLaunchPolicy prompt then
    if localRouteTextIncludes prompt "affected-launch-ready=false" then
      true
    else if localRouteTextIncludes prompt "\"ready\":false" then
      true
    else if localRouteTextIncludes prompt "\"ready\": false" then
      true
    else if localRouteAffectedVerificationTouchesCompilerState prompt then
      true
    else
      localRouteAffectedVerificationRequiresManaged prompt
  else
    false

localRouteTaskKindForPrompt : Str -> Str
localRouteTaskKindForPrompt prompt =
  if localRouteHasAnyPlannerResourcePressure prompt then
    localRouteTaskKindResourcePressure
  else if localRouteHasAffectedVerificationLaunchGap prompt then
    localRouteTaskKindAffectedVerification
  else if localRouteHasSwarmCapabilityAudit prompt then
    localRouteTaskKindCapabilityAudit
  else if localRouteHasCapabilityAuditContextHandoff prompt then
    localRouteTaskKindCapabilityAudit
  else if localRouteHasAutonomousLaunchGateGap prompt then
    localRouteTaskKindStandaloneSwarm
  else if localRouteHasCapabilityMailboxHandoff prompt then
    localRouteTaskKindCapabilityAudit
  else if localRouteHasManagedSwarmProofHandoff prompt then
    localRouteTaskKindCapabilityAudit
  else if localRouteHasStandaloneSwarmClosureHandoff prompt then
    localRouteTaskKindStandaloneSwarm
  else if localRouteHasBackendConfigRepair prompt then
    localRouteTaskKindStandaloneSwarm
  else if localRouteTextIncludes prompt "verify-affected" then
    localRouteTaskKindIterationSpeed
  else if localRouteTextIncludes prompt "compiler-slice" then
    localRouteTaskKindIterationSpeed
  else if localRouteTextIncludes prompt "iteration time" then
    localRouteTaskKindIterationSpeed
  else if localRouteHasAiAgentSwarmGoal prompt then
    localRouteTaskKindStandaloneSwarm
  else if localRouteMentionsStandaloneSwarmIntent prompt then
    localRouteTaskKindStandaloneSwarm
  else if localRouteHasCompilerContextEvidence prompt then
    localRouteTaskKindIterationSpeed
  else if localRouteTextIncludes prompt "semantic index projections" then
    localRouteTaskKindSemanticContext
  else if localRouteTextIncludes prompt "standalone-agent routing" then
    localRouteTaskKindSemanticContext
  else if localRouteHasSemanticContextEvidence prompt then
    localRouteTaskKindSemanticContext
  else
    localRouteTaskKindGeneric

localRouteSelectsIterationSpeed : Str -> Bool
localRouteSelectsIterationSpeed prompt =
  localRouteTaskKindForPrompt prompt == localRouteTaskKindIterationSpeed

localRouteSelectsResourcePressure : Str -> Bool
localRouteSelectsResourcePressure prompt =
  localRouteTaskKindForPrompt prompt == localRouteTaskKindResourcePressure

localRouteSelectsAffectedVerification : Str -> Bool
localRouteSelectsAffectedVerification prompt =
  localRouteTaskKindForPrompt prompt == localRouteTaskKindAffectedVerification

localRouteSelectsProviderNeutral : Str -> Bool
localRouteSelectsProviderNeutral prompt =
  if localRouteTextIncludes prompt "provider-neutral planner" then
    true
  else if localRouteTextIncludes prompt "child agent command templates" then
    true
  else
    localRouteTextIncludes prompt "generic agent command"

localRouteSelectsMemoryResourcePressure : Str -> Bool
localRouteSelectsMemoryResourcePressure prompt =
  localRouteResourcePressureKindForPrompt prompt == localRouteResourcePressureKindMemory

localRouteSelectsDiskResourcePressure : Str -> Bool
localRouteSelectsDiskResourcePressure prompt =
  localRouteResourcePressureKindForPrompt prompt == localRouteResourcePressureKindDisk

localRouteSelectsSemanticContext : Str -> Bool
localRouteSelectsSemanticContext prompt =
  localRouteTaskKindForPrompt prompt == localRouteTaskKindSemanticContext

localRouteSelectsStandaloneSwarm : Str -> Bool
localRouteSelectsStandaloneSwarm prompt =
  localRouteTaskKindForPrompt prompt == localRouteTaskKindStandaloneSwarm

localRouteSelectsCapabilityAudit : Str -> Bool
localRouteSelectsCapabilityAudit prompt =
  localRouteTaskKindForPrompt prompt == localRouteTaskKindCapabilityAudit

localRoutePlannerRouteKeyForPrompt : Str -> Str
localRoutePlannerRouteKeyForPrompt prompt =
  if localRouteSelectsProviderNeutral prompt then
    localRoutePlannerRouteKeyProviderNeutral
  else if localRouteSelectsResourcePressure prompt then
    localRouteResourcePressureKindForPrompt prompt
  else
    localRouteTaskKindForPrompt prompt
