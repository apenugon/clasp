localRouteHasAutonomousLaunchGateGap : Str -> Bool
localRouteHasAutonomousLaunchGateGap prompt =
  if localRouteTextIncludes prompt "capability-gap=autonomous_launch_gate:" then
    true
  else if localRouteTextIncludes prompt "retryRecordRecoveryTask=standalone-swarm-autonomous-launch-gate-repair" then
    true
  else if localRouteTextIncludes prompt "retryRecordRecoveryKind=autonomous-launch-gate" then
    true
  else if localRouteTextIncludes prompt "retryRecordLatest=phase=autonomous-launch-gate" then
    true
  else if localRouteTextIncludes prompt "manager-replan-blocker=autonomous-launch-gate" then
    true
  else if localRouteTextIncludes prompt "autonomous-launch-gate-blocker" then
    true
  else if localRouteTextIncludes prompt "autonomous-launch:close-launch-gaps" then
    true
  else if localRouteTextIncludes prompt "autonomous-launch-ready=false" then
    true
  else if localRouteTextIncludes prompt "autonomous-launch-gate-mode:blocked-" then
    true
  else if localRouteTextIncludes prompt "autonomous-launch-mode=blocked-" then
    true
  else if localRouteTextIncludes prompt "Autonomous launch gate JSON:" then
    if localRouteTextIncludes prompt "\"ready\":false" then
      true
    else if localRouteTextIncludes prompt "\"ready\": false" then
      true
    else if localRouteTextIncludes prompt "\"mode\":\"blocked-" then
      true
    else
      localRouteTextIncludes prompt "\"mode\": \"blocked-"
  else
    false

localRouteHasBackendConfigRepair : Str -> Bool
localRouteHasBackendConfigRepair prompt =
  if localRouteTextIncludes prompt "backendConfigRepair=agent-backend" then
    true
  else if localRouteTextIncludes prompt "plannerBackendConfigRepair=agent-backend" then
    true
  else
    localRouteTextIncludes prompt "plannerBackendConfigError="

localRouteMentionsStandaloneSwarmIntent : Str -> Bool
localRouteMentionsStandaloneSwarmIntent prompt =
  if localRouteTextIncludes prompt "standalone-swarm" then
    true
  else if localRouteTextIncludes prompt "standalone swarm" then
    true
  else if localRouteTextIncludes prompt "ordinary-Clasp swarm runtime" then
    true
  else if localRouteTextIncludes prompt "Clasp-native swarm" then
    true
  else if localRouteTextIncludes prompt "clasp-native swarm" then
    true
  else if localRouteTextIncludes prompt "self-improving swarm" then
    true
  else if localRouteTextIncludes prompt "self improving swarm" then
    true
  else if localRouteTextIncludes prompt "swarm could run" then
    true
  else if localRouteTextIncludes prompt "swarm can run" then
    true
  else if localRouteTextIncludes prompt "run and improve Clasp itself" then
    true
  else if localRouteTextIncludes prompt "run and improve clasp itself" then
    true
  else if localRouteTextIncludes prompt "swarms can be implemented in Clasp" then
    true
  else if localRouteTextIncludes prompt "swarms can be implemented in clasp" then
    true
  else if localRouteTextIncludes prompt "non-Codex swarm" then
    true
  else if localRouteTextIncludes prompt "Codex-free swarm" then
    true
  else if localRouteTextIncludes prompt "without Codex-specific control flow" then
    true
  else if localRouteTextIncludes prompt "without Codex" then
    localRouteTextIncludes prompt "swarm"
  else
    false

localRouteHasPlannerResourcePressure : Str -> Bool
localRouteHasPlannerResourcePressure prompt =
  if localRouteTextIncludes prompt "Planner resource health:" then
    if localRouteTextIncludes prompt "status=blocked" then
      true
    else if localRouteTextIncludes prompt "memory-admission: status=blocked" then
      true
    else if localRouteTextIncludes prompt "memory-concurrency-admission: status=reduced" then
      true
    else if localRouteTextIncludes prompt "memory-concurrency-admission: status=blocked" then
      true
    else if localRouteTextIncludes prompt "reserveMet=false" then
      true
    else
      localRouteTextIncludes prompt "headroomMet=false"
  else if localRouteTextIncludes prompt "resource-pressure-recovery" then
    true
  else if localRouteTextIncludes prompt "resource-memory-pressure-recovery" then
    true
  else if localRouteTextIncludes prompt "resource-pressure-kind=" then
    true
  else if localRouteTextIncludes prompt "resource pressure" then
    true
  else if localRouteTextIncludes prompt "generated-state cleanup" then
    true
  else if localRouteTextIncludes prompt "GeneratedStateCleanupPlan" then
    true
  else if localRouteTextIncludes prompt "CLASP_GENERATED_STATE_APPLY_JSON" then
    true
  else
    false

localRouteHasPlannerMemoryResourcePressure : Str -> Bool
localRouteHasPlannerMemoryResourcePressure prompt =
  if localRouteTextIncludes prompt "resource-memory-pressure-recovery" then
    true
  else if localRouteTextIncludes prompt "resource-pressure-kind=memory" then
    true
  else if localRouteTextIncludes prompt "resource-memory-pressure" then
    true
  else if localRouteTextIncludes prompt "memory-admission: status=blocked" then
    true
  else if localRouteTextIncludes prompt "memory-concurrency-admission: status=reduced" then
    true
  else if localRouteTextIncludes prompt "memory-concurrency-admission: status=blocked" then
    true
  else if localRouteTextIncludes prompt "reason=host-memory-reserve" then
    true
  else if localRouteTextIncludes prompt "reason=projected-child-memory-reserve" then
    true
  else if localRouteTextIncludes prompt "reason=external-agent-memory-reserve" then
    true
  else if localRouteTextIncludes prompt "reason=configured-concurrency-exceeds-memory-capacity" then
    true
  else if localRouteTextIncludes prompt "reason=no-child-memory-capacity" then
    true
  else if localRouteTextIncludes prompt "action=wait-for-memory-or-stop-only-managed-jobs-by-metadata" then
    true
  else if localRouteTextIncludes prompt "action=lower-concurrency-or-child-memory-budget" then
    true
  else if localRouteTextIncludes prompt "action=lower-concurrency-to-admitted-child-capacity" then
    true
  else if localRouteTextIncludes prompt "action=wait-for-memory-or-lower-concurrency-before-launch" then
    true
  else if localRouteTextIncludes prompt "action=wait-for-external-agent-pressure-or-lower-concurrency" then
    true
  else if localRouteTextIncludes prompt "memory-exceeded" then
    true
  else if localRouteTextIncludes prompt "oom-kill" then
    true
  else if localRouteTextIncludes prompt "OOM" then
    true
  else if localRouteTextIncludes prompt "out of memory" then
    true
  else if localRouteTextIncludes prompt "Out of memory" then
    true
  else if localRouteTextIncludes prompt "Killed" then
    true
  else if localRouteTextIncludes prompt "SIGKILL" then
    true
  else if localRouteTextIncludes prompt "signal 9" then
    true
  else if localRouteTextIncludes prompt "exit 137" then
    true
  else if localRouteTextIncludes prompt "exit-status=137" then
    true
  else if localRouteTextIncludes prompt "status=137" then
    true
  else if localRouteTextIncludes prompt "externalAgentRssMb=" then
    true
  else if localRouteTextIncludes prompt "external_agent_rss_mb" then
    true
  else if localRouteTextIncludes prompt "externalAgentReservedMb=" then
    true
  else if localRouteTextIncludes prompt "external_agent_reserved_memory_mb" then
    true
  else if localRouteTextIncludes prompt "unmanagedRssMb=" then
