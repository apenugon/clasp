module LocalRouting

localRouteTextIncludes : Str -> Str -> Bool
localRouteTextIncludes value needle = length (textSplit value needle) > 1

localRouteTaskKindGeneric : Str
localRouteTaskKindGeneric = "generic"

localRouteTaskKindIterationSpeed : Str
localRouteTaskKindIterationSpeed = "iteration-speed"

localRouteTaskKindResourcePressure : Str
localRouteTaskKindResourcePressure = "resource-pressure"

localRouteTaskKindAffectedVerification : Str
localRouteTaskKindAffectedVerification = "affected-verification"

localRouteTaskKindCapabilityAudit : Str
localRouteTaskKindCapabilityAudit = "capability-audit"

localRouteTaskKindStandaloneSwarm : Str
localRouteTaskKindStandaloneSwarm = "standalone-swarm"

localRouteTaskKindSemanticContext : Str
localRouteTaskKindSemanticContext = "semantic-context"

localRouteResourcePressureKindGeneric : Str
localRouteResourcePressureKindGeneric = "generic"

localRouteResourcePressureKindMemory : Str
localRouteResourcePressureKindMemory = "resource-memory-pressure"

localRouteResourcePressureKindDisk : Str
localRouteResourcePressureKindDisk = "resource-disk-pressure"

localRoutePlannerRouteKeyProviderNeutral : Str
localRoutePlannerRouteKeyProviderNeutral = "provider-neutral"

localRoutePlannerRouteKeyWildcard : Str
localRoutePlannerRouteKeyWildcard = "*"

localRoutePlannerRouteKeyKnown : Str -> Bool
localRoutePlannerRouteKeyKnown key =
  if key == localRoutePlannerRouteKeyWildcard then
    true
  else if key == localRoutePlannerRouteKeyProviderNeutral then
    true
  else if key == localRouteTaskKindGeneric then
    true
  else if key == localRouteTaskKindIterationSpeed then
    true
  else if key == localRouteTaskKindResourcePressure then
    true
  else if key == localRouteTaskKindAffectedVerification then
    true
  else if key == localRouteTaskKindCapabilityAudit then
    true
  else if key == localRouteTaskKindStandaloneSwarm then
    true
  else if key == localRouteTaskKindSemanticContext then
    true
  else if key == localRouteResourcePressureKindMemory then
    true
  else
    key == localRouteResourcePressureKindDisk

localRouteHasNonEmptySection : Str -> Str -> Bool
localRouteHasNonEmptySection prompt title =
  if localRouteTextIncludes prompt (textConcat [title, "\n- none"]) then
    false
  else
    localRouteTextIncludes prompt title

localRouteHasCompilerContextEvidence : Str -> Bool
localRouteHasCompilerContextEvidence prompt =
  if localRouteTextIncludes prompt "src/Compiler/" then
    true
  else if localRouteTextIncludes prompt "Compiler." then
    true
  else
    localRouteTextIncludes prompt "compiler:"

localRouteHasSemanticContextEvidence : Str -> Bool
localRouteHasSemanticContextEvidence prompt =
  if localRouteHasNonEmptySection prompt "semantic index artifact matches:" then
    true
  else if localRouteHasNonEmptySection prompt "semantic index edit files:" then
    true
  else if localRouteHasNonEmptySection prompt "semantic index artifact refs:" then
    true
  else if localRouteHasNonEmptySection prompt "semantic index surface ids:" then
    true
  else
    localRouteHasNonEmptySection prompt "semantic index query texts:"

localRouteMentionsAiAgents : Str -> Bool
localRouteMentionsAiAgents prompt =
  if localRouteTextIncludes prompt "AI agents" then
    true
  else if localRouteTextIncludes prompt "ai agents" then
    true
  else
    false

localRouteMentionsAgentSwarms : Str -> Bool
localRouteMentionsAgentSwarms prompt =
  if localRouteTextIncludes prompt "agent swarms" then
    true
  else if localRouteTextIncludes prompt "create agent swarms" then
    true
  else if localRouteTextIncludes prompt "agent swarm" then
    true
  else
    false

localRouteHasAiAgentSwarmGoal : Str -> Bool
localRouteHasAiAgentSwarmGoal prompt =
  if localRouteMentionsAiAgents prompt then
    localRouteMentionsAgentSwarms prompt
  else
    false

localRouteHasSwarmCapabilityAudit : Str -> Bool
localRouteHasSwarmCapabilityAudit prompt =
  if localRouteTextIncludes prompt "clasp-swarm-capability-audit" then
    true
  else if localRouteTextIncludes prompt "capability_statuses" then
    if localRouteTextIncludes prompt "overall_status" then
      localRouteTextIncludes prompt "blocking_gaps"
    else
      false
  else
    false

localRouteHasCapabilityAuditContextHandoff : Str -> Bool
localRouteHasCapabilityAuditContextHandoff prompt =
  if localRouteTextIncludes prompt "Capability audit decision JSON path:" then
    true
  else if localRouteTextIncludes prompt "Capability audit decision JSON:" then
    true
  else if localRouteTextIncludes prompt "Capability audit JSON path:" then
    true
  else if localRouteTextIncludes prompt "Capability audit JSON:" then
    true
  else if localRouteTextIncludes prompt "capability-audit-context" then
    true
  else if localRouteTextIncludes prompt "capability-audit-json-decode-failed" then
    true
  else
    localRouteTextIncludes prompt "capability-audit-json:repair-context"

localRouteHasCapabilityMailboxHandoff : Str -> Bool
localRouteHasCapabilityMailboxHandoff prompt =
  if localRouteTextIncludes prompt "capability-gap=" then
    true
  else
    localRouteTextIncludes prompt "capability-closure="

