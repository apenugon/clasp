affectedVerificationPlanCapabilityStatus : AgentAffectedVerificationPlanDecision -> CapabilityStatus
affectedVerificationPlanCapabilityStatus decision = {
  let launchPolicy = agentAffectedVerificationLaunchPolicy decision;
  CapabilityStatus {
    name = "affected_verification_plan",
    status =
      if launchPolicy.ready then
        "pass"
      else if launchPolicy.valid then
        "partial"
      else
        "fail",
    evidence =
      append
        (append
          decision.evidence
          [
            textConcat ["affected-verification-plan-status:", decision.status],
            textConcat ["affected-verification-plan-recommendation:", decision.recommendation],
            textConcat ["affected-verification-plan-command-count:", encode decision.commandCount],
            textConcat ["affected-verification-plan-static-command-count:", encode decision.staticCommandCount],
            textConcat ["affected-verification-plan-focused-command-count:", encode decision.focusedCommandCount],
            textConcat ["affected-verification-plan-heavy-command-count:", encode decision.heavyCommandCount],
            textConcat ["affected-verification-plan-safe-direct-command-count:", encode decision.safeDirectCommandCount],
            textConcat ["affected-verification-plan-managed-guard-command-count:", encode decision.managedGuardCommandCount],
            textConcat ["affected-verification-plan-compiler-state-free-command-count:", encode decision.compilerStateFreeCommandCount],
            textConcat ["affected-verification-plan-compiler-state-touching-command-count:", encode decision.compilerStateTouchingCommandCount],
            textConcat ["affected-verification-plan-can-run-without-compiler-state:", if decision.canRunWithoutCompilerState then "true" else "false"],
            textConcat ["affected-verification-plan-requires-managed:", if decision.requiresManagedGuard then "true" else "false"]
          ])
        launchPolicy.evidence,
    blocking_gaps = launchPolicy.blockingGaps,
    required_closure = launchPolicy.requiredClosure
  }
}

