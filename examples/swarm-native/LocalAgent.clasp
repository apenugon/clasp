repoScaleSourceEditTestsRun : [Str]
repoScaleSourceEditTestsRun =
  ["clasp-local-agent-repo-scale-source-patch"]

routeTestsRunWithEvidence : Str -> Bool -> Bool -> Bool -> Bool -> [Str]
routeTestsRunWithEvidence route hasDependencyEvidence hasBackendPolicyRepair hasSourceEditPlan hasRepoScaleSourceEditPlan = {
  let sourceTests =
    if hasSourceEditPlan then
      append (routeTestsRun route) sourceEditTestsRun
    else
      routeTestsRun route in
  let repoScaleTests =
    if hasRepoScaleSourceEditPlan then
      append sourceTests repoScaleSourceEditTestsRun
    else
      sourceTests in
  let dependencyTests =
    if hasDependencyEvidence then
      append repoScaleTests ["clasp-local-agent-dependency-evidence"]
    else
      repoScaleTests in
  if hasBackendPolicyRepair then
    append dependencyTests ["clasp-local-agent-backend-policy-repair"]
  else
    dependencyTests
}

routeBuilderErgonomics : Str -> [Str]
routeBuilderErgonomics route =
  if route == "generic" then
    [
      "ordinary Clasp program can act as a swarm agent backend",
      "local builder consumed the native swarm context pack",
      "local builder received the task file content in its prompt"
    ]
  else if route == "capability-audit" then
    [
      "ordinary Clasp program can act as a swarm agent backend",
      "local builder consumed the native swarm context pack",
      "local builder received the task file content in its prompt",
      "local builder routed task kind: capability-audit",
      "local builder produced a concrete capability-audit closure source artifact"
    ]
  else if route == "standalone-swarm" then
    [
      "ordinary Clasp program can act as a swarm agent backend",
      "local builder consumed the native swarm context pack",
      "local builder received the task file content in its prompt",
      "local builder routed task kind: standalone-swarm"
    ]
  else
    [
      "ordinary Clasp program can act as a swarm agent backend",
      "local builder consumed the native swarm context pack",
      "local builder received the task file content in its prompt",
      textConcat ["local builder routed task kind: ", route]
    ]

sourceEditBuilderErgonomics : [Str]
sourceEditBuilderErgonomics =
  [
    "local builder consumed a prompt source-edit plan",
    "local builder consumed a prompt source-patch plan",
    "local builder edited an existing ordinary-Clasp source file",
    "local builder edited multiple existing ordinary-Clasp source files",
    "local builder applied targeted replacements inside existing source files",
    "local builder applied targeted replacements across safe repo source surfaces",
    "local builder preflighted all planned source patches before writing files",
    "local builder postchecked patched source fingerprints before reporting success"
  ]

repoScaleSourceEditBuilderErgonomics : [Str]
repoScaleSourceEditBuilderErgonomics =
  ["local builder demonstrated repo-scale source patching across src, examples, scripts, docs, and runtime"]

routeBuilderErgonomicsWithEvidence : Str -> Bool -> Bool -> Bool -> Bool -> [Str]
routeBuilderErgonomicsWithEvidence route hasDependencyEvidence hasBackendPolicyRepair hasSourceEditPlan hasRepoScaleSourceEditPlan = {
  let sourceErgonomics =
    if hasSourceEditPlan then
      append (routeBuilderErgonomics route) sourceEditBuilderErgonomics
    else
      routeBuilderErgonomics route in
  let repoScaleErgonomics =
    if hasRepoScaleSourceEditPlan then
      append sourceErgonomics repoScaleSourceEditBuilderErgonomics
    else
      sourceErgonomics in
  let dependencyErgonomics =
    if hasDependencyEvidence then
      append repoScaleErgonomics ["local builder consumed dependency completion evidence"]
    else
      repoScaleErgonomics in
  if hasBackendPolicyRepair then
    append dependencyErgonomics ["local builder consumed backend policy repair context"]
  else
    dependencyErgonomics
}

repoScaleSourceEditCapabilityEvidence : [Str]
repoScaleSourceEditCapabilityEvidence =
  ["local Clasp agent demonstrated repo-scale source patching across src, examples, scripts, docs, and runtime"]

capabilityEvidenceForRoute : Str -> Bool -> Bool -> Bool -> Bool -> [Str]
capabilityEvidenceForRoute route hasDependencyEvidence hasBackendPolicyRepair hasSourceEditPlan hasRepoScaleSourceEditPlan = {
  let routedEvidence =
    if route == "generic" then
      [
        "builder and verifier reports were produced by examples/swarm-native/LocalAgent.clasp",
        "local Clasp agent consumed native builder and verifier context packs",
        "local Clasp agent received task file content without reading a separate task file"
      ]
    else
      [
        "builder and verifier reports were produced by examples/swarm-native/LocalAgent.clasp",
        "local Clasp agent consumed native builder and verifier context packs",
        "local Clasp agent received task file content without reading a separate task file",
        textConcat ["local Clasp agent completed routed task kind: ", route]
      ] in
  let closureEvidence =
    if route == "capability-audit" then
      append routedEvidence [
        "local Clasp agent produced capability-audit closure source artifact",
        "local Clasp agent produced capability-audit closure proof"
      ]
    else if route == "standalone-swarm" && hasSourceEditPlan then
      append routedEvidence [
        "local Clasp agent consumed a prompt source-edit plan",
        "local Clasp agent consumed a prompt source-patch plan",
        "local Clasp agent edited an existing ordinary-Clasp source file",
        "local Clasp agent edited multiple existing ordinary-Clasp source files",
        "local Clasp agent applied targeted replacements inside existing source files",
        "local Clasp agent applied targeted replacements across safe repo source surfaces",
        "local Clasp agent preflighted all planned source patches before writing files",
        "local Clasp agent postchecked patched source fingerprints before reporting success",
        "local Clasp verifier required direct source edit proof before passing"
      ]
    else
      routedEvidence in
  let repoScaleEvidence =
    if hasRepoScaleSourceEditPlan then
      append closureEvidence repoScaleSourceEditCapabilityEvidence
    else
      closureEvidence in
  let dependencyEvidence =
    if hasDependencyEvidence then
      append repoScaleEvidence ["local Clasp agent consumed dependency completion evidence"]
    else
      repoScaleEvidence in
  if hasBackendPolicyRepair then
    append dependencyEvidence ["local Clasp agent consumed backend policy repair context"]
  else
    dependencyEvidence
}

failingCapabilityEvidenceForRoute : Str -> Bool -> Bool -> [Str]
failingCapabilityEvidenceForRoute route hasDependencyEvidence hasBackendPolicyRepair = {
  let routedEvidence =
    if route == "generic" then
      ["local verifier observed first-attempt workspace state"]
    else
      [
        "local verifier observed first-attempt workspace state",
        textConcat ["local verifier classified routed task kind: ", route]
      ] in
  let dependencyEvidence =
    if hasDependencyEvidence then
      append routedEvidence ["local verifier observed dependency completion evidence"]
    else
      routedEvidence in
  if hasBackendPolicyRepair then
    append dependencyEvidence ["local verifier observed backend policy repair context"]
  else
    dependencyEvidence
}

routeFilesTouched : Str -> [Str]
routeFilesTouched route =
  if route == "generic" then
    ["workspace.txt", "notes/child-artifact.txt"]
  else if route == "capability-audit" then
    [
      "workspace.txt",
      "notes/child-artifact.txt",
      "notes/local-agent-route.txt",
      "notes/capability-audit-closure.txt",
      "notes/capability-audit-decision.json",
      "src/CapabilityAuditClosure.clasp"
    ]
  else if route == "standalone-swarm" then
    [
      "workspace.txt",
      "notes/child-artifact.txt",
      "notes/local-agent-route.txt"
    ]
  else
    ["workspace.txt", "notes/child-artifact.txt", "notes/local-agent-route.txt"]

routeFilesTouchedForPrompt : Str -> Str -> [Str]
routeFilesTouchedForPrompt route prompt =
  if route == "standalone-swarm" && promptHasSourceEditPlan prompt then
    append ["workspace.txt", "notes/child-artifact.txt", "notes/local-agent-route.txt", "notes/direct-source-edit.txt", standaloneSwarmDirectSourceEditManifestPath] (sourceEditPlanTargetsFromPrompt prompt)
  else
    routeFilesTouched route

capabilityAuditClosureSource : Str -> AgentCapabilityAuditClosureDecision -> Str
capabilityAuditClosureSource content decision =
  textJoin "\n" [
    "module CapabilityAuditClosure",
    "",
    "record ClosureSignal = { route : Str, status : Str, decisionKind : Str, evidence : Str }",
    "",
    "closureSignal : ClosureSignal",
    textConcat ["closureSignal = ClosureSignal { route = \"capability-audit\", status = \"closed\", decisionKind = \"", decision.kind, "\", evidence = \"local-agent-non-codex-source-artifact\" }"],
    "",
    "main : Str",
    textConcat ["main = \"", content, "\""],
    ""
  ]

capabilityAuditClosureProofText : Str -> AgentCapabilityAuditClosureDecision -> Str
capabilityAuditClosureProofText content decision =
  textJoin "\n" [
    "kind=clasp-local-agent-capability-audit-closure",
    "route=capability-audit",
    textConcat ["decisionKind=", decision.kind],
    textConcat ["decisionDetail=", decision.detail],
    textConcat ["status=", content],
    "sourceFile=src/CapabilityAuditClosure.clasp",
    "decisionFile=notes/capability-audit-decision.json",
    "verification=bash scripts/test-local-agent-capability-closure.sh",
    ""
  ]

writeCapabilityAuditClosureArtifacts : Str -> Str -> Str -> Str -> Str
writeCapabilityAuditClosureArtifacts workspaceRoot route content prompt =
  if route != "capability-audit" then
    ""
  else {
    let decision = capabilityAuditClosureDecisionForPrompt prompt;
    let srcRoot = pathJoin [workspaceRoot, "src"] in
    let srcError = ensureDirOrMessage srcRoot in
    if srcError != "" then
      srcError
    else {
      let sourcePath = pathJoin [srcRoot, "CapabilityAuditClosure.clasp"] in
      let sourceError = writeTextOrMessage sourcePath (capabilityAuditClosureSource content decision) in
      if sourceError != "" then
        sourceError
      else {
        let proofError = writeTextOrMessage (pathJoin [workspaceRoot, "notes", "capability-audit-closure.txt"]) (capabilityAuditClosureProofText content decision) in
        if proofError != "" then
          proofError
        else
          writeTextOrMessage (pathJoin [workspaceRoot, "notes", "capability-audit-decision.json"]) (encode decision)
      }
    }
  }

capabilityAuditDecisionJsonValid : Str -> Bool
capabilityAuditDecisionJsonValid raw =
  match tryDecode AgentCapabilityAuditClosureDecision raw {
    Ok decision ->
      if decision.kind == "" then
        false
      else if decision.taskPrompt == "" then
        false
      else
        length decision.coordinationFocus > 0,
    Err message -> false
  }

capabilityAuditClosureArtifactsPresent : Str -> Str -> Bool
capabilityAuditClosureArtifactsPresent workspaceRoot route =
  if route != "capability-audit" then
    true
  else {
    let source = readTextOr (pathJoin [workspaceRoot, "src", "CapabilityAuditClosure.clasp"]) "" in
    let proof = readTextOr (pathJoin [workspaceRoot, "notes", "capability-audit-closure.txt"]) "" in
    let decisionJson = readTextOr (pathJoin [workspaceRoot, "notes", "capability-audit-decision.json"]) "" in
    if textIncludes source "local-agent-non-codex-source-artifact" then
      if textIncludes source "decisionKind" then
        if textIncludes proof "decisionKind=" then
          if textIncludes proof "decisionFile=notes/capability-audit-decision.json" then
            capabilityAuditDecisionJsonValid decisionJson
          else
            false
        else
          false
      else
        false
    else
      false
  }

localVerifierWorkspaceFindingsForRoute : Str -> [Str]
localVerifierWorkspaceFindingsForRoute route =
  if route == "generic" then
    ["workspace.txt still has first-attempt content"]
  else
    [textConcat ["workspace.txt still has first-attempt content for ", route]]

localVerifierFindingsFor : Str -> Str -> Str -> Str -> [Str]
localVerifierFindingsFor workspaceRoot route prompt content =
  if content != textConcat [routeFixedContent route, "\n"] then
    localVerifierWorkspaceFindingsForRoute route
  else if capabilityAuditClosureArtifactsPresent workspaceRoot route == false then
    [textConcat ["capability-audit closure artifacts missing or invalid for ", route]]
  else if standaloneSwarmDirectSourceEditPresent workspaceRoot route prompt == false then
    append
      (append
        [
          "standalone-swarm direct source edit proof missing or invalid",
          "Check notes/direct-source-edit.txt and notes/direct-source-edit-manifest.json"
        ]
        (standaloneSwarmDirectSourceEditIssueTexts workspaceRoot route prompt))
      (standaloneSwarmDirectSourceEditRepairHints workspaceRoot route prompt)
  else
    [textConcat ["local verifier failed unknown condition for ", route]]

runBuilder : Str -> Str -> Str -> Str -> Str
runBuilder reportPath workspaceRoot reportRoot prompt = {
  let workspaceTextPath = pathJoin [workspaceRoot, "workspace.txt"] in
  let workspaceArtifactPath = pathJoin [workspaceRoot, "notes", "child-artifact.txt"] in
  let routeArtifactPath = pathJoin [workspaceRoot, "notes", "local-agent-route.txt"] in
  let route = taskRouteForPrompt prompt in
  let hasDependencyEvidence = promptHasDependencyCompletionEvidence prompt in
  let hasBackendPolicyRepair = promptHasAgentBackendPolicyRepair prompt in
  if promptHasBuilderContextPack prompt == false then
    "local-agent-error:missing builder context pack"
  else if promptHasTaskFileContent prompt == false then
    "local-agent-error:missing task file content"
  else {
    let rootError = ensureDirOrMessage workspaceRoot in
    if rootError != "" then
      rootError
    else {
      let notesError = ensureDirOrMessage (pathJoin [workspaceRoot, "notes"]) in
      if notesError != "" then
        notesError
      else {
        let reportError = ensureDirOrMessage reportRoot in
        if reportError != "" then
          reportError
        else {
          let content =
            if textIncludes prompt "Verifier feedback from the previous attempt:" then
              if textIncludes prompt "force-close-category" then
                routeFixedContent route
              else
                routeFirstAttemptContent route
            else
              routeFirstAttemptContent route in
          let workspaceError = writeTextOrMessage workspaceTextPath (textConcat [content, "\n"]) in
          if workspaceError != "" then
            workspaceError
          else {
            let artifactError = writeTextOrMessage workspaceArtifactPath (textConcat [content, "\n"]) in
            if artifactError != "" then
              artifactError
            else {
              let routeError =
                if route == "generic" then
                  ""
                else
                  writeTextOrMessage routeArtifactPath (textConcat [route, "\n"]) in
              if routeError != "" then
                routeError
              else {
                let closureError = writeCapabilityAuditClosureArtifacts workspaceRoot route content prompt in
                if closureError != "" then
                  closureError
                else {
                  let sourceEditError = writeStandaloneSwarmDirectSourceEdit workspaceRoot route content prompt in
                  if sourceEditError != "" then
                    sourceEditError
                  else
                    writeBuilderReportForRoute reportPath workspaceRoot content route hasDependencyEvidence hasBackendPolicyRepair prompt
                }
              }
            }
          }
        }
      }
    }
  }
}

runVerifier : Str -> Str -> Str -> Str -> Str
runVerifier reportPath workspaceRoot reportRoot prompt = {
  let workspaceTextPath = pathJoin [workspaceRoot, "workspace.txt"] in
  let builderPolicyPath = pathJoin [reportRoot, "builder-policy.md"] in
  let route = taskRouteForPrompt prompt in
  let hasDependencyEvidence = promptHasDependencyCompletionEvidence prompt in
  let hasBackendPolicyRepair = promptHasAgentBackendPolicyRepair prompt in
  let hasSourceEditPlan = promptHasSourceEditPlan prompt in
  let hasRepoScaleSourceEditPlan = promptHasRepoScaleSourceEditPlan prompt in
  let affectedPlanStatuses = affectedVerificationPlanCapabilityStatuses prompt in
  let focusedPlanStatuses = focusedVerificationPlanCapabilityStatuses prompt in
  let autonomousGateStatuses = autonomousLaunchGateCapabilityStatuses prompt in
  if promptHasVerifierContextPack prompt == false then
    "local-agent-error:missing verifier context pack"
  else if promptHasTaskFileContent prompt == false then
    "local-agent-error:missing task file content"
  else {
    let reportError = ensureDirOrMessage reportRoot in
    if reportError != "" then
      reportError
    else {
      let content = readTextOr workspaceTextPath "" in
      if content == textConcat [routeFixedContent route, "\n"] && capabilityAuditClosureArtifactsPresent workspaceRoot route && standaloneSwarmDirectSourceEditPresent workspaceRoot route prompt then
        {
          let gate = localVerifierGateFor route true emptyTexts in
          writeVerifierReport
            reportPath
            (VerifierReport {
              verdict = "pass",
              summary =
                if route == "generic" then
                  "local Clasp verifier passed"
                else
                  textConcat ["local Clasp verifier passed ", route],
              workspace_fingerprint_manifest = standaloneSwarmWorkspaceFingerprintManifestForPrompt route prompt,
              workspace_fingerprint_manifest_fingerprint64_hex =
                standaloneSwarmWorkspaceFingerprintManifestFingerprint64Hex workspaceRoot route prompt,
              findings = emptyTexts,
              tests_run =
                append
                  (append
                    (append
                      (append
                        (routeTestsRunWithEvidence route hasDependencyEvidence hasBackendPolicyRepair hasSourceEditPlan hasRepoScaleSourceEditPlan)
                        ["clasp-local-agent-verifier-gate"])
                      (affectedVerificationPlanTestsRun prompt))
                    (focusedVerificationPlanTestsRun prompt))
                  (autonomousLaunchGateTestsRun prompt),
              follow_up = emptyTexts,
              capability_statuses =
                append
                  (append
                    (append
                      (append
                        [
                          passingCapability route hasDependencyEvidence hasBackendPolicyRepair hasSourceEditPlan hasRepoScaleSourceEditPlan,
                          localVerifierGateCapability gate
                        ]
                        (capabilityAuditClosureDecisionCapabilityStatuses route prompt))
                      affectedPlanStatuses)
                    focusedPlanStatuses)
                  autonomousGateStatuses
            })
        }
      else {
        let policyError = writeTextOrMessage builderPolicyPath "force-close-category\n" in
        if policyError != "" then
          policyError
        else {
          let findings = localVerifierFindingsFor workspaceRoot route prompt content in
          let gate = localVerifierGateFor route false findings in
          writeVerifierReport
            reportPath
            (VerifierReport {
              verdict = "fail",
              summary =
                if route == "generic" then
                  "local Clasp verifier requested feedback retry"
                else
                  textConcat ["local Clasp verifier requested feedback retry for ", route],
              workspace_fingerprint_manifest = standaloneSwarmWorkspaceFingerprintManifestForPrompt route prompt,
              workspace_fingerprint_manifest_fingerprint64_hex =
                standaloneSwarmWorkspaceFingerprintManifestFingerprint64Hex workspaceRoot route prompt,
              findings = findings,
              tests_run =
                append
                  (append
                    (append
                      (append
                        (routeTestsRunWithEvidence route hasDependencyEvidence hasBackendPolicyRepair hasSourceEditPlan hasRepoScaleSourceEditPlan)
                        ["clasp-local-agent-verifier-gate"])
                      (affectedVerificationPlanTestsRun prompt))
                    (focusedVerificationPlanTestsRun prompt))
                  (autonomousLaunchGateTestsRun prompt),
              follow_up = ["Close the clasp_native_agent_backend category by consuming verifier feedback."],
              capability_statuses =
                append
                  (append
                    (append
                      (append
                        [
                          failingCapability route hasDependencyEvidence hasBackendPolicyRepair,
                          localVerifierGateCapability gate
                        ]
                        (capabilityAuditClosureDecisionCapabilityStatuses route prompt))
                      affectedPlanStatuses)
                    focusedPlanStatuses)
                  autonomousGateStatuses
            })
        }
      }
    }
  }
}

main : Str
main = {
  let currentRole = argValue "--role" "builder" in
  let currentReportPath = argValue "--report" "local-agent-report.json" in
  let currentWorkspaceRoot = argValue "--workspace" "." in
  let currentReportRoot = pathDirname currentReportPath in
  let currentPrompt = localAgentPromptTextFromArgs "" in
  if currentRole == "builder" then
    runBuilder currentReportPath currentWorkspaceRoot currentReportRoot currentPrompt
  else if currentRole == "verifier" then
    runVerifier currentReportPath currentWorkspaceRoot currentReportRoot currentPrompt
  else
    textConcat ["unknown-role:", currentRole]
}
