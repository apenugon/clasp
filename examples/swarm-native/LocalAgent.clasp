          textConcat ["affected-verification-launch-policy-can-run-direct:", if launchPolicy.canRunDirect then "true" else "false"],
          textConcat ["affected-verification-launch-policy-can-run-without-compiler-state:", if launchPolicy.canRunWithoutCompilerState then "true" else "false"],
          textConcat ["affected-verification-launch-policy-requires-managed:", if launchPolicy.requiresManagedGuard then "true" else "false"]
        ],
    blocking_gaps = launchPolicy.blockingGaps,
    required_closure = launchPolicy.requiredClosure
  }

