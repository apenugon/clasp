module Main

import AgentErgonomics
import LocalRouting
import LocalSourceEdit

record BuilderFeedback = {
  summary : Str,
  ergonomics : [Str],
  follow_ups : [Str],
  warnings : [Str]
}

record BuilderReport = {
  summary : Str,
  workspace_fingerprint_manifest : Str,
  workspace_fingerprint_manifest_fingerprint64_hex : Str,
  files_touched : [Str],
  tests_run : [Str],
  residual_risks : [Str],
  feedback : BuilderFeedback
}

record CapabilityStatus = {
  name : Str,
  status : Str,
  evidence : [Str],
  blocking_gaps : [Str],
  required_closure : [Str]
}

record VerifierReport = {
  verdict : Str,
  summary : Str,
  workspace_fingerprint_manifest : Str,
  workspace_fingerprint_manifest_fingerprint64_hex : Str,
  findings : [Str],
  tests_run : [Str],
  follow_up : [Str],
  capability_statuses : [CapabilityStatus]
}

emptyTexts : [Str]
emptyTexts = []

emptyCapabilityStatuses : [CapabilityStatus]
emptyCapabilityStatuses = []

textIncludes : Str -> Str -> Bool
textIncludes value needle = length (textSplit value needle) > 1

argValue : Str -> Str -> Str
argValue flag fallback = {
  let mut previous = "";
  let mut found = false;
  let mut result = fallback;
  for arg in argv {
    if found then
      found
    else if previous == flag then {
      result = arg;
      found = true;
      found
    } else {
      previous = arg;
      found
    }
  };
  result
}

readTextOr : Str -> Str -> Str
readTextOr path fallback =
  match readFile path {
    Ok raw -> raw,
    Err message -> fallback
  }

localAgentPromptTextFromArgs : Str -> Str
localAgentPromptTextFromArgs unused = {
  let inlinePrompt = argValue "--prompt" "" in
  if inlinePrompt != "" then
    inlinePrompt
  else {
    let promptPath = argValue "--prompt-path" "" in
    if promptPath == "" then "" else readTextOr promptPath ""
  }
}

writeTextOrMessage : Str -> Str -> Str
writeTextOrMessage path value =
  match writeFile path value {
    Ok written -> "",
    Err message -> textConcat ["write-error:", path, ":", message]
  }

ensureDirOrMessage : Str -> Str
ensureDirOrMessage path =
  match mkdirAll path {
    Ok created -> "",
    Err message -> textConcat ["mkdir-error:", path, ":", message]
  }

standaloneSwarmWorkspaceFingerprintManifestForPrompt : Str -> Str -> Str
standaloneSwarmWorkspaceFingerprintManifestForPrompt route prompt =
  if route == "standalone-swarm" && promptHasSourceEditPlan prompt then
    standaloneSwarmDirectSourceEditManifestPath
  else
    ""

standaloneSwarmWorkspaceFingerprintManifestFingerprint64Hex : Str -> Str -> Str -> Str
standaloneSwarmWorkspaceFingerprintManifestFingerprint64Hex workspaceRoot route prompt = {
  let manifestPath = standaloneSwarmWorkspaceFingerprintManifestForPrompt route prompt in
  if manifestPath == "" then
    ""
  else
    textFingerprint64Hex (readTextOr (pathJoin [workspaceRoot, manifestPath]) "")
}

writeBuilderReportForRoute : Str -> Str -> Str -> Str -> Bool -> Bool -> Str -> Str
writeBuilderReportForRoute reportPath workspaceRoot content route hasDependencyEvidence hasBackendPolicyRepair prompt =
  {
    let hasSourceEditPlan = promptHasSourceEditPlan prompt in
    let hasRepoScaleSourceEditPlan = promptHasRepoScaleSourceEditPlan prompt in
    writeTextOrMessage
      reportPath
      (encode
        (BuilderReport {
          summary =
            if route == "generic" then
              textConcat ["local Clasp builder wrote ", content]
            else
              textConcat ["local Clasp builder wrote ", content, " for ", route],
          workspace_fingerprint_manifest = standaloneSwarmWorkspaceFingerprintManifestForPrompt route prompt,
          workspace_fingerprint_manifest_fingerprint64_hex =
            standaloneSwarmWorkspaceFingerprintManifestFingerprint64Hex workspaceRoot route prompt,
          files_touched = routeFilesTouchedForPrompt route prompt,
          tests_run = routeTestsRunWithEvidence route hasDependencyEvidence hasBackendPolicyRepair hasSourceEditPlan hasRepoScaleSourceEditPlan,
          residual_risks = emptyTexts,
          feedback =
            BuilderFeedback {
              summary = "local Clasp builder backend completed",
              ergonomics =
                append
                  (routeBuilderErgonomicsWithEvidence route hasDependencyEvidence hasBackendPolicyRepair hasSourceEditPlan hasRepoScaleSourceEditPlan)
                  (capabilityAuditClosureDecisionBuilderErgonomics route prompt),
              follow_ups = emptyTexts,
              warnings = emptyTexts
            }
        }))
  }

passingCapability : Str -> Bool -> Bool -> Bool -> Bool -> CapabilityStatus
passingCapability route hasDependencyEvidence hasBackendPolicyRepair hasSourceEditPlan hasRepoScaleSourceEditPlan =
  CapabilityStatus {
    name = "clasp_native_agent_backend",
    status = "pass",
    evidence =
      capabilityEvidenceForRoute route hasDependencyEvidence hasBackendPolicyRepair hasSourceEditPlan hasRepoScaleSourceEditPlan,
    blocking_gaps = emptyTexts,
    required_closure = emptyTexts
  }

failingCapability : Str -> Bool -> Bool -> CapabilityStatus
failingCapability route hasDependencyEvidence hasBackendPolicyRepair =
  CapabilityStatus {
    name = "clasp_native_agent_backend",
    status = "fail",
    evidence =
      failingCapabilityEvidenceForRoute route hasDependencyEvidence hasBackendPolicyRepair,
    blocking_gaps = ["builder has not consumed verifier feedback yet"],
    required_closure = ["Use the persisted verifier feedback to update workspace.txt on the next attempt."]
  }

localVerifierGateStep : Str -> Bool -> [Str] -> AgentCommandStepResult
localVerifierGateStep route ok issues =
  AgentCommandStepResult {
    label = "clasp-local-agent-verifier-gate",
    ok = ok,
    status = if ok then "ok" else "verifier-findings",
    processSummary =
      textConcat [
        if ok then "pass" else "fail",
        ":0:finished:",
        if ok then "no-error" else "verifier-findings"
      ],
    stdout = route,
    stderr = textJoin "\n" issues,
    issueTexts = issues,
    evidence =
      [
        "local verifier emitted typed gate evidence",
        textConcat ["local-verifier-gate-route:", route],
        textConcat ["local-verifier-gate-status:", if ok then "pass" else "fail"]
      ]
  }

localVerifierGatePlan : Str -> Bool -> [Str] -> AgentCommandPlanResult
localVerifierGatePlan route ok issues =
  agentCommandPlanResultFromResults
    1
    [localVerifierGateStep route ok issues]

localVerifierGateFor : Str -> Bool -> [Str] -> AgentVerifierGate
localVerifierGateFor route ok issues =
  agentVerifierGate
    (agentVerifierMemoryPolicySummary agentVerifierMemoryPolicyDefault)
    (localVerifierGatePlan route ok issues)

localVerifierGateCapability : AgentVerifierGate -> CapabilityStatus
localVerifierGateCapability gate =
  CapabilityStatus {
    name = "local_verifier_gate",
    status = if gate.ok then "pass" else "fail",
    evidence =
      append
        gate.evidence
        [
          textConcat ["local-verifier-gate-status:", gate.status],
          textConcat ["local-verifier-gate-recommendation:", gate.recommendation]
        ],
    blocking_gaps = if gate.ok then emptyTexts else gate.issueTexts,
    required_closure = if gate.ok then emptyTexts else [gate.recommendation]
  }

