standaloneSwarmTask : PlannedTask
standaloneSwarmTask =
  PlannedTask {
    taskId = agentPlannerTaskIdStandaloneSwarmReadiness,
    role = "swarm-runtime-worker",
    detail = "Close one bounded launch/readiness gap so a Clasp-native swarm can improve Clasp without Codex-specific control flow.",
    dependencies = emptyTexts,
    taskPrompt =
      textJoin
        "\n"
        [
          "Close one bounded standalone-swarm readiness gap. If the prompt carries Autonomous launch gate JSON, preserve autonomous-launch-mode=, autonomous-launch-ready=, autonomous-launch-gate-mode:, autonomous-launch-gate-recommendation:, blockingGaps, and requiredClosure. If the prompt carries retryRecordRecoveryTask=standalone-swarm-autonomous-launch-gate-repair, retryRecordRecoveryKind=autonomous-launch-gate, retryRecordLatest=phase=autonomous-launch-gate, manager-replan-blocker=autonomous-launch-gate, or autonomous-launch-gate-blocker, preserve those retry-record markers too, then repair the specific launch blocker before spawning agents. Prefer checkpoint, resource-admission, managed-supervisor, focused-verification-policy, or bounded-task fixes over broad source edits. For direct source-edit tasks, edit existing Clasp, script, doc, and runtime source files, apply targeted replacements from the source patch plan, record verifier-required direct-source-edit proof, avoid new compiler subcommands or Codex-specific control flow, and verify it through scripts/standalone-swarm-verify.sh --closure --json, local-agent direct-source-edit coverage, the readiness gate, or focused runtime tests. Do not run full verify-all, promotion, broad native-image rebuilds, or unmanaged compiler work from this task.",
          standaloneSwarmSourceEditPromptSection
        ],
    coordinationFocus = ["standalone-swarm", "autonomous-launch-gate", "ordinary-clasp-program", "agent-ergonomics", "managed-supervisor", "focused-verification-policy", "direct-source-edit", "multi-file-source-edit", "source-patch-plan", "multi-surface-source-patch", "repo-scale-source-patch"]
  }

standaloneSwarmSourceEditRepairKindForPrompt : Str -> Str
standaloneSwarmSourceEditRepairKindForPrompt prompt =
  if textIncludes prompt "standalone-source-edit-repair:apply-planned-patch-replacements" then
    "apply-planned-patch-replacements"
  else if textIncludes prompt "standalone-source-edit-repair:regenerate-direct-source-edit-manifest" then
    "regenerate-direct-source-edit-manifest"
  else if textIncludes prompt "standalone-source-edit-repair:rerun-target-postchecks-and-proof-lines" then
    "rerun-target-postchecks-and-proof-lines"
  else if textIncludes prompt "standalone-source-edit-repair:restore-patch-fingerprint-proof-lines" then
    "restore-patch-fingerprint-proof-lines"
  else if textIncludes prompt "standalone-source-edit-repair:restore-direct-source-edit-proof-metadata" then
    "restore-direct-source-edit-proof-metadata"
  else if textIncludes prompt "standalone-source-edit-repair:write-direct-source-edit-proof" then
    "write-direct-source-edit-proof"
  else if textIncludes prompt "standalone-source-edit-repair:restore-multi-target-source-edit-plan" then
    "restore-multi-target-source-edit-plan"
  else if textIncludes prompt "standalone-source-edit-repair:inspect-direct-source-edit-proof" then
    "inspect-direct-source-edit-proof"
  else
    ""

standaloneSwarmPromptHasSourceEditRepairHint : Str -> Bool
standaloneSwarmPromptHasSourceEditRepairHint prompt =
  standaloneSwarmSourceEditRepairKindForPrompt prompt != ""

standaloneSwarmSourceEditRepairRoleForKind : Str -> Str
standaloneSwarmSourceEditRepairRoleForKind repairKind =
  if repairKind == "apply-planned-patch-replacements" then
    "swarm-source-patch-repair-worker"
  else if repairKind == "regenerate-direct-source-edit-manifest" then
    "swarm-manifest-repair-worker"
  else if repairKind == "rerun-target-postchecks-and-proof-lines" then
    "swarm-postcheck-repair-worker"
  else if repairKind == "restore-patch-fingerprint-proof-lines" then
    "swarm-patch-proof-repair-worker"
  else if repairKind == "restore-direct-source-edit-proof-metadata" then
    "swarm-proof-metadata-repair-worker"
  else if repairKind == "write-direct-source-edit-proof" then
    "swarm-proof-repair-worker"
  else if repairKind == "restore-multi-target-source-edit-plan" then
    "swarm-source-plan-repair-worker"
  else
    "swarm-source-edit-repair-worker"

standaloneSwarmSourceEditRepairPromptForKind : Str -> Str
standaloneSwarmSourceEditRepairPromptForKind repairKind =
  if repairKind == "apply-planned-patch-replacements" then
    "Repair only the missing standalone-swarm planned patch replacements. Re-read the Source edit patches section, apply the targeted workspaceReplaceText replacements that are absent, preserve existing valid proof lines, then refresh notes/direct-source-edit.txt and notes/direct-source-edit-manifest.json. Do not redo unrelated source edits, promotion, full verification, or broad swarm work."
  else if repairKind == "regenerate-direct-source-edit-manifest" then
    "Repair only the standalone-swarm workspace fingerprint manifest. Regenerate notes/direct-source-edit-manifest.json from current candidate workspace bytes, keep workspaceFingerprintManifest=notes/direct-source-edit-manifest.json and workspaceFingerprintAlgorithm=textFingerprint64Hex in notes/direct-source-edit.txt, then rerun the focused standalone-swarm closure verifier if needed."
  else if repairKind == "rerun-target-postchecks-and-proof-lines" then
    "Repair only the standalone-swarm target postcheck evidence. Re-read each Source edit plan target, verify the edited bytes in the candidate workspace, restore targetStatus=postwrite-present proof lines and targetFingerprint64Hex entries, then refresh the manifest. Do not apply unrelated edits."
  else if repairKind == "restore-patch-fingerprint-proof-lines" then
    "Repair only the standalone-swarm patch fingerprint proof. Preserve the applied source edits, restore patchFindFingerprint and patchReplacementFingerprint proof lines for every Source edit patches entry, then rerun focused verifier coverage."
  else if repairKind == "restore-direct-source-edit-proof-metadata" then
    "Repair only the standalone-swarm direct-source-edit proof metadata. Restore sourceEditTargetCount, sourceEditPatchCount, workspaceFingerprintManifest, workspaceFingerprintAlgorithm, workspaceConfinedWrite, sourceEditPrimitive, and workspaceApi proof fields without changing unrelated files."
  else if repairKind == "write-direct-source-edit-proof" then
    "Repair only the missing standalone-swarm direct-source-edit proof file. Write notes/direct-source-edit.txt with fixed markers, target postchecks, patch fingerprints, manifest metadata, and local-agent direct-source-edit evidence for the already edited candidate workspace."
  else if repairKind == "restore-multi-target-source-edit-plan" then
    "Repair only the standalone-swarm multi-target source edit plan handoff. Restore the Source edit plan section with more than one safe repo source target and keep the Source edit patches section aligned with those targets before rerunning focused verifier coverage."
  else
    "Inspect and repair the standalone-swarm direct-source-edit proof handoff using the verifier source-edit issue categories. Keep the task bounded to proof, manifest, postcheck, or planned patch replacement repair."

standaloneSwarmSourceEditRepairTaskForPrompt : Str -> PlannedTask
standaloneSwarmSourceEditRepairTaskForPrompt prompt = {
  let repairKind = standaloneSwarmSourceEditRepairKindForPrompt prompt in
  PlannedTask {
    taskId = agentPlannerTaskIdStandaloneSwarmReadiness,
    role = standaloneSwarmSourceEditRepairRoleForKind repairKind,
    detail = textConcat ["Repair the standalone-swarm direct-source-edit handoff from local verifier feedback: ", repairKind],
    dependencies = emptyTexts,
    taskPrompt = standaloneSwarmSourceEditRepairPromptForKind repairKind,
    coordinationFocus = ["standalone-swarm", "source-edit-repair", repairKind, "direct-source-edit-proof", "bounded-verification"]
  }
}

standaloneSwarmClosureTaskFromDecision : StandaloneSwarmClosureDecision -> PlannedTask
standaloneSwarmClosureTaskFromDecision decision = {
  let repairKind = standaloneSwarmClosureRepairKindForDecision decision in
  PlannedTask {
    taskId = agentPlannerTaskIdStandaloneSwarmReadiness,
    role =
      if decision.closed then
        "swarm-closure-recorder"
      else if repairKind == "repair-workspace-fingerprint-manifest" then
        "swarm-manifest-repair-worker"
      else if repairKind == "repair-direct-source-edit-proof" then
        "swarm-proof-repair-worker"
      else if repairKind == "repair-builder-verifier-reports" then
        "swarm-report-repair-worker"
      else if repairKind == "repair-local-verifier-gate" then
        "swarm-verifier-gate-repair-worker"
      else
        "swarm-closure-repair-worker",
    detail =
      if decision.closed then
        "Record the accepted standalone-swarm closure report and move broader planning to the remaining capability-audit or iteration-speed gaps."
      else
        textConcat ["Repair the standalone-swarm closure report handoff before redoing source edits (", repairKind, "): ", textJoin "; " decision.issueTexts],
    dependencies = emptyTexts,
    taskPrompt = standaloneSwarmClosureRepairPromptForDecision decision,
    coordinationFocus = ["standalone-swarm", "closure-report", repairKind, "typed-verifier-gate", "bounded-verification"]
  }
}

standaloneSwarmTaskForPrompt : Str -> PlannedTask
standaloneSwarmTaskForPrompt prompt =
  if standaloneSwarmHasClosureReportJson prompt then
    standaloneSwarmClosureTaskFromDecision (standaloneSwarmClosureDecisionFromPromptOrRaw prompt)
  else if standaloneSwarmPromptHasSourceEditRepairHint prompt then
    standaloneSwarmSourceEditRepairTaskForPrompt prompt
  else
    standaloneSwarmTask

standaloneSwarmTaskForClosureReportJson : Str -> PlannedTask
standaloneSwarmTaskForClosureReportJson raw =
  standaloneSwarmClosureTaskFromDecision (standaloneSwarmClosureDecisionFromJson raw)

standaloneSwarmTaskForClosureReportPath : Str -> PlannedTask
standaloneSwarmTaskForClosureReportPath path =
  standaloneSwarmClosureTaskFromDecision (standaloneSwarmClosureDecisionFromPath path)

plannedTaskWithDependencies : PlannedTask -> [Str] -> PlannedTask
plannedTaskWithDependencies task dependencies =
  PlannedTask {
    taskId = task.taskId,
    role = task.role,
    detail = task.detail,
    dependencies = dependencies,
    taskPrompt = task.taskPrompt,
    coordinationFocus = task.coordinationFocus
  }

standaloneSwarmTaskAfter : [Str] -> PlannedTask
standaloneSwarmTaskAfter dependencies =
  plannedTaskWithDependencies standaloneSwarmTask dependencies

promptSelectsProviderNeutral : Str -> Bool
promptSelectsProviderNeutral prompt =
  localRouteSelectsProviderNeutral prompt

promptSelectsIterationSpeed : Str -> Bool
promptSelectsIterationSpeed prompt = localRouteSelectsIterationSpeed prompt

promptSelectsResourcePressure : Str -> Bool
promptSelectsResourcePressure prompt = localRouteSelectsResourcePressure prompt

promptSelectsAffectedVerification : Str -> Bool
promptSelectsAffectedVerification prompt = localRouteSelectsAffectedVerification prompt

promptSelectsCapabilityAudit : Str -> Bool
promptSelectsCapabilityAudit prompt = localRouteSelectsCapabilityAudit prompt

promptSelectsStandaloneSwarm : Str -> Bool
promptSelectsStandaloneSwarm prompt = localRouteSelectsStandaloneSwarm prompt

promptSelectsSemanticContext : Str -> Bool
promptSelectsSemanticContext prompt = localRouteSelectsSemanticContext prompt

plannerTaskForPrompt : Str -> PlannedTask
plannerTaskForPrompt prompt =
  if promptSelectsProviderNeutral prompt then
    providerNeutralTask
  else if promptSelectsResourcePressure prompt then
    resourcePressureTaskForPrompt prompt
  else if promptSelectsAffectedVerification prompt then
    affectedVerificationLaunchTask
  else if promptSelectsCapabilityAudit prompt then
    if agentHasManagedSwarmProofJson prompt then
      managedSwarmProofTaskForPrompt prompt
    else
      capabilityAuditTaskForPrompt prompt
  else if promptSelectsIterationSpeed prompt then
    iterationSpeedTask
  else if promptSelectsStandaloneSwarm prompt then
    standaloneSwarmTaskForPrompt prompt
  else if promptSelectsSemanticContext prompt then
    semanticContextTask
  else
    standaloneSwarmTaskForPrompt prompt

plannerTaskBudgetContractLine : Int -> Str
plannerTaskBudgetContractLine budget =
  agentPlannerTaskBudgetContractLine budget

promptHasExactTaskBudget : Str -> Int -> Bool
promptHasExactTaskBudget prompt budget =
  agentPromptHasExactTaskBudget prompt budget

promptHasTaskBudgetContract : Str -> Bool
promptHasTaskBudgetContract prompt =
  agentPromptHasTaskBudgetContract prompt

promptHasPlannerBackendPolicyRepair : Str -> Bool
promptHasPlannerBackendPolicyRepair prompt =
  agentPromptHasPlannerBackendPolicyRepair prompt

plannerTaskBudgetForPrompt : Str -> Int
plannerTaskBudgetForPrompt prompt =
  agentPromptTaskBudgetOrDefault prompt 3

plannerTasksForPrompt : Str -> [PlannedTask]
plannerTasksForPrompt prompt = {
  let budget = plannerTaskBudgetForPrompt prompt in
  if promptSelectsProviderNeutral prompt then
    if budget == 1 then
      [providerNeutralTask]
    else
      [providerNeutralTask, standaloneSwarmTaskAfter [agentPlannerTaskIdProviderNeutral]]
  else if promptSelectsResourcePressure prompt then
    [resourcePressureTaskForPrompt prompt]
  else if promptSelectsAffectedVerification prompt then
    [affectedVerificationLaunchTask]
  else if promptSelectsCapabilityAudit prompt then
    {
      let auditTask = if agentHasManagedSwarmProofJson prompt then managedSwarmProofTaskForPrompt prompt else capabilityAuditTaskForPrompt prompt in
      if auditTask.taskId == agentPlannerTaskIdIterationSpeed then
        if budget == 1 then
          [auditTask]
        else if budget == 2 then
          [auditTask, standaloneSwarmTaskAfter [agentPlannerTaskIdIterationSpeed]]
        else
          [auditTask, semanticContextTask, standaloneSwarmTaskAfter [agentPlannerTaskIdIterationSpeed, agentPlannerTaskIdSemanticContext]]
      else
        if budget == 1 then
          [auditTask]
        else if budget == 2 then
          [auditTask, standaloneSwarmTaskAfter [agentPlannerTaskIdCapabilityAuditClosure]]
        else
          [auditTask, iterationSpeedTask, standaloneSwarmTaskAfter [agentPlannerTaskIdCapabilityAuditClosure, agentPlannerTaskIdIterationSpeed]]
    }
  else if promptSelectsIterationSpeed prompt then
    if budget == 1 then
      [iterationSpeedTask]
    else if budget == 2 then
      [iterationSpeedTask, semanticContextTask]
    else
      [iterationSpeedTask, semanticContextTask, standaloneSwarmTaskAfter [agentPlannerTaskIdIterationSpeed, agentPlannerTaskIdSemanticContext]]
  else if promptSelectsStandaloneSwarm prompt then
    if standaloneSwarmHasClosureReportJson prompt then
      [standaloneSwarmTaskForPrompt prompt]
    else if standaloneSwarmPromptHasSourceEditRepairHint prompt then
      [standaloneSwarmTaskForPrompt prompt]
    else if budget == 1 then
      [standaloneSwarmTask]
    else if budget == 2 then
      [semanticContextTask, standaloneSwarmTaskAfter [agentPlannerTaskIdSemanticContext]]
    else
      [iterationSpeedTask, semanticContextTask, standaloneSwarmTaskAfter [agentPlannerTaskIdIterationSpeed, agentPlannerTaskIdSemanticContext]]
  else if promptSelectsSemanticContext prompt then
    if budget == 1 then
      [semanticContextTask]
    else if budget == 2 then
      [semanticContextTask, standaloneSwarmTaskAfter [agentPlannerTaskIdSemanticContext]]
    else
      [semanticContextTask, iterationSpeedTask, standaloneSwarmTaskAfter [agentPlannerTaskIdSemanticContext, agentPlannerTaskIdIterationSpeed]]
  else if budget == 1 then
    [standaloneSwarmTask]
  else if budget == 2 then
    [semanticContextTask, standaloneSwarmTaskAfter [agentPlannerTaskIdSemanticContext]]
  else
    [iterationSpeedTask, semanticContextTask, standaloneSwarmTaskAfter [agentPlannerTaskIdIterationSpeed, agentPlannerTaskIdSemanticContext]]
}

plannerObjectiveSummaryForTask : PlannedTask -> Str
plannerObjectiveSummaryForTask task =
  if task.taskId == agentPlannerTaskIdProviderNeutral then
    "Prove the manager can plan with a Clasp-native non-Codex backend."
  else if task.taskId == agentPlannerTaskIdMemoryResourcePressure then
    "Plan a bounded memory-pressure recovery step before launching more swarm work."
  else if task.taskId == agentPlannerTaskIdDiskResourcePressure then
    "Plan a bounded disk-pressure recovery step before launching more swarm work."
  else if task.taskId == agentPlannerTaskIdAffectedVerifierLaunch then
    "Plan a bounded affected-verifier launch preflight before spawning verifier work."
  else if task.taskId == agentPlannerTaskIdCapabilityAuditClosure then
    "Plan a bounded closure step from the swarm capability audit."
  else if task.taskId == agentPlannerTaskIdIterationSpeed then
    "Plan a focused iteration-speed improvement for Clasp self-improvement."
  else if task.taskId == agentPlannerTaskIdSemanticContext then
    "Plan a semantic-context routing improvement for standalone Clasp agents."
  else
    "Plan a bounded standalone-swarm readiness improvement."

plannerStrategyForTask : PlannedTask -> Str
plannerStrategyForTask task =
  if task.taskId == agentPlannerTaskIdProviderNeutral then
    "Use the native planner context pack plus one child loop task while preserving provider-neutral child agent command configuration."
  else if task.taskId == agentPlannerTaskIdMemoryResourcePressure then
    "Route the prompt to one memory guard worker that reduces concurrency or exact managed-job pressure before any expensive verification or rebuild."
  else if task.taskId == agentPlannerTaskIdDiskResourcePressure then
    "Route the prompt to one cleanup worker that uses the Clasp-native generated-state cleanup plan before any expensive verification or rebuild."
  else if task.taskId == agentPlannerTaskIdAffectedVerifierLaunch then
    "Route the prompt to one verifier-launch worker that consumes affected-verifier launch policy before running direct cache-touching or managed verifier work."
  else if task.taskId == agentPlannerTaskIdCapabilityAuditClosure then
    "Route the prompt to one audit-closure worker that turns machine-readable readiness gaps into a focused, memory-guarded implementation step."
  else if task.taskId == agentPlannerTaskIdIterationSpeed then
    "Route the prompt to one compiler-speed worker that uses focused verification instead of broad native-image rebuilds."
  else if task.taskId == agentPlannerTaskIdSemanticContext then
    "Route the prompt to one context-pack worker that improves typed semantic-index evidence for local agents."
  else
    "Route the prompt to one ordinary-Clasp swarm-runtime worker and keep the change independent of Codex-specific control flow."

localPlannerDefaultRoutePlanForPrompt : Str -> LocalPlannerRoutePlan
localPlannerDefaultRoutePlanForPrompt prompt = {
  let task = plannerTaskForPrompt prompt in
  let tasks = plannerTasksForPrompt prompt in
  LocalPlannerRoutePlan {
    route = localPlannerRouteKeyForPrompt prompt,
    objectiveSummary = plannerObjectiveSummaryForTask task,
    strategy = plannerStrategyForTask task,
    tasks = tasks,
    testsRun = ["clasp-local-planner-template", "clasp-local-planner-context-pack", "clasp-local-planner-heuristic-routing"],
    residualRisks = emptyTexts
  }
}

localPlannerRouteKeyForPrompt : Str -> Str
localPlannerRouteKeyForPrompt prompt =
  localRoutePlannerRouteKeyForPrompt prompt

readLocalPlannerRoutePlans : Str -> [LocalPlannerRoutePlan]
readLocalPlannerRoutePlans raw =
  if raw == "" then
    emptyLocalPlannerRoutePlans
  else
    match tryDecode [LocalPlannerRoutePlan] raw {
      Ok plans -> plans,
      Err message -> emptyLocalPlannerRoutePlans
    }

localPlannerCatalogReadIssue : Str -> Str -> Str -> Str
localPlannerCatalogReadIssue source kind message =
  textConcat ["planner-catalog-error:", source, ":", kind, ":", message]

localPlannerCatalogTaskIdentity : LocalPlannerRoutePlan -> PlannedTask -> Str
localPlannerCatalogTaskIdentity plan task =
  if textMissing task.taskId then
    if textMissing plan.route then
      "<missing-task-id>"
    else
      textConcat [plan.route, ":<missing-task-id>"]
  else
    task.taskId

localPlannerCatalogTaskIssues : Str -> LocalPlannerRoutePlan -> PlannedTask -> [Str]
localPlannerCatalogTaskIssues source plan task = {
  let taskName = localPlannerCatalogTaskIdentity plan task in
  let mut issues = emptyTexts;
  if textMissing task.taskId then
    issues = append issues [localPlannerCatalogReadIssue source "task" (textConcat [taskName, ":missing taskId"])]
  else if task.taskId == agentPlannerReservedTaskId then
    issues = append issues [localPlannerCatalogReadIssue source "task" (textConcat [taskName, ":reserved taskId"])]
  else
    issues = issues;
  if textMissing task.role then
    issues = append issues [localPlannerCatalogReadIssue source "task" (textConcat [taskName, ":missing role"])]
  else
    issues = issues;
  if textMissing task.detail then
    issues = append issues [localPlannerCatalogReadIssue source "task" (textConcat [taskName, ":missing detail"])]
  else
    issues = issues;
  if textMissing task.taskPrompt then
    issues = append issues [localPlannerCatalogReadIssue source "task" (textConcat [taskName, ":missing taskPrompt"])]
  else
    issues = issues;
  issues
}

localPlannerCatalogRouteIssues : Str -> LocalPlannerRoutePlan -> [Str]
localPlannerCatalogRouteIssues source plan =
  if textMissing plan.route then
    [localPlannerCatalogReadIssue source "route" "missing route"]
  else if localRoutePlannerRouteKeyKnown plan.route then
    emptyTexts
  else
    [localPlannerCatalogReadIssue source "route" (textConcat ["unknown route:", plan.route])]

localPlannerCatalogTaskValid : Str -> LocalPlannerRoutePlan -> PlannedTask -> Bool
localPlannerCatalogTaskValid source plan task =
  length (localPlannerCatalogTaskIssues source plan task) == 0

localPlannerTextListHas : Str -> [Str] -> Bool
localPlannerTextListHas wanted values = {
  let mut found = false;
  for value in values {
    if found then
      found
    else if value == wanted then {
      found = true;
      found
    } else
      found
  };
  found
}

localPlannerCatalogBaseValidTaskIds : Str -> LocalPlannerRoutePlan -> [Str]
localPlannerCatalogBaseValidTaskIds source plan = {
  let mut taskIds = emptyTexts;
  let mut seenTaskIds = emptyTexts;
  for task in plan.tasks {
    if textMissing task.taskId then
      taskIds
    else if localPlannerCatalogTaskValid source plan task then
      if localPlannerTextListHas task.taskId seenTaskIds then
        taskIds
      else {
        taskIds = append taskIds [task.taskId];
        seenTaskIds = append seenTaskIds [task.taskId];
        taskIds
      }
    else {
      seenTaskIds = append seenTaskIds [task.taskId];
      taskIds
    }
  };
  taskIds
}

localPlannerCatalogTaskDependencyIssues : Str -> [Str] -> PlannedTask -> [Str]
localPlannerCatalogTaskDependencyIssues source knownTaskIds task = {
  let taskName =
    if textMissing task.taskId then
      "<missing-task-id>"
    else
      task.taskId in
  let mut issues = emptyTexts;
  for dependency in task.dependencies {
    if textMissing dependency then {
      issues = append issues [localPlannerCatalogReadIssue source "dependency" (textConcat [taskName, ":missing dependency"])];
      issues
    } else if dependency == task.taskId then {
      issues = append issues [localPlannerCatalogReadIssue source "dependency" (textConcat [taskName, ":self dependency"])];
      issues
    } else if localPlannerTextListHas dependency knownTaskIds then
      issues
    else {
      issues = append issues [localPlannerCatalogReadIssue source "dependency" (textConcat [taskName, ":unknown dependency:", dependency])];
      issues
    }
  };
  issues
}

localPlannerCatalogDuplicateTaskIssues : Str -> LocalPlannerRoutePlan -> [Str]
localPlannerCatalogDuplicateTaskIssues source plan = {
  let mut seenTaskIds = emptyTexts;
  let mut issues = emptyTexts;
  for task in plan.tasks {
    if textMissing task.taskId then
      issues
    else if localPlannerTextListHas task.taskId seenTaskIds then {
      issues = append issues [localPlannerCatalogReadIssue source "task" (textConcat [task.taskId, ":duplicate taskId"])];
      issues
    } else {
      seenTaskIds = append seenTaskIds [task.taskId];
      issues
    }
  };
  issues
}

localPlannerCatalogValidTasksBeforeCycles : Str -> LocalPlannerRoutePlan -> [PlannedTask]
localPlannerCatalogValidTasksBeforeCycles source plan = {
  let knownTaskIds = localPlannerCatalogBaseValidTaskIds source plan;
  let mut validTasks = emptyPlannedTasks;
  let mut seenTaskIds = emptyTexts;
  for task in plan.tasks {
    let taskShapeValid = localPlannerCatalogTaskValid source plan task;
    let taskDuplicate =
      if textMissing task.taskId then
        false
      else
        localPlannerTextListHas task.taskId seenTaskIds;
    let taskDependenciesValid = length (localPlannerCatalogTaskDependencyIssues source knownTaskIds task) == 0;
    if textMissing task.taskId then
      validTasks
    else if taskShapeValid then
      if taskDuplicate then {
        seenTaskIds = append seenTaskIds [task.taskId];
        validTasks
      } else if taskDependenciesValid then {
      validTasks = append validTasks [task];
      seenTaskIds = append seenTaskIds [task.taskId];
      validTasks
      } else {
        seenTaskIds = append seenTaskIds [task.taskId];
        validTasks
      }
    else {
      seenTaskIds = append seenTaskIds [task.taskId];
      validTasks
    }
  };
  validTasks
}

localPlannerCatalogDependenciesResolved : [Str] -> [Str] -> Bool
localPlannerCatalogDependenciesResolved resolvedTaskIds dependencies = {
  let mut resolved = true;
  for dependency in dependencies {
    if resolved then {
      resolved = localPlannerTextListHas dependency resolvedTaskIds;
      resolved
    } else
      resolved
  };
  resolved
}

localPlannerCatalogCyclePartitionStep : LocalPlannerCatalogCyclePartition -> PlannedTask -> LocalPlannerCatalogCyclePartition
localPlannerCatalogCyclePartitionStep state task =
  if localPlannerCatalogDependenciesResolved state.resolvedTaskIds task.dependencies then
    LocalPlannerCatalogCyclePartition {
      remaining = state.remaining,
      resolvedTaskIds = append state.resolvedTaskIds [task.taskId],
      progressed = true
    }
  else
    LocalPlannerCatalogCyclePartition {
      remaining = append state.remaining [task],
      resolvedTaskIds = state.resolvedTaskIds,
      progressed = state.progressed
    }

localPlannerCatalogCycleBlockedTaskIds : [PlannedTask] -> [Str] -> [Str]
localPlannerCatalogCycleBlockedTaskIds pendingTasks resolvedTaskIds =
  if length pendingTasks == 0 then
    emptyTexts
  else {
    let partition =
      fold
        localPlannerCatalogCyclePartitionStep
        (LocalPlannerCatalogCyclePartition {
          remaining = emptyPlannedTasks,
          resolvedTaskIds = resolvedTaskIds,
          progressed = false
        })
        pendingTasks in
    if partition.progressed then
      localPlannerCatalogCycleBlockedTaskIds partition.remaining partition.resolvedTaskIds
    else
      map plannedTaskIdOf partition.remaining
  }

plannedTaskIdOf : PlannedTask -> Str
plannedTaskIdOf task = task.taskId

localPlannerCatalogCycleBlockedTaskIdsForPlan : Str -> LocalPlannerRoutePlan -> [Str]
localPlannerCatalogCycleBlockedTaskIdsForPlan source plan =
  localPlannerCatalogCycleBlockedTaskIds (localPlannerCatalogValidTasksBeforeCycles source plan) emptyTexts

localPlannerCatalogCycleIssues : Str -> LocalPlannerRoutePlan -> [Str]
localPlannerCatalogCycleIssues source plan = {
  let mut issues = emptyTexts;
  for taskId in localPlannerCatalogCycleBlockedTaskIdsForPlan source plan {
    issues = append issues [localPlannerCatalogReadIssue source "dependency" (textConcat [taskId, ":cycle dependency"])];
    issues
  };
  issues
}

localPlannerCatalogPlanIssues : Str -> LocalPlannerRoutePlan -> [Str]
localPlannerCatalogPlanIssues source plan = {
  let knownTaskIds = localPlannerCatalogBaseValidTaskIds source plan in
  let mut issues = localPlannerCatalogRouteIssues source plan;
  for task in plan.tasks {
    issues = append issues (localPlannerCatalogTaskIssues source plan task);
    issues = append issues (localPlannerCatalogTaskDependencyIssues source knownTaskIds task);
    issues
  };
  issues = append issues (localPlannerCatalogDuplicateTaskIssues source plan);
  issues = append issues (localPlannerCatalogCycleIssues source plan);
  issues
}

localPlannerCatalogValidTasks : Str -> LocalPlannerRoutePlan -> [PlannedTask]
localPlannerCatalogValidTasks source plan = {
  let cycleBlockedTaskIds = localPlannerCatalogCycleBlockedTaskIdsForPlan source plan;
  let mut validTasks = emptyPlannedTasks;
  for task in localPlannerCatalogValidTasksBeforeCycles source plan {
    if localPlannerTextListHas task.taskId cycleBlockedTaskIds then
      validTasks
    else {
      validTasks = append validTasks [task];
      validTasks
    }
  };
  validTasks
}

localPlannerCatalogValidatedPlan : Str -> LocalPlannerRoutePlan -> LocalPlannerRoutePlan
localPlannerCatalogValidatedPlan source plan =
  LocalPlannerRoutePlan {
    route = plan.route,
    objectiveSummary = plan.objectiveSummary,
    strategy = plan.strategy,
    tasks = localPlannerCatalogValidTasks source plan,
    testsRun = plan.testsRun,
    residualRisks = plan.residualRisks
  }

localPlannerCatalogValidatedPlans : Str -> [LocalPlannerRoutePlan] -> [LocalPlannerRoutePlan]
localPlannerCatalogValidatedPlans source plans = {
  let mut validated = emptyLocalPlannerRoutePlans;
  for plan in plans {
    validated = append validated [localPlannerCatalogValidatedPlan source plan];
    validated
  };
  validated
}

localPlannerCatalogPlanIssuesAll : Str -> [LocalPlannerRoutePlan] -> [Str]
localPlannerCatalogPlanIssuesAll source plans = {
  let mut issues = emptyTexts;
  for plan in plans {
    issues = append issues (localPlannerCatalogPlanIssues source plan);
    issues
  };
  issues
}

readLocalPlannerRoutePlansResult : Str -> Str -> LocalPlannerCatalogReadResult
readLocalPlannerRoutePlansResult source raw =
  if raw == "" then
    emptyLocalPlannerCatalogReadResult
  else
    match tryDecode [LocalPlannerRoutePlan] raw {
      Ok plans ->
        LocalPlannerCatalogReadResult {
          plans = localPlannerCatalogValidatedPlans source plans,
          issues = localPlannerCatalogPlanIssuesAll source plans
        },
      Err message ->
        LocalPlannerCatalogReadResult {
          plans = emptyLocalPlannerRoutePlans,
          issues = [localPlannerCatalogReadIssue source "decode" message]
        }
    }

localPlannerRoutePlansFromEnv : [LocalPlannerRoutePlan]
localPlannerRoutePlansFromEnv =
  localPlannerRoutePlansFromEnvResult.plans

localPlannerRoutePlansFromEnvResult : LocalPlannerCatalogReadResult
localPlannerRoutePlansFromEnvResult =
  match envVar "CLASP_LOCAL_PLANNER_TASK_CATALOG_JSON" {
    Ok raw -> readLocalPlannerRoutePlansResult "env:CLASP_LOCAL_PLANNER_TASK_CATALOG_JSON" raw,
    Err message -> emptyLocalPlannerCatalogReadResult
  }

localPlannerTaskCatalogPathFromEnv : Str
localPlannerTaskCatalogPathFromEnv =
  match envVar "CLASP_LOCAL_PLANNER_TASK_CATALOG_PATH" {
    Ok raw -> raw,
    Err message -> ""
  }

readLocalPlannerRoutePlansFromPath : Str -> [LocalPlannerRoutePlan]
readLocalPlannerRoutePlansFromPath path = {
  let result = readLocalPlannerRoutePlansFromPathResult "path" path false in
  result.plans
}

readLocalPlannerRoutePlansFromPathResult : Str -> Str -> Bool -> LocalPlannerCatalogReadResult
readLocalPlannerRoutePlansFromPathResult source path reportReadFailure =
  if path == "" then
    emptyLocalPlannerCatalogReadResult
  else
    match readFile path {
      Ok raw -> readLocalPlannerRoutePlansResult source raw,
      Err message ->
        if reportReadFailure then
          LocalPlannerCatalogReadResult {
            plans = emptyLocalPlannerRoutePlans,
            issues = [localPlannerCatalogReadIssue source "read" (textConcat [path, ":", message])]
          }
        else
          emptyLocalPlannerCatalogReadResult
    }

localPlannerWorkspaceTaskCatalogPath : Str -> Str
localPlannerWorkspaceTaskCatalogPath workspaceRoot =
  if workspaceRoot == "" then
    ""
  else
    pathJoin [workspaceRoot, ".clasp-local-planner", "task-catalog.json"]

localPlannerRoutePlansForWorkspace : Str -> [LocalPlannerRoutePlan]
localPlannerRoutePlansForWorkspace workspaceRoot = {
  let result = localPlannerRoutePlansForWorkspaceResult workspaceRoot in
  result.plans
}

localPlannerCatalogReadResultAppend : LocalPlannerCatalogReadResult -> LocalPlannerCatalogReadResult -> LocalPlannerCatalogReadResult
localPlannerCatalogReadResultAppend left right =
  LocalPlannerCatalogReadResult {
    plans = append left.plans right.plans,
    issues = append left.issues right.issues
  }

localPlannerRoutePlansForWorkspaceResult : Str -> LocalPlannerCatalogReadResult
localPlannerRoutePlansForWorkspaceResult workspaceRoot =
  localPlannerCatalogReadResultAppend
    (localPlannerCatalogReadResultAppend
      localPlannerRoutePlansFromEnvResult
      (readLocalPlannerRoutePlansFromPathResult "env:CLASP_LOCAL_PLANNER_TASK_CATALOG_PATH" localPlannerTaskCatalogPathFromEnv true))
    (readLocalPlannerRoutePlansFromPathResult "workspace:.clasp-local-planner/task-catalog.json" (localPlannerWorkspaceTaskCatalogPath workspaceRoot) false)

localPlannerRoutePlanMatches : Str -> LocalPlannerRoutePlan -> Bool
localPlannerRoutePlanMatches route plan =
  if plan.route == route then
    true
  else
    plan.route == localRoutePlannerRouteKeyWildcard

localPlannerMergeRoutePlan : LocalPlannerRoutePlan -> LocalPlannerRoutePlan -> LocalPlannerRoutePlan
localPlannerMergeRoutePlan fallback plan =
  LocalPlannerRoutePlan {
    route =
      if plan.route == "" then
        fallback.route
      else
        plan.route,
    objectiveSummary =
      if plan.objectiveSummary == "" then
        fallback.objectiveSummary
      else
        plan.objectiveSummary,
    strategy =
      if plan.strategy == "" then
        fallback.strategy
      else
        plan.strategy,
    tasks =
      if length plan.tasks == 0 then
        fallback.tasks
      else
        plan.tasks,
    testsRun = append fallback.testsRun plan.testsRun,
    residualRisks = append fallback.residualRisks plan.residualRisks
  }

localPlannerCatalogPlanForRoute : [LocalPlannerRoutePlan] -> Str -> LocalPlannerRoutePlan -> LocalPlannerRoutePlan
localPlannerCatalogPlanForRoute plans route fallback = {
  let mut found = false;
  let mut selected = fallback;
  for plan in plans {
    if found then
      found
    else if localPlannerRoutePlanMatches route plan then {
      selected = localPlannerMergeRoutePlan fallback plan;
      found = true;
      found
    } else
      found
  };
  selected
}

localPlannerBoundedTasks : [PlannedTask] -> Int -> [PlannedTask]
localPlannerBoundedTasks tasks budget = {
  let mut selected = emptyPlannedTasks;
  for task in tasks {
    if length selected < budget then {
      selected = append selected [task];
      selected
    } else
      selected
  };
  selected
}

localPlannerRoutePlanForPromptWithCatalog : [LocalPlannerRoutePlan] -> Str -> LocalPlannerRoutePlan
localPlannerRoutePlanForPromptWithCatalog catalog prompt = {
  let fallback = localPlannerDefaultRoutePlanForPrompt prompt in
  let route = localPlannerRouteKeyForPrompt prompt in
  let configured = localPlannerCatalogPlanForRoute catalog route fallback in
  let boundedTasks = localPlannerBoundedTasks configured.tasks (plannerTaskBudgetForPrompt prompt) in
  if length boundedTasks == 0 then
    fallback
  else
    LocalPlannerRoutePlan {
      route = configured.route,
      objectiveSummary = configured.objectiveSummary,
      strategy = configured.strategy,
      tasks = boundedTasks,
      testsRun = configured.testsRun,
      residualRisks = configured.residualRisks
    }
}

localPlannerRoutePlanForPrompt : Str -> LocalPlannerRoutePlan
localPlannerRoutePlanForPrompt prompt =
  localPlannerRoutePlanForPromptWithCatalog localPlannerRoutePlansFromEnv prompt

localPlannerTestsRunWithPromptEvidence : [Str] -> Str -> [Str]
localPlannerTestsRunWithPromptEvidence testsRun prompt =
  if promptHasPlannerBackendPolicyRepair prompt then
    append testsRun ["clasp-local-planner-backend-policy-repair"]
  else
    testsRun

localPlannerTestsRunWithCatalogIssues : [Str] -> [Str] -> [Str]
localPlannerTestsRunWithCatalogIssues testsRun issues =
  if length issues > 0 then
    append testsRun ["clasp-local-planner-task-catalog-error"]
  else
    testsRun

plannerReportWithCatalogIssues : PlannerReport -> [Str] -> PlannerReport
plannerReportWithCatalogIssues report issues =
  if length issues > 0 then
    PlannerReport {
      objectiveSummary = report.objectiveSummary,
      strategy = report.strategy,
      tasks = report.tasks,
      testsRun = localPlannerTestsRunWithCatalogIssues report.testsRun issues,
      residualRisks = append report.residualRisks issues
    }
  else
    report

plannerReportForPromptWithCatalog : [LocalPlannerRoutePlan] -> Str -> PlannerReport
plannerReportForPromptWithCatalog catalog prompt = {
  let effectivePrompt = promptWithAffectedVerificationPathContext prompt in
  let plan = localPlannerRoutePlanForPromptWithCatalog catalog effectivePrompt in
  PlannerReport {
    objectiveSummary = plan.objectiveSummary,
    strategy = plan.strategy,
    tasks = plan.tasks,
    testsRun = localPlannerTestsRunWithPromptEvidence plan.testsRun effectivePrompt,
    residualRisks = plan.residualRisks
  }
}

plannerReportForPromptWithCatalogIssues : [LocalPlannerRoutePlan] -> [Str] -> Str -> PlannerReport
plannerReportForPromptWithCatalogIssues catalog issues prompt =
  plannerReportWithCatalogIssues (plannerReportForPromptWithCatalog catalog prompt) issues

plannerReportForPrompt : Str -> PlannerReport
plannerReportForPrompt prompt =
  plannerReportForPromptWithCatalog localPlannerRoutePlansFromEnv prompt

promptHasPlannerContextPack : Str -> Bool
promptHasPlannerContextPack prompt =
  agentPromptHasPlannerContextPack prompt

runPlanner : Str -> Str -> Str -> Str -> Str -> Str
runPlanner reportPath promptPath schemaPath workspaceRoot fallbackLogPath = {
  let prompt = readTextOr promptPath "" in
  if textIncludes prompt "planner subagent" then
    if promptHasPlannerContextPack prompt then {
      if promptHasTaskBudgetContract prompt then {
        let reportDirError = ensureDirOrMessage (pathDirname reportPath) in
        if reportDirError != "" then
          reportDirError
        else {
          let workspaceError = ensureDirOrMessage workspaceRoot in
          if workspaceError != "" then
            workspaceError
          else {
            let logError =
              logPlannerInvocation
                fallbackLogPath
                (PlannerInvocation {
                  backend = "clasp-local-planner",
                  role = "planner",
                  reportPath = reportPath,
                  promptPath = promptPath,
                  schemaPath = schemaPath,
                  workspaceRoot = workspaceRoot
                }) in
            if logError != "" then
              logError
            else {
              let catalog = localPlannerRoutePlansForWorkspaceResult workspaceRoot in
              writeTextOrMessage reportPath (encode (plannerReportForPromptWithCatalogIssues catalog.plans catalog.issues prompt))
            }
          }
        }
      } else
        "planner-error:missing task budget contract"
    }
    else
      "planner-error:missing native context pack"
  else
    "planner-error:missing planner prompt"
}

main : Str
main = {
  let currentRole = argValue "--role" "planner" in
  let currentReportPath = argValue "--report" "local-planner-report.json" in
  let currentPromptPath = argValue "--prompt-path" "" in
  let currentSchemaPath = argValue "--schema" "" in
  let currentWorkspaceRoot = argValue "--workspace" "." in
  let currentLogPath = argValue "--log" "" in
  if currentRole == "planner" then
    runPlanner currentReportPath currentPromptPath currentSchemaPath currentWorkspaceRoot currentLogPath
  else
    textConcat ["unknown-role:", currentRole]
}
