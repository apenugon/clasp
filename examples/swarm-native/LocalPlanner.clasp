record PlannedTask = {
  taskId : Str,
  role : Str,
  detail : Str,
  dependencies : [Str],
  taskPrompt : Str,
  coordinationFocus : [Str]
}

record PlannerReport = {
  objectiveSummary : Str,
  strategy : Str,
  tasks : [PlannedTask],
  testsRun : [Str],
  residualRisks : [Str]
}

record PlannerInvocation = {
  backend : Str,
  role : Str,
  reportPath : Str,
  promptPath : Str,
  schemaPath : Str,
  workspaceRoot : Str
}

record LocalPlannerRoutePlan = {
  route : Str,
  objectiveSummary : Str,
  strategy : Str,
  tasks : [PlannedTask],
  testsRun : [Str],
  residualRisks : [Str]
}

record LocalPlannerCatalogReadResult = {
  plans : [LocalPlannerRoutePlan],
  issues : [Str]
}

record LocalPlannerCatalogCyclePartition = {
  remaining : [PlannedTask],
  resolvedTaskIds : [Str],
  progressed : Bool
}

emptyTexts : [Str]
emptyTexts = []

emptyPlannedTasks : [PlannedTask]
emptyPlannedTasks = []

emptyLocalPlannerRoutePlans : [LocalPlannerRoutePlan]
emptyLocalPlannerRoutePlans = []

emptyLocalPlannerCatalogReadResult : LocalPlannerCatalogReadResult
emptyLocalPlannerCatalogReadResult =
  LocalPlannerCatalogReadResult {
    plans = emptyLocalPlannerRoutePlans,
    issues = emptyTexts
  }

textIncludes : Str -> Str -> Bool
textIncludes value needle = length (textSplit value needle) > 1

textMissing : Str -> Bool
textMissing value =
  value == ""

argValue : Str -> Str -> Str
argValue flag fallback = {
  let mut previous = "";
  let mut found = false;
  let mut result = fallback;
  for arg in argv {
    if found then
      found
    else if previous == flag then {
      result = arg;
      found = true;
      found
    } else {
      previous = arg;
      found
    }
  };
  result
}

readTextOr : Str -> Str -> Str
readTextOr path fallback =
  match readFile path {
    Ok raw -> raw,
    Err message -> fallback
  }

promptAffectedVerificationPlanPath : Str -> Str
promptAffectedVerificationPlanPath prompt =
  agentAffectedVerificationPlanPathFromPrompt prompt

promptAffectedVerificationLaunchPolicyPath : Str -> Str
promptAffectedVerificationLaunchPolicyPath prompt =
  agentAffectedVerificationLaunchPolicyPathFromPrompt prompt

promptAffectedVerificationPlanJsonBlockFromPath : Str -> Str
promptAffectedVerificationPlanJsonBlockFromPath path =
  agentAffectedVerificationPlanJsonBlockFromPath path

promptAffectedVerificationLaunchPolicyJsonBlockFromPath : Str -> Str
promptAffectedVerificationLaunchPolicyJsonBlockFromPath path =
  agentAffectedVerificationLaunchPolicyJsonBlockFromPath path

promptWithAffectedVerificationPathContext : Str -> Str
promptWithAffectedVerificationPathContext prompt =
  agentPromptWithAffectedVerificationPathContext prompt

writeTextOrMessage : Str -> Str -> Str
writeTextOrMessage path value =
  match writeFile path value {
    Ok written -> "",
    Err message -> textConcat ["write-error:", path, ":", message]
  }

appendTextOrMessage : Str -> Str -> Str
appendTextOrMessage path value =
  match appendFile path value {
    Ok written -> "",
    Err message -> textConcat ["append-error:", path, ":", message]
  }

ensureDirOrMessage : Str -> Str
ensureDirOrMessage path =
  match mkdirAll path {
    Ok created -> "",
    Err message -> textConcat ["mkdir-error:", path, ":", message]
  }

logPlannerInvocation : Str -> PlannerInvocation -> Str
logPlannerInvocation fallbackLogPath invocation =
  match envVar "CLASP_TEST_AGENT_LOG" {
    Ok raw ->
      if raw == "" then
        ""
      else
        appendTextOrMessage raw (textConcat [encode invocation, "\n"]),
    Err message ->
      if fallbackLogPath == "" then
        ""
      else
        appendTextOrMessage fallbackLogPath (textConcat [encode invocation, "\n"])
  }

