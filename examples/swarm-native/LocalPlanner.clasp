managedSwarmProofTaskFromDecision : AgentManagedSwarmProofDecision -> PlannedTask
managedSwarmProofTaskFromDecision decision =
  if decision.passed then
    iterationSpeedTask
  else
    PlannedTask {
      taskId = agentPlannerTaskIdCapabilityAuditClosure,
      role = "managed-swarm-proof-repair-worker",
      detail = textConcat ["Repair the managed swarm proof handoff before broad swarm work: ", textJoin "; " decision.issueTexts],
      dependencies = emptyTexts,
      taskPrompt = "Repair the managed swarm proof handoff. Provide a passing clasp-managed-swarm-proof JSON artifact from a GoalManager local planner/child-loop run with prompt-path template backend, no Codex fallback, dependency-ordered child tasks, propagated local child-agent commands, source-edit/source-patch plans, and dependency completion evidence. Do not launch an unbounded swarm or full verification from this task.",
      coordinationFocus = ["capability-audit", "managed-swarm-proof", "goal-manager", "non-codex-backend", "bounded-child-loop"]
    }

managedSwarmProofTaskForJson : Str -> PlannedTask
managedSwarmProofTaskForJson raw =
  managedSwarmProofTaskFromDecision (agentManagedSwarmProofDecisionFromJson raw)

