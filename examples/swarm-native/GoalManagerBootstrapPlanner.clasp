module GoalManagerBootstrapPlanner

import AgentBackend
import GoalManagerMailboxSummary
import GoalManagerPlannerMemory
import GoalManagerResourceHealth
import GoalManagerPreludeProject
import GoalManagerPrelude
import GoalManagerConfig
import Swarm

plannerPromptPathForWave : Int -> Str
plannerPromptPathForWave wave =
  pathJoin [stateRootPath, textConcat ["planner-", encode wave, ".prompt.txt"]]

plannerAgentBackend : AgentBackendSpec
plannerAgentBackend =
  goalManagerAgentBackend plannerAgentCommandTemplate resolvedWorkspaceRoot

plannerAgentBackendSummary : AgentBackendSummary
plannerAgentBackendSummary =
  agentBackendSummary plannerAgentBackend

plannerAgentBackendPolicySummary : AgentBackendPolicySummary
plannerAgentBackendPolicySummary =
  if plannerRequireStandaloneAgentBackend then
    agentBackendStandalonePolicySummary plannerAgentBackend
  else
    agentBackendPolicySummary "default" agentBackendDefaultPolicy plannerAgentBackend

plannerAgentBackendCapabilityProfile : AgentBackendCapabilityProfile
plannerAgentBackendCapabilityProfile =
  agentBackendCapabilityProfileForBackend plannerAgentCapabilityProfileName plannerAgentBackend

plannerAgentBackendCapabilitySummary : AgentBackendCapabilitySummary
plannerAgentBackendCapabilitySummary =
  agentBackendStandaloneCapabilitySummary plannerAgentBackendCapabilityProfile plannerAgentBackend

plannerAgentBackendValidationMessage : Str
plannerAgentBackendValidationMessage =
  if plannerRequireStandaloneAgentBackend then
    agentBackendPolicyValidationMessage agentBackendStandalonePolicy plannerAgentBackend
  else
    agentBackendValidationMessage plannerAgentBackend

plannerAgentBackendPolicyListText : [Str] -> Str
plannerAgentBackendPolicyListText values =
  if length values == 0 then
    "none"
  else
    textJoin " | " values

plannerAgentBackendSummaryText : Str
plannerAgentBackendSummaryText =
  textConcat [
    "Planner agent backend: kind=",
    plannerAgentBackendSummary.kind,
    " promptTransport=",
    plannerAgentBackendSummary.promptTransport,
    " valid=",
    if plannerAgentBackendSummary.valid then "true" else "false",
    " standaloneRequired=",
    if plannerRequireStandaloneAgentBackend then "true" else "false",
    " policyValid=",
    if plannerAgentBackendPolicySummary.valid then "true" else "false",
    " policyMessage=",
    plannerAgentBackendPolicySummary.validationMessage
  ]

plannerAgentBackendPolicyRepairText : Str
plannerAgentBackendPolicyRepairText =
  textJoin "\n" [
    "Planner agent backend policy repair:",
    textConcat [
      "policyBlockingGaps=",
      plannerAgentBackendPolicyListText plannerAgentBackendPolicySummary.blockingGaps
    ],
    textConcat [
      "policyMessages=",
      plannerAgentBackendPolicyListText plannerAgentBackendPolicySummary.validationMessages
    ],
    textConcat [
      "policyRequiredClosure=",
      plannerAgentBackendPolicyListText plannerAgentBackendPolicySummary.requiredClosure
    ],
    textConcat [
      "policyMissingPlaceholders=",
      plannerAgentBackendPolicyListText plannerAgentBackendPolicySummary.missingPlaceholders
    ],
    textConcat [
      "policyRecommendedTemplate=",
      plannerAgentBackendPolicyListText plannerAgentBackendPolicySummary.recommendedTemplate
    ]
  ]

plannerAgentBackendCapabilityText : Str
plannerAgentBackendCapabilityText =
  textJoin "\n" [
    "Planner agent backend capability repair:",
    textConcat [
      "capabilityProfile=",
      plannerAgentBackendCapabilitySummary.profileName,
      " backendKind=",
      plannerAgentBackendCapabilitySummary.backendKind,
      " promptTransport=",
      plannerAgentBackendCapabilitySummary.promptTransport,
      " standaloneReady=",
      if plannerAgentBackendCapabilitySummary.standaloneReady then "true" else "false",
      " roleCoverage=",
      plannerAgentBackendPolicyListText plannerAgentBackendCapabilitySummary.roleCoverage
    ],
    textConcat [
      "capabilitySupports=planner:",
      if plannerAgentBackendCapabilitySummary.supportsPlannerRole then "true" else "false",
      " builder:",
      if plannerAgentBackendCapabilitySummary.supportsBuilderRole then "true" else "false",
      " verifier:",
      if plannerAgentBackendCapabilitySummary.supportsVerifierRole then "true" else "false",
      " workspaceEdits:",
      if plannerAgentBackendCapabilitySummary.supportsWorkspaceEdits then "true" else "false",
      " childTaskPlanning:",
      if plannerAgentBackendCapabilitySummary.supportsChildTaskPlanning then "true" else "false",
      " structuredReports:",
      if plannerAgentBackendCapabilitySummary.supportsStructuredReports then "true" else "false",
      " externalModel:",
      if plannerAgentBackendCapabilitySummary.requiresExternalModel then "true" else "false"
    ],
    textConcat [
      "capabilityMessages=",
      plannerAgentBackendPolicyListText plannerAgentBackendCapabilitySummary.validationMessages
    ],
    textConcat [
      "capabilityBlockingGaps=",
      plannerAgentBackendPolicyListText plannerAgentBackendCapabilitySummary.blockingGaps
    ],
    textConcat [
      "capabilityRequiredClosure=",
      plannerAgentBackendPolicyListText plannerAgentBackendCapabilitySummary.requiredClosure
    ]
  ]

plannerAgentBackendConfigRepairText : Str -> Str
plannerAgentBackendConfigRepairText backendError =
  textJoin "\n" [
    textConcat ["plannerBackendConfigError=", backendError],
    "plannerBackendConfigRepair=agent-backend",
    plannerAgentBackendSummaryText,
    plannerAgentBackendPolicyRepairText,
    plannerAgentBackendCapabilityText
  ]

codexCommandDefault : Str -> Str -> Str -> [Str]
codexCommandDefault schemaPath reportPath prompt =
  agentBackendCodexCommand
    plannerAgentBackend
    (agentCommandRequest "planner" schemaPath reportPath "" prompt)

plannerAgentCommandArgs : Str -> Str -> Str -> Str -> [Str]
plannerAgentCommandArgs schemaPath reportPath promptPath prompt =
  agentBackendCommand
    plannerAgentBackend
    (agentCommandRequest "planner" schemaPath reportPath promptPath prompt)

codexCommand : Str -> Str -> Str -> [Str]
codexCommand schemaPath reportPath prompt = plannerAgentCommandArgs schemaPath reportPath "" prompt

plannerBenchmarkContextFor : Int -> Str -> Str
plannerBenchmarkContextFor wave benchmarkSummary =
  if benchmarkEnabled then
    if benchmarkSummary == "" then
      textJoin "\n" [
        "Benchmark target is enabled for this manager.",
        textConcat ["Current wave: ", encode wave, " of ", encode maxWaves],
        "No benchmark checkpoint exists yet. Plan the first bounded wave toward beating the benchmark target."
      ]
    else
      textJoin "\n" [
        "Benchmark target is enabled for this manager.",
        textConcat ["Current wave: ", encode wave, " of ", encode maxWaves],
        textConcat ["Latest benchmark summary: ", benchmarkSummary],
        "If the target is still unmet, plan the next bounded wave specifically to improve the benchmark."
      ]
  else
    textConcat ["Current wave: ", encode wave, " of ", encode maxWaves]

plannerTaskWorkspaceCacheRoot : Str
plannerTaskWorkspaceCacheRoot = taskWorkspaceCacheRoot

plannerTaskWorkspaceBaselineCacheRoot : Str
plannerTaskWorkspaceBaselineCacheRoot = taskWorkspaceBaselineCacheRoot

managerHealthSummaryText : Int -> Str
managerHealthSummaryText wave =
  textJoin "\n" [
    textConcat ["wave=", encode wave],
    textConcat ["stateRoot=", stateRootPath],
    textConcat ["taskWorkspaceRoot=", plannerTaskWorkspaceCacheRoot],
    textConcat ["taskBaselineRoot=", plannerTaskWorkspaceBaselineCacheRoot],
    textConcat ["managerCache=", managerXdgCacheHome],
    managerResourceHealthSummary
  ]

plannerContextBoolText : Bool -> Str
plannerContextBoolText value = if value then "true" else "false"

plannerContextMemoryLine : SwarmMemorySearchResult -> Str
plannerContextMemoryLine item =
  textConcat [
    "- score=",
    encode item.score,
    " key=",
    item.memory.key,
    " actor=",
    item.memory.actor,
    " value=",
    item.memory.value,
    " matched=",
    item.matchedText
  ]

plannerContextTraceLine : VerificationTraceEntry -> Str
plannerContextTraceLine entry =
  textConcat [
    "- verifier=",
    entry.verifierName,
    " status=",
    entry.status,
    " exit=",
    encode entry.exitCode,
    " timedOut=",
    plannerContextBoolText entry.timedOut,
    " class=",
    entry.failedVerifierClassification
  ]

plannerContextArtifactExcerptLine : SwarmArtifactContent -> Str
plannerContextArtifactExcerptLine excerpt =
  textConcat [
    "- id=",
    encode excerpt.artifactId,
    " kind=",
    excerpt.kind,
    " bytes=",
    encode excerpt.bytesRead,
    "/",
    encode excerpt.totalBytes,
    " truncated=",
    plannerContextBoolText excerpt.truncated,
    " text=",
    excerpt.text
  ]

plannerContextListSection : Str -> [Str] -> Str
plannerContextListSection title values =
  if length values == 0 then
    textJoin "\n" [title, "- none"]
  else
    textJoin "\n" [title, textJoin "\n" values]

plannerMemorySection : Str -> [SwarmMemorySearchResult] -> Str
plannerMemorySection title values =
  plannerContextListSection title (map plannerContextMemoryLine values)

plannerTraceSection : Str -> [VerificationTraceEntry] -> Str
plannerTraceSection title values =
  plannerContextListSection title (map plannerContextTraceLine values)

plannerArtifactExcerptSection : Str -> [SwarmArtifactContent] -> Str
plannerArtifactExcerptSection title values =
  plannerContextListSection title (map plannerContextArtifactExcerptLine values)

plannerContextArtifactSearchLine : SwarmArtifactSearchResult -> Str
plannerContextArtifactSearchLine item =
  textConcat [
    "- artifact#",
    encode item.artifact.artifactId,
    " task=",
    item.artifact.taskId,
    " kind=",
    item.artifact.kind,
    " score=",
    encode item.score,
    " matched=",
    item.matchedText,
    " excerpt=",
    item.excerpt.text
  ]

plannerArtifactSearchSection : Str -> [SwarmArtifactSearchResult] -> Str
plannerArtifactSearchSection title values =
  plannerContextListSection title (map plannerContextArtifactSearchLine values)

plannerContextPackQuery : Str
plannerContextPackQuery = "planner task child loop verifier feedback benchmark evidence"

renderPlannerContextPack : SwarmContextPack -> Str
renderPlannerContextPack pack =
  textJoin "\n" [
    "Planner context pack:",
    textConcat [
      "task: ",
      pack.task.taskId,
      " status=",
      pack.task.status,
      " ready=",
      plannerContextBoolText pack.task.ready,
      " attempts=",
      encode pack.task.attempts
    ],
    textConcat [
      "objective: ",
      pack.task.objectiveId,
      " manager-action=",
      pack.managerAction.action,
      " manager-task=",
      pack.managerAction.taskId,
      " manager-task-status=",
      pack.managerAction.taskStatus
    ],
    textConcat [
      "spawn policy: parent=",
      pack.task.parentTaskId,
      " depth=",
      encode pack.task.spawnDepth,
      "/",
      encode pack.task.maxSpawnDepth,
      " children=",
      encode pack.task.childTaskCount,
      "/",
      encode pack.task.maxChildTasks,
      " remaining-child-budget=",
      encode pack.task.remainingChildTaskBudget
    ],
    plannerContextListSection "child task ids:" pack.task.childTaskIds,
    textConcat ["ready tasks: ", textJoin ", " pack.readyTaskIds],
    plannerContextListSection "dependency task ids:" pack.dependencyTaskIds,
    plannerContextListSection "dependency task statuses:" pack.dependencyTaskStatuses,
    plannerContextListSection "dependency task ready:" (map plannerContextBoolText pack.dependencyTaskReady),
    textConcat [
      "mailbox: runs=",
      encode pack.mailboxSummary.runCount,
      " artifacts=",
      encode pack.mailboxSummary.artifactCount,
      " memory=",
      encode pack.mailboxSummary.memoryCount,
      " latest-run=",
      pack.mailboxSummary.latestRunName,
      "/",
      pack.mailboxSummary.latestRunStatus,
      " latest-verifier=",
      pack.mailboxSummary.latestVerifier,
      "/",
      pack.mailboxSummary.latestVerifierStatus
    ],
    plannerMemorySection "planner task memory matches:" pack.taskMemoryMatches,
    plannerMemorySection "objective memory matches:" pack.objectiveMemoryMatches,
    plannerMemorySection "benchmark history matches:" pack.benchmarkMemoryMatches,
    plannerArtifactSearchSection "artifact search matches:" pack.artifactSearchMatches,
    plannerArtifactSearchSection "semantic index artifact matches:" pack.semanticArtifactMatches,
    plannerContextListSection "semantic index entry ids:" pack.semanticIndexEntryIds,
    plannerContextListSection "semantic index edit files:" pack.semanticIndexEditFiles,
    plannerContextListSection "semantic index artifact refs:" pack.semanticIndexArtifactRefs,
    plannerContextListSection "semantic index surface ids:" pack.semanticIndexSurfaceIds,
    plannerContextListSection "semantic index query texts:" pack.semanticIndexQueryTexts,
    plannerTraceSection "planner run trace:" pack.runTrace,
    plannerContextListSection "artifact paths:" pack.artifactPaths,
    plannerArtifactExcerptSection "artifact excerpts:" pack.artifactExcerpts
  ]

plannerContextSectionFor : Int -> Str
plannerContextSectionFor wave =
  match taskContextPack (plannerHandleForWave wave) plannerContextPackQuery 8 {
    Ok pack -> renderPlannerContextPack pack,
    Err message -> textConcat ["Planner context pack unavailable: ", message]
  }

plannerPromptNonEmptyText : Str -> Bool
plannerPromptNonEmptyText value = value != ""

plannerPromptJsonBlockOrEmpty : Str -> Str -> Str -> Str
plannerPromptJsonBlockOrEmpty header footer raw =
  if raw == "" then
    ""
  else
    textJoin "\n" [header, raw, footer]

plannerPromptPathBlockOrEmpty : Str -> Str -> Str -> Str
plannerPromptPathBlockOrEmpty header footer path =
  if path == "" then
    ""
  else
    textJoin "\n" [header, path, footer]

plannerAffectedVerificationPlanPromptBlock : Str
plannerAffectedVerificationPlanPromptBlock =
  plannerPromptJsonBlockOrEmpty
    "Affected verification plan JSON:"
    "End affected verification plan JSON."
    childAffectedVerificationPlanInlineJson

plannerAffectedVerificationPlanPathPromptBlock : Str
plannerAffectedVerificationPlanPathPromptBlock =
  plannerPromptPathBlockOrEmpty
    "Affected verification plan path:"
    "End affected verification plan path."
    childAffectedVerificationPlanPath

plannerAffectedVerificationLaunchPolicyPromptBlock : Str
plannerAffectedVerificationLaunchPolicyPromptBlock =
  plannerPromptJsonBlockOrEmpty
    "Affected verification launch policy JSON:"
    "End affected verification launch policy JSON."
    childAffectedVerificationLaunchPolicyInlineJson

plannerAffectedVerificationLaunchPolicyPathPromptBlock : Str
plannerAffectedVerificationLaunchPolicyPathPromptBlock =
  plannerPromptPathBlockOrEmpty
    "Affected verification launch policy path:"
    "End affected verification launch policy path."
    childAffectedVerificationLaunchPolicyPath

plannerAffectedVerificationContextSection : Str
plannerAffectedVerificationContextSection =
  textJoin
    "\n"
    (filter plannerPromptNonEmptyText [
      plannerAffectedVerificationPlanPromptBlock,
      plannerAffectedVerificationPlanPathPromptBlock,
      plannerAffectedVerificationLaunchPolicyPromptBlock,
      plannerAffectedVerificationLaunchPolicyPathPromptBlock
    ])

plannerPromptFor : Int -> Str -> Str
plannerPromptFor wave benchmarkSummary =
  textJoin "\n" [
    "You are the planner subagent for the Clasp repository.",
    "Plan the next bounded tasks needed to improve Clasp autonomously.",
    plannerBenchmarkContextFor wave benchmarkSummary,
    "High-level goal:",
    goalText,
    "Current manager health/resource context:",
    managerHealthSummaryText wave,
    "Prior swarm mailbox/recovery context:",
    mailboxSummaryText wave,
    plannerAgentBackendSummaryText,
    plannerAgentBackendPolicyRepairText,
    plannerAgentBackendCapabilityText,
    plannerAffectedVerificationContextSection,
    plannerContextSectionFor wave,
    "Planning is a control-plane step, not a verification or implementation step.",
    "Do not run repo-wide verification, benchmarks, builds, package installs, or other long commands from the planner.",
    "Do not inspect files, run shell commands, invoke tools, or gather extra repository context from the planner.",
    "Use only this prompt, the manager health context, and the benchmark summary as planner inputs.",
    "If uncertain, create a bounded inspection or verification task instead of inspecting from the planner.",
    "If verification is needed, encode it in the planned task prompts and verifier expectations instead of doing it here.",
    "Return JSON matching the planner schema.",
    "Return the final planner-report JSON immediately; do not stream interim plans or empty task lists.",
    textConcat ["Plan 1-", encode maxTaskLoops, " bounded tasks with explicit dependencies and task prompts."],
    "Each planned task must include an explicit role and a coordinationFocus list.",
    "When tasks are independent, prefer complementary parallel roles instead of serializing all work through one branch."
  ]

plannerCommandFor : Int -> Str -> SwarmCommand
plannerCommandFor wave benchmarkSummary =
  commandSpec
    managerProjectRoot
    (plannerAgentCommandArgs
      resolvedPlannerSchemaPath
      (plannerReportPathFor wave)
      (plannerPromptPathForWave wave)
      (plannerPromptFor wave benchmarkSummary))
