agentResultIsOk : Result a -> Bool
agentResultIsOk value = match value {
  Ok inner -> true,
  Err message -> false
}

agentResultIsErr : Result a -> Bool
agentResultIsErr value = match value {
  Ok inner -> false,
  Err message -> true
}

agentResultWithDefault : a -> Result a -> a
agentResultWithDefault fallback value = match value {
  Ok inner -> inner,
  Err message -> fallback
}

agentResultErrorOr : Str -> Result a -> Str
agentResultErrorOr fallback value = match value {
  Ok inner -> fallback,
  Err message -> message
}

agentResultToList : Result a -> [a]
agentResultToList value = match value {
  Ok inner -> [inner],
  Err message -> []
}

agentResultStatus : Str -> Str -> Result a -> Str
agentResultStatus okStatus errPrefix value = match value {
  Ok inner -> okStatus,
  Err message -> textConcat [errPrefix, message]
}

agentReadTextOr : Str -> Str -> Str
agentReadTextOr path fallback =
  match readFile path {
    Ok raw -> raw,
    Err message -> fallback
  }

agentReadEnvInt : Str -> Int -> Int
agentReadEnvInt name fallback = match envVar name {
  Ok raw -> if raw == "" then fallback else decode Int raw,
  Err message -> fallback
}

agentNonEmptyText : Str -> Bool
agentNonEmptyText value = value != ""

agentTextOr : Str -> Str -> Str
agentTextOr fallback value =
  if value == "" then fallback else value

agentNonEmptyTexts : [Str] -> [Str]
agentNonEmptyTexts values = {
  let mut kept = [];
  for value in values {
    if value == "" then
      kept
    else {
      kept = append kept [value];
      kept
    }
  };
  kept
}

agentJoinNonEmpty : Str -> [Str] -> Str
agentJoinNonEmpty separator values =
  textJoin separator (agentNonEmptyTexts values)

agentFirstTextOrEmpty : [Str] -> Str
agentFirstTextOrEmpty values = {
  let mut first = "";
  let mut found = false;
  for value in values {
    if found then
      found
    else {
      first = value;
      found = true;
      found
    }
  };
  first
}

agentSecondTextOrEmpty : [Str] -> Str
agentSecondTextOrEmpty values = {
  let mut second = "";
  let mut index = 0;
  for value in values {
    if index == 0 then {
      index = 1;
      index
    } else if index == 1 then {
      second = value;
      index = 2;
      index
    } else
      index
  };
  second
}

agentPromptBlockText : Str -> Str -> Str -> Str
agentPromptBlockText prompt startMarker endMarker = {
  let afterMarker = agentSecondTextOrEmpty (textSplit prompt startMarker);
  if afterMarker == "" then
    ""
  else
    agentFirstTextOrEmpty (textSplit afterMarker endMarker)
}

agentPromptBlockPresent : Str -> Str -> Str -> Bool
agentPromptBlockPresent prompt startMarker endMarker =
  agentPromptBlockText prompt startMarker endMarker != ""

agentPromptBlockOrEmpty : Str -> Str -> Str -> Str
agentPromptBlockOrEmpty header footer raw =
  if raw == "" then
    ""
  else
    textJoin "\n" [header, raw, footer]

agentPromptPrefixedLines : Str -> Str -> [Str]
agentPromptPrefixedLines prompt prefix = {
  let mut matches = [];
  for line in textSplit prompt "\n" {
    let bulletPrefix = textConcat ["- ", prefix];
    let indentedBulletPrefix = textConcat ["  - ", prefix];
    let remainder = match textPrefix line prefix {
      Ok value -> value,
      Err message ->
        match textPrefix line bulletPrefix {
          Ok value -> value,
          Err bulletMessage ->
            match textPrefix line indentedBulletPrefix {
              Ok value -> value,
              Err indentedMessage -> ""
            }
        }
    };
    if remainder == "" then
      matches
    else {
      matches = append matches [remainder];
      matches
    }
  };
  matches
}

agentCapabilityMailboxEvidenceFromPrompt : Str -> [Str]
agentCapabilityMailboxEvidenceFromPrompt prompt =
  agentPromptPrefixedLines prompt "capability-evidence="

agentCapabilityMailboxBlockingGapsFromPrompt : Str -> [Str]
agentCapabilityMailboxBlockingGapsFromPrompt prompt =
  agentPromptPrefixedLines prompt "capability-gap="

agentCapabilityMailboxRequiredClosureFromPrompt : Str -> [Str]
agentCapabilityMailboxRequiredClosureFromPrompt prompt =
  agentPromptPrefixedLines prompt "capability-closure="

agentCapabilityMailboxSummaryFromPrompt : Str -> AgentCapabilityMailboxSummary
agentCapabilityMailboxSummaryFromPrompt prompt = {
  let evidence = agentCapabilityMailboxEvidenceFromPrompt prompt;
  let blockingGaps = agentCapabilityMailboxBlockingGapsFromPrompt prompt;
  let requiredClosure = agentCapabilityMailboxRequiredClosureFromPrompt prompt;
  AgentCapabilityMailboxSummary {
    hasEvidence = length evidence > 0,
    hasBlockingGaps = length blockingGaps > 0,
    hasRequiredClosure = length requiredClosure > 0,
    evidenceCount = length evidence,
    blockingGapCount = length blockingGaps,
    requiredClosureCount = length requiredClosure,
    evidence = evidence,
    blockingGaps = blockingGaps,
    requiredClosure = requiredClosure,
    firstBlockingGap = agentFirstTextOrEmpty blockingGaps,
    recommendation =
      if length blockingGaps > 0 then
        "plan capability-audit closure from mailbox capability-gap details"
      else if length requiredClosure > 0 then
        "track required capability closure from mailbox detail lines"
      else if length evidence > 0 then
        "reuse mailbox capability evidence"
      else
        "no mailbox capability details found"
  }
}

agentPromptHasCapabilityMailboxGaps : Str -> Bool
agentPromptHasCapabilityMailboxGaps prompt = {
  let summary = agentCapabilityMailboxSummaryFromPrompt prompt;
  summary.hasBlockingGaps || summary.hasRequiredClosure
}

agentCapabilityMailboxFirstRequiredClosure : AgentCapabilityMailboxSummary -> Str
agentCapabilityMailboxFirstRequiredClosure summary =
  agentFirstTextOrEmpty summary.requiredClosure

agentCapabilityMailboxClosureDetail : AgentCapabilityMailboxSummary -> Str
agentCapabilityMailboxClosureDetail summary =
  if summary.firstBlockingGap != "" then
    textConcat ["Close typed capability mailbox gap: ", summary.firstBlockingGap]
  else if agentCapabilityMailboxFirstRequiredClosure summary != "" then
    textConcat ["Close typed capability mailbox closure: ", agentCapabilityMailboxFirstRequiredClosure summary]
  else
    "Close one typed capability gap from GoalManager mailbox capability detail lines."

agentCapabilityMailboxClosurePrompt : AgentCapabilityMailboxSummary -> Str
agentCapabilityMailboxClosurePrompt summary =
  textJoin
    "\n"
    [
      "Use the typed GoalManager mailbox capability details below to close one bounded capability gap. Preserve the concrete capability detail in the resulting evidence, prefer focused ordinary-Clasp helper or planner/runtime work, and verify with the narrow static or affected route that covers the changed surface. Do not launch a broad swarm, full verify-all, promotion, or unmanaged compiler rebuild from this task.",
      "Capability mailbox evidence:",
      textJoin "\n" summary.evidence,
      "Capability mailbox blocking gaps:",
      textJoin "\n" summary.blockingGaps,
      "Capability mailbox required closure:",
      textJoin "\n" summary.requiredClosure,
      agentCapabilityAuditClosureVerificationSectionForKind "capability-mailbox"
    ]

