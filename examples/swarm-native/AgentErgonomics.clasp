agentHasCapabilityAuditJsonPath : Str -> Bool
agentHasCapabilityAuditJsonPath prompt =
  agentCapabilityAuditJsonPathFromPrompt prompt != ""

agentCapabilityAuditJsonFromPrompt : Str -> Str
agentCapabilityAuditJsonFromPrompt prompt = {
  let inlineJson = agentCapabilityAuditInlineJsonFromPrompt prompt;
  if inlineJson != "" then
    inlineJson
  else {
    let auditPath = agentCapabilityAuditJsonPathFromPrompt prompt;
    if auditPath == "" then
      ""
    else
      agentBoundedCapabilityAuditJsonFromPath auditPath
  }
}

