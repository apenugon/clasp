agentCapabilityAuditClosureDetailForKind : Str -> Str
agentCapabilityAuditClosureDetailForKind kind =
  if kind == "capability-audit-context" then
    "Repair the capability-audit JSON handoff before planning broader swarm closure work."
  else if kind == "managed-verify-all" then
    "Close the managed verification evidence gap reported by the swarm capability audit."
  else if kind == "managed-swarm-proof" then
    "Close the broad managed swarm proof gap reported by the swarm capability audit."
  else if kind == "native-runtime-parity" then
    "Close one native workflow/supervisor/tool/verifier/mergegate runtime parity gap for standalone Clasp swarms."
  else if kind == "backend-surface-parity" then
    "Close one backend-surface parity gap so standalone Clasp agent backends do not depend on JS helper semantics."
  else if kind == "iteration-speed" then
    "Close the compiler iteration-speed evidence gap reported by the swarm capability audit."
  else if kind == "semantic-memory" then
    "Close one semantic-memory embedding adapter or vector-store persistence gap from the swarm capability audit."
  else if kind == "safety-governance" then
    "Close one safety/governance hostile-tool policy gap from the swarm capability audit."
  else if kind == "agent-ergonomics" then
    "Close one agent ergonomics helper gap from the swarm capability audit."
  else if kind == "capability-mailbox" then
    "Close one typed capability gap from GoalManager mailbox capability detail lines."
  else
    "Convert the machine-readable swarm capability audit into the next bounded implementation task."

