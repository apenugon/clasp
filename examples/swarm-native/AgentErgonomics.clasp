record AgentAutonomousLaunchGateInput = {
  workspaceCheckpointReady : Bool,
  dirtyWorktree : Bool,
  resourceAdmissionOk : Bool,
  loopAlreadyRunning : Bool,
  boundedTaskCount : Int,
  requestedChildAgents : Int,
  admittedChildCapacity : Int,
  managedLaunch : Bool,
  focusedVerificationReady : Bool,
  fullVerificationRequested : Bool,
  promotionRequested : Bool,
  compilerMutationRequested : Bool
}

record AgentAutonomousLaunchGate = {
  valid : Bool,
  ready : Bool,
  mode : Str,
  maySpawn : Bool,
  mayMutateCompiler : Bool,
  requestedChildAgents : Int,
  admittedChildCapacity : Int,
  recommendation : Str,
  blockingGaps : [Str],
  requiredClosure : [Str],
  evidence : [Str]
}

agentAutonomousLaunchGateRepairMaySpawn : AgentAutonomousLaunchGateInput -> Bool
agentAutonomousLaunchGateRepairMaySpawn input =
  if input.workspaceCheckpointReady == false then
    false
  else if input.resourceAdmissionOk == false then
    false
  else if input.loopAlreadyRunning then
    false
  else if input.boundedTaskCount <= 0 then
    false
  else if input.requestedChildAgents <= 0 then
    false
  else if input.admittedChildCapacity <= 0 then
    false
  else if input.requestedChildAgents > input.admittedChildCapacity then
    false
  else if input.managedLaunch == false then
    false
  else if input.fullVerificationRequested then
    false
  else if input.promotionRequested then
    false
  else
    true

agentAutonomousLaunchGateRepairRecommendation : AgentAutonomousLaunchGateInput -> Str
agentAutonomousLaunchGateRepairRecommendation input =
  if agentAutonomousLaunchGateRepairMaySpawn input then
    "autonomous-launch-repair:ready-managed-gate-repair-loop"
  else if input.workspaceCheckpointReady == false then
    "autonomous-launch-repair:checkpoint-current-worktree-before-child-repair"
  else if input.resourceAdmissionOk == false then
    "autonomous-launch-repair:wait-or-lower-concurrency-before-child-repair"
  else if input.loopAlreadyRunning then
    "autonomous-launch-repair:attach-or-stop-existing-loop-before-child-repair"
  else if input.boundedTaskCount <= 0 then
    "autonomous-launch-repair:declare-bounded-task-count-before-child-repair"
  else if input.requestedChildAgents <= 0 then
    "autonomous-launch-repair:declare-requested-child-agents-before-child-repair"
  else if input.admittedChildCapacity <= 0 then
    "autonomous-launch-repair:restore-child-admission-before-child-repair"
  else if input.requestedChildAgents > input.admittedChildCapacity then
    "autonomous-launch-repair:lower-requested-child-agents-before-child-repair"
  else if input.managedLaunch == false then
    "autonomous-launch-repair:use-managed-supervisor-before-child-repair"
  else if input.fullVerificationRequested then
    "autonomous-launch-repair:replace-full-verification-before-child-repair"
  else if input.promotionRequested then
    "autonomous-launch-repair:defer-promotion-before-child-repair"
  else
    "autonomous-launch-repair:close-launch-gaps-before-child-repair"

