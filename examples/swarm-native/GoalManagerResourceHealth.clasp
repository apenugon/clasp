managerDiskLaunchResourceError : Str
managerDiskLaunchResourceError =
  if managerMinAvailableDiskMb < 1 then
    ""
  else
    match managerAvailableDiskMbAt managerDiskReserveResolvedPath {
      Err message ->
        textConcat [
          "manager resource guard blocked child launch: disk reserve unavailable: path=",
          managerDiskReserveResolvedPath,
          ":requiredMb=",
          encode managerMinAvailableDiskMb,
          ":error=",
          message
        ],
      Ok availableMb ->
        if availableMb < managerMinAvailableDiskMb then
          managerDiskResourceGuardBlockMessage (encode availableMb)
        else if managerMinDiskHeadroomMb > 0 && managerDiskHeadroomMbFromAvailable availableMb < managerMinDiskHeadroomMb then
          managerDiskHeadroomResourceGuardBlockMessage (encode availableMb) (encode (managerDiskHeadroomMbFromAvailable availableMb))
        else
          ""
    }

managerBenchmarkDiskLaunchResourceError : Str
managerBenchmarkDiskLaunchResourceError =
  if managerMinAvailableDiskMb < 1 then
    ""
  else
    match managerAvailableDiskMbAt managerDiskReserveResolvedPath {
      Err message ->
        textConcat [
          "manager resource guard blocked benchmark launch: disk reserve unavailable: path=",
          managerDiskReserveResolvedPath,
          ":requiredMb=",
          encode managerMinAvailableDiskMb,
          ":error=",
          message
        ],
      Ok availableMb ->
        if availableMb < managerMinAvailableDiskMb then
          managerBenchmarkDiskResourceGuardBlockMessage (encode availableMb)
        else if managerMinDiskHeadroomMb > 0 && managerDiskHeadroomMbFromAvailable availableMb < managerMinDiskHeadroomMb then
          managerBenchmarkDiskHeadroomResourceGuardBlockMessage (encode availableMb) (encode (managerDiskHeadroomMbFromAvailable availableMb))
        else
          ""
    }

