    managerPlannerMemoryReserveBlockMessage (encode availableMb)
  else if managerPlannerMemoryReserveMb > 0 && availableMb < managerPlannerMemoryLaunchRequiredMb then
    managerPlannerMemoryResourceGuardBlockMessage (encode availableMb) (encode (managerMemoryLaunchHeadroomMbFromAvailable availableMb))
  else
