        if availableMb < managerPlannerMemoryLaunchRequiredWithExternalStatsMb pressure.count pressure.rssMb then
          managerPlannerExternalAgentMemoryResourceGuardBlockMessage pressure.count pressure.rssMb (encode availableMb) (encode (managerMemoryLaunchHeadroomMbFromAvailable availableMb))
        else
          ""
    }

managerMemoryLaunchResourceErrorFromAvailableForActiveChildren : Int -> Int -> Str
managerMemoryLaunchResourceErrorFromAvailableForActiveChildren projectedActiveChildren availableMb =
  let childError =
    resourceGuardMemoryProjectedLaunchErrorFromAvailable
      managerMinAvailableMemoryMb
      managerChildMemoryReserveMb
      projectedActiveChildren
      availableMb in
  if childError != "" then
    childError
  else
    match managerExternalAgentPressure {
      Err message -> managerExternalAgentCountUnavailableBlockMessage message,
      Ok pressure ->
        if availableMb < managerMemoryLaunchRequiredWithExternalStatsMbForActiveChildren projectedActiveChildren pressure.count pressure.rssMb then
          managerExternalAgentMemoryResourceGuardBlockMessage projectedActiveChildren pressure.count pressure.rssMb (encode availableMb) (encode (managerMemoryLaunchHeadroomMbFromAvailable availableMb))
        else
          ""
    }

