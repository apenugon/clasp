managerResourceHealthLaunchSummary : Str
managerResourceHealthLaunchSummary =
  if managerResourceGuardEnabled == false then
    "launch: guardEnabled=false status=allowed"
  else {
    let diskError = managerDiskLaunchResourceError in
    if diskError != "" then
      textConcat ["launch: guardEnabled=true status=blocked reason=", diskError]
    else {
      let memoryError = managerMemoryLaunchResourceError in
      if memoryError != "" then
        textConcat ["launch: guardEnabled=true status=blocked reason=", memoryError]
      else
        "launch: guardEnabled=true status=allowed"
    }
  }

managerWorktreeCheckpointKind : Str
managerWorktreeCheckpointKind = "clasp-manager-worktree-checkpoint"

managerWorktreeCheckpointPath : Str
managerWorktreeCheckpointPath =
  readEnvText
    "CLASP_MANAGER_WORKTREE_CHECKPOINT_PATH_JSON"
    (pathJoin [stateRootPath, "worktree-checkpoint.json"])

managerGitWorktreeStatusResult : Result Str
managerGitWorktreeStatusResult =
  match runCommand managerProjectRoot ["git", "status", "--porcelain", "--untracked-files=normal"] {
    Err message -> Err message,
    Ok process ->
      if process.exitCode == 0 then
        Ok process.stdout
      else
        Err process.stderr
  }

managerGitWorktreeStatusTextOrEmpty : Str
managerGitWorktreeStatusTextOrEmpty =
  match managerGitWorktreeStatusResult {
    Ok statusText -> statusText,
    Err message -> ""
  }

managerGitWorktreeStatusFingerprint64Hex : Str
managerGitWorktreeStatusFingerprint64Hex =
  textFingerprint64Hex managerGitWorktreeStatusTextOrEmpty

managerGitWorktreeDirtyDefault : Bool -> Bool
managerGitWorktreeDirtyDefault fallback =
  match managerGitWorktreeStatusResult {
    Ok statusText -> statusText != "",
    Err message -> fallback
  }

managerReadWorktreeCheckpoint : Result ManagerWorktreeCheckpoint
managerReadWorktreeCheckpoint =
  if fileExists managerWorktreeCheckpointPath then
    match readFile managerWorktreeCheckpointPath {
      Ok raw -> tryDecode ManagerWorktreeCheckpoint raw,
      Err message -> Err message
    }
  else
    Err "missing-manager-worktree-checkpoint"

managerWorktreeCheckpointMatchesCurrentStatus : Bool
managerWorktreeCheckpointMatchesCurrentStatus =
  match managerGitWorktreeStatusResult {
    Err message -> false,
    Ok statusText ->
      match managerReadWorktreeCheckpoint {
        Err checkpointMessage -> false,
        Ok checkpoint ->
          if checkpoint.schemaVersion != 1 then
            false
          else if checkpoint.kind != managerWorktreeCheckpointKind then
            false
          else if checkpoint.projectRoot != managerProjectRoot then
            false
          else
            checkpoint.statusText == statusText
      }
  }

managerWorkspaceCheckpointReadyDefault : Bool
managerWorkspaceCheckpointReadyDefault =
  if managerGitWorktreeDirtyDefault true == false then
    true
  else
    managerWorktreeCheckpointMatchesCurrentStatus

managerWorkspaceCheckpointReady : Bool
managerWorkspaceCheckpointReady =
  readEnvBool "CLASP_MANAGER_WORKSPACE_CHECKPOINT_READY_JSON" managerWorkspaceCheckpointReadyDefault

managerDirtyWorktree : Bool
managerDirtyWorktree =
  readEnvBool "CLASP_MANAGER_DIRTY_WORKTREE_JSON" (managerGitWorktreeDirtyDefault false)

managerLoopAlreadyRunning : Bool
managerLoopAlreadyRunning =
  readEnvBool "CLASP_MANAGER_LOOP_ALREADY_RUNNING_JSON" false

managerAutonomousFocusedVerificationReady : Bool
managerAutonomousFocusedVerificationReady =
  readEnvBool "CLASP_MANAGER_AUTONOMOUS_FOCUSED_VERIFICATION_READY_JSON" false

managerAutonomousFullVerificationRequested : Bool
managerAutonomousFullVerificationRequested =
  readEnvBool "CLASP_MANAGER_AUTONOMOUS_FULL_VERIFICATION_REQUESTED_JSON" false

managerAutonomousPromotionRequested : Bool
managerAutonomousPromotionRequested =
  readEnvBool "CLASP_MANAGER_AUTONOMOUS_PROMOTION_REQUESTED_JSON" false

managerAutonomousCompilerMutationRequested : Bool
managerAutonomousCompilerMutationRequested =
  readEnvBool "CLASP_MANAGER_AUTONOMOUS_COMPILER_MUTATION_REQUESTED_JSON" false

managerManagedLaunchReady : Bool
managerManagedLaunchReady =
  match envVar "CLASP_MANAGED_JOB_ID" {
    Ok raw -> raw != "",
    Err message -> readEnvBool "CLASP_MANAGER_ASSUME_MANAGED_LAUNCH_JSON" false
  }

managerAutonomousRequestedChildAgents : Int
managerAutonomousRequestedChildAgents =
  resourceGuardConfiguredChildLimit managerConfiguredMaxConcurrentChildren

managerAutonomousBoundedTaskCount : Int
managerAutonomousBoundedTaskCount =
  readEnvInt "CLASP_MANAGER_MAX_TASKS_JSON" 4

managerAutonomousAdmittedChildCapacity : Int
managerAutonomousAdmittedChildCapacity =
  if managerResourceGuardEnabled == false then
    managerAutonomousRequestedChildAgents
  else
    match managerAvailableMemoryMb {
      Err message -> 0,
      Ok availableMb ->
        match managerExternalAgentPressure {
          Err pressureMessage -> 0,
          Ok pressure ->
            (managerMemoryConcurrencyDecisionWithExternalStats pressure.count pressure.rssMb availableMb).admittedChildCapacity
        }
    }

managerAutonomousResourceAdmissionOkForActiveChildren : Int -> Bool
managerAutonomousResourceAdmissionOkForActiveChildren projectedActiveChildren =
  if managerResourceGuardEnabled == false then
    true
  else {
    let diskError = managerDiskLaunchResourceError in
    if diskError != "" then
      false
    else
      managerMemoryLaunchResourceErrorForActiveChildren projectedActiveChildren == ""
  }

managerAutonomousLaunchGateInputForActiveChildren : Int -> AgentAutonomousLaunchGateInput
managerAutonomousLaunchGateInputForActiveChildren projectedActiveChildren =
  AgentAutonomousLaunchGateInput {
    workspaceCheckpointReady = managerWorkspaceCheckpointReady,
    dirtyWorktree = managerDirtyWorktree,
    resourceAdmissionOk = managerAutonomousResourceAdmissionOkForActiveChildren projectedActiveChildren,
    loopAlreadyRunning = managerLoopAlreadyRunning,
    boundedTaskCount = managerAutonomousBoundedTaskCount,
    requestedChildAgents = managerAutonomousRequestedChildAgents,
    admittedChildCapacity = managerAutonomousAdmittedChildCapacity,
    managedLaunch = managerManagedLaunchReady,
    focusedVerificationReady = managerAutonomousFocusedVerificationReady,
    fullVerificationRequested = managerAutonomousFullVerificationRequested,
    promotionRequested = managerAutonomousPromotionRequested,
    compilerMutationRequested = managerAutonomousCompilerMutationRequested
  }

managerAutonomousLaunchGateForActiveChildren : Int -> AgentAutonomousLaunchGate
managerAutonomousLaunchGateForActiveChildren projectedActiveChildren =
  agentAutonomousLaunchGate (managerAutonomousLaunchGateInputForActiveChildren projectedActiveChildren)

managerAutonomousLaunchGateRepairMaySpawnForActiveChildren : Int -> Bool
managerAutonomousLaunchGateRepairMaySpawnForActiveChildren projectedActiveChildren =
  agentAutonomousLaunchGateRepairMaySpawn (managerAutonomousLaunchGateInputForActiveChildren projectedActiveChildren)

managerAutonomousLaunchGateRepairRecommendationForActiveChildren : Int -> Str
managerAutonomousLaunchGateRepairRecommendationForActiveChildren projectedActiveChildren =
  agentAutonomousLaunchGateRepairRecommendation (managerAutonomousLaunchGateInputForActiveChildren projectedActiveChildren)

managerAutonomousLaunchGate : AgentAutonomousLaunchGate
managerAutonomousLaunchGate = managerAutonomousLaunchGateForActiveChildren 1

managerAutonomousLaunchGateJson : Str
managerAutonomousLaunchGateJson = encode managerAutonomousLaunchGate

managerAutonomousLaunchGateSummary : Str
managerAutonomousLaunchGateSummary =
  textJoin "\n" [
    "Autonomous launch gate:",
    textConcat ["autonomous-launch-gate-mode:", managerAutonomousLaunchGate.mode],
    textConcat ["autonomous-launch-gate-ready:", managerResourceBoolText managerAutonomousLaunchGate.ready],
    textConcat ["autonomous-launch-gate-may-spawn:", managerResourceBoolText managerAutonomousLaunchGate.maySpawn],
    textConcat ["autonomous-launch-gate-may-spawn-repair:", managerResourceBoolText (managerAutonomousLaunchGateRepairMaySpawnForActiveChildren 1)],
    textConcat ["autonomous-launch-gate-recommendation:", managerAutonomousLaunchGate.recommendation],
    textConcat ["autonomous-launch-gate-repair-recommendation:", managerAutonomousLaunchGateRepairRecommendationForActiveChildren 1],
    textConcat ["autonomous-launch-worktree-checkpoint-path:", managerWorktreeCheckpointPath],
    textConcat ["autonomous-launch-worktree-status-fingerprint64:", managerGitWorktreeStatusFingerprint64Hex],
    textConcat ["autonomous-launch-worktree-checkpoint-matches:", managerResourceBoolText managerWorktreeCheckpointMatchesCurrentStatus],
    "Autonomous launch gate JSON:",
    managerAutonomousLaunchGateJson,
    "End autonomous launch gate JSON."
  ]

managerResourceHealthSummary : Str
managerResourceHealthSummary =
  textJoin "\n" [
    "Planner resource health:",
    managerResourceHealthDiskSummary,
    managerGeneratedStateCleanupPlanSummary,
    managerResourceHealthMemorySummary,
    managerResourceHealthExternalAgentSummary,
    managerResourceHealthMemoryAdmissionSummary,
    managerResourceHealthMemoryConcurrencySummary,
    managerResourceHealthLaunchSummary,
    managerAutonomousLaunchGateSummary
  ]

resourceBlockMessageIsMemoryPressure : Str -> Bool
resourceBlockMessageIsMemoryPressure message = resourceRecoveryMessageIsMemoryPressure message

resourceBlockRecoveryTaskId : Str -> Str
resourceBlockRecoveryTaskId message = resourceRecoveryTaskIdForMessage message

resourceBlockRecoveryKind : Str -> Str
resourceBlockRecoveryKind message = resourceRecoveryKindForMessage message

resourceBlockRecoveryGuidance : Str -> Str
resourceBlockRecoveryGuidance message = resourceRecoveryGuidanceForMessage message

managerTraceResourceBlock : Str -> Str
managerTraceResourceBlock blockMessage =
  let traceError = appendManagerTrace (textConcat ["resource-guard:child-launch-blocked:", blockMessage]) in
  if traceError != "" then
    textConcat [blockMessage, "; trace failed: ", traceError]
  else
    blockMessage

