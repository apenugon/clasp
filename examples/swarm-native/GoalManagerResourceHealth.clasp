managerMemoryLaunchResourceErrorFromAvailable : Int -> Str
managerMemoryLaunchResourceErrorFromAvailable availableMb =
  resourceGuardMemoryLaunchErrorFromAvailable
    managerMinAvailableMemoryMb
    managerChildMemoryReserveMb
    availableMb

managerBenchmarkMemoryLaunchResourceErrorFromAvailable : Int -> Str
managerBenchmarkMemoryLaunchResourceErrorFromAvailable availableMb =
  if managerMinAvailableMemoryMb > 0 && availableMb < managerMinAvailableMemoryMb then
    managerBenchmarkMemoryReserveBlockMessage (encode availableMb)
  else if managerBenchmarkMemoryReserveMb > 0 && availableMb < managerBenchmarkMemoryLaunchRequiredMb then
    managerBenchmarkMemoryResourceGuardBlockMessage (encode availableMb) (encode (managerMemoryLaunchHeadroomMbFromAvailable availableMb))
  else
    match managerExternalAgentPressure {
      Err message -> managerBenchmarkExternalAgentCountUnavailableBlockMessage message,
      Ok pressure ->
        if availableMb < managerBenchmarkMemoryLaunchRequiredWithExternalStatsMb pressure.count pressure.rssMb then
          managerBenchmarkExternalAgentMemoryResourceGuardBlockMessage pressure.count pressure.rssMb (encode availableMb) (encode (managerMemoryLaunchHeadroomMbFromAvailable availableMb))
        else
          ""
    }

managerScopedMemoryLaunchResourceErrorFromAvailable : Str -> Str -> Int -> Int -> Int -> Str
managerScopedMemoryLaunchResourceErrorFromAvailable scope reserveName reserveMb launchRequiredMb availableMb =
  if managerMinAvailableMemoryMb > 0 && availableMb < managerMinAvailableMemoryMb then
    managerScopedMemoryReserveBlockMessage scope (encode availableMb)
  else if reserveMb > 0 && availableMb < launchRequiredMb then
    managerScopedMemoryResourceGuardBlockMessage scope reserveName reserveMb launchRequiredMb (encode availableMb) (encode (managerMemoryLaunchHeadroomMbFromAvailable availableMb))
  else
    match managerExternalAgentPressure {
      Err message -> managerScopedExternalAgentCountUnavailableBlockMessage scope message,
      Ok pressure -> {
        let launchRequiredWithExternalMb =
          intAdd launchRequiredMb pressure.reservedMemoryMb in
        if availableMb < launchRequiredWithExternalMb then
          managerScopedExternalAgentMemoryResourceGuardBlockMessage scope reserveName reserveMb launchRequiredWithExternalMb pressure.count pressure.rssMb (encode availableMb) (encode (managerMemoryLaunchHeadroomMbFromAvailable availableMb))
        else
          ""
      }
    }

managerServiceMemoryLaunchResourceErrorFromAvailable : Int -> Str
managerServiceMemoryLaunchResourceErrorFromAvailable availableMb =
  managerScopedMemoryLaunchResourceErrorFromAvailable
    "service"
    "serviceReserveMb"
    managerServiceMemoryReserveMb
    managerServiceMemoryLaunchRequiredMb
    availableMb

managerUpgradeMemoryLaunchResourceErrorFromAvailable : Int -> Str
