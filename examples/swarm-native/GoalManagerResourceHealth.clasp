managerPlannerExternalAgentMemoryResourceGuardBlockMessage : Int -> Int -> Str -> Str -> Str
managerPlannerExternalAgentMemoryResourceGuardBlockMessage externalAgentCount externalAgentRssMb availableText headroomText =
  textConcat [
    "manager resource guard blocked planner launch: memory external agent reserve unmet: availableMb=",
    availableText,
    ":requiredMb=",
    encode managerMinAvailableMemoryMb,
    ":plannerReserveMb=",
    encode managerPlannerMemoryReserveMb,
    ":externalAgentReserveMb=",
    encode managerExternalAgentReserveMb,
    ":externalAgentProcessNames=",
    encode managerExternalAgentProcessNames,
    ":externalAgentCount=",
    encode externalAgentCount,
    ":externalAgentRssMb=",
    encode externalAgentRssMb,
    ":externalAgentReservedMb=",
    encode (managerExternalAgentReservedMemoryMbFromStats externalAgentCount externalAgentRssMb),
    ":launchRequiredMb=",
    encode (managerPlannerMemoryLaunchRequiredWithExternalStatsMb externalAgentCount externalAgentRssMb),
    ":launchHeadroomMb=",
    headroomText
  ]

managerExternalAgentCountUnavailableBlockMessage : Str -> Str
managerExternalAgentCountUnavailableBlockMessage message =
  textConcat [
    "manager resource guard blocked child launch: memory external agent reserve unavailable: processNames=",
    encode managerExternalAgentProcessNames,
    ":externalAgentReserveMb=",
    encode managerExternalAgentReserveMb,
    ":error=",
    message
  ]

managerBenchmarkExternalAgentCountUnavailableBlockMessage : Str -> Str
managerBenchmarkExternalAgentCountUnavailableBlockMessage message =
