module GoalManagerResourceHealth

import GoalManagerResourceContext
import AgentErgonomics
import ResourceGuardPolicy
import ResourceRecoveryPolicy
import GoalManagerGeneratedCleanupHealth
import HostResources

record ManagerExternalAgentPressure = {
  count : Int,
  rssMb : Int,
  reservedMemoryMb : Int
}

record ManagerWorktreeCheckpoint = {
  schemaVersion : Int,
  kind : Str,
  projectRoot : Str,
  statusText : Str
}

managerDiskReserveResolvedPath : Str
managerDiskReserveResolvedPath =
  if managerDiskReservePath == "" then
    resolvedWorkspaceRoot
  else
    resolveWorkspacePath managerDiskReservePath

managerAvailableDiskMbAt : Str -> Result Int
managerAvailableDiskMbAt path = hostAvailableDiskMb path

managerAvailableMemoryMb : Result Int
managerAvailableMemoryMb = hostAvailableMemoryMb

managerResourceBoolText : Bool -> Str
managerResourceBoolText value = if value then "true" else "false"

managerDiskHeadroomMbFromAvailable : Int -> Int
managerDiskHeadroomMbFromAvailable availableMb = intSubtract availableMb managerMinAvailableDiskMb

managerDiskReserveMetFromAvailable : Int -> Bool
managerDiskReserveMetFromAvailable availableMb =
  if managerMinAvailableDiskMb < 1 then
    true
  else
    availableMb >= managerMinAvailableDiskMb

managerDiskHeadroomMetFromAvailable : Int -> Bool
managerDiskHeadroomMetFromAvailable availableMb =
  if managerMinDiskHeadroomMb < 1 then
    true
  else
    managerDiskHeadroomMbFromAvailable availableMb >= managerMinDiskHeadroomMb

managerMemoryReserveMetFromAvailable : Int -> Bool
managerMemoryReserveMetFromAvailable availableMb =
  resourceGuardMemoryReserveMet managerMinAvailableMemoryMb availableMb

managerMemoryLaunchRequiredMb : Int
managerMemoryLaunchRequiredMb =
  resourceGuardMemoryLaunchRequiredMb managerMinAvailableMemoryMb managerChildMemoryReserveMb

managerPlannerMemoryLaunchRequiredMb : Int
managerPlannerMemoryLaunchRequiredMb =
  resourceGuardMemoryLaunchRequiredMb managerMinAvailableMemoryMb managerPlannerMemoryReserveMb

managerBenchmarkMemoryLaunchRequiredMb : Int
managerBenchmarkMemoryLaunchRequiredMb =
  resourceGuardMemoryLaunchRequiredMb managerMinAvailableMemoryMb managerBenchmarkMemoryReserveMb

managerServiceMemoryLaunchRequiredMb : Int
managerServiceMemoryLaunchRequiredMb =
  resourceGuardMemoryLaunchRequiredMb managerMinAvailableMemoryMb managerServiceMemoryReserveMb

managerUpgradeMemoryLaunchRequiredMb : Int
managerUpgradeMemoryLaunchRequiredMb =
  resourceGuardMemoryLaunchRequiredMb managerMinAvailableMemoryMb managerUpgradeMemoryReserveMb

managerMemoryLaunchRequiredMbForActiveChildren : Int -> Int
managerMemoryLaunchRequiredMbForActiveChildren projectedActiveChildren =
  resourceGuardMemoryProjectedLaunchRequiredMb
    managerMinAvailableMemoryMb
    managerChildMemoryReserveMb
    projectedActiveChildren

managerExternalAgentProcessCount : Result Int
managerExternalAgentProcessCount =
  if managerExternalAgentReserveMb < 1 then
    Ok 0
  else if length managerExternalAgentProcessNames < 1 then
    Ok 0
  else
    hostUnmanagedProcessCountByName managerExternalAgentProcessNames

managerExternalAgentRssMb : Result Int
managerExternalAgentRssMb =
  if managerExternalAgentReserveMb < 1 then
    Ok 0
  else if length managerExternalAgentProcessNames < 1 then
    Ok 0
  else
    hostUnmanagedProcessRssMbByName managerExternalAgentProcessNames

managerExternalAgentReservedMemoryMbFromCount : Int -> Int
managerExternalAgentReservedMemoryMbFromCount externalAgentCount =
  resourceGuardExternalAgentReserveMb managerExternalAgentReserveMb externalAgentCount

managerExternalAgentReservedMemoryMbFromStats : Int -> Int -> Int
managerExternalAgentReservedMemoryMbFromStats externalAgentCount externalAgentRssMb =
  resourceGuardExternalAgentReservedMemoryMb managerExternalAgentReserveMb externalAgentCount externalAgentRssMb

managerExternalAgentPressure : Result ManagerExternalAgentPressure
managerExternalAgentPressure =
  match managerExternalAgentProcessCount {
    Err message -> Err message,
    Ok externalAgentCount ->
      match managerExternalAgentRssMb {
        Err message -> Err message,
        Ok externalAgentRssMb ->
          Ok (ManagerExternalAgentPressure {
            count = externalAgentCount,
            rssMb = externalAgentRssMb,
            reservedMemoryMb =
              managerExternalAgentReservedMemoryMbFromStats
                externalAgentCount
                externalAgentRssMb
          })
      }
  }

managerMemoryLaunchRequiredWithExternalMbForActiveChildren : Int -> Int -> Int
managerMemoryLaunchRequiredWithExternalMbForActiveChildren projectedActiveChildren externalAgentCount =
  resourceGuardMemoryProjectedLaunchRequiredWithExternalMb
    managerMinAvailableMemoryMb
    managerChildMemoryReserveMb
    projectedActiveChildren
    managerExternalAgentReserveMb
    externalAgentCount

managerMemoryLaunchRequiredWithExternalStatsMbForActiveChildren : Int -> Int -> Int -> Int
managerMemoryLaunchRequiredWithExternalStatsMbForActiveChildren projectedActiveChildren externalAgentCount externalAgentRssMb =
  resourceGuardMemoryProjectedLaunchRequiredWithExternalStatsMb
    managerMinAvailableMemoryMb
    managerChildMemoryReserveMb
    projectedActiveChildren
    managerExternalAgentReserveMb
    externalAgentCount
    externalAgentRssMb

managerPlannerMemoryLaunchRequiredWithExternalMb : Int -> Int
managerPlannerMemoryLaunchRequiredWithExternalMb externalAgentCount =
  intAdd
    managerPlannerMemoryLaunchRequiredMb
    (managerExternalAgentReservedMemoryMbFromCount externalAgentCount)

managerPlannerMemoryLaunchRequiredWithExternalStatsMb : Int -> Int -> Int
managerPlannerMemoryLaunchRequiredWithExternalStatsMb externalAgentCount externalAgentRssMb =
  intAdd
    managerPlannerMemoryLaunchRequiredMb
    (managerExternalAgentReservedMemoryMbFromStats externalAgentCount externalAgentRssMb)

managerBenchmarkMemoryLaunchRequiredWithExternalMb : Int -> Int
managerBenchmarkMemoryLaunchRequiredWithExternalMb externalAgentCount =
  intAdd
    managerBenchmarkMemoryLaunchRequiredMb
    (managerExternalAgentReservedMemoryMbFromCount externalAgentCount)

managerBenchmarkMemoryLaunchRequiredWithExternalStatsMb : Int -> Int -> Int
managerBenchmarkMemoryLaunchRequiredWithExternalStatsMb externalAgentCount externalAgentRssMb =
  intAdd
    managerBenchmarkMemoryLaunchRequiredMb
    (managerExternalAgentReservedMemoryMbFromStats externalAgentCount externalAgentRssMb)

managerServiceMemoryLaunchRequiredWithExternalMb : Int -> Int
managerServiceMemoryLaunchRequiredWithExternalMb externalAgentCount =
  intAdd
    managerServiceMemoryLaunchRequiredMb
    (managerExternalAgentReservedMemoryMbFromCount externalAgentCount)

managerServiceMemoryLaunchRequiredWithExternalStatsMb : Int -> Int -> Int
managerServiceMemoryLaunchRequiredWithExternalStatsMb externalAgentCount externalAgentRssMb =
  intAdd
    managerServiceMemoryLaunchRequiredMb
    (managerExternalAgentReservedMemoryMbFromStats externalAgentCount externalAgentRssMb)

managerUpgradeMemoryLaunchRequiredWithExternalMb : Int -> Int
managerUpgradeMemoryLaunchRequiredWithExternalMb externalAgentCount =
  intAdd
    managerUpgradeMemoryLaunchRequiredMb
    (managerExternalAgentReservedMemoryMbFromCount externalAgentCount)

managerUpgradeMemoryLaunchRequiredWithExternalStatsMb : Int -> Int -> Int
managerUpgradeMemoryLaunchRequiredWithExternalStatsMb externalAgentCount externalAgentRssMb =
  intAdd
    managerUpgradeMemoryLaunchRequiredMb
    (managerExternalAgentReservedMemoryMbFromStats externalAgentCount externalAgentRssMb)

managerMemoryLaunchHeadroomMbFromAvailable : Int -> Int
managerMemoryLaunchHeadroomMbFromAvailable availableMb =
  resourceGuardMemoryHeadroomMb managerMinAvailableMemoryMb availableMb

managerMemoryLaunchReserveMetFromAvailable : Int -> Bool
managerMemoryLaunchReserveMetFromAvailable availableMb =
  resourceGuardMemoryLaunchReserveMet managerMinAvailableMemoryMb managerChildMemoryReserveMb availableMb

managerMemoryProjectedLaunchReserveMetFromAvailable : Int -> Int -> Bool
managerMemoryProjectedLaunchReserveMetFromAvailable projectedActiveChildren availableMb =
  resourceGuardMemoryProjectedLaunchReserveMet
    managerMinAvailableMemoryMb
    managerChildMemoryReserveMb
    projectedActiveChildren
    availableMb

managerResourceHealthDiskSummary : Str
managerResourceHealthDiskSummary =
  match managerAvailableDiskMbAt managerDiskReserveResolvedPath {
    Err message ->
      textConcat [
        "disk: path=",
        managerDiskReserveResolvedPath,
        " availableMb=unknown requiredMb=",
        encode managerMinAvailableDiskMb,
        " requiredHeadroomMb=",
        encode managerMinDiskHeadroomMb,
        " error=",
        message
      ],
    Ok availableMb ->
      textConcat [
        "disk: path=",
        managerDiskReserveResolvedPath,
        " availableMb=",
        encode availableMb,
        " requiredMb=",
        encode managerMinAvailableDiskMb,
        " headroomMb=",
        encode (managerDiskHeadroomMbFromAvailable availableMb),
        " requiredHeadroomMb=",
        encode managerMinDiskHeadroomMb,
        " reserveMet=",
        managerResourceBoolText (managerDiskReserveMetFromAvailable availableMb),
        " headroomMet=",
        managerResourceBoolText (managerDiskHeadroomMetFromAvailable availableMb)
      ]
  }

managerResourceHealthMemorySummaryFromAvailable : Int -> Str
managerResourceHealthMemorySummaryFromAvailable availableMb =
  textConcat [
    "memory: availableMb=",
    encode availableMb,
    " requiredMb=",
    encode managerMinAvailableMemoryMb,
    " childReserveMb=",
    encode managerChildMemoryReserveMb,
    " launchRequiredMb=",
    encode managerMemoryLaunchRequiredMb,
    " launchHeadroomMb=",
    encode (managerMemoryLaunchHeadroomMbFromAvailable availableMb),
    " reserveMet=",
    managerResourceBoolText (managerMemoryReserveMetFromAvailable availableMb),
    " launchReserveMet=",
    managerResourceBoolText (managerMemoryLaunchReserveMetFromAvailable availableMb)
  ]

managerResourceHealthMemoryUnavailableSummary : Str -> Str
managerResourceHealthMemoryUnavailableSummary message =
  textConcat [
    "memory: availableMb=unknown requiredMb=",
    encode managerMinAvailableMemoryMb,
    " childReserveMb=",
    encode managerChildMemoryReserveMb,
    " launchRequiredMb=",
    encode managerMemoryLaunchRequiredMb,
    " error=",
    message
  ]

managerResourceHealthMemorySummary : Str
managerResourceHealthMemorySummary =
  match managerAvailableMemoryMb {
    Err message -> managerResourceHealthMemoryUnavailableSummary message,
    Ok availableMb -> managerResourceHealthMemorySummaryFromAvailable availableMb
  }

managerResourceHealthExternalAgentSummaryFromPressure : ManagerExternalAgentPressure -> Str
managerResourceHealthExternalAgentSummaryFromPressure pressure =
  textConcat [
    "external-agents: processNames=",
    encode managerExternalAgentProcessNames,
    " unmanagedCount=",
    encode pressure.count,
    " unmanagedRssMb=",
    encode pressure.rssMb,
    " reserveMb=",
    encode managerExternalAgentReserveMb,
    " reservedMemoryMb=",
    encode pressure.reservedMemoryMb
  ]

managerResourceHealthExternalAgentSummary : Str
managerResourceHealthExternalAgentSummary =
  match managerExternalAgentPressure {
    Err message ->
      textConcat [
        "external-agents: processNames=",
        encode managerExternalAgentProcessNames,
        " unmanagedCount=unknown unmanagedRssMb=unknown reserveMb=",
        encode managerExternalAgentReserveMb,
        " error=",
        message
      ],
    Ok pressure -> managerResourceHealthExternalAgentSummaryFromPressure pressure
  }

managerMemoryAdmissionDecisionWithExternalStatsForActiveChildren : Int -> Int -> Int -> Int -> ResourceGuardAdmissionDecision
managerMemoryAdmissionDecisionWithExternalStatsForActiveChildren projectedActiveChildren externalAgentCount externalAgentRssMb availableMb =
  resourceGuardMemoryAdmissionDecisionWithExternalStats
    managerMinAvailableMemoryMb
    managerChildMemoryReserveMb
    projectedActiveChildren
    managerExternalAgentReserveMb
    externalAgentCount
    externalAgentRssMb
    availableMb

managerMemoryConcurrencyDecisionWithExternalStats : Int -> Int -> Int -> ResourceGuardConcurrencyDecision
managerMemoryConcurrencyDecisionWithExternalStats externalAgentCount externalAgentRssMb availableMb =
  resourceGuardMemoryConcurrencyDecisionWithExternalStats
    managerMinAvailableMemoryMb
    managerChildMemoryReserveMb
    managerConfiguredMaxConcurrentChildren
    managerExternalAgentReserveMb
    externalAgentCount
    externalAgentRssMb
    availableMb

managerResourceHealthMemoryConcurrencySummaryFromDecision : ResourceGuardConcurrencyDecision -> Str
managerResourceHealthMemoryConcurrencySummaryFromDecision decision =
  textConcat [
    "memory-concurrency-admission: status=",
    decision.status,
    " reason=",
    decision.reason,
    " configuredMaxChildren=",
    encode decision.configuredMaxChildren,
    " capacityLimit=",
    encode decision.capacityLimit,
    " admittedChildCapacity=",
    encode decision.admittedChildCapacity,
    " effectiveMaxChildren=",
    encode decision.effectiveMaxChildren,
    " availableMb=",
    encode decision.availableMb,
    " requiredMb=",
    encode decision.requiredMb,
    " headroomMb=",
    encode decision.headroomMb,
    " childReserveMb=",
    encode decision.childReserveMb,
    " externalAgentReservedMb=",
    encode decision.externalAgentReservedMb,
    " action=",
    decision.recommendedAction
  ]

managerResourceHealthMemoryConcurrencySummaryFromAvailable : Int -> Str
managerResourceHealthMemoryConcurrencySummaryFromAvailable availableMb =
  match managerExternalAgentPressure {
    Err message ->
      textConcat [
        "memory-concurrency-admission: status=blocked reason=external-agent-stats-unavailable configuredMaxChildren=",
        encode managerConfiguredMaxConcurrentChildren,
        " admittedChildCapacity=0 effectiveMaxChildren=0 availableMb=",
        encode availableMb,
        " requiredMb=",
        encode (managerMemoryLaunchRequiredMbForActiveChildren managerConfiguredMaxConcurrentChildren),
        " headroomMb=",
        encode (managerMemoryLaunchHeadroomMbFromAvailable availableMb),
        " action=wait-for-external-agent-pressure-or-lower-concurrency error=",
        message
      ],
    Ok pressure ->
      managerResourceHealthMemoryConcurrencySummaryFromDecision
        (managerMemoryConcurrencyDecisionWithExternalStats pressure.count pressure.rssMb availableMb)
  }

managerResourceHealthMemoryConcurrencySummary : Str
managerResourceHealthMemoryConcurrencySummary =
  if managerResourceGuardEnabled == false then
    textConcat [
      "memory-concurrency-admission: status=admitted reason=guard-disabled configuredMaxChildren=",
      encode managerConfiguredMaxConcurrentChildren,
      " admittedChildCapacity=",
      encode managerConfiguredMaxConcurrentChildren,
      " effectiveMaxChildren=",
      encode managerConfiguredMaxConcurrentChildren,
      " action=launch-managed-job"
    ]
  else
    match managerAvailableMemoryMb {
      Err message ->
        textConcat [
          "memory-concurrency-admission: status=blocked reason=host-memory-stats-unavailable configuredMaxChildren=",
          encode managerConfiguredMaxConcurrentChildren,
          " admittedChildCapacity=0 effectiveMaxChildren=0 requiredMb=",
          encode (managerMemoryLaunchRequiredMbForActiveChildren managerConfiguredMaxConcurrentChildren),
          " action=wait-for-memory-or-lower-concurrency-before-launch error=",
          message
        ],
      Ok availableMb -> managerResourceHealthMemoryConcurrencySummaryFromAvailable availableMb
    }

managerResourceHealthMemoryAdmissionSummaryFromDecision : ResourceGuardAdmissionDecision -> Str
managerResourceHealthMemoryAdmissionSummaryFromDecision decision =
  textConcat [
    "memory-admission: status=",
    decision.status,
    " reason=",
    decision.reason,
    " availableMb=",
    encode decision.availableMb,
    " requiredMb=",
    encode decision.requiredMb,
    " headroomMb=",
    encode decision.headroomMb,
    " projectedActiveChildren=",
    encode decision.projectedActiveChildren,
    " externalAgentReservedMb=",
    encode decision.externalAgentReservedMb,
    " action=",
    decision.recommendedAction
  ]

managerResourceHealthMemoryAdmissionSummaryFromAvailableForActiveChildren : Int -> Int -> Str
managerResourceHealthMemoryAdmissionSummaryFromAvailableForActiveChildren projectedActiveChildren availableMb =
  match managerExternalAgentPressure {
    Err message ->
      textConcat [
        "memory-admission: status=blocked reason=external-agent-stats-unavailable availableMb=",
        encode availableMb,
        " requiredMb=",
        encode (managerMemoryLaunchRequiredMbForActiveChildren projectedActiveChildren),
        " headroomMb=",
        encode (managerMemoryLaunchHeadroomMbFromAvailable availableMb),
        " projectedActiveChildren=",
        encode (resourceGuardProjectedChildCount projectedActiveChildren),
        " action=wait-for-external-agent-pressure-or-lower-concurrency error=",
        message
      ],
    Ok pressure ->
      managerResourceHealthMemoryAdmissionSummaryFromDecision
        (managerMemoryAdmissionDecisionWithExternalStatsForActiveChildren
          projectedActiveChildren
          pressure.count
          pressure.rssMb
          availableMb)
  }

managerResourceHealthMemoryAdmissionSummaryForActiveChildren : Int -> Str
managerResourceHealthMemoryAdmissionSummaryForActiveChildren projectedActiveChildren =
  if managerResourceGuardEnabled == false then
    "memory-admission: status=admitted reason=guard-disabled action=launch-managed-job"
  else
    match managerAvailableMemoryMb {
      Err message ->
        textConcat [
          "memory-admission: status=blocked reason=host-memory-stats-unavailable requiredMb=",
          encode (managerMemoryLaunchRequiredMbForActiveChildren projectedActiveChildren),
          " projectedActiveChildren=",
          encode (resourceGuardProjectedChildCount projectedActiveChildren),
          " action=wait-for-memory-or-stop-only-managed-jobs-by-metadata error=",
          message
        ],
      Ok availableMb ->
        managerResourceHealthMemoryAdmissionSummaryFromAvailableForActiveChildren
          projectedActiveChildren
          availableMb
    }

managerResourceHealthMemoryAdmissionSummary : Str
managerResourceHealthMemoryAdmissionSummary =
  managerResourceHealthMemoryAdmissionSummaryForActiveChildren 1

