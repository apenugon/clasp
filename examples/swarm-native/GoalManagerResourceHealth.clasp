        else if managerMinDiskHeadroomMb > 0 && managerDiskHeadroomMbFromAvailable availableMb < managerMinDiskHeadroomMb then
          managerScopedDiskHeadroomResourceGuardBlockMessage scope (encode availableMb) (encode (managerDiskHeadroomMbFromAvailable availableMb))
        else
          ""
    }

