managerScopedMemoryResourceGuardBlockMessage : Str -> Str -> Int -> Int -> Str -> Str -> Str
managerScopedMemoryResourceGuardBlockMessage scope reserveName reserveMb launchRequiredMb availableText headroomText =
  textConcat [
    "manager resource guard blocked ",
    scope,
    " launch: memory ",
    scope,
    " reserve unmet: availableMb=",
    availableText,
    ":requiredMb=",
    encode managerMinAvailableMemoryMb,
    ":",
    reserveName,
    "=",
    encode reserveMb,
    ":launchRequiredMb=",
    encode launchRequiredMb,
    ":launchHeadroomMb=",
    headroomText
  ]

managerProjectedChildMemoryResourceGuardBlockMessage : Int -> Str -> Str -> Str
managerProjectedChildMemoryResourceGuardBlockMessage projectedActiveChildren availableText headroomText =
  textConcat [
    "manager resource guard blocked child launch: memory projected child reserve unmet: availableMb=",
    availableText,
    ":requiredMb=",
    encode managerMinAvailableMemoryMb,
    ":childReserveMb=",
    encode managerChildMemoryReserveMb,
    ":projectedActiveChildren=",
    encode (resourceGuardProjectedChildCount projectedActiveChildren),
    ":launchRequiredMb=",
    encode (managerMemoryLaunchRequiredMbForActiveChildren projectedActiveChildren),
    ":launchHeadroomMb=",
    headroomText
  ]

managerExternalAgentMemoryResourceGuardBlockMessage : Int -> Int -> Int -> Str -> Str -> Str
managerExternalAgentMemoryResourceGuardBlockMessage projectedActiveChildren externalAgentCount externalAgentRssMb availableText headroomText =
  textConcat [
    "manager resource guard blocked child launch: memory external agent reserve unmet: availableMb=",
    availableText,
    ":requiredMb=",
    encode managerMinAvailableMemoryMb,
    ":childReserveMb=",
    encode managerChildMemoryReserveMb,
    ":projectedActiveChildren=",
    encode (resourceGuardProjectedChildCount projectedActiveChildren),
    ":externalAgentReserveMb=",
    encode managerExternalAgentReserveMb,
    ":externalAgentProcessNames=",
    encode managerExternalAgentProcessNames,
    ":externalAgentCount=",
    encode externalAgentCount,
    ":externalAgentRssMb=",
    encode externalAgentRssMb,
    ":externalAgentReservedMb=",
    encode (managerExternalAgentReservedMemoryMbFromStats externalAgentCount externalAgentRssMb),
    ":launchRequiredMb=",
    encode (managerMemoryLaunchRequiredWithExternalStatsMbForActiveChildren projectedActiveChildren externalAgentCount externalAgentRssMb),
    ":launchHeadroomMb=",
    headroomText
  ]

