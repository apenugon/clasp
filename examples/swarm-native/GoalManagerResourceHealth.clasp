managerScopedExternalAgentMemoryResourceGuardBlockMessage : Str -> Str -> Int -> Int -> Int -> Int -> Str -> Str -> Str
managerScopedExternalAgentMemoryResourceGuardBlockMessage scope reserveName reserveMb launchRequiredMb externalAgentCount externalAgentRssMb availableText headroomText =
  textConcat [
    "manager resource guard blocked ",
    scope,
    " launch: memory external agent reserve unmet: availableMb=",
    availableText,
    ":requiredMb=",
    encode managerMinAvailableMemoryMb,
    ":",
    reserveName,
    "=",
    encode reserveMb,
    ":externalAgentReserveMb=",
    encode managerExternalAgentReserveMb,
    ":externalAgentProcessNames=",
    encode managerExternalAgentProcessNames,
    ":externalAgentCount=",
    encode externalAgentCount,
    ":externalAgentRssMb=",
    encode externalAgentRssMb,
    ":externalAgentReservedMb=",
    encode (managerExternalAgentReservedMemoryMbFromStats externalAgentCount externalAgentRssMb),
    ":launchRequiredMb=",
    encode launchRequiredMb,
    ":launchHeadroomMb=",
    headroomText
