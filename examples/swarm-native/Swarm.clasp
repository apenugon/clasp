embeddedMemoryFromMemory : SwarmMemory -> Result SwarmEmbeddedMemory
embeddedMemoryFromMemory memory =
  match tryDecode SwarmEmbeddedMemoryValue memory.value {
    Ok value ->
      Ok (SwarmEmbeddedMemory {
        memory = memory,
        text = value.text,
        embedding = value.embedding
      }),
    Err message ->
      embeddedMemoryResultError message
  }

embeddedMemoriesFromMemory : [SwarmMemory] -> [SwarmEmbeddedMemory]
embeddedMemoriesFromMemory memories = {
  let mut decoded = [];
  for memory in memories {
    match embeddedMemoryFromMemory memory {
      Ok embedded -> {
        decoded = append decoded [embedded];
        decoded
      },
      Err message ->
        decoded
    }
  };
  decoded
}

weightedEmbeddedMemoryFromMemory : SwarmMemory -> Result SwarmWeightedEmbeddedMemory
weightedEmbeddedMemoryFromMemory memory =
  match tryDecode SwarmWeightedEmbeddedMemoryValue memory.value {
    Ok value ->
      Ok (SwarmWeightedEmbeddedMemory {
        memory = memory,
        text = value.text,
        embedding = value.embedding
      }),
    Err message ->
      weightedEmbeddedMemoryResultError message
  }

weightedEmbeddedMemoriesFromMemory : [SwarmMemory] -> [SwarmWeightedEmbeddedMemory]
weightedEmbeddedMemoriesFromMemory memories = {
  let mut decoded = [];
  for memory in memories {
    match weightedEmbeddedMemoryFromMemory memory {
      Ok embedded -> {
        decoded = append decoded [embedded];
        decoded
      },
      Err message ->
        decoded
    }
  };
  decoded
}

