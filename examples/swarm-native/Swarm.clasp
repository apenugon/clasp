firstRunStatus : Str -> SwarmRun -> Str
firstRunStatus current run = if current == "" then run.status else current

firstRunName : Str -> SwarmRun -> Str
firstRunName current run = if current == "" then run.name else current

firstVerifierStatus : Str -> SwarmRun -> Str
firstVerifierStatus current run =
  if current == "" then
    if run.role == "verifier" then run.status else ""
  else
    current

firstVerifierName : Str -> SwarmRun -> Str
firstVerifierName current run =
  if current == "" then
    if run.role == "verifier" then run.name else ""
  else
    current

artifactKind : SwarmArtifact -> Str
artifactKind artifact = artifact.kind

artifactPath : SwarmArtifact -> Str
artifactPath artifact = artifact.path

readyTaskId : SwarmTask -> Str
readyTaskId task = task.taskId

swarmTextSearchStep : SwarmTextSearch -> Str -> SwarmTextSearch
swarmTextSearchStep search value =
  if search.found then
    search
  else
    SwarmTextSearch { wanted = search.wanted, found = value == search.wanted }

swarmTextListHas : Str -> [Str] -> Bool
swarmTextListHas wanted values =
  (fold swarmTextSearchStep (SwarmTextSearch { wanted = wanted, found = false }) values).found

swarmSparseEmbedding : Str -> [Str] -> SwarmSparseEmbedding
swarmSparseEmbedding model dimensions =
  SwarmSparseEmbedding {
    model = model,
    dimensions = dimensions
  }

swarmEmbeddedMemoryValue : Str -> SwarmSparseEmbedding -> SwarmEmbeddedMemoryValue
swarmEmbeddedMemoryValue text embedding =
  SwarmEmbeddedMemoryValue {
    text = text,
    embedding = embedding
  }

swarmEmbeddedMemoryText : Str -> SwarmSparseEmbedding -> Str
swarmEmbeddedMemoryText text embedding =
  encode (swarmEmbeddedMemoryValue text embedding)

swarmSparseEmbeddingMatchedDimensions : SwarmSparseEmbedding -> SwarmSparseEmbedding -> [Str]
swarmSparseEmbeddingMatchedDimensions query candidate = {
  let mut matches = [];
  for dimension in query.dimensions {
    if swarmTextListHas dimension candidate.dimensions then {
      matches = append matches [dimension];
      matches
    } else
      matches
  };
  matches
}

swarmSparseEmbeddingScore : SwarmSparseEmbedding -> SwarmSparseEmbedding -> Int
swarmSparseEmbeddingScore query candidate =
  if query.model == candidate.model then
    length (swarmSparseEmbeddingMatchedDimensions query candidate)
  else
    0

swarmEmbeddedMemorySearchResult : SwarmSparseEmbedding -> SwarmEmbeddedMemory -> SwarmEmbeddedMemorySearchResult
swarmEmbeddedMemorySearchResult query embedded = {
  let matched = swarmSparseEmbeddingMatchedDimensions query embedded.embedding;
  SwarmEmbeddedMemorySearchResult {
    memory = embedded.memory,
    text = embedded.text,
    score = if query.model == embedded.embedding.model then length matched else 0,
    matchedDimensions = matched,
    model = embedded.embedding.model
  }
}

swarmEmbeddedMemorySearchInsert : [SwarmEmbeddedMemorySearchResult] -> SwarmEmbeddedMemorySearchResult -> [SwarmEmbeddedMemorySearchResult]
swarmEmbeddedMemorySearchInsert ranked candidate = {
  let mut next = [];
  let mut inserted = false;
  for existing in ranked {
    if inserted then {
      next = append next [existing];
      next
    } else if candidate.score > existing.score then {
      next = append next [candidate, existing];
      inserted = true;
      next
    } else {
      next = append next [existing];
      next
    }
  };
  if inserted then
    next
  else
    append next [candidate]
}

swarmEmbeddedMemorySearchLimit : Int -> [SwarmEmbeddedMemorySearchResult] -> [SwarmEmbeddedMemorySearchResult]
swarmEmbeddedMemorySearchLimit limit ranked = {
  let mut kept = [];
  for item in ranked {
    if length kept < limit then {
      kept = append kept [item];
      kept
    } else
      kept
  };
  kept
}

swarmEmbeddedMemorySearch : SwarmSparseEmbedding -> [SwarmEmbeddedMemory] -> Int -> [SwarmEmbeddedMemorySearchResult]
swarmEmbeddedMemorySearch query candidates limit = {
  let mut ranked = [];
  for candidate in candidates {
    let result = swarmEmbeddedMemorySearchResult query candidate;
    if result.score > 0 then {
      ranked = swarmEmbeddedMemorySearchLimit limit (swarmEmbeddedMemorySearchInsert ranked result);
      ranked
    } else
      ranked
  };
  ranked
}

swarmEmbeddedMemorySearchFromMemory : SwarmSparseEmbedding -> [SwarmMemory] -> Int -> [SwarmEmbeddedMemorySearchResult]
swarmEmbeddedMemorySearchFromMemory query memories limit =
  swarmEmbeddedMemorySearch query (embeddedMemoriesFromMemory memories) limit

swarmEmbeddedMemorySearchResultText : SwarmEmbeddedMemorySearchResult -> Str
swarmEmbeddedMemorySearchResultText result = result.text

swarmEmbeddedMemorySearchResultScore : SwarmEmbeddedMemorySearchResult -> Int
swarmEmbeddedMemorySearchResultScore result = result.score

swarmWeightedEmbeddingDimension : Str -> Int -> SwarmWeightedEmbeddingDimension
swarmWeightedEmbeddingDimension name weight =
  SwarmWeightedEmbeddingDimension {
    name = name,
    weight = weight
  }

swarmWeightedEmbedding : Str -> Int -> [SwarmWeightedEmbeddingDimension] -> SwarmWeightedEmbedding
swarmWeightedEmbedding model scale dimensions =
  SwarmWeightedEmbedding {
    model = model,
    scale = scale,
    dimensions = dimensions
  }

swarmWeightedEmbeddedMemoryValue : Str -> SwarmWeightedEmbedding -> SwarmWeightedEmbeddedMemoryValue
swarmWeightedEmbeddedMemoryValue text embedding =
  SwarmWeightedEmbeddedMemoryValue {
    text = text,
    embedding = embedding
  }

swarmWeightedEmbeddedMemoryText : Str -> SwarmWeightedEmbedding -> Str
swarmWeightedEmbeddedMemoryText text embedding =
  encode (swarmWeightedEmbeddedMemoryValue text embedding)

swarmWeightedDimensionOverlapScore : SwarmWeightedEmbeddingDimension -> SwarmWeightedEmbeddingDimension -> Int
swarmWeightedDimensionOverlapScore query candidate =
  if query.name == candidate.name then
    if query.weight < candidate.weight then query.weight else candidate.weight
  else
    0

swarmWeightedDimensionBestScore : SwarmWeightedEmbeddingDimension -> [SwarmWeightedEmbeddingDimension] -> Int
swarmWeightedDimensionBestScore query candidates = {
  let mut best = 0;
  for candidate in candidates {
    let score = swarmWeightedDimensionOverlapScore query candidate;
    if score > best then {
      best = score;
      best
    } else
      best
  };
  best
}

swarmWeightedEmbeddingMatchedDimensions : SwarmWeightedEmbedding -> SwarmWeightedEmbedding -> [Str]
swarmWeightedEmbeddingMatchedDimensions query candidate = {
  let mut matches = [];
  if query.model == candidate.model then
    if query.scale == candidate.scale then {
      for dimension in query.dimensions {
        if swarmWeightedDimensionBestScore dimension candidate.dimensions > 0 then {
          matches = append matches [dimension.name];
          matches
        } else
          matches
      };
      matches
    } else
      matches
  else
    matches
}

swarmWeightedEmbeddingScore : SwarmWeightedEmbedding -> SwarmWeightedEmbedding -> Int
swarmWeightedEmbeddingScore query candidate = {
  let mut score = 0;
  if query.model == candidate.model then
    if query.scale == candidate.scale then {
      for dimension in query.dimensions {
        score = intAdd score (swarmWeightedDimensionBestScore dimension candidate.dimensions);
        score
      };
      score
    } else
      0
  else
    0
}

swarmWeightedEmbeddedMemorySearchResult : SwarmWeightedEmbedding -> SwarmWeightedEmbeddedMemory -> SwarmWeightedEmbeddedMemorySearchResult
swarmWeightedEmbeddedMemorySearchResult query embedded =
  SwarmWeightedEmbeddedMemorySearchResult {
    memory = embedded.memory,
    text = embedded.text,
    score = swarmWeightedEmbeddingScore query embedded.embedding,
    matchedDimensions = swarmWeightedEmbeddingMatchedDimensions query embedded.embedding,
    model = embedded.embedding.model,
    scale = embedded.embedding.scale
  }

swarmWeightedEmbeddedMemorySearchInsert : [SwarmWeightedEmbeddedMemorySearchResult] -> SwarmWeightedEmbeddedMemorySearchResult -> [SwarmWeightedEmbeddedMemorySearchResult]
swarmWeightedEmbeddedMemorySearchInsert ranked candidate = {
  let mut next = [];
  let mut inserted = false;
  for existing in ranked {
    if inserted then {
      next = append next [existing];
      next
    } else if candidate.score > existing.score then {
      next = append next [candidate, existing];
      inserted = true;
      next
    } else {
      next = append next [existing];
      next
    }
  };
  if inserted then
    next
  else
    append next [candidate]
}

swarmWeightedEmbeddedMemorySearchLimit : Int -> [SwarmWeightedEmbeddedMemorySearchResult] -> [SwarmWeightedEmbeddedMemorySearchResult]
swarmWeightedEmbeddedMemorySearchLimit limit ranked = {
  let mut kept = [];
  for item in ranked {
    if length kept < limit then {
      kept = append kept [item];
      kept
    } else
      kept
  };
  kept
}

swarmWeightedEmbeddedMemorySearch : SwarmWeightedEmbedding -> [SwarmWeightedEmbeddedMemory] -> Int -> [SwarmWeightedEmbeddedMemorySearchResult]
swarmWeightedEmbeddedMemorySearch query candidates limit = {
  let mut ranked = [];
  for candidate in candidates {
    let result = swarmWeightedEmbeddedMemorySearchResult query candidate;
    if result.score > 0 then {
      ranked = swarmWeightedEmbeddedMemorySearchLimit limit (swarmWeightedEmbeddedMemorySearchInsert ranked result);
      ranked
    } else
      ranked
  };
  ranked
}

swarmWeightedEmbeddedMemorySearchFromMemory : SwarmWeightedEmbedding -> [SwarmMemory] -> Int -> [SwarmWeightedEmbeddedMemorySearchResult]
swarmWeightedEmbeddedMemorySearchFromMemory query memories limit =
  swarmWeightedEmbeddedMemorySearch query (weightedEmbeddedMemoriesFromMemory memories) limit

swarmWeightedEmbeddedMemorySearchResultText : SwarmWeightedEmbeddedMemorySearchResult -> Str
swarmWeightedEmbeddedMemorySearchResultText result = result.text

swarmWeightedEmbeddedMemorySearchResultScore : SwarmWeightedEmbeddedMemorySearchResult -> Int
swarmWeightedEmbeddedMemorySearchResultScore result = result.score

swarmTextIncludes : Str -> Str -> Bool
swarmTextIncludes value needle = length (textSplit value needle) > 1

swarmEmbeddingProviderRequest : Str -> Str -> Str -> Int -> SwarmEmbeddingProviderRequest
swarmEmbeddingProviderRequest provider model inputText scale =
  SwarmEmbeddingProviderRequest {
    provider = provider,
    model = model,
    inputText = inputText,
    scale = scale,
    schemaVersion = 1
  }

swarmUntrustedEmbeddingProviderOutput : Str -> Str -> Str -> Str -> Bool -> UntrustedEmbeddingProviderOutput
swarmUntrustedEmbeddingProviderOutput provider model status rawText trusted =
  UntrustedEmbeddingProviderOutput {
    provider = provider,
    model = model,
    status = status,
    rawText = rawText,
    trusted = trusted
  }

trustedWeightedEmbeddingProviderOutput : Str -> Str -> SwarmWeightedEmbedding -> TrustedWeightedEmbeddingProviderOutput
trustedWeightedEmbeddingProviderOutput provider model embedding =
  TrustedWeightedEmbeddingProviderOutput {
    provider = provider,
    model = model,
    trust = "validated",
    embedding = embedding
  }

trustedWeightedEmbeddingProviderOutputResultError : Str -> Result TrustedWeightedEmbeddingProviderOutput
trustedWeightedEmbeddingProviderOutputResultError message = Err message

swarmAppendWeightedDimensionIf : [SwarmWeightedEmbeddingDimension] -> Bool -> Str -> Int -> [SwarmWeightedEmbeddingDimension]
swarmAppendWeightedDimensionIf dimensions include name weight =
  if include then
    append dimensions [swarmWeightedEmbeddingDimension name weight]
  else
    dimensions

swarmLocalWeightedEmbeddingDimensionsForText : Str -> [SwarmWeightedEmbeddingDimension]
swarmLocalWeightedEmbeddingDimensionsForText text =
  swarmAppendWeightedDimensionIf
    (swarmAppendWeightedDimensionIf
      (swarmAppendWeightedDimensionIf
        (swarmAppendWeightedDimensionIf
          (swarmAppendWeightedDimensionIf
            []
            (swarmTextIncludes text "compiler")
            "compiler"
            800)
          (swarmTextIncludes text "runtime")
          "runtime"
          700)
        (swarmTextIncludes text "verifier")
        "verification"
        500)
      (swarmTextIncludes text "guard")
      "resource-guard"
      600)
    (swarmTextIncludes text "swarm")
    "swarm"
    400

swarmLocalWeightedEmbeddingForText : Str -> Int -> Str -> SwarmWeightedEmbedding
swarmLocalWeightedEmbeddingForText model scale text =
  swarmWeightedEmbedding model scale (swarmLocalWeightedEmbeddingDimensionsForText text)

swarmLocalWeightedEmbeddingProviderOutput : SwarmEmbeddingProviderRequest -> UntrustedEmbeddingProviderOutput
swarmLocalWeightedEmbeddingProviderOutput request =
  swarmUntrustedEmbeddingProviderOutput
    request.provider
    request.model
    "ok"
    (encode (swarmLocalWeightedEmbeddingForText request.model request.scale request.inputText))
    false

validateWeightedEmbeddingProviderOutput : SwarmEmbeddingProviderRequest -> UntrustedEmbeddingProviderOutput -> Result TrustedWeightedEmbeddingProviderOutput
validateWeightedEmbeddingProviderOutput request output =
  if output.trusted then
    trustedWeightedEmbeddingProviderOutputResultError "embedding provider output arrived pretrusted"
  else if output.status != "ok" then
    trustedWeightedEmbeddingProviderOutputResultError output.status
  else if output.provider != request.provider then
    trustedWeightedEmbeddingProviderOutputResultError "embedding provider mismatch"
  else if output.model != request.model then
    trustedWeightedEmbeddingProviderOutputResultError "embedding model mismatch"
  else
    match tryDecode SwarmWeightedEmbedding output.rawText {
      Ok embedding ->
        if embedding.model != request.model then
          trustedWeightedEmbeddingProviderOutputResultError "embedding payload model mismatch"
        else if embedding.scale != request.scale then
          trustedWeightedEmbeddingProviderOutputResultError "embedding payload scale mismatch"
        else
          Ok (trustedWeightedEmbeddingProviderOutput request.provider request.model embedding),
      Err message ->
        trustedWeightedEmbeddingProviderOutputResultError message
    }

swarmEmbeddingProviderCommandTransport : Str -> Int -> [Str] -> SwarmEmbeddingProviderCommandTransport
swarmEmbeddingProviderCommandTransport cwd timeoutMs commandTemplate =
  SwarmEmbeddingProviderCommandTransport {
    cwd = cwd,
    timeoutMs = timeoutMs,
    commandTemplate = commandTemplate
  }

swarmEmbeddingProviderNetworkAdapter : Str -> Str -> Str -> Str -> Str -> Str -> Str -> SwarmEmbeddingProviderCommandTransport -> SwarmEmbeddingProviderNetworkAdapter
swarmEmbeddingProviderNetworkAdapter provider model endpoint authMode authEnvVar networkAccess allowedDestination transport =
  SwarmEmbeddingProviderNetworkAdapter {
    provider = provider,
    model = model,
    endpoint = endpoint,
    authMode = authMode,
    authEnvVar = authEnvVar,
    networkAccess = networkAccess,
    allowedDestination = allowedDestination,
    transport = transport
  }

swarmEmbeddingProviderNetworkAdapterCommandTransport : Str -> Int -> Str -> SwarmEmbeddingProviderCommandTransport
swarmEmbeddingProviderNetworkAdapterCommandTransport cwd timeoutMs commandPath =
  swarmEmbeddingProviderCommandTransport
    cwd
    timeoutMs
    [
      commandPath,
      "--endpoint",
      "{endpoint}",
      "--auth-env",
      "{auth_env}",
      "--network-destination",
      "{network_destination}",
      "--provider",
      "{provider}",
      "--model",
      "{model}",
      "--input",
      "{input_text}",
      "--scale",
      "{scale}"
    ]

swarmEmbeddingProviderBearerNetworkAdapter : Str -> Str -> Str -> Str -> Str -> Str -> Int -> Str -> SwarmEmbeddingProviderNetworkAdapter
swarmEmbeddingProviderBearerNetworkAdapter provider model endpoint authEnvVar allowedDestination cwd timeoutMs commandPath =
  swarmEmbeddingProviderNetworkAdapter
    provider
    model
    endpoint
    "bearer-env"
    authEnvVar
    "allowlisted"
    allowedDestination
    (swarmEmbeddingProviderNetworkAdapterCommandTransport cwd timeoutMs commandPath)

swarmOpenAiEmbeddingProviderNetworkAdapter : Str -> Str -> Int -> Str -> SwarmEmbeddingProviderNetworkAdapter
swarmOpenAiEmbeddingProviderNetworkAdapter model cwd timeoutMs commandPath =
  swarmEmbeddingProviderBearerNetworkAdapter
    "openai"
    model
    "https://api.openai.com/v1/embeddings"
    "OPENAI_API_KEY"
    "api.openai.com:443"
    cwd
    timeoutMs
    commandPath

swarmTextHasPrefix : Str -> Str -> Bool
swarmTextHasPrefix value prefix =
  match textPrefix value prefix {
    Ok remainder -> true,
    Err message -> false
  }

swarmEmbeddingProviderNetworkAdapterEndpointHttps : SwarmEmbeddingProviderNetworkAdapter -> Bool
swarmEmbeddingProviderNetworkAdapterEndpointHttps adapter =
  swarmTextHasPrefix adapter.endpoint "https://"

swarmEmbeddingProviderNetworkAdapterAuthValid : SwarmEmbeddingProviderNetworkAdapter -> Bool
swarmEmbeddingProviderNetworkAdapterAuthValid adapter =
  if adapter.authMode == "bearer-env" then
    adapter.authEnvVar != ""
  else if adapter.authMode == "header-env" then
    adapter.authEnvVar != ""
  else
    adapter.authMode == "none"

swarmEmbeddingProviderNetworkAdapterAuthenticated : SwarmEmbeddingProviderNetworkAdapter -> Bool
swarmEmbeddingProviderNetworkAdapterAuthenticated adapter =
  if adapter.authMode == "bearer-env" then
    adapter.authEnvVar != ""
  else if adapter.authMode == "header-env" then
    adapter.authEnvVar != ""
  else
    false

swarmEmbeddingProviderNetworkAdapterAllowlisted : SwarmEmbeddingProviderNetworkAdapter -> Bool
swarmEmbeddingProviderNetworkAdapterAllowlisted adapter =
  if adapter.networkAccess == "allowlisted" then
    adapter.allowedDestination != ""
  else
    false

swarmEmbeddingProviderNetworkAdapterCommandHasEndpoint : SwarmEmbeddingProviderNetworkAdapter -> Bool
swarmEmbeddingProviderNetworkAdapterCommandHasEndpoint adapter =
  swarmEmbeddingProviderCommandTemplateContains adapter.transport "{endpoint}"

swarmEmbeddingProviderNetworkAdapterCommandHasAuthEnv : SwarmEmbeddingProviderNetworkAdapter -> Bool
swarmEmbeddingProviderNetworkAdapterCommandHasAuthEnv adapter =
  swarmEmbeddingProviderCommandTemplateContains adapter.transport "{auth_env}"

swarmEmbeddingProviderNetworkAdapterCommandHasNetworkDestination : SwarmEmbeddingProviderNetworkAdapter -> Bool
swarmEmbeddingProviderNetworkAdapterCommandHasNetworkDestination adapter =
  swarmEmbeddingProviderCommandTemplateContains adapter.transport "{network_destination}"

swarmEmbeddingProviderNetworkAdapterValidationMessage : SwarmEmbeddingProviderNetworkAdapter -> Str
swarmEmbeddingProviderNetworkAdapterValidationMessage adapter =
  if adapter.provider == "" then
    "embedding-provider-network-adapter-missing-provider"
  else if adapter.model == "" then
    "embedding-provider-network-adapter-missing-model"
  else if swarmEmbeddingProviderNetworkAdapterEndpointHttps adapter == false then
    "embedding-provider-network-adapter-endpoint-not-https"
  else if swarmEmbeddingProviderNetworkAdapterAuthValid adapter == false then
    "embedding-provider-network-adapter-auth-invalid"
  else if swarmEmbeddingProviderNetworkAdapterAllowlisted adapter == false then
    "embedding-provider-network-adapter-network-not-allowlisted"
  else if swarmEmbeddingProviderCommandValidationMessage adapter.transport != "" then
    swarmEmbeddingProviderCommandValidationMessage adapter.transport
  else if swarmEmbeddingProviderNetworkAdapterCommandHasEndpoint adapter == false then
    "embedding-provider-network-adapter-missing-endpoint-placeholder"
  else if adapter.authMode != "none" && swarmEmbeddingProviderNetworkAdapterCommandHasAuthEnv adapter == false then
    "embedding-provider-network-adapter-missing-auth-env-placeholder"
  else if swarmEmbeddingProviderNetworkAdapterCommandHasNetworkDestination adapter == false then
    "embedding-provider-network-adapter-missing-network-destination-placeholder"
  else
    ""

swarmEmbeddingProviderNetworkAdapterSummary : SwarmEmbeddingProviderNetworkAdapter -> SwarmEmbeddingProviderNetworkAdapterSummary
swarmEmbeddingProviderNetworkAdapterSummary adapter = {
  let validationMessage = swarmEmbeddingProviderNetworkAdapterValidationMessage adapter;
  SwarmEmbeddingProviderNetworkAdapterSummary {
    valid = validationMessage == "",
    status = if validationMessage == "" then "valid" else "invalid",
    provider = adapter.provider,
    model = adapter.model,
    endpoint = adapter.endpoint,
    authMode = adapter.authMode,
    authEnvVar = adapter.authEnvVar,
    networkAccess = adapter.networkAccess,
    allowedDestination = adapter.allowedDestination,
    commandValid = swarmEmbeddingProviderCommandValid adapter.transport,
    endpointHttps = swarmEmbeddingProviderNetworkAdapterEndpointHttps adapter,
    authenticated = swarmEmbeddingProviderNetworkAdapterAuthenticated adapter,
    allowlisted = swarmEmbeddingProviderNetworkAdapterAllowlisted adapter,
    commandHasEndpoint = swarmEmbeddingProviderNetworkAdapterCommandHasEndpoint adapter,
    commandHasAuthEnv = swarmEmbeddingProviderNetworkAdapterCommandHasAuthEnv adapter,
    commandHasNetworkDestination = swarmEmbeddingProviderNetworkAdapterCommandHasNetworkDestination adapter,
    validationMessage = validationMessage
  }
}

swarmEmbeddingProviderProcessResultError : Str -> Result SwarmEmbeddingProviderProcessResult
swarmEmbeddingProviderProcessResultError message = Err message

swarmEmbeddingProviderProcessResultFromJson : Result Str -> Result SwarmEmbeddingProviderProcessResult
swarmEmbeddingProviderProcessResultFromJson value = match value {
  Ok raw -> Ok (decode SwarmEmbeddingProviderProcessResult raw),
  Err message -> swarmEmbeddingProviderProcessResultError message
}

swarmEmbeddingProviderCommandTemplateContains : SwarmEmbeddingProviderCommandTransport -> Str -> Bool
swarmEmbeddingProviderCommandTemplateContains transport needle = {
  let mut found = false;
  for arg in transport.commandTemplate {
    if found then
      found
    else {
      found = swarmTextIncludes arg needle;
      found
    }
  };
  found
}

swarmEmbeddingProviderCommandHasTextInput : SwarmEmbeddingProviderCommandTransport -> Bool
swarmEmbeddingProviderCommandHasTextInput transport =
  swarmEmbeddingProviderCommandTemplateContains transport "{input_text}"

swarmEmbeddingProviderCommandHasJsonInput : SwarmEmbeddingProviderCommandTransport -> Bool
swarmEmbeddingProviderCommandHasJsonInput transport =
  swarmEmbeddingProviderCommandTemplateContains transport "{input_json}"

swarmEmbeddingProviderCommandValidationMessage : SwarmEmbeddingProviderCommandTransport -> Str
swarmEmbeddingProviderCommandValidationMessage transport =
  if length transport.commandTemplate == 0 then
    "embedding-provider-command-missing-template"
  else if swarmEmbeddingProviderCommandTemplateContains transport "{provider}" == false then
    "embedding-provider-command-missing-provider"
  else if swarmEmbeddingProviderCommandTemplateContains transport "{model}" == false then
    "embedding-provider-command-missing-model"
  else if swarmEmbeddingProviderCommandHasTextInput transport == false && swarmEmbeddingProviderCommandHasJsonInput transport == false then
    "embedding-provider-command-missing-input"
  else if swarmEmbeddingProviderCommandTemplateContains transport "{scale}" == false then
    "embedding-provider-command-missing-scale"
  else
    ""

swarmEmbeddingProviderCommandValid : SwarmEmbeddingProviderCommandTransport -> Bool
swarmEmbeddingProviderCommandValid transport =
  swarmEmbeddingProviderCommandValidationMessage transport == ""

swarmEmbeddingProviderCommandReplace : Str -> Str -> Str -> Str
swarmEmbeddingProviderCommandReplace value needle replacement =
  textJoin replacement (textSplit value needle)

swarmEmbeddingProviderCommandArg : SwarmEmbeddingProviderRequest -> Str -> Str
swarmEmbeddingProviderCommandArg request value =
  swarmEmbeddingProviderCommandReplace
    (swarmEmbeddingProviderCommandReplace
      (swarmEmbeddingProviderCommandReplace
        (swarmEmbeddingProviderCommandReplace
          (swarmEmbeddingProviderCommandReplace
            value
            "{provider}"
            request.provider)
          "{model}"
          request.model)
        "{input_text}"
        request.inputText)
      "{input_json}"
      (encode request.inputText))
    "{scale}"
    (encode request.scale)

swarmEmbeddingProviderCommand : SwarmEmbeddingProviderCommandTransport -> SwarmEmbeddingProviderRequest -> [Str]
swarmEmbeddingProviderCommand transport request = {
  let mut rendered = [];
  for arg in transport.commandTemplate {
    rendered = append rendered [swarmEmbeddingProviderCommandArg request arg];
    rendered
  };
  rendered
}

swarmEmbeddingProviderNetworkAdapterCommandArg : SwarmEmbeddingProviderNetworkAdapter -> SwarmEmbeddingProviderRequest -> Str -> Str
swarmEmbeddingProviderNetworkAdapterCommandArg adapter request value =
  swarmEmbeddingProviderCommandReplace
    (swarmEmbeddingProviderCommandReplace
      (swarmEmbeddingProviderCommandReplace
        (swarmEmbeddingProviderCommandArg request value)
        "{endpoint}"
        adapter.endpoint)
      "{auth_env}"
      adapter.authEnvVar)
    "{network_destination}"
    adapter.allowedDestination

swarmEmbeddingProviderNetworkAdapterCommand : SwarmEmbeddingProviderNetworkAdapter -> SwarmEmbeddingProviderRequest -> [Str]
swarmEmbeddingProviderNetworkAdapterCommand adapter request = {
  let mut rendered = [];
  for arg in adapter.transport.commandTemplate {
    rendered = append rendered [swarmEmbeddingProviderNetworkAdapterCommandArg adapter request arg];
    rendered
  };
  rendered
}

swarmRunEmbeddingProviderCommandResultError : Str -> Result TrustedWeightedEmbeddingProviderOutput
swarmRunEmbeddingProviderCommandResultError message = Err message

swarmRunEmbeddingProviderProcessResult : SwarmEmbeddingProviderCommandTransport -> SwarmEmbeddingProviderRequest -> Result SwarmEmbeddingProviderProcessResult
swarmRunEmbeddingProviderProcessResult transport request =
  swarmEmbeddingProviderProcessResultFromJson
    (runCommandTimeoutRaw transport.cwd transport.timeoutMs (swarmEmbeddingProviderCommand transport request))

swarmRunEmbeddingProviderCommand : SwarmEmbeddingProviderCommandTransport -> SwarmEmbeddingProviderRequest -> Result TrustedWeightedEmbeddingProviderOutput
swarmRunEmbeddingProviderCommand transport request = {
  let validationMessage = swarmEmbeddingProviderCommandValidationMessage transport in
  if validationMessage != "" then
    swarmRunEmbeddingProviderCommandResultError validationMessage
  else
    match swarmRunEmbeddingProviderProcessResult transport request {
      Err message ->
        swarmRunEmbeddingProviderCommandResultError message,
      Ok process ->
        if process.timedOut then
          swarmRunEmbeddingProviderCommandResultError "embedding-provider-command-timeout"
        else if process.error != "" then
          swarmRunEmbeddingProviderCommandResultError process.error
        else if process.exitCode != 0 then
          swarmRunEmbeddingProviderCommandResultError (textConcat ["embedding-provider-command-exit:", encode process.exitCode, ":", process.stderr])
        else
          validateWeightedEmbeddingProviderOutput
            request
            (swarmUntrustedEmbeddingProviderOutput request.provider request.model "ok" process.stdout false)
    }
}

swarmRunEmbeddingProviderNetworkAdapterProcessResult : SwarmEmbeddingProviderNetworkAdapter -> SwarmEmbeddingProviderRequest -> Result SwarmEmbeddingProviderProcessResult
swarmRunEmbeddingProviderNetworkAdapterProcessResult adapter request =
  swarmEmbeddingProviderProcessResultFromJson
    (runCommandTimeoutRaw adapter.transport.cwd adapter.transport.timeoutMs (swarmEmbeddingProviderNetworkAdapterCommand adapter request))

swarmRunEmbeddingProviderNetworkAdapter : SwarmEmbeddingProviderNetworkAdapter -> SwarmEmbeddingProviderRequest -> Result TrustedWeightedEmbeddingProviderOutput
swarmRunEmbeddingProviderNetworkAdapter adapter request = {
  let validationMessage = swarmEmbeddingProviderNetworkAdapterValidationMessage adapter in
  if validationMessage != "" then
    swarmRunEmbeddingProviderCommandResultError validationMessage
  else if request.provider != adapter.provider then
    swarmRunEmbeddingProviderCommandResultError "embedding-provider-network-adapter-request-provider-mismatch"
  else if request.model != adapter.model then
    swarmRunEmbeddingProviderCommandResultError "embedding-provider-network-adapter-request-model-mismatch"
  else
    match swarmRunEmbeddingProviderNetworkAdapterProcessResult adapter request {
      Err message ->
        swarmRunEmbeddingProviderCommandResultError message,
      Ok process ->
        if process.timedOut then
          swarmRunEmbeddingProviderCommandResultError "embedding-provider-network-adapter-timeout"
        else if process.error != "" then
          swarmRunEmbeddingProviderCommandResultError process.error
        else if process.exitCode != 0 then
          swarmRunEmbeddingProviderCommandResultError (textConcat ["embedding-provider-network-adapter-exit:", encode process.exitCode, ":", process.stderr])
        else
          validateWeightedEmbeddingProviderOutput
            request
            (swarmUntrustedEmbeddingProviderOutput request.provider request.model "ok" process.stdout false)
    }
}

swarmWeightedVectorIndexEntry : SwarmMemory -> Str -> SwarmWeightedEmbedding -> SwarmWeightedVectorIndexEntry
swarmWeightedVectorIndexEntry memory text embedding =
  SwarmWeightedVectorIndexEntry {
    memory = memory,
    text = text,
    embedding = embedding
  }

swarmWeightedVectorIndexEntryResultError : Str -> Result SwarmWeightedVectorIndexEntry
swarmWeightedVectorIndexEntryResultError message = Err message

swarmWeightedVectorIndexEntryFromMemory : Str -> Int -> SwarmMemory -> Result SwarmWeightedVectorIndexEntry
swarmWeightedVectorIndexEntryFromMemory model scale memory =
  match weightedEmbeddedMemoryFromMemory memory {
    Ok embedded ->
      if embedded.embedding.model != model then
        swarmWeightedVectorIndexEntryResultError "weighted vector index model mismatch"
      else if embedded.embedding.scale != scale then
        swarmWeightedVectorIndexEntryResultError "weighted vector index scale mismatch"
      else
        Ok (swarmWeightedVectorIndexEntry embedded.memory embedded.text embedded.embedding),
    Err message ->
      swarmWeightedVectorIndexEntryResultError message
  }

swarmWeightedVectorIndexEntriesFromMemory : Str -> Int -> [SwarmMemory] -> [SwarmWeightedVectorIndexEntry]
swarmWeightedVectorIndexEntriesFromMemory model scale memories = {
  let mut entries = [];
  for memory in memories {
    match swarmWeightedVectorIndexEntryFromMemory model scale memory {
      Ok entry -> {
        entries = append entries [entry];
        entries
      },
      Err message ->
        entries
    }
  };
  entries
}

swarmWeightedVectorIndex : Str -> Str -> Int -> [SwarmWeightedVectorIndexEntry] -> SwarmWeightedVectorIndex
swarmWeightedVectorIndex provider model scale entries =
  SwarmWeightedVectorIndex {
    provider = provider,
    model = model,
    scale = scale,
    entries = entries
  }

swarmWeightedVectorIndexFromMemory : Str -> Str -> Int -> [SwarmMemory] -> SwarmWeightedVectorIndex
swarmWeightedVectorIndexFromMemory provider model scale memories =
  swarmWeightedVectorIndex provider model scale (swarmWeightedVectorIndexEntriesFromMemory model scale memories)

swarmWeightedVectorIndexText : SwarmWeightedVectorIndex -> Str
swarmWeightedVectorIndexText index = encode index

swarmWeightedVectorIndexFromText : Str -> Result SwarmWeightedVectorIndex
swarmWeightedVectorIndexFromText raw = tryDecode SwarmWeightedVectorIndex raw

swarmWeightedVectorIndexEntryCount : SwarmWeightedVectorIndex -> Int
swarmWeightedVectorIndexEntryCount index = length index.entries

swarmWeightedVectorStoreEntryCount : [SwarmWeightedVectorIndex] -> Int
swarmWeightedVectorStoreEntryCount shards = {
  let mut count = 0;
  for shard in shards {
    count = intAdd count (swarmWeightedVectorIndexEntryCount shard);
    count
  };
  count
}

swarmWeightedVectorStore : [SwarmWeightedVectorIndex] -> SwarmWeightedVectorStore
swarmWeightedVectorStore shards =
  SwarmWeightedVectorStore {
    shardCount = length shards,
    entryCount = swarmWeightedVectorStoreEntryCount shards,
    shards = shards
  }

swarmWeightedVectorStoreFromIndexes : [SwarmWeightedVectorIndex] -> SwarmWeightedVectorStore
swarmWeightedVectorStoreFromIndexes shards = swarmWeightedVectorStore shards

swarmWeightedVectorStoreText : SwarmWeightedVectorStore -> Str
swarmWeightedVectorStoreText store = encode store

swarmWeightedVectorStoreFromText : Str -> Result SwarmWeightedVectorStore
swarmWeightedVectorStoreFromText raw =
  match tryDecode SwarmWeightedVectorStore raw {
    Ok store -> Ok (swarmWeightedVectorStore store.shards),
    Err message -> Err message
  }

swarmWeightedVectorIndexMatches : Str -> Str -> Int -> SwarmWeightedVectorIndex -> Bool
swarmWeightedVectorIndexMatches provider model scale index =
  if index.provider == provider then
    if index.model == model then
      index.scale == scale
    else
      false
  else
    false

swarmWeightedVectorStoreShardCountForQuery : Str -> SwarmWeightedEmbedding -> SwarmWeightedVectorStore -> Int
swarmWeightedVectorStoreShardCountForQuery provider query store = {
  let mut count = 0;
  for shard in store.shards {
    if swarmWeightedVectorIndexMatches provider query.model query.scale shard then {
      count = intAdd count 1;
      count
    } else
      count
  };
  count
}

swarmWeightedVectorIndexSearchResult : SwarmWeightedEmbedding -> SwarmWeightedVectorIndex -> SwarmWeightedVectorIndexEntry -> SwarmWeightedVectorIndexSearchResult
swarmWeightedVectorIndexSearchResult query index entry =
  SwarmWeightedVectorIndexSearchResult {
    memory = entry.memory,
    text = entry.text,
    score = swarmWeightedEmbeddingScore query entry.embedding,
    matchedDimensions = swarmWeightedEmbeddingMatchedDimensions query entry.embedding,
    provider = index.provider,
    model = entry.embedding.model,
    scale = entry.embedding.scale
  }

swarmWeightedVectorIndexSearchInsert : [SwarmWeightedVectorIndexSearchResult] -> SwarmWeightedVectorIndexSearchResult -> [SwarmWeightedVectorIndexSearchResult]
swarmWeightedVectorIndexSearchInsert ranked candidate = {
  let mut next = [];
  let mut inserted = false;
  for existing in ranked {
    if inserted then {
      next = append next [existing];
      next
    } else if candidate.score > existing.score then {
      next = append next [candidate, existing];
      inserted = true;
      next
    } else {
      next = append next [existing];
      next
    }
  };
  if inserted then
    next
  else
    append next [candidate]
}

swarmWeightedVectorIndexSearchLimit : Int -> [SwarmWeightedVectorIndexSearchResult] -> [SwarmWeightedVectorIndexSearchResult]
swarmWeightedVectorIndexSearchLimit limit ranked = {
  let mut kept = [];
  for item in ranked {
    if length kept < limit then {
      kept = append kept [item];
      kept
    } else
      kept
  };
  kept
}

swarmWeightedVectorIndexSearch : SwarmWeightedEmbedding -> SwarmWeightedVectorIndex -> Int -> [SwarmWeightedVectorIndexSearchResult]
swarmWeightedVectorIndexSearch query index limit = {
  let mut ranked = [];
  if query.model == index.model then
    if query.scale == index.scale then {
      for entry in index.entries {
        let result = swarmWeightedVectorIndexSearchResult query index entry;
        if result.score > 0 then {
          ranked = swarmWeightedVectorIndexSearchLimit limit (swarmWeightedVectorIndexSearchInsert ranked result);
          ranked
        } else
          ranked
      };
      ranked
    } else
      ranked
  else
    ranked
}

swarmWeightedVectorStoreSearch : Str -> SwarmWeightedEmbedding -> SwarmWeightedVectorStore -> Int -> [SwarmWeightedVectorIndexSearchResult]
swarmWeightedVectorStoreSearch provider query store limit = {
  let mut ranked = [];
  for shard in store.shards {
    if swarmWeightedVectorIndexMatches provider query.model query.scale shard then {
      for result in swarmWeightedVectorIndexSearch query shard limit {
        ranked = swarmWeightedVectorIndexSearchLimit limit (swarmWeightedVectorIndexSearchInsert ranked result);
        ranked
      };
      ranked
    } else
      ranked
  };
  ranked
}

swarmWeightedVectorIndexSearchResultText : SwarmWeightedVectorIndexSearchResult -> Str
swarmWeightedVectorIndexSearchResultText result = result.text

swarmWeightedVectorIndexSearchResultScore : SwarmWeightedVectorIndexSearchResult -> Int
swarmWeightedVectorIndexSearchResultScore result = result.score

emptyDependencyProjection : [Str] -> SwarmDependencyProjection
emptyDependencyProjection dependencyIds =
  SwarmDependencyProjection {
    dependencyProjectionIds = dependencyIds,
    dependencyProjectionStatuses = emptySwarmTexts,
    dependencyProjectionReady = emptySwarmBools
  }

dependencyProjectionStep : SwarmDependencyProjection -> SwarmTask -> SwarmDependencyProjection
dependencyProjectionStep projection task =
  if swarmTextListHas task.taskId projection.dependencyProjectionIds then
    SwarmDependencyProjection {
      dependencyProjectionIds = projection.dependencyProjectionIds,
      dependencyProjectionStatuses = append projection.dependencyProjectionStatuses [task.status],
      dependencyProjectionReady = append projection.dependencyProjectionReady [task.ready]
    }
  else
    projection

dependencyProjectionFrom : [Str] -> [SwarmTask] -> SwarmDependencyProjection
dependencyProjectionFrom dependencyIds taskValues =
  fold dependencyProjectionStep (emptyDependencyProjection dependencyIds) taskValues

memorySearchResultMemoryValue : SwarmMemorySearchResult -> Str
memorySearchResultMemoryValue item = item.memory.value

memorySearchResultMatchedText : SwarmMemorySearchResult -> Str
memorySearchResultMatchedText item = item.matchedText

memorySearchResultScore : SwarmMemorySearchResult -> Int
memorySearchResultScore item = item.score

artifactSearchResultMatchedText : SwarmArtifactSearchResult -> Str
artifactSearchResultMatchedText item = item.matchedText

artifactSearchResultScore : SwarmArtifactSearchResult -> Int
artifactSearchResultScore item = item.score

verificationTraceFailureClassification : SwarmRun -> Str
verificationTraceFailureClassification run =
  if runPassed run then
    "none"
  else
    if run.timedOut then
      "timeout"
    else
      "exit-code"

verificationTraceEntry : Str -> SwarmRun -> VerificationTraceEntry
verificationTraceEntry verifierName run =
  VerificationTraceEntry {
    verifierName = textConcat [verifierName],
    runId = run.runId,
    status = textConcat [run.status],
    exitCode = run.exitCode,
    timedOut = run.timedOut,
    memoryLimitMb = run.memoryLimitMb,
    stdoutArtifactPath = textConcat [run.stdoutArtifactPath],
    stderrArtifactPath = textConcat [run.stderrArtifactPath],
    failedVerifierClassification = textConcat [verificationTraceFailureClassification run]
  }

verificationTraceVerifierName : VerificationTraceEntry -> Str
verificationTraceVerifierName entry = entry.verifierName

verificationTraceFailedVerifierClassification : VerificationTraceEntry -> Str
verificationTraceFailedVerifierClassification entry = entry.failedVerifierClassification

verificationTraceStdoutArtifactPath : VerificationTraceEntry -> Str
verificationTraceStdoutArtifactPath entry = entry.stdoutArtifactPath

verificationTraceStderrArtifactPath : VerificationTraceEntry -> Str
verificationTraceStderrArtifactPath entry = entry.stderrArtifactPath

runTraceEntry : SwarmRun -> VerificationTraceEntry
runTraceEntry run = verificationTraceEntry run.name run

verificationPlanMailboxSummary : SwarmMailbox -> VerificationPlanMailboxSummary
verificationPlanMailboxSummary mailbox =
  VerificationPlanMailboxSummary {
    historyCount = length mailbox.history,
    tailCount = length mailbox.tail,
    approvalCount = length mailbox.approvals,
    runCount = length mailbox.runs,
    artifactCount = length mailbox.artifacts,
    memoryCount = length mailbox.memory,
    latestRunStatus = mailbox.latestRunStatus,
    latestRunName = mailbox.latestRunName,
    latestVerifierStatus = mailbox.latestVerifierStatus,
    latestVerifier = mailbox.latestVerifier,
    artifactKinds = map artifactKind mailbox.artifacts,
    artifactPaths = map artifactPath mailbox.artifacts
  }

taskEvidencePack : TaskHandle -> Str -> Int -> Result SwarmEvidencePack
taskEvidencePack handle query limit =
  match status handle {
    Ok taskValue ->
      let objective = objectiveHandle handle.root taskValue.objectiveId in
      match taskMailbox handle limit {
        Ok mailboxValue ->
          match taskMemorySearch handle query limit {
            Ok taskMemoryMatchesValue ->
              match objectiveMemorySearch objective query limit {
                Ok objectiveMemoryMatchesValue ->
                  match benchmarkHistorySearch objective limit {
                    Ok benchmarkMemoryMatchesValue ->
                      match artifactSearch handle "" query limit contextPackArtifactReadBytes {
                        Ok searchResultsValue ->
                          match semanticArtifactSearch handle contextPackSemanticIndexQuery limit contextPackArtifactReadBytes {
                            Ok semanticSearchResultsValue ->
                              let semanticIndexEntriesValue = semanticIndexEntriesFromSearchResultsRoot handle.root semanticSearchResultsValue in
                              match readArtifactContents handle.root mailboxValue.artifacts contextPackArtifactReadBytes limit {
                                Ok artifactContentValues ->
                                  let memoryMatches = append taskMemoryMatchesValue objectiveMemoryMatchesValue in
                                  let mailboxSummary = verificationPlanMailboxSummary mailboxValue in
                                  match tasks handle.root {
                                    Ok taskValues ->
                                      let dependencyProjection = dependencyProjectionFrom taskValue.dependencies taskValues in
                                      Ok (SwarmEvidencePack {
                                        task = taskValue,
                                        query = query,
                                        dependencyTaskIds = dependencyProjection.dependencyProjectionIds,
                                        dependencyTaskStatuses = dependencyProjection.dependencyProjectionStatuses,
                                        dependencyTaskReady = dependencyProjection.dependencyProjectionReady,
                                        mailboxSummary = mailboxSummary,
                                        taskMemoryMatches = taskMemoryMatchesValue,
                                        objectiveMemoryMatches = objectiveMemoryMatchesValue,
                                        benchmarkMemoryMatches = benchmarkMemoryMatchesValue,
                                        artifactSearchMatches = searchResultsValue,
                                        semanticArtifactMatches = semanticSearchResultsValue,
                                        memoryValues = map memorySearchResultMemoryValue memoryMatches,
                                        memoryMatchedText = map memorySearchResultMatchedText memoryMatches,
                                        memoryScores = map memorySearchResultScore memoryMatches,
                                        benchmarkValues = map memorySearchResultMemoryValue benchmarkMemoryMatchesValue,
                                        benchmarkMatchedText = map memorySearchResultMatchedText benchmarkMemoryMatchesValue,
                                        benchmarkScores = map memorySearchResultScore benchmarkMemoryMatchesValue,
                                        artifactSearchMatchedText = map artifactSearchResultMatchedText searchResultsValue,
                                        artifactSearchScores = map artifactSearchResultScore searchResultsValue,
                                        semanticArtifactMatchedText = map artifactSearchResultMatchedText semanticSearchResultsValue,
                                        semanticArtifactScores = map artifactSearchResultScore semanticSearchResultsValue,
                                        semanticIndexEntries = semanticIndexEntriesValue,
                                        semanticIndexEntryIds = map semanticIndexEntryId semanticIndexEntriesValue,
                                        semanticIndexEditFiles = semanticIndexEntryEditFiles semanticIndexEntriesValue,
                                        semanticIndexArtifactRefs = semanticIndexEntryArtifactRefs semanticIndexEntriesValue,
                                        semanticIndexSurfaceIds = semanticIndexEntrySurfaceIds semanticIndexEntriesValue,
                                        semanticIndexQueryTexts = map semanticIndexEntryQueryText semanticIndexEntriesValue,
                                        runTrace = map runTraceEntry mailboxValue.runs,
                                        artifactKinds = mailboxSummary.artifactKinds,
                                        artifactPaths = mailboxSummary.artifactPaths,
                                        artifactExcerpts = artifactContentValues
                                      }),
                                    Err message ->
                                      evidencePackResultError message
                                  },
                                Err message ->
                                  evidencePackResultError message
                              },
                            Err message ->
                              evidencePackResultError message
                          },
                        Err message ->
                          evidencePackResultError message
                      },
                    Err message ->
                      evidencePackResultError message
                  },
                Err message ->
                  evidencePackResultError message
              },
            Err message ->
              evidencePackResultError message
          },
        Err message ->
          evidencePackResultError message
      },
    Err message ->
      evidencePackResultError message
  }

contextPackFromEvidence : SwarmEvidencePack -> [SwarmTask] -> SwarmManagerAction -> SwarmContextPack
contextPackFromEvidence evidence readyTasks managerActionValue =
  SwarmContextPack {
    task = evidence.task,
    readyTaskIds = map readyTaskId readyTasks,
    dependencyTaskIds = evidence.dependencyTaskIds,
    dependencyTaskStatuses = evidence.dependencyTaskStatuses,
    dependencyTaskReady = evidence.dependencyTaskReady,
    managerAction = managerActionValue,
    mailboxSummary = evidence.mailboxSummary,
    taskMemoryMatches = evidence.taskMemoryMatches,
    objectiveMemoryMatches = evidence.objectiveMemoryMatches,
    benchmarkMemoryMatches = evidence.benchmarkMemoryMatches,
    artifactSearchMatches = evidence.artifactSearchMatches,
    semanticArtifactMatches = evidence.semanticArtifactMatches,
    memoryValues = evidence.memoryValues,
    memoryMatchedText = evidence.memoryMatchedText,
    memoryScores = evidence.memoryScores,
    benchmarkValues = evidence.benchmarkValues,
    benchmarkMatchedText = evidence.benchmarkMatchedText,
    benchmarkScores = evidence.benchmarkScores,
    artifactSearchMatchedText = evidence.artifactSearchMatchedText,
    artifactSearchScores = evidence.artifactSearchScores,
    semanticArtifactMatchedText = evidence.semanticArtifactMatchedText,
    semanticArtifactScores = evidence.semanticArtifactScores,
    semanticIndexEntries = evidence.semanticIndexEntries,
    semanticIndexEntryIds = evidence.semanticIndexEntryIds,
    semanticIndexEditFiles = evidence.semanticIndexEditFiles,
    semanticIndexArtifactRefs = evidence.semanticIndexArtifactRefs,
    semanticIndexSurfaceIds = evidence.semanticIndexSurfaceIds,
    semanticIndexQueryTexts = evidence.semanticIndexQueryTexts,
    runTrace = evidence.runTrace,
    artifactKinds = evidence.artifactKinds,
    artifactPaths = evidence.artifactPaths,
    artifactExcerpts = evidence.artifactExcerpts
  }

taskContextPack : TaskHandle -> Str -> Int -> Result SwarmContextPack
taskContextPack handle query limit =
  match taskEvidencePack handle query limit {
    Ok evidence ->
      let objective = objectiveHandle handle.root evidence.task.objectiveId in
      match ready objective {
        Ok readyTasks ->
          match managerNext objective {
            Ok managerActionValue ->
              Ok (contextPackFromEvidence evidence readyTasks managerActionValue),
            Err message ->
              contextPackResultError message
          },
        Err message ->
          contextPackResultError message
      },
    Err message ->
      contextPackResultError message
  }

taskMailbox : TaskHandle -> Int -> Result SwarmMailbox
taskMailbox handle limit =
  match history handle {
    Ok historyValue ->
      match tail handle limit {
        Ok tailValue ->
          match approvals handle {
            Ok approvalsValue ->
              match runs handle {
                Ok runsValue ->
                  match artifacts handle {
                    Ok artifactsValue ->
                      match taskMemory handle "" limit {
                        Ok memoryValue ->
                          Ok (SwarmMailbox {
                            history = historyValue,
                            tail = tailValue,
                            approvals = approvalsValue,
                            runs = runsValue,
                            artifacts = artifactsValue,
                            memory = memoryValue,
                            latestRunStatus = fold firstRunStatus "" runsValue,
                            latestRunName = fold firstRunName "" runsValue,
                            latestVerifierStatus = fold firstVerifierStatus "" runsValue,
                            latestVerifier = fold firstVerifierName "" runsValue
                          }),
                        Err message ->
                          mailboxResultError message
                      },
                    Err message ->
                      mailboxResultError message
                  },
                Err message ->
                  mailboxResultError message
              },
            Err message ->
              mailboxResultError message
          },
        Err message ->
          mailboxResultError message
      },
    Err message ->
      mailboxResultError message
  }

runToolStep : TaskHandle -> SwarmCommand -> Int -> Result ToolStepResult
runToolStep handle spec mailboxLimit =
  match lease handle {
    Ok leaseValue ->
      match toolRun handle spec {
        Ok runValue ->
          match finishToolRun handle runValue {
            Ok statusValue ->
              match taskMailbox handle mailboxLimit {
                Ok mailboxValue ->
                  Ok (ToolStepResult {
                    lease = leaseValue,
                    run = runValue,
                    status = statusValue,
                    mailbox = mailboxValue
                  }),
                Err message ->
                  toolStepResultError message
              },
            Err message ->
              toolStepResultError message
          },
        Err message ->
          toolStepResultError message
      },
    Err message ->
      toolStepResultError message
  }

runToolStepWithTimeout : TaskHandle -> SwarmCommand -> Int -> Int -> Result ToolStepResult
runToolStepWithTimeout handle spec timeoutMs mailboxLimit =
  match lease handle {
    Ok leaseValue ->
      match toolRunWithTimeout handle spec timeoutMs {
        Ok runValue ->
          match finishToolRun handle runValue {
            Ok statusValue ->
              match taskMailbox handle mailboxLimit {
                Ok mailboxValue ->
                  Ok (ToolStepResult {
                    lease = leaseValue,
                    run = runValue,
                    status = statusValue,
                    mailbox = mailboxValue
                  }),
                Err message ->
                  toolStepResultError message
              },
            Err message ->
              toolStepResultError message
          },
        Err message ->
          toolStepResultError message
      },
    Err message ->
      toolStepResultError message
  }

runToolStepWithLimits : TaskHandle -> SwarmCommand -> Int -> Int -> Int -> Result ToolStepResult
runToolStepWithLimits handle spec timeoutMs memoryLimitMb mailboxLimit =
  match lease handle {
    Ok leaseValue ->
      match toolRunWithLimits handle spec timeoutMs memoryLimitMb {
        Ok runValue ->
          match finishToolRun handle runValue {
            Ok statusValue ->
              match taskMailbox handle mailboxLimit {
                Ok mailboxValue ->
                  Ok (ToolStepResult {
                    lease = leaseValue,
                    run = runValue,
                    status = statusValue,
                    mailbox = mailboxValue
                  }),
                Err message ->
                  toolStepResultError message
              },
            Err message ->
              toolStepResultError message
          },
        Err message ->
          toolStepResultError message
      },
    Err message ->
      toolStepResultError message
  }

runToolStepWithOptionalLimits : TaskHandle -> SwarmCommand -> Int -> Int -> Int -> Result ToolStepResult
runToolStepWithOptionalLimits handle spec timeoutMs memoryLimitMb mailboxLimit =
  if memoryLimitMb > 0 then
    runToolStepWithLimits handle spec timeoutMs memoryLimitMb mailboxLimit
  else if timeoutMs > 0 then
    runToolStepWithTimeout handle spec timeoutMs mailboxLimit
  else
    runToolStep handle spec mailboxLimit

runVerifierStep : TaskHandle -> Str -> SwarmCommand -> Int -> Result VerifierStepResult
runVerifierStep handle verifierName spec mailboxLimit =
  match verifierRun handle verifierName spec {
    Ok runValue ->
      match taskMailbox handle mailboxLimit {
        Ok mailboxValue ->
          Ok (VerifierStepResult {
            run = runValue,
            mailbox = mailboxValue
          }),
        Err message ->
          verifierStepResultError message
      },
    Err message ->
      verifierStepResultError message
  }

runVerifierStepWithTimeout : TaskHandle -> Str -> SwarmCommand -> Int -> Int -> Result VerifierStepResult
runVerifierStepWithTimeout handle verifierName spec timeoutMs mailboxLimit =
  match verifierRunWithTimeout handle verifierName spec timeoutMs {
    Ok runValue ->
      match taskMailbox handle mailboxLimit {
        Ok mailboxValue ->
          Ok (VerifierStepResult {
            run = runValue,
            mailbox = mailboxValue
          }),
        Err message ->
          verifierStepResultError message
      },
    Err message ->
      verifierStepResultError message
  }

runVerifierStepWithLimits : TaskHandle -> Str -> SwarmCommand -> Int -> Int -> Int -> Result VerifierStepResult
runVerifierStepWithLimits handle verifierName spec timeoutMs memoryLimitMb mailboxLimit =
  match verifierRunWithLimits handle verifierName spec timeoutMs memoryLimitMb {
    Ok runValue ->
      match taskMailbox handle mailboxLimit {
        Ok mailboxValue ->
          Ok (VerifierStepResult {
            run = runValue,
            mailbox = mailboxValue
          }),
        Err message ->
          verifierStepResultError message
      },
    Err message ->
      verifierStepResultError message
  }

runVerifierStepWithOptionalLimits : TaskHandle -> Str -> SwarmCommand -> Int -> Int -> Int -> Result VerifierStepResult
runVerifierStepWithOptionalLimits handle verifierName spec timeoutMs memoryLimitMb mailboxLimit =
  if memoryLimitMb > 0 then
    runVerifierStepWithLimits handle verifierName spec timeoutMs memoryLimitMb mailboxLimit
  else if timeoutMs > 0 then
    runVerifierStepWithTimeout handle verifierName spec timeoutMs mailboxLimit
  else
    runVerifierStep handle verifierName spec mailboxLimit

emptyVerifierStepResults : [VerifierStepResult]
emptyVerifierStepResults = []

emptyVerifierNames : [Str]
emptyVerifierNames = []

emptyVerificationTraceEntries : [VerificationTraceEntry]
emptyVerificationTraceEntries = []

emptyArtifactContents : [SwarmArtifactContent]
emptyArtifactContents = []

contextPackArtifactReadBytes : Int
contextPackArtifactReadBytes = 4096

contextPackSemanticIndexReadBytes : Int
contextPackSemanticIndexReadBytes = 65536

contextPackSemanticIndexQuery : Str
contextPackSemanticIndexQuery = "semanticIndex entries editFiles artifactRefs surfaceIds queryText route schema host-boundary action-item"

contextPackBenchmarkQuery : Str
contextPackBenchmarkQuery = "benchmark score target suite wave meetsTarget summary regression improvement"

readArtifactContents : SwarmRoot -> [SwarmArtifact] -> Int -> Int -> Result [SwarmArtifactContent]
readArtifactContents root artifactValues maxBytes limit = {
  let mut contents = emptyArtifactContents;
  let mut remaining = limit;
  let mut error = "";
  for artifact in artifactValues {
    if error != "" then
      error
    else if remaining <= 0 then
      error
    else {
      match readArtifactFrom root artifact maxBytes {
        Ok content -> {
          contents = append contents [content];
          remaining = intSubtract remaining 1;
          error
        },
        Err message -> {
          error = message;
          error
        }
      }
    }
  };
  if error == "" then
    Ok contents
  else
    artifactContentListResultError error
}

emptyVerificationPlanExecution : TaskHandle -> Int -> Int -> Bool -> Int -> VerificationPlanExecution
emptyVerificationPlanExecution handle mailboxLimit timeoutMs useTimeout memoryLimitMb =
  VerificationPlanExecution {
    handle = handle,
    mailboxLimit = mailboxLimit,
    timeoutMs = timeoutMs,
    useTimeout = useTimeout,
    memoryLimitMb = memoryLimitMb,
    steps = emptyVerifierStepResults,
    passed = true,
    failedVerifiers = emptyVerifierNames,
    trace = emptyVerificationTraceEntries,
    error = ""
  }

verificationPlanExecutionError : VerificationPlanExecution -> Str -> VerificationPlanExecution
verificationPlanExecutionError state message =
  VerificationPlanExecution {
    handle = state.handle,
    mailboxLimit = state.mailboxLimit,
    timeoutMs = state.timeoutMs,
    useTimeout = state.useTimeout,
    memoryLimitMb = state.memoryLimitMb,
    steps = state.steps,
    passed = state.passed,
    failedVerifiers = state.failedVerifiers,
    trace = state.trace,
    error = message
  }

verificationPlanExecutionAppend : VerificationPlanExecution -> Str -> VerifierStepResult -> VerificationPlanExecution
verificationPlanExecutionAppend state verifierName step =
  VerificationPlanExecution {
    handle = state.handle,
    mailboxLimit = state.mailboxLimit,
    timeoutMs = state.timeoutMs,
    useTimeout = state.useTimeout,
    memoryLimitMb = state.memoryLimitMb,
    steps = append state.steps [step],
    passed = if runPassed step.run then state.passed else false,
    failedVerifiers = if runPassed step.run then state.failedVerifiers else append state.failedVerifiers [verifierName],
    trace = append state.trace [verificationTraceEntry verifierName step.run],
    error = state.error
  }

verificationPlanRunStep : VerificationPlanExecution -> VerificationCommand -> Result VerifierStepResult
verificationPlanRunStep state command =
  if state.memoryLimitMb > 0 then
    runVerifierStepWithLimits state.handle command.verifierName command.command state.timeoutMs state.memoryLimitMb state.mailboxLimit
  else if state.useTimeout then
    runVerifierStepWithTimeout state.handle command.verifierName command.command state.timeoutMs state.mailboxLimit
  else
    runVerifierStep state.handle command.verifierName command.command state.mailboxLimit

verificationPlanExecutionStep : VerificationPlanExecution -> VerificationCommand -> VerificationPlanExecution
verificationPlanExecutionStep state command =
  if state.error != "" then
    state
  else
    match verificationPlanRunStep state command {
      Ok stepValue ->
        verificationPlanExecutionAppend state command.verifierName stepValue,
      Err message ->
        verificationPlanExecutionError state message
    }

executeVerificationPlan : TaskHandle -> VerificationPlan -> Int -> Result VerificationPlanResult
executeVerificationPlan handle plan mailboxLimit =
  let execution = fold verificationPlanExecutionStep (emptyVerificationPlanExecution handle mailboxLimit 0 false 0) plan.commands in
  if execution.error != "" then
    verificationPlanResultError execution.error
  else
    match taskMailbox handle mailboxLimit {
      Ok mailboxValue ->
        Ok (VerificationPlanResult {
          plan = plan,
          steps = execution.steps,
          passed = execution.passed,
          failedVerifiers = execution.failedVerifiers,
          trace = execution.trace,
          mailbox = mailboxValue,
          mailboxSummary = verificationPlanMailboxSummary mailboxValue
        }),
      Err message ->
        verificationPlanResultError message
    }

executeVerificationPlanWithTimeout : TaskHandle -> VerificationPlan -> Int -> Int -> Result VerificationPlanResult
executeVerificationPlanWithTimeout handle plan timeoutMs mailboxLimit =
  let execution = fold verificationPlanExecutionStep (emptyVerificationPlanExecution handle mailboxLimit timeoutMs true 0) plan.commands in
  if execution.error != "" then
    verificationPlanResultError execution.error
  else
    match taskMailbox handle mailboxLimit {
      Ok mailboxValue ->
        Ok (VerificationPlanResult {
          plan = plan,
          steps = execution.steps,
          passed = execution.passed,
          failedVerifiers = execution.failedVerifiers,
          trace = execution.trace,
          mailbox = mailboxValue,
          mailboxSummary = verificationPlanMailboxSummary mailboxValue
        }),
      Err message ->
        verificationPlanResultError message
    }

executeVerificationPlanWithLimits : TaskHandle -> VerificationPlan -> Int -> Int -> Int -> Result VerificationPlanResult
executeVerificationPlanWithLimits handle plan timeoutMs memoryLimitMb mailboxLimit =
  let useTimeout = timeoutMs > 0 in
  let execution = fold verificationPlanExecutionStep (emptyVerificationPlanExecution handle mailboxLimit timeoutMs useTimeout memoryLimitMb) plan.commands in
  if execution.error != "" then
    verificationPlanResultError execution.error
  else
    match taskMailbox handle mailboxLimit {
      Ok mailboxValue ->
        Ok (VerificationPlanResult {
          plan = plan,
          steps = execution.steps,
          passed = execution.passed,
          failedVerifiers = execution.failedVerifiers,
          trace = execution.trace,
          mailbox = mailboxValue,
          mailboxSummary = verificationPlanMailboxSummary mailboxValue
        }),
      Err message ->
        verificationPlanResultError message
    }

executeVerificationPlanWithOptionalLimits : TaskHandle -> VerificationPlan -> Int -> Int -> Int -> Result VerificationPlanResult
executeVerificationPlanWithOptionalLimits handle plan timeoutMs memoryLimitMb mailboxLimit =
  if memoryLimitMb > 0 then
    executeVerificationPlanWithLimits handle plan timeoutMs memoryLimitMb mailboxLimit
  else if timeoutMs > 0 then
    executeVerificationPlanWithTimeout handle plan timeoutMs mailboxLimit
  else
    executeVerificationPlan handle plan mailboxLimit

policySetForVerificationPlan : TaskHandle -> Str -> [Str] -> VerificationPlan -> Result SwarmPolicy
policySetForVerificationPlan handle mergegateName requiredApprovals plan =
  policySet handle mergegateName requiredApprovals plan.requiredVerifierNames

policySetForVerificationPlanWithProcessAccess : TaskHandle -> Str -> [Str] -> VerificationPlan -> [Str] -> Result SwarmPolicy
policySetForVerificationPlanWithProcessAccess handle mergegateName requiredApprovals plan allowedProcesses =
  policySetWithProcessAccess handle mergegateName requiredApprovals plan.requiredVerifierNames allowedProcesses

policySetForVerificationPlanWithAccess : TaskHandle -> Str -> [Str] -> VerificationPlan -> [Str] -> [Str] -> Result SwarmPolicy
policySetForVerificationPlanWithAccess handle mergegateName requiredApprovals plan allowedProcesses allowedWorkspaceRoots =
  policySetWithAccess handle mergegateName requiredApprovals plan.requiredVerifierNames allowedProcesses allowedWorkspaceRoots

policySetForVerificationPlanWithCapabilities : TaskHandle -> Str -> [Str] -> VerificationPlan -> [Str] -> [Str] -> Str -> Result SwarmPolicy
policySetForVerificationPlanWithCapabilities handle mergegateName requiredApprovals plan allowedProcesses allowedWorkspaceRoots networkAccess =
  policySetWithCapabilities handle mergegateName requiredApprovals plan.requiredVerifierNames allowedProcesses allowedWorkspaceRoots networkAccess

policySetForVerificationPlanWithNetworkAccess : TaskHandle -> Str -> [Str] -> VerificationPlan -> [Str] -> [Str] -> Str -> [Str] -> Result SwarmPolicy
policySetForVerificationPlanWithNetworkAccess handle mergegateName requiredApprovals plan allowedProcesses allowedWorkspaceRoots networkAccess allowedNetworkDestinations =
  policySetWithNetworkAccess handle mergegateName requiredApprovals plan.requiredVerifierNames allowedProcesses allowedWorkspaceRoots networkAccess allowedNetworkDestinations

policySetForVerificationPlanWithAccessPolicy : TaskHandle -> Str -> [Str] -> VerificationPlan -> SwarmAccessPolicy -> Result SwarmPolicy
policySetForVerificationPlanWithAccessPolicy handle mergegateName requiredApprovals plan access =
  policySetWithAccessPolicy handle mergegateName requiredApprovals plan.requiredVerifierNames access

verificationPolicyForPlan : Str -> [Str] -> VerificationPlan -> SwarmAccessPolicy -> SwarmVerificationPolicy
verificationPolicyForPlan mergegateName requiredApprovals plan access =
  swarmVerificationPolicy mergegateName requiredApprovals plan.requiredVerifierNames access

mergegateDecideVerificationPlan : TaskHandle -> Str -> VerificationPlan -> Result SwarmMergeDecision
mergegateDecideVerificationPlan handle mergegateName plan =
  mergegateDecide handle mergegateName plan.requiredVerifierNames

approveAndMergeVerificationPlan : TaskHandle -> Str -> Str -> VerificationPlan -> Int -> Result ReviewStepResult
approveAndMergeVerificationPlan handle approvalName mergegateName plan mailboxLimit =
  approveAndMerge handle approvalName mergegateName plan.requiredVerifierNames mailboxLimit

approveAndMerge : TaskHandle -> Str -> Str -> [Str] -> Int -> Result ReviewStepResult
approveAndMerge handle approvalName mergegateName requiredVerifiers mailboxLimit =
  match approve handle approvalName {
    Ok approvalValue ->
      match approvals handle {
        Ok approvalsValue ->
          match status handle {
            Ok taskStatusValue ->
              match managerNext (objectiveHandle handle.root taskStatusValue.objectiveId) {
                Ok managerAfterApprovalValue ->
                  match mergegateDecide handle mergegateName requiredVerifiers {
                    Ok mergeDecisionValue ->
                      match taskMailbox handle mailboxLimit {
                        Ok mailboxValue ->
                          Ok (ReviewStepResult {
                            approval = approvalValue,
                            approvals = approvalsValue,
                            managerAfterApproval = managerAfterApprovalValue,
                            mergeDecision = mergeDecisionValue,
                            mailbox = mailboxValue
                          }),
                        Err message ->
                          reviewStepResultError message
                      },
                    Err message ->
                      reviewStepResultError message
                  },
                Err message ->
                  reviewStepResultError message
              },
            Err message ->
              reviewStepResultError message
          },
        Err message ->
          reviewStepResultError message
      },
    Err message ->
      reviewStepResultError message
  }
