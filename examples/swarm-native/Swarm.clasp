record SwarmRoot = { path : Str }
record ObjectiveHandle = { root : SwarmRoot, objectiveId : Str }
record TaskHandle = { root : SwarmRoot, taskId : Str, actor : Str }
record SwarmCommand = { cwd : Str, command : [Str] }

record SwarmObjective = {
  createdAtMs : Int,
  deadlineAtMs : Int,
  objectiveId : Str,
  detail : Str,
  maxRuns : Int,
  maxTasks : Int,
  projectedStatus : Str,
  status : Str,
  taskCount : Int,
  runCount : Int,
  updatedAtMs : Int
}

record SwarmTask = {
  attempts : Int,
  taskId : Str,
  status : Str,
  objectiveId : Str,
  detail : Str,
  dependencies : [Str],
  ready : Bool,
  blockedBy : [Str],
  createdAtMs : Int,
  deadlineAtMs : Int,
  heartbeatSeen : Bool,
  lastError : Str,
  lastHeartbeatAtMs : Int,
  leaseActor : Str,
  leaseExpired : Bool,
  leaseTimeoutMs : Int,
  maxRuns : Int,
  parentTaskId : Str,
  priority : Int,
  spawnDepth : Int,
  maxSpawnDepth : Int,
  maxChildTasks : Int,
  childTaskIds : [Str],
  childTaskCount : Int,
  remainingChildTaskBudget : Int,
  objectiveDeadlineAtMs : Int,
  updatedAtMs : Int
}

record SwarmSpawnPolicy = {
  parentTaskId : Str,
  maxSpawnDepth : Int,
  maxChildTasks : Int
}

record SwarmTaskCapabilities = {
  processes : [Str],
  filesystemRoots : [Str],
  readonlyFilesystemRoots : [Str],
  networkAccess : Str,
  networkDestinations : [Str],
  approvals : [Str],
  verifiers : [Str]
}

record SwarmPolicy = {
  createdAtMs : Int,
  taskId : Str,
  mergegateName : Str,
  requiredApprovals : [Str],
  requiredVerifiers : [Str],
  allowedProcesses : [Str],
  allowedWorkspaceRoots : [Str],
  allowedReadonlyRoots : [Str],
  networkAccess : Str,
  allowedNetworkDestinations : [Str],
  capabilities : SwarmTaskCapabilities,
  updatedAtMs : Int
}

record SwarmAccessPolicy = {
  allowedProcesses : [Str],
  allowedWorkspaceRoots : [Str],
  allowedReadonlyRoots : [Str],
  networkAccess : Str,
  allowedNetworkDestinations : [Str]
}

record SwarmVerificationPolicy = {
  mergegateName : Str,
  requiredApprovals : [Str],
  requiredVerifiers : [Str],
  access : SwarmAccessPolicy
}

record SwarmRun = {
  actor : Str,
  command : [Str],
  cwd : Str,
  endedAtMs : Int,
  exitCode : Int,
  name : Str,
  role : Str,
  runId : Int,
  startedAtMs : Int,
  status : Str,
  stderrArtifactPath : Str,
  stdoutArtifactPath : Str,
  taskId : Str,
  timedOut : Bool,
  memoryLimitMb : Int
}

record SwarmApproval = {
  actor : Str,
  approvalId : Int,
  atMs : Int,
  detail : Str,
  name : Str,
  taskId : Str
}

record SwarmMergeDecision = {
  taskId : Str,
  mergegateName : Str,
  verdict : Str
}

record SwarmArtifact = {
  artifactId : Int,
  createdAtMs : Int,
  taskId : Str,
  kind : Str,
  path : Str
}

record SwarmArtifactContent = {
  artifactId : Int,
  createdAtMs : Int,
  taskId : Str,
  kind : Str,
  path : Str,
  maxBytes : Int,
  bytesRead : Int,
  totalBytes : Int,
  truncated : Bool,
  lossyUtf8 : Bool,
  text : Str
}

record SwarmArtifactSearchResult = {
  artifact : SwarmArtifact,
  score : Int,
  matchedText : Str,
  excerpt : SwarmArtifactContent
}

record SwarmSemanticIndexEntry = {
  id : Str,
  kind : Str,
  editFiles : [Str],
  artifactRefs : [Str],
  surfaceIds : [Str],
  queryText : Str
}

record SwarmSemanticIndex = {
  entries : [SwarmSemanticIndexEntry]
}

record SwarmSemanticIndexArtifact = {
  semanticIndex : SwarmSemanticIndex
}

record SwarmMemory = {
  actor : Str,
  createdAtMs : Int,
  memoryId : Int,
  objectiveId : Str,
  taskId : Str,
  key : Str,
  value : Str,
  updatedAtMs : Int
}

record SwarmMemorySearchResult = {
  memory : SwarmMemory,
  score : Int,
  matchedText : Str
}

record SwarmSparseEmbedding = {
  model : Str,
  dimensions : [Str]
}

record SwarmEmbeddedMemoryValue = {
  text : Str,
  embedding : SwarmSparseEmbedding
}

record SwarmEmbeddedMemory = {
  memory : SwarmMemory,
  text : Str,
  embedding : SwarmSparseEmbedding
}

record SwarmEmbeddedMemorySearchResult = {
  memory : SwarmMemory,
  text : Str,
  score : Int,
  matchedDimensions : [Str],
  model : Str
}

record SwarmWeightedEmbeddingDimension = {
  name : Str,
  weight : Int
}

record SwarmWeightedEmbedding = {
  model : Str,
  scale : Int,
  dimensions : [SwarmWeightedEmbeddingDimension]
}

record SwarmWeightedEmbeddedMemoryValue = {
  text : Str,
  embedding : SwarmWeightedEmbedding
}

record SwarmWeightedEmbeddedMemory = {
  memory : SwarmMemory,
  text : Str,
  embedding : SwarmWeightedEmbedding
}

record SwarmWeightedEmbeddedMemorySearchResult = {
  memory : SwarmMemory,
  text : Str,
  score : Int,
  matchedDimensions : [Str],
  model : Str,
  scale : Int
}

record SwarmEmbeddingProviderRequest = {
  provider : Str,
  model : Str,
  inputText : Str,
  scale : Int,
  schemaVersion : Int
}

record UntrustedEmbeddingProviderOutput = {
  provider : Str,
  model : Str,
  status : Str,
  rawText : Str,
  trusted : Bool
}

record TrustedWeightedEmbeddingProviderOutput = {
  provider : Str,
  model : Str,
  trust : Str,
  embedding : SwarmWeightedEmbedding
}

record SwarmEmbeddingProviderCommandTransport = {
  cwd : Str,
  timeoutMs : Int,
  commandTemplate : [Str]
}

record SwarmEmbeddingProviderNetworkAdapter = {
  provider : Str,
  model : Str,
  endpoint : Str,
  authMode : Str,
  authEnvVar : Str,
  networkAccess : Str,
  allowedDestination : Str,
  transport : SwarmEmbeddingProviderCommandTransport
}

record SwarmEmbeddingProviderNetworkAdapterSummary = {
  valid : Bool,
  status : Str,
  provider : Str,
  model : Str,
  endpoint : Str,
  authMode : Str,
  authEnvVar : Str,
  networkAccess : Str,
  allowedDestination : Str,
  commandValid : Bool,
  endpointHttps : Bool,
  authenticated : Bool,
  allowlisted : Bool,
  commandHasEndpoint : Bool,
  commandHasAuthEnv : Bool,
  commandHasNetworkDestination : Bool,
  validationMessage : Str
}

record SwarmEmbeddingProviderProcessResult = {
  exitCode : Int,
  stdout : Str,
  stderr : Str,
  timedOut : Bool,
  error : Str
}

record SwarmWeightedVectorIndexEntry = {
  memory : SwarmMemory,
  text : Str,
  embedding : SwarmWeightedEmbedding
}

record SwarmWeightedVectorIndex = {
  provider : Str,
  model : Str,
  scale : Int,
  entries : [SwarmWeightedVectorIndexEntry]
}

record SwarmWeightedVectorIndexSearchResult = {
  memory : SwarmMemory,
  text : Str,
  score : Int,
  matchedDimensions : [Str],
  provider : Str,
  model : Str,
  scale : Int
}

record SwarmWeightedVectorStore = {
  shardCount : Int,
  entryCount : Int,
  shards : [SwarmWeightedVectorIndex]
}

record SwarmEvent = {
  actor : Str,
  atMs : Int,
  detail : Str,
  kind : Str,
  taskId : Str,
}

record SwarmTaskUpdate = {
  database : Str,
  event : SwarmEvent,
  root : Str,
  task : SwarmTask
}

record SwarmSummary = {
  allTaskIds : [Str],
  completedTaskIds : [Str],
  readyTaskIds : [Str],
  hasBootstrap : Bool,
  bootstrapStatus : Str
}

record SwarmManagerAction = {
  objectiveId : Str,
  status : Str,
  action : Str,
  suggestedCommand : [Str],
  taskId : Str,
  taskStatus : Str,
  taskPriority : Int,
  blockedBy : [Str],
  blockerTaskIds : [Str],
  requiredApprovals : [Str],
  requiredVerifiers : [Str],
  latestRunId : Int,
  latestRunRole : Str,
  latestRunName : Str,
  latestRunStatus : Str,
  latestRunExitCode : Int,
  latestVerifier : Str,
  latestVerifierStatus : Str,
  latestVerifierExitCode : Int,
  mergegateName : Str,
  mergegateVerdict : Str,
  mergegateDetail : Str
}

record SwarmObjectiveStatus = {
  objective : SwarmObjective,
  projectedStatus : Str,
  tasks : [SwarmTask]
}

record SwarmMailbox = {
  history : [SwarmEvent],
  tail : [SwarmEvent],
  approvals : [SwarmApproval],
  runs : [SwarmRun],
  artifacts : [SwarmArtifact],
  memory : [SwarmMemory],
  latestRunStatus : Str,
  latestRunName : Str,
  latestVerifierStatus : Str,
  latestVerifier : Str
}

record ToolStepResult = {
  lease : SwarmTaskUpdate,
  run : SwarmRun,
  status : SwarmTaskUpdate,
  mailbox : SwarmMailbox
}

record VerifierStepResult = {
  run : SwarmRun,
  mailbox : SwarmMailbox
}

record VerificationCommand = {
  verifierName : Str,
  command : SwarmCommand
}

record VerificationPlan = {
  name : Str,
  commands : [VerificationCommand],
  requiredVerifierNames : [Str]
}

record VerificationTraceEntry = {
  verifierName : Str,
  runId : Int,
  status : Str,
  exitCode : Int,
  timedOut : Bool,
  memoryLimitMb : Int,
  stdoutArtifactPath : Str,
  stderrArtifactPath : Str,
  failedVerifierClassification : Str
}

record VerificationPlanMailboxSummary = {
  historyCount : Int,
  tailCount : Int,
  approvalCount : Int,
  runCount : Int,
  artifactCount : Int,
  memoryCount : Int,
  latestRunStatus : Str,
  latestRunName : Str,
  latestVerifierStatus : Str,
  latestVerifier : Str,
  artifactKinds : [Str],
  artifactPaths : [Str]
}

record SwarmTextSearch = {
  wanted : Str,
  found : Bool
}

record SwarmDependencyProjection = {
  dependencyProjectionIds : [Str],
  dependencyProjectionStatuses : [Str],
  dependencyProjectionReady : [Bool]
}

record SwarmContextPack = {
  task : SwarmTask,
  readyTaskIds : [Str],
  dependencyTaskIds : [Str],
  dependencyTaskStatuses : [Str],
  dependencyTaskReady : [Bool],
  managerAction : SwarmManagerAction,
  mailboxSummary : VerificationPlanMailboxSummary,
  taskMemoryMatches : [SwarmMemorySearchResult],
  objectiveMemoryMatches : [SwarmMemorySearchResult],
  benchmarkMemoryMatches : [SwarmMemorySearchResult],
  artifactSearchMatches : [SwarmArtifactSearchResult],
  semanticArtifactMatches : [SwarmArtifactSearchResult],
  memoryValues : [Str],
  memoryMatchedText : [Str],
  memoryScores : [Int],
  benchmarkValues : [Str],
  benchmarkMatchedText : [Str],
  benchmarkScores : [Int],
  artifactSearchMatchedText : [Str],
  artifactSearchScores : [Int],
  semanticArtifactMatchedText : [Str],
  semanticArtifactScores : [Int],
  semanticIndexEntries : [SwarmSemanticIndexEntry],
  semanticIndexEntryIds : [Str],
  semanticIndexEditFiles : [Str],
  semanticIndexArtifactRefs : [Str],
  semanticIndexSurfaceIds : [Str],
  semanticIndexQueryTexts : [Str],
  runTrace : [VerificationTraceEntry],
  artifactKinds : [Str],
  artifactPaths : [Str],
  artifactExcerpts : [SwarmArtifactContent]
}

record SwarmEvidencePack = {
  task : SwarmTask,
  query : Str,
  dependencyTaskIds : [Str],
  dependencyTaskStatuses : [Str],
  dependencyTaskReady : [Bool],
  mailboxSummary : VerificationPlanMailboxSummary,
  taskMemoryMatches : [SwarmMemorySearchResult],
  objectiveMemoryMatches : [SwarmMemorySearchResult],
  benchmarkMemoryMatches : [SwarmMemorySearchResult],
  artifactSearchMatches : [SwarmArtifactSearchResult],
  semanticArtifactMatches : [SwarmArtifactSearchResult],
  memoryValues : [Str],
  memoryMatchedText : [Str],
  memoryScores : [Int],
  benchmarkValues : [Str],
  benchmarkMatchedText : [Str],
  benchmarkScores : [Int],
  artifactSearchMatchedText : [Str],
  artifactSearchScores : [Int],
  semanticArtifactMatchedText : [Str],
  semanticArtifactScores : [Int],
  semanticIndexEntries : [SwarmSemanticIndexEntry],
  semanticIndexEntryIds : [Str],
  semanticIndexEditFiles : [Str],
  semanticIndexArtifactRefs : [Str],
  semanticIndexSurfaceIds : [Str],
  semanticIndexQueryTexts : [Str],
  runTrace : [VerificationTraceEntry],
  artifactKinds : [Str],
  artifactPaths : [Str],
  artifactExcerpts : [SwarmArtifactContent]
}

record VerificationPlanResult = {
  plan : VerificationPlan,
  steps : [VerifierStepResult],
  passed : Bool,
  failedVerifiers : [Str],
  trace : [VerificationTraceEntry],
  mailbox : SwarmMailbox,
  mailboxSummary : VerificationPlanMailboxSummary
}

record VerificationPlanExecution = {
  handle : TaskHandle,
  mailboxLimit : Int,
  timeoutMs : Int,
  useTimeout : Bool,
  memoryLimitMb : Int,
  steps : [VerifierStepResult],
  passed : Bool,
  failedVerifiers : [Str],
  trace : [VerificationTraceEntry],
  error : Str
}

record ReviewStepResult = {
  approval : SwarmApproval,
  approvals : [SwarmApproval],
  managerAfterApproval : SwarmManagerAction,
  mergeDecision : SwarmMergeDecision,
  mailbox : SwarmMailbox
}

noDeadlineAtMs : Int
noDeadlineAtMs = 0

swarmRoot : Str -> SwarmRoot
swarmRoot path = SwarmRoot { path = path }

objectiveHandle : SwarmRoot -> Str -> ObjectiveHandle
objectiveHandle root objectiveId = ObjectiveHandle { root = root, objectiveId = objectiveId }

taskHandle : SwarmRoot -> Str -> Str -> TaskHandle
taskHandle root taskId actor = TaskHandle { root = root, taskId = taskId, actor = actor }

commandSpec : Str -> [Str] -> SwarmCommand
commandSpec cwd command = SwarmCommand { cwd = cwd, command = command }

swarmNetworkAmbient : Str
swarmNetworkAmbient = "ambient"

swarmNetworkDenied : Str
swarmNetworkDenied = "denied"

swarmNetworkAllowlisted : Str
swarmNetworkAllowlisted = "allowlisted"

swarmAccessPolicy : [Str] -> [Str] -> Str -> SwarmAccessPolicy
swarmAccessPolicy allowedProcesses allowedWorkspaceRoots networkAccess =
  SwarmAccessPolicy {
    allowedProcesses = allowedProcesses,
    allowedWorkspaceRoots = allowedWorkspaceRoots,
    allowedReadonlyRoots = [],
    networkAccess = networkAccess,
    allowedNetworkDestinations = []
  }

swarmAccessPolicyWithNetworkDestinations : [Str] -> [Str] -> Str -> [Str] -> SwarmAccessPolicy
swarmAccessPolicyWithNetworkDestinations allowedProcesses allowedWorkspaceRoots networkAccess allowedNetworkDestinations =
  SwarmAccessPolicy {
    allowedProcesses = allowedProcesses,
    allowedWorkspaceRoots = allowedWorkspaceRoots,
    allowedReadonlyRoots = [],
    networkAccess = networkAccess,
    allowedNetworkDestinations = allowedNetworkDestinations
  }

swarmAccessPolicyWithReadonlyRoots : [Str] -> [Str] -> [Str] -> Str -> [Str] -> SwarmAccessPolicy
swarmAccessPolicyWithReadonlyRoots allowedProcesses allowedWorkspaceRoots allowedReadonlyRoots networkAccess allowedNetworkDestinations =
  SwarmAccessPolicy {
    allowedProcesses = allowedProcesses,
    allowedWorkspaceRoots = allowedWorkspaceRoots,
    allowedReadonlyRoots = allowedReadonlyRoots,
    networkAccess = networkAccess,
    allowedNetworkDestinations = allowedNetworkDestinations
  }

swarmAmbientAccess : SwarmAccessPolicy
swarmAmbientAccess =
  swarmAccessPolicy [] [] swarmNetworkAmbient

swarmDenyNetworkAccess : [Str] -> [Str] -> SwarmAccessPolicy
swarmDenyNetworkAccess allowedProcesses allowedWorkspaceRoots =
  swarmAccessPolicy allowedProcesses allowedWorkspaceRoots swarmNetworkDenied

swarmAllowNetworkDestinations : [Str] -> [Str] -> [Str] -> SwarmAccessPolicy
swarmAllowNetworkDestinations allowedProcesses allowedWorkspaceRoots allowedNetworkDestinations =
  swarmAccessPolicyWithNetworkDestinations allowedProcesses allowedWorkspaceRoots swarmNetworkAllowlisted allowedNetworkDestinations

swarmTaskCapabilities : [Str] -> [Str] -> Str -> [Str] -> [Str] -> [Str] -> SwarmTaskCapabilities
swarmTaskCapabilities processes filesystemRoots networkAccess networkDestinations approvals verifiers =
  SwarmTaskCapabilities {
    processes = processes,
    filesystemRoots = filesystemRoots,
    readonlyFilesystemRoots = [],
    networkAccess = networkAccess,
    networkDestinations = networkDestinations,
    approvals = approvals,
    verifiers = verifiers
  }

swarmTaskCapabilitiesDenyNetwork : [Str] -> [Str] -> [Str] -> [Str] -> SwarmTaskCapabilities
swarmTaskCapabilitiesDenyNetwork processes filesystemRoots approvals verifiers =
  swarmTaskCapabilities processes filesystemRoots swarmNetworkDenied [] approvals verifiers

swarmTaskCapabilitiesAllowNetworkDestinations : [Str] -> [Str] -> [Str] -> [Str] -> [Str] -> SwarmTaskCapabilities
swarmTaskCapabilitiesAllowNetworkDestinations processes filesystemRoots networkDestinations approvals verifiers =
  swarmTaskCapabilities processes filesystemRoots swarmNetworkAllowlisted networkDestinations approvals verifiers

swarmTaskCapabilitiesWithReadonlyRoots : [Str] -> [Str] -> [Str] -> Str -> [Str] -> [Str] -> [Str] -> SwarmTaskCapabilities
swarmTaskCapabilitiesWithReadonlyRoots processes filesystemRoots readonlyFilesystemRoots networkAccess networkDestinations approvals verifiers =
  SwarmTaskCapabilities {
    processes = processes,
    filesystemRoots = filesystemRoots,
    readonlyFilesystemRoots = readonlyFilesystemRoots,
    networkAccess = networkAccess,
    networkDestinations = networkDestinations,
    approvals = approvals,
    verifiers = verifiers
  }

swarmAccessPolicyForTaskCapabilities : SwarmTaskCapabilities -> SwarmAccessPolicy
swarmAccessPolicyForTaskCapabilities capabilities =
  SwarmAccessPolicy {
    allowedProcesses = capabilities.processes,
    allowedWorkspaceRoots = capabilities.filesystemRoots,
    allowedReadonlyRoots = capabilities.readonlyFilesystemRoots,
    networkAccess = capabilities.networkAccess,
    allowedNetworkDestinations = capabilities.networkDestinations
  }

swarmVerificationPolicy : Str -> [Str] -> [Str] -> SwarmAccessPolicy -> SwarmVerificationPolicy
swarmVerificationPolicy mergegateName requiredApprovals requiredVerifiers access =
  SwarmVerificationPolicy {
    mergegateName = mergegateName,
    requiredApprovals = requiredApprovals,
    requiredVerifiers = requiredVerifiers,
    access = access
  }

swarmVerificationPolicyForTaskCapabilities : Str -> SwarmTaskCapabilities -> SwarmVerificationPolicy
swarmVerificationPolicyForTaskCapabilities mergegateName capabilities =
  swarmVerificationPolicy mergegateName capabilities.approvals capabilities.verifiers (swarmAccessPolicyForTaskCapabilities capabilities)

verificationCommand : Str -> SwarmCommand -> VerificationCommand
verificationCommand verifierName command =
  VerificationCommand { verifierName = verifierName, command = command }

verificationCommandName : VerificationCommand -> Str
verificationCommandName command = command.verifierName

verificationPlan : Str -> [VerificationCommand] -> VerificationPlan
verificationPlan name commands =
  VerificationPlan {
    name = name,
    commands = commands,
    requiredVerifierNames = map verificationCommandName commands
  }

taskResultError : Str -> Result SwarmTask
taskResultError message = Err message

objectiveResultError : Str -> Result SwarmObjective
objectiveResultError message = Err message

policyResultError : Str -> Result SwarmPolicy
policyResultError message = Err message

runResultError : Str -> Result SwarmRun
runResultError message = Err message

approvalResultError : Str -> Result SwarmApproval
approvalResultError message = Err message

mergeDecisionResultError : Str -> Result SwarmMergeDecision
mergeDecisionResultError message = Err message

summaryResultError : Str -> Result SwarmSummary
summaryResultError message = Err message

managerActionResultError : Str -> Result SwarmManagerAction
managerActionResultError message = Err message

objectiveStatusResultError : Str -> Result SwarmObjectiveStatus
objectiveStatusResultError message = Err message

taskListResultError : Str -> Result [SwarmTask]
taskListResultError message = Err message

runListResultError : Str -> Result [SwarmRun]
runListResultError message = Err message

artifactListResultError : Str -> Result [SwarmArtifact]
artifactListResultError message = Err message

artifactResultError : Str -> Result SwarmArtifact
artifactResultError message = Err message

artifactContentResultError : Str -> Result SwarmArtifactContent
artifactContentResultError message = Err message

artifactContentListResultError : Str -> Result [SwarmArtifactContent]
artifactContentListResultError message = Err message

artifactSearchResultListError : Str -> Result [SwarmArtifactSearchResult]
artifactSearchResultListError message = Err message

memoryResultError : Str -> Result SwarmMemory
memoryResultError message = Err message

memoryListResultError : Str -> Result [SwarmMemory]
memoryListResultError message = Err message

memorySearchResultListError : Str -> Result [SwarmMemorySearchResult]
memorySearchResultListError message = Err message

embeddedMemoryResultError : Str -> Result SwarmEmbeddedMemory
