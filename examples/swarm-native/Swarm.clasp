          Ok (VerifierStepResult {
            run = runValue,
            mailbox = mailboxValue
          }),
        Err message ->
          verifierStepResultError message
      },
    Err message ->
      verifierStepResultError message
  }

runVerifierStepWithLimits : TaskHandle -> Str -> SwarmCommand -> Int -> Int -> Int -> Result VerifierStepResult
runVerifierStepWithLimits handle verifierName spec timeoutMs memoryLimitMb mailboxLimit =
  match verifierRunWithLimits handle verifierName spec timeoutMs memoryLimitMb {
    Ok runValue ->
      match taskMailbox handle mailboxLimit {
