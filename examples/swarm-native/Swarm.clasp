appendSemanticIndexEntrySurfaceIds values entry =
  append values entry.surfaceIds

semanticIndexEntryEditFiles : [SwarmSemanticIndexEntry] -> [Str]
semanticIndexEntryEditFiles entries =
  fold appendSemanticIndexEntryEditFiles emptySwarmTexts entries

semanticIndexEntryArtifactRefs : [SwarmSemanticIndexEntry] -> [Str]
