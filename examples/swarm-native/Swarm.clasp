swarmSpawnPolicyWithChildBudget parentTaskId maxSpawnDepth maxChildTasks =
  SwarmSpawnPolicy {
    parentTaskId = parentTaskId,
    maxSpawnDepth = maxSpawnDepth,
    maxChildTasks = maxChildTasks
  }

taskCreateWithSpawnPolicy : ObjectiveHandle -> SwarmSpawnPolicy -> Str -> Str -> [Str] -> Int -> Int -> Int -> Int -> Result SwarmTask
taskCreateWithSpawnPolicy handle spawn taskId detail dependencies maxRuns deadlineAtMs priority leaseTimeoutMs =
  taskResult (swarmTaskCreateChildWithPolicyRaw handle.root.path handle.objectiveId spawn.parentTaskId taskId detail dependencies maxRuns deadlineAtMs priority spawn.maxSpawnDepth spawn.maxChildTasks leaseTimeoutMs)

taskCreateChildWithDeadlineAndPriority : ObjectiveHandle -> TaskHandle -> Str -> Str -> [Str] -> Int -> Int -> Int -> Int -> Result SwarmTask
taskCreateChildWithDeadlineAndPriority objective parent taskId detail dependencies maxRuns deadlineAtMs priority leaseTimeoutMs =
  taskCreateWithSpawnPolicy objective (swarmSpawnPolicy parent.taskId 0) taskId detail dependencies maxRuns deadlineAtMs priority leaseTimeoutMs

taskCreateChildWithPriority : ObjectiveHandle -> TaskHandle -> Str -> Str -> [Str] -> Int -> Int -> Int -> Result SwarmTask
taskCreateChildWithPriority objective parent taskId detail dependencies maxRuns priority leaseTimeoutMs =
  taskCreateChildWithDeadlineAndPriority objective parent taskId detail dependencies maxRuns noDeadlineAtMs priority leaseTimeoutMs

