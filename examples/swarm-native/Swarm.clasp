firstRunStatus : Str -> SwarmRun -> Str
firstRunStatus current run = if current == "" then run.status else current

firstRunName : Str -> SwarmRun -> Str
firstRunName current run = if current == "" then run.name else current

firstVerifierStatus : Str -> SwarmRun -> Str
firstVerifierStatus current run =
  if current == "" then
    if run.role == "verifier" then run.status else ""
  else
    current

firstVerifierName : Str -> SwarmRun -> Str
firstVerifierName current run =
  if current == "" then
    if run.role == "verifier" then run.name else ""
  else
    current

artifactKind : SwarmArtifact -> Str
artifactKind artifact = artifact.kind

artifactPath : SwarmArtifact -> Str
artifactPath artifact = artifact.path

readyTaskId : SwarmTask -> Str
readyTaskId task = task.taskId

memorySearchResultMemoryValue : SwarmMemorySearchResult -> Str
memorySearchResultMemoryValue item = item.memory.value

memorySearchResultMatchedText : SwarmMemorySearchResult -> Str
memorySearchResultMatchedText item = item.matchedText

memorySearchResultScore : SwarmMemorySearchResult -> Int
memorySearchResultScore item = item.score

artifactSearchResultMatchedText : SwarmArtifactSearchResult -> Str
artifactSearchResultMatchedText item = item.matchedText

artifactSearchResultScore : SwarmArtifactSearchResult -> Int
artifactSearchResultScore item = item.score

verificationTraceFailureClassification : SwarmRun -> Str
verificationTraceFailureClassification run =
  if runPassed run then
    "none"
  else
    if run.timedOut then
      "timeout"
    else
      "exit-code"

verificationTraceEntry : Str -> SwarmRun -> VerificationTraceEntry
verificationTraceEntry verifierName run =
  VerificationTraceEntry {
    verifierName = textConcat [verifierName],
    runId = run.runId,
    status = textConcat [run.status],
    exitCode = run.exitCode,
    timedOut = run.timedOut,
    memoryLimitMb = run.memoryLimitMb,
    stdoutArtifactPath = textConcat [run.stdoutArtifactPath],
    stderrArtifactPath = textConcat [run.stderrArtifactPath],
    failedVerifierClassification = textConcat [verificationTraceFailureClassification run]
  }

verificationTraceVerifierName : VerificationTraceEntry -> Str
verificationTraceVerifierName entry = entry.verifierName

verificationTraceFailedVerifierClassification : VerificationTraceEntry -> Str
verificationTraceFailedVerifierClassification entry = entry.failedVerifierClassification

verificationTraceStdoutArtifactPath : VerificationTraceEntry -> Str
verificationTraceStdoutArtifactPath entry = entry.stdoutArtifactPath

verificationTraceStderrArtifactPath : VerificationTraceEntry -> Str
verificationTraceStderrArtifactPath entry = entry.stderrArtifactPath

runTraceEntry : SwarmRun -> VerificationTraceEntry
runTraceEntry run = verificationTraceEntry run.name run

verificationPlanMailboxSummary : SwarmMailbox -> VerificationPlanMailboxSummary
verificationPlanMailboxSummary mailbox =
  VerificationPlanMailboxSummary {
    historyCount = length mailbox.history,
    tailCount = length mailbox.tail,
    approvalCount = length mailbox.approvals,
    runCount = length mailbox.runs,
    artifactCount = length mailbox.artifacts,
    memoryCount = length mailbox.memory,
    latestRunStatus = mailbox.latestRunStatus,
    latestRunName = mailbox.latestRunName,
    latestVerifierStatus = mailbox.latestVerifierStatus,
    latestVerifier = mailbox.latestVerifier,
    artifactKinds = map artifactKind mailbox.artifacts,
    artifactPaths = map artifactPath mailbox.artifacts
  }

taskContextPack : TaskHandle -> Str -> Int -> Result SwarmContextPack
taskContextPack handle query limit =
  match status handle {
    Ok taskValue ->
      let objective = objectiveHandle handle.root taskValue.objectiveId in
      match ready objective {
        Ok readyTasks ->
          match managerNext objective {
            Ok managerActionValue ->
              match taskMailbox handle limit {
                Ok mailboxValue ->
                  match taskMemorySearch handle query limit {
                    Ok taskMemoryMatchesValue ->
                      match objectiveMemorySearch objective query limit {
                        Ok objectiveMemoryMatchesValue ->
                          match benchmarkHistorySearch objective limit {
                            Ok benchmarkMemoryMatchesValue ->
                              match artifactSearch handle "" query limit contextPackArtifactReadBytes {
                                Ok searchResultsValue ->
                                  match artifactSearch handle "" contextPackSemanticIndexQuery limit contextPackArtifactReadBytes {
                                    Ok semanticSearchResultsValue ->
                                      match readArtifactContents handle.root mailboxValue.artifacts contextPackArtifactReadBytes limit {
                                        Ok artifactContentValues ->
                                          let memoryMatches = append taskMemoryMatchesValue objectiveMemoryMatchesValue in
                                          let mailboxSummary = verificationPlanMailboxSummary mailboxValue in
                                          Ok (SwarmContextPack {
                                            task = taskValue,
                                            readyTaskIds = map readyTaskId readyTasks,
                                            managerAction = managerActionValue,
                                            mailboxSummary = mailboxSummary,
                                            taskMemoryMatches = taskMemoryMatchesValue,
                                            objectiveMemoryMatches = objectiveMemoryMatchesValue,
                                            benchmarkMemoryMatches = benchmarkMemoryMatchesValue,
                                            artifactSearchMatches = searchResultsValue,
                                            semanticArtifactMatches = semanticSearchResultsValue,
                                            memoryValues = map memorySearchResultMemoryValue memoryMatches,
                                            memoryMatchedText = map memorySearchResultMatchedText memoryMatches,
                                            memoryScores = map memorySearchResultScore memoryMatches,
                                            benchmarkValues = map memorySearchResultMemoryValue benchmarkMemoryMatchesValue,
                                            benchmarkMatchedText = map memorySearchResultMatchedText benchmarkMemoryMatchesValue,
                                            benchmarkScores = map memorySearchResultScore benchmarkMemoryMatchesValue,
                                            artifactSearchMatchedText = map artifactSearchResultMatchedText searchResultsValue,
                                            artifactSearchScores = map artifactSearchResultScore searchResultsValue,
                                            semanticArtifactMatchedText = map artifactSearchResultMatchedText semanticSearchResultsValue,
                                            semanticArtifactScores = map artifactSearchResultScore semanticSearchResultsValue,
                                            runTrace = map runTraceEntry mailboxValue.runs,
                                            artifactKinds = mailboxSummary.artifactKinds,
                                            artifactPaths = mailboxSummary.artifactPaths,
                                            artifactExcerpts = artifactContentValues
                                          }),
                                        Err message ->
                                          contextPackResultError message
                                      },
                                    Err message ->
                                      contextPackResultError message
                                  },
                                Err message ->
                                  contextPackResultError message
                              },
                            Err message ->
                              contextPackResultError message
                          },
                        Err message ->
                          contextPackResultError message
                      },
                    Err message ->
                      contextPackResultError message
                  },
                Err message ->
                  contextPackResultError message
              },
            Err message ->
              contextPackResultError message
          },
        Err message ->
          contextPackResultError message
      },
    Err message ->
      contextPackResultError message
  }

taskMailbox : TaskHandle -> Int -> Result SwarmMailbox
taskMailbox handle limit =
  match history handle {
    Ok historyValue ->
      match tail handle limit {
        Ok tailValue ->
          match approvals handle {
            Ok approvalsValue ->
              match runs handle {
                Ok runsValue ->
                  match artifacts handle {
                    Ok artifactsValue ->
                      match taskMemory handle "" limit {
                        Ok memoryValue ->
                          Ok (SwarmMailbox {
                            history = historyValue,
                            tail = tailValue,
                            approvals = approvalsValue,
                            runs = runsValue,
                            artifacts = artifactsValue,
                            memory = memoryValue,
                            latestRunStatus = fold firstRunStatus "" runsValue,
                            latestRunName = fold firstRunName "" runsValue,
                            latestVerifierStatus = fold firstVerifierStatus "" runsValue,
                            latestVerifier = fold firstVerifierName "" runsValue
                          }),
                        Err message ->
                          mailboxResultError message
                      },
                    Err message ->
                      mailboxResultError message
                  },
                Err message ->
                  mailboxResultError message
              },
            Err message ->
              mailboxResultError message
          },
        Err message ->
          mailboxResultError message
      },
    Err message ->
      mailboxResultError message
  }

runToolStep : TaskHandle -> SwarmCommand -> Int -> Result ToolStepResult
runToolStep handle spec mailboxLimit =
  match lease handle {
    Ok leaseValue ->
      match toolRun handle spec {
        Ok runValue ->
          match finishToolRun handle runValue {
            Ok statusValue ->
              match taskMailbox handle mailboxLimit {
                Ok mailboxValue ->
                  Ok (ToolStepResult {
                    lease = leaseValue,
                    run = runValue,
                    status = statusValue,
                    mailbox = mailboxValue
                  }),
                Err message ->
                  toolStepResultError message
              },
            Err message ->
              toolStepResultError message
          },
        Err message ->
          toolStepResultError message
      },
    Err message ->
      toolStepResultError message
  }

runToolStepWithTimeout : TaskHandle -> SwarmCommand -> Int -> Int -> Result ToolStepResult
runToolStepWithTimeout handle spec timeoutMs mailboxLimit =
  match lease handle {
    Ok leaseValue ->
      match toolRunWithTimeout handle spec timeoutMs {
        Ok runValue ->
          match finishToolRun handle runValue {
            Ok statusValue ->
              match taskMailbox handle mailboxLimit {
                Ok mailboxValue ->
                  Ok (ToolStepResult {
                    lease = leaseValue,
                    run = runValue,
                    status = statusValue,
                    mailbox = mailboxValue
                  }),
                Err message ->
                  toolStepResultError message
              },
            Err message ->
              toolStepResultError message
          },
        Err message ->
          toolStepResultError message
      },
    Err message ->
      toolStepResultError message
  }

runToolStepWithLimits : TaskHandle -> SwarmCommand -> Int -> Int -> Int -> Result ToolStepResult
runToolStepWithLimits handle spec timeoutMs memoryLimitMb mailboxLimit =
  match lease handle {
    Ok leaseValue ->
      match toolRunWithLimits handle spec timeoutMs memoryLimitMb {
        Ok runValue ->
          match finishToolRun handle runValue {
            Ok statusValue ->
              match taskMailbox handle mailboxLimit {
                Ok mailboxValue ->
                  Ok (ToolStepResult {
                    lease = leaseValue,
                    run = runValue,
                    status = statusValue,
                    mailbox = mailboxValue
                  }),
                Err message ->
                  toolStepResultError message
              },
            Err message ->
              toolStepResultError message
          },
        Err message ->
          toolStepResultError message
      },
    Err message ->
      toolStepResultError message
  }

runToolStepWithOptionalLimits : TaskHandle -> SwarmCommand -> Int -> Int -> Int -> Result ToolStepResult
runToolStepWithOptionalLimits handle spec timeoutMs memoryLimitMb mailboxLimit =
  if memoryLimitMb > 0 then
    runToolStepWithLimits handle spec timeoutMs memoryLimitMb mailboxLimit
  else if timeoutMs > 0 then
    runToolStepWithTimeout handle spec timeoutMs mailboxLimit
  else
    runToolStep handle spec mailboxLimit

runVerifierStep : TaskHandle -> Str -> SwarmCommand -> Int -> Result VerifierStepResult
runVerifierStep handle verifierName spec mailboxLimit =
  match verifierRun handle verifierName spec {
    Ok runValue ->
      match taskMailbox handle mailboxLimit {
        Ok mailboxValue ->
          Ok (VerifierStepResult {
            run = runValue,
            mailbox = mailboxValue
          }),
        Err message ->
          verifierStepResultError message
      },
    Err message ->
      verifierStepResultError message
  }

runVerifierStepWithTimeout : TaskHandle -> Str -> SwarmCommand -> Int -> Int -> Result VerifierStepResult
runVerifierStepWithTimeout handle verifierName spec timeoutMs mailboxLimit =
  match verifierRunWithTimeout handle verifierName spec timeoutMs {
