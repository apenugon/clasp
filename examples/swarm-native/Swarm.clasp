module Swarm

foreign swarmBootstrapRaw : Str -> Str -> Str -> Result Str = "swarmBootstrapJson"
foreign swarmStartRaw : Str -> Str -> Str -> Result Str = "swarmStartJson"
foreign swarmLeaseRaw : Str -> Str -> Str -> Result Str = "swarmLeaseJson"
foreign swarmReleaseRaw : Str -> Str -> Str -> Result Str = "swarmReleaseJson"
foreign swarmHeartbeatRaw : Str -> Str -> Str -> Result Str = "swarmHeartbeatJson"
foreign swarmCompleteRaw : Str -> Str -> Str -> Result Str = "swarmCompleteJson"
foreign swarmFailRaw : Str -> Str -> Str -> Result Str = "swarmFailJson"
foreign swarmRetryRaw : Str -> Str -> Str -> Result Str = "swarmRetryJson"
foreign swarmStopRaw : Str -> Str -> Str -> Result Str = "swarmStopJson"
foreign swarmResumeRaw : Str -> Str -> Str -> Result Str = "swarmResumeJson"
foreign swarmStatusRaw : Str -> Str -> Result Str = "swarmStatusJson"
foreign swarmSummaryRaw : Str -> Result Str = "swarmSummaryJson"
foreign swarmReadyRaw : Str -> Str -> Result Str = "swarmReadyJson"
foreign swarmManagerNextRaw : Str -> Str -> Result Str = "swarmManagerNextJson"
foreign swarmObjectiveCreateRaw : Str -> Str -> Str -> Int -> Int -> Result Str = "swarmObjectiveCreateJson"
foreign swarmObjectiveCreateWithDeadlineRaw : Str -> Str -> Str -> Int -> Int -> Int -> Result Str = "swarmObjectiveCreateWithDeadlineJson"
foreign swarmObjectiveStatusRaw : Str -> Str -> Result Str = "swarmObjectiveStatusJson"
foreign swarmObjectivesRaw : Str -> Result Str = "swarmObjectivesJson"
foreign swarmTaskCreateRaw : Str -> Str -> Str -> Str -> [Str] -> Int -> Int -> Result Str = "swarmTaskCreateJson"
foreign swarmTaskCreateWithDeadlineRaw : Str -> Str -> Str -> Str -> [Str] -> Int -> Int -> Int -> Result Str = "swarmTaskCreateWithDeadlineJson"
foreign swarmPolicySetRaw : Str -> Str -> Str -> [Str] -> [Str] -> Result Str = "swarmPolicySetJson"
foreign swarmPolicySetWithProcessAccessRaw : Str -> Str -> Str -> [Str] -> [Str] -> [Str] -> Result Str = "swarmPolicySetWithProcessAccessJson"
foreign swarmPolicySetWithAccessRaw : Str -> Str -> Str -> [Str] -> [Str] -> [Str] -> [Str] -> Result Str = "swarmPolicySetWithAccessJson"
foreign swarmPolicySetWithCapabilitiesRaw : Str -> Str -> Str -> [Str] -> [Str] -> [Str] -> [Str] -> Str -> Result Str = "swarmPolicySetWithCapabilitiesJson"
foreign swarmToolRunRaw : Str -> Str -> Str -> Str -> [Str] -> Result Str = "swarmToolRunJson"
foreign swarmToolRunWithTimeoutRaw : Str -> Str -> Str -> Str -> Int -> [Str] -> Result Str = "swarmToolRunWithTimeoutJson"
foreign swarmToolRunWithLimitsRaw : Str -> Str -> Str -> Str -> Int -> Int -> [Str] -> Result Str = "swarmToolRunWithLimitsJson"
foreign swarmVerifierRunRaw : Str -> Str -> Str -> Str -> Str -> [Str] -> Result Str = "swarmVerifierRunJson"
foreign swarmVerifierRunWithTimeoutRaw : Str -> Str -> Str -> Str -> Str -> Int -> [Str] -> Result Str = "swarmVerifierRunWithTimeoutJson"
foreign swarmVerifierRunWithLimitsRaw : Str -> Str -> Str -> Str -> Str -> Int -> Int -> [Str] -> Result Str = "swarmVerifierRunWithLimitsJson"
foreign swarmApproveRaw : Str -> Str -> Str -> Str -> Result Str = "swarmApproveJson"
foreign swarmApprovalsRaw : Str -> Str -> Result Str = "swarmApprovalsJson"
foreign swarmMergegateDecideRaw : Str -> Str -> Str -> Str -> [Str] -> Result Str = "swarmMergegateDecideJson"
foreign swarmRunsRaw : Str -> Str -> Result Str = "swarmRunsJson"
foreign swarmArtifactsRaw : Str -> Str -> Result Str = "swarmArtifactsJson"
foreign swarmArtifactReadRaw : Str -> Int -> Int -> Result Str = "swarmArtifactReadJson"
foreign swarmArtifactSearchRaw : Str -> Str -> Str -> Str -> Int -> Int -> Result Str = "swarmArtifactSearchJson"
foreign swarmArtifactWriteRaw : Str -> Str -> Str -> Str -> Str -> Result Str = "swarmArtifactWriteJson"
foreign swarmMemoryPutRaw : Str -> Str -> Str -> Str -> Str -> Str -> Result Str = "swarmMemoryPutJson"
foreign swarmMemoryQueryRaw : Str -> Str -> Str -> Str -> Int -> Result Str = "swarmMemoryQueryJson"
foreign swarmMemorySearchRaw : Str -> Str -> Str -> Str -> Int -> Result Str = "swarmMemorySearchJson"
foreign swarmHistoryRaw : Str -> Str -> Result Str = "swarmHistoryJson"
foreign swarmTailRaw : Str -> Str -> Int -> Result Str = "swarmTailJson"
foreign swarmTasksRaw : Str -> Result Str = "swarmTasksJson"

record SwarmRoot = { path : Str }
record ObjectiveHandle = { root : SwarmRoot, objectiveId : Str }
record TaskHandle = { root : SwarmRoot, taskId : Str, actor : Str }
record SwarmCommand = { cwd : Str, command : [Str] }

record SwarmObjective = {
  createdAtMs : Int,
  deadlineAtMs : Int,
  objectiveId : Str,
  detail : Str,
  maxRuns : Int,
  maxTasks : Int,
  projectedStatus : Str,
  status : Str,
  taskCount : Int,
  runCount : Int,
  updatedAtMs : Int
}

record SwarmTask = {
  attempts : Int,
  taskId : Str,
  status : Str,
  objectiveId : Str,
  detail : Str,
  dependencies : [Str],
  ready : Bool,
  blockedBy : [Str],
  createdAtMs : Int,
  deadlineAtMs : Int,
  heartbeatSeen : Bool,
  lastError : Str,
  lastHeartbeatAtMs : Int,
  leaseActor : Str,
  leaseExpired : Bool,
  leaseTimeoutMs : Int,
  maxRuns : Int,
  objectiveDeadlineAtMs : Int,
  updatedAtMs : Int
}

record SwarmPolicy = {
  createdAtMs : Int,
  taskId : Str,
  mergegateName : Str,
  requiredApprovals : [Str],
  requiredVerifiers : [Str],
  allowedProcesses : [Str],
  allowedWorkspaceRoots : [Str],
  networkAccess : Str,
  updatedAtMs : Int
}

record SwarmRun = {
  actor : Str,
  command : [Str],
  cwd : Str,
  endedAtMs : Int,
  exitCode : Int,
  name : Str,
  role : Str,
  runId : Int,
  startedAtMs : Int,
  status : Str,
  stderrArtifactPath : Str,
  stdoutArtifactPath : Str,
  taskId : Str,
  timedOut : Bool,
  memoryLimitMb : Int
}

record SwarmApproval = {
  actor : Str,
  approvalId : Int,
  atMs : Int,
  detail : Str,
  name : Str,
  taskId : Str
}

record SwarmMergeDecision = {
  taskId : Str,
  mergegateName : Str,
  verdict : Str
}

record SwarmArtifact = {
  artifactId : Int,
  createdAtMs : Int,
  taskId : Str,
  kind : Str,
  path : Str
}

record SwarmArtifactContent = {
  artifactId : Int,
  createdAtMs : Int,
  taskId : Str,
  kind : Str,
  path : Str,
  maxBytes : Int,
  bytesRead : Int,
  totalBytes : Int,
  truncated : Bool,
  lossyUtf8 : Bool,
  text : Str
}

record SwarmArtifactSearchResult = {
  artifact : SwarmArtifact,
  score : Int,
  matchedText : Str,
  excerpt : SwarmArtifactContent
}

record SwarmMemory = {
  actor : Str,
  createdAtMs : Int,
  memoryId : Int,
  objectiveId : Str,
  taskId : Str,
  key : Str,
  value : Str,
  updatedAtMs : Int
}

record SwarmMemorySearchResult = {
  memory : SwarmMemory,
  score : Int,
  matchedText : Str
}

record SwarmEvent = {
  actor : Str,
  atMs : Int,
  detail : Str,
  kind : Str,
  taskId : Str,
}

record SwarmTaskUpdate = {
  database : Str,
  event : SwarmEvent,
  root : Str,
  task : SwarmTask
}

record SwarmSummary = {
  allTaskIds : [Str],
  completedTaskIds : [Str],
  readyTaskIds : [Str],
  hasBootstrap : Bool,
  bootstrapStatus : Str
}

record SwarmManagerAction = {
  objectiveId : Str,
  status : Str,
  action : Str,
  suggestedCommand : [Str],
  taskId : Str,
  taskStatus : Str,
  blockedBy : [Str],
  blockerTaskIds : [Str],
  requiredApprovals : [Str],
  requiredVerifiers : [Str],
  latestRunId : Int,
  latestRunRole : Str,
  latestRunName : Str,
  latestRunStatus : Str,
  latestRunExitCode : Int,
  latestVerifier : Str,
  latestVerifierStatus : Str,
  latestVerifierExitCode : Int,
  mergegateName : Str,
  mergegateVerdict : Str,
  mergegateDetail : Str
}

record SwarmObjectiveStatus = {
  objective : SwarmObjective,
  projectedStatus : Str,
  tasks : [SwarmTask]
}

record SwarmMailbox = {
  history : [SwarmEvent],
  tail : [SwarmEvent],
  approvals : [SwarmApproval],
  runs : [SwarmRun],
  artifacts : [SwarmArtifact],
  memory : [SwarmMemory],
  latestRunStatus : Str,
  latestRunName : Str,
  latestVerifierStatus : Str,
  latestVerifier : Str
}

record ToolStepResult = {
  lease : SwarmTaskUpdate,
  run : SwarmRun,
  status : SwarmTaskUpdate,
  mailbox : SwarmMailbox
}

record VerifierStepResult = {
  run : SwarmRun,
  mailbox : SwarmMailbox
}

record VerificationCommand = {
  verifierName : Str,
  command : SwarmCommand
}

record VerificationPlan = {
  name : Str,
  commands : [VerificationCommand],
  requiredVerifierNames : [Str]
}

record VerificationTraceEntry = {
  verifierName : Str,
  runId : Int,
  status : Str,
  exitCode : Int,
  timedOut : Bool,
  memoryLimitMb : Int,
  stdoutArtifactPath : Str,
  stderrArtifactPath : Str,
  failedVerifierClassification : Str
}

record VerificationPlanMailboxSummary = {
  historyCount : Int,
  tailCount : Int,
  approvalCount : Int,
  runCount : Int,
  artifactCount : Int,
  memoryCount : Int,
  latestRunStatus : Str,
  latestRunName : Str,
  latestVerifierStatus : Str,
  latestVerifier : Str,
  artifactKinds : [Str],
  artifactPaths : [Str]
}

record SwarmContextPack = {
  task : SwarmTask,
  readyTaskIds : [Str],
  managerAction : SwarmManagerAction,
  mailboxSummary : VerificationPlanMailboxSummary,
  taskMemoryMatches : [SwarmMemorySearchResult],
  objectiveMemoryMatches : [SwarmMemorySearchResult],
  benchmarkMemoryMatches : [SwarmMemorySearchResult],
  artifactSearchMatches : [SwarmArtifactSearchResult],
  semanticArtifactMatches : [SwarmArtifactSearchResult],
  memoryValues : [Str],
  memoryMatchedText : [Str],
  memoryScores : [Int],
  benchmarkValues : [Str],
  benchmarkMatchedText : [Str],
  benchmarkScores : [Int],
  artifactSearchMatchedText : [Str],
  artifactSearchScores : [Int],
  semanticArtifactMatchedText : [Str],
  semanticArtifactScores : [Int],
  runTrace : [VerificationTraceEntry],
  artifactKinds : [Str],
  artifactPaths : [Str],
  artifactExcerpts : [SwarmArtifactContent]
}

record VerificationPlanResult = {
  plan : VerificationPlan,
  steps : [VerifierStepResult],
  passed : Bool,
  failedVerifiers : [Str],
  trace : [VerificationTraceEntry],
  mailbox : SwarmMailbox,
  mailboxSummary : VerificationPlanMailboxSummary
}

record VerificationPlanExecution = {
  handle : TaskHandle,
  mailboxLimit : Int,
  timeoutMs : Int,
  useTimeout : Bool,
  memoryLimitMb : Int,
  steps : [VerifierStepResult],
  passed : Bool,
  failedVerifiers : [Str],
  trace : [VerificationTraceEntry],
  error : Str
}

record ReviewStepResult = {
  approval : SwarmApproval,
  approvals : [SwarmApproval],
  managerAfterApproval : SwarmManagerAction,
  mergeDecision : SwarmMergeDecision,
  mailbox : SwarmMailbox
}

record ManagedLoopSpec = {
  root : SwarmRoot,
  objectiveId : Str,
  objectiveDetail : Str,
  objectiveMaxTasks : Int,
  objectiveMaxRuns : Int,
  taskId : Str,
  taskDetail : Str,
  taskMaxRuns : Int,
  leaseTimeoutMs : Int,
  actor : Str,
  maxAttempts : Int,
  mailboxLimit : Int,
  statusPath : Str,
  builderCommand : SwarmCommand,
  builderTimeoutMs : Int,
  useBuilderTimeout : Bool,
  builderMemoryLimitMb : Int,
  verificationPlan : VerificationPlan,
  verifierTimeoutMs : Int,
  useVerifierTimeout : Bool,
  verifierMemoryLimitMb : Int,
  approvalName : Str,
  mergegateName : Str,
  requiredApprovals : [Str]
}

record ManagedLoopReport = {
  phase : Str,
  attempt : Int,
  maxAttempts : Int,
  builderMemoryLimitMb : Int,
  verifierMemoryLimitMb : Int,
  completed : Bool,
  exhausted : Bool,
  requeued : Bool,
  requeueCount : Int,
  objectiveId : Str,
  taskId : Str,
  taskStatus : Str,
  objectiveProjectedStatus : Str,
  verificationPlanName : Str,
  requiredVerifiers : [Str],
  readyTaskIds : [Str],
  blockedBy : [Str],
  blockerTaskIds : [Str],
  managerAction : Str,
  latestRunStatus : Str,
  latestRunName : Str,
  latestVerifierStatus : Str,
  latestVerifier : Str,
  latestFailureClassification : Str,
  failedVerifiers : [Str],
  verificationTrace : [VerificationTraceEntry],
  verificationTraceClassifications : [Str],
  failedVerificationTrace : [VerificationTraceEntry],
  failedVerificationTraceClassifications : [Str],
  approvalCount : Int,
  mergegateVerdict : Str,
  mailboxSummary : VerificationPlanMailboxSummary,
  contextMemoryValues : [Str],
  contextMemoryScores : [Int],
  contextRunTraceClassifications : [Str],
  contextArtifactPaths : [Str]
}

noDeadlineAtMs : Int
noDeadlineAtMs = 0

swarmRoot : Str -> SwarmRoot
swarmRoot path = SwarmRoot { path = path }

objectiveHandle : SwarmRoot -> Str -> ObjectiveHandle
objectiveHandle root objectiveId = ObjectiveHandle { root = root, objectiveId = objectiveId }

taskHandle : SwarmRoot -> Str -> Str -> TaskHandle
taskHandle root taskId actor = TaskHandle { root = root, taskId = taskId, actor = actor }

commandSpec : Str -> [Str] -> SwarmCommand
commandSpec cwd command = SwarmCommand { cwd = cwd, command = command }

verificationCommand : Str -> SwarmCommand -> VerificationCommand
verificationCommand verifierName command =
  VerificationCommand { verifierName = verifierName, command = command }

verificationCommandName : VerificationCommand -> Str
verificationCommandName command = command.verifierName

verificationPlan : Str -> [VerificationCommand] -> VerificationPlan
verificationPlan name commands =
  VerificationPlan {
    name = name,
    commands = commands,
    requiredVerifierNames = map verificationCommandName commands
  }

taskResultError : Str -> Result SwarmTask
taskResultError message = Err message

objectiveResultError : Str -> Result SwarmObjective
objectiveResultError message = Err message

policyResultError : Str -> Result SwarmPolicy
policyResultError message = Err message

runResultError : Str -> Result SwarmRun
runResultError message = Err message

approvalResultError : Str -> Result SwarmApproval
approvalResultError message = Err message

mergeDecisionResultError : Str -> Result SwarmMergeDecision
mergeDecisionResultError message = Err message

summaryResultError : Str -> Result SwarmSummary
summaryResultError message = Err message

managerActionResultError : Str -> Result SwarmManagerAction
managerActionResultError message = Err message

objectiveStatusResultError : Str -> Result SwarmObjectiveStatus
objectiveStatusResultError message = Err message

taskListResultError : Str -> Result [SwarmTask]
taskListResultError message = Err message

runListResultError : Str -> Result [SwarmRun]
runListResultError message = Err message

artifactListResultError : Str -> Result [SwarmArtifact]
artifactListResultError message = Err message

artifactResultError : Str -> Result SwarmArtifact
artifactResultError message = Err message

artifactContentResultError : Str -> Result SwarmArtifactContent
artifactContentResultError message = Err message

artifactContentListResultError : Str -> Result [SwarmArtifactContent]
artifactContentListResultError message = Err message

artifactSearchResultListError : Str -> Result [SwarmArtifactSearchResult]
artifactSearchResultListError message = Err message

memoryResultError : Str -> Result SwarmMemory
memoryResultError message = Err message

memoryListResultError : Str -> Result [SwarmMemory]
memoryListResultError message = Err message

memorySearchResultListError : Str -> Result [SwarmMemorySearchResult]
memorySearchResultListError message = Err message

eventListResultError : Str -> Result [SwarmEvent]
eventListResultError message = Err message

approvalListResultError : Str -> Result [SwarmApproval]
approvalListResultError message = Err message

objectiveListResultError : Str -> Result [SwarmObjective]
objectiveListResultError message = Err message

mailboxResultError : Str -> Result SwarmMailbox
mailboxResultError message = Err message

toolStepResultError : Str -> Result ToolStepResult
toolStepResultError message = Err message

verifierStepResultError : Str -> Result VerifierStepResult
verifierStepResultError message = Err message

verificationPlanResultError : Str -> Result VerificationPlanResult
verificationPlanResultError message = Err message

contextPackResultError : Str -> Result SwarmContextPack
contextPackResultError message = Err message

reviewStepResultError : Str -> Result ReviewStepResult
reviewStepResultError message = Err message

runPassed : SwarmRun -> Bool
runPassed run = run.status == "passed"

finishToolRun : TaskHandle -> SwarmRun -> Result SwarmTaskUpdate
finishToolRun handle run =
  if runPassed run then
    complete handle
  else
    fail handle

taskResult : Result Str -> Result SwarmTask
taskResult value = match value {
  Ok raw -> Ok (decode SwarmTask raw),
  Err message -> taskResultError message
}

taskUpdateResultError : Str -> Result SwarmTaskUpdate
taskUpdateResultError message = Err message

taskUpdateResult : Result Str -> Result SwarmTaskUpdate
taskUpdateResult value = match value {
  Ok raw -> Ok (decode SwarmTaskUpdate raw),
  Err message -> taskUpdateResultError message
}

objectiveResult : Result Str -> Result SwarmObjective
objectiveResult value = match value {
  Ok raw -> Ok (decode SwarmObjective raw),
  Err message -> objectiveResultError message
}

policyResult : Result Str -> Result SwarmPolicy
policyResult value = match value {
  Ok raw -> Ok (decode SwarmPolicy raw),
  Err message -> policyResultError message
