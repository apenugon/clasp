verifierRunWithOptionalLimits : TaskHandle -> Str -> SwarmCommand -> Int -> Int -> Result SwarmRun
verifierRunWithOptionalLimits handle verifierName spec timeoutMs memoryLimitMb =
  if memoryLimitMb > 0 then
    verifierRunWithLimits handle verifierName spec timeoutMs memoryLimitMb
  else if timeoutMs > 0 then
    verifierRunWithTimeout handle verifierName spec timeoutMs
  else
    verifierRun handle verifierName spec

