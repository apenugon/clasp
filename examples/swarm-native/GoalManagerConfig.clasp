module GoalManagerConfig

import GoalManagerCounters
import GoalManagerTypes
import Swarm

foreign runCommandRaw : Str -> [Str] -> Result Str = "runCommandJson"
foreign spawnCommandRaw : Str -> Str -> Str -> Str -> Int -> [Str] -> Result Str = "spawnCommandJson"
foreign watchCommandRaw : Str -> Str -> Str -> Str -> Int -> [Str] -> Result Str = "watchCommandJson"
foreign reconcileWatchedProcessRaw : Str -> Result Str = "reconcileWatchedProcessJson"
foreign awaitWatchedProcessRaw : Str -> Int -> Result Str = "awaitWatchedProcessJson"
foreign awaitWatchedProcessTimeoutRaw : Str -> Int -> Int -> Result Str = "awaitWatchedProcessTimeoutJson"
foreign sleepMsRaw : Int -> Result Str = "sleepMs"

stateRootPath : Str
stateRootPath =
  if textJoin "" argv == "" then
    "swarm-native-goal-manager-state"
  else
    pathJoin argv

swarmStateRoot : SwarmRoot
swarmStateRoot = swarmRoot stateRootPath

readEnvText : Str -> Str -> Str
readEnvText name fallback = match envVar name {
  Ok raw -> if raw == "" then fallback else decode Str raw,
  Err message -> fallback
}

readEnvTextList : Str -> [Str] -> [Str]
readEnvTextList name fallback = match envVar name {
  Ok raw -> if raw == "" then fallback else decode [Str] raw,
  Err message -> fallback
}

readEnvCommandTextSetting : Str -> Str -> Str
readEnvCommandTextSetting name fallback = match envVar name {
  Ok raw ->
    if raw == "" then
      fallback
    else
      match textPrefix raw "[" {
        Ok arrayTail -> textJoin "\n" (decode [Str] raw),
        Err notArray -> decode Str raw
      },
  Err message -> fallback
}

readEnvBool : Str -> Bool -> Bool
readEnvBool name fallback = match envVar name {
  Ok raw -> if raw == "" then fallback else decode Bool raw,
  Err message -> fallback
}

readEnvInt : Str -> Int -> Int
readEnvInt name fallback = match envVar name {
  Ok raw -> if raw == "" then fallback else decode Int raw,
  Err message -> fallback
}

goalText : Str
goalText =
  readEnvText
    "CLASP_MANAGER_GOAL_JSON"
    "Improve Clasp by planning bounded native compiler/runtime/language tasks and closing them with ordinary Clasp loops."

objectiveIdFromStatusOr : Str -> Str
objectiveIdFromStatusOr fallback =
  match readFile (pathJoin [stateRootPath, "status.json"]) {
    Ok raw -> objectiveIdFromStatusRawOr raw fallback,
    Err message ->
      fallback
  }

configFirstTextOrEmpty : [Str] -> Str
configFirstTextOrEmpty values = {
  let mut first = "";
  let mut found = false;
  for value in values {
    if found then
      found
    else {
      first = value;
      found = true;
      found
    }
  };
  first
}

configSecondTextOrEmpty : [Str] -> Str
configSecondTextOrEmpty values = {
  let mut second = "";
  let mut index = 0;
  for value in values {
    if index == 0 then {
      index = 1;
      index
    } else if index == 1 then {
      second = value;
      index = 2;
      index
    } else
      index
  };
  second
}

objectiveIdFromStatusRawWithMarker : Str -> Str -> Str
objectiveIdFromStatusRawWithMarker raw marker = {
  let afterMarker = configSecondTextOrEmpty (textSplit raw marker);
  if afterMarker == "" then
    ""
  else
    configFirstTextOrEmpty (textSplit afterMarker "\"")
}

objectiveIdFromStatusRawOr : Str -> Str -> Str
objectiveIdFromStatusRawOr raw fallback = {
  let compact = objectiveIdFromStatusRawWithMarker raw "\"objectiveId\":\"" in
  if compact != "" then
    compact
  else {
    let spaced = objectiveIdFromStatusRawWithMarker raw "\"objectiveId\": \"" in
    if spaced != "" then
      spaced
    else
      fallback
  }
}

objectiveId : Str
objectiveId =
  match envVar "CLASP_MANAGER_OBJECTIVE_ID_JSON" {
    Ok raw -> if raw == "" then objectiveIdFromStatusOr "improve-clasp" else decode Str raw,
    Err message -> objectiveIdFromStatusOr "improve-clasp"
  }

effectiveObjectiveId : Str
effectiveObjectiveId = objectiveIdFromStatusOr objectiveId

managerProgramPath : Str
managerProgramPath = readEnvText "CLASP_MANAGER_PROGRAM_JSON" "examples/swarm-native/GoalManager.wrapper.clasp"

workspaceRoot : Str
workspaceRoot = readEnvText "CLASP_LOOP_WORKSPACE_JSON" "."

managerXdgCacheHome : Str
managerXdgCacheHome =
  readEnvText "CLASP_MANAGER_XDG_CACHE_HOME_JSON" (pathJoin [stateRootPath, "manager-xdg-cache"])

taskWorkspaceBaseRoot : Str
taskWorkspaceBaseRoot =
  readEnvText
    "CLASP_MANAGER_TASK_WORKSPACE_ROOT_JSON"
    (pathJoin ["/tmp", textConcat ["clasp-goal-manager-workspaces-", textFingerprint64Hex stateRootPath]])

codexBin : Str
codexBin = readEnvText "CLASP_LOOP_CODEX_BIN_JSON" (readEnvText "CLASP_LOOP_AGENT_BIN_JSON" "codex")

managerClaspcBin : Str
