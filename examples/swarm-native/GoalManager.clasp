taskProcessStderrPath : Str -> Str
taskProcessStderrPath taskId = pathJoin [taskReportStateRoot taskId, "loop.stderr.log"]

taskProcessHeartbeatPath : Str -> Str
taskProcessHeartbeatPath taskId = pathJoin [taskReportStateRoot taskId, "loop.process.heartbeat.json"]

taskManagerRetryPath : Str -> Str
taskManagerRetryPath taskId = pathJoin [stateRootPath, textConcat ["child-loop-retries-", taskId, ".json"]]

taskBuilderHeartbeatPath : Str -> Int -> Str
taskBuilderHeartbeatPath taskId attempt =
  pathJoin [taskReportStateRoot taskId, textConcat ["builder-", encode attempt, ".heartbeat.json"]]

taskVerifierHeartbeatPath : Str -> Int -> Str
