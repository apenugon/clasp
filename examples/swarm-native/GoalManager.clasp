module Main

import Service
import Swarm

record WatchedProcess = {
  pid : Int,
  running : Bool,
  completed : Bool,
  exitCode : Int,
  stdoutPath : Str,
  stderrPath : Str,
  heartbeatPath : Str,
  updatedAtMs : Int
}

record PlannerTaskSpec = {
  taskId : Str,
  role : Str,
  detail : Str,
  dependencies : [Str],
  taskPrompt : Str,
  coordinationFocus : [Str]
}

record PlannerReport = {
  objectiveSummary : Str,
  strategy : Str,
  tasks : [PlannerTaskSpec],
  testsRun : [Str],
  residualRisks : [Str]
}

record LegacyPlannerTaskSpec = {
  taskId : Str,
  detail : Str,
  dependencies : [Str],
  taskPrompt : Str
}

record LegacyPlannerReport = {
  objectiveSummary : Str,
  strategy : Str,
  tasks : [LegacyPlannerTaskSpec],
  testsRun : [Str],
  residualRisks : [Str]
}

record CapabilityStatus = {
  name : Str,
  status : Str,
  evidence : [Str],
  blocking_gaps : [Str],
  required_closure : [Str]
}

record VerifierReport = {
  verdict : Str,
  summary : Str,
  findings : [Str],
  tests_run : [Str],
  follow_up : [Str],
  capability_statuses : [CapabilityStatus]
}

record BuilderFeedback = {
  summary : Str,
  ergonomics : [Str],
  follow_ups : [Str],
  warnings : [Str]
}

record BuilderReport = {
  summary : Str,
  files_touched : [Str],
  tests_run : [Str],
  residual_risks : [Str],
  feedback : BuilderFeedback
}

record SwarmMailboxMessage = {
  source : Str,
  taskId : Str,
  wave : Int,
  summary : Str,
  details : [Str]
}

record BenchmarkSignal = {
  suite : Str,
  summary : Str,
  passed : Bool,
  meetsTarget : Bool,
  scoreName : Str,
  scoreValue : Int,
  targetName : Str,
  targetValue : Int
}

record BenchmarkCheckpoint = {
  wave : Int,
  suite : Str,
  summary : Str,
  passed : Bool,
  meetsTarget : Bool,
  scoreName : Str,
  scoreValue : Int,
  targetName : Str,
  targetValue : Int,
  command : [Str]
}

record ProcessResult = { exitCode : Int, stdout : Str, stderr : Str }

record ManagerState = {
  phase : Str,
  verdict : Str,
  completed : Bool,
  objectiveId : Str,
  plannerTaskId : Str,
  activeTaskId : Str,
  plannedTaskIds : [Str],
  wave : Int,
  benchmarkRuns : Int,
  final : Bool
}

record ManagerUpgradeSnapshot = {
  state : ManagerState,
  feedback : Str,
  projectRoot : Str
}

record ManagerUpgradeRestoreRecord = {
  serviceRoot : Str,
  serviceId : Str,
  generation : Int,
  transactionPath : Str,
  projectRoot : Str,
  snapshot : ManagerUpgradeSnapshot
}

record StatusWaitingReason = {
  kind : Str,
  taskIds : [Str],
  relatedTaskIds : [Str],
  details : [Str]
}

record StatusView = {
  state : ManagerState,
  plannerSummary : Str,
  objectiveProjectedStatus : Str,
  plannedTaskIds : [Str],
  allTaskIds : [Str],
  readyTaskIds : [Str],
  activeTaskIds : [Str],
  completedTaskIds : [Str],
  failedTaskIds : [Str],
  waitingReasons : [StatusWaitingReason],
  primaryWaitingReason : Str,
  primaryWaitingTaskIds : [Str],
  benchmarkSummary : Str,
  benchmarkTargetMet : Bool,
  feedbackSummary : Str
}

record TextSearch = {
  wanted : Str,
  found : Bool
}

record PlannerTaskPick = {
  readyTasks : [SwarmTask],
  found : Bool,
  spec : PlannerTaskSpec
}

record TaskStatusLookup = {
  wanted : Str,
  found : Bool,
  status : Str
}

record EnsurePlanState = {
  error : Str
}

record PlanValidationIssue = {
  code : Str,
  taskId : Str,
  detail : Str
}

record PlanValidationResult = {
  valid : Bool,
  issues : [PlanValidationIssue],
  plannedTaskCount : Int,
  plannerTaskLimit : Int,
  objectiveTaskBudget : Int,
  objectiveRunBudget : Int,
  cycleBlockedTaskIds : [Str]
}

record PlanValidationFoldState = {
  issues : [PlanValidationIssue],
  seenTaskIds : [Str],
  knownTaskIds : [Str]
}

record DependencyIssueState = {
  issues : [PlanValidationIssue],
  taskId : Str,
  knownTaskIds : [Str]
}

record DependencyCheck = {
  resolvedTaskIds : [Str],
  allResolved : Bool
}

record CyclePartitionState = {
  remaining : [PlannerTaskSpec],
  resolvedTaskIds : [Str],
  progressed : Bool
}

record PlannerInputState = {
  fingerprint : Str,
  goalText : Str,
  plannerPolicy : Str,
  schemaPath : Str,
  workspaceRoot : Str,
  mailboxSummary : Str
}

record LegacyPlannerInputState = {
  fingerprint : Str,
  goalText : Str,
  plannerPolicy : Str,
  schemaPath : Str,
  workspaceRoot : Str
}

record ChildLoopState = {
  attempt : Int,
  phase : Str,
  verdict : Str,
  completed : Bool,
  builderRuns : Int,
  verifierRuns : Int,
  healthy : Bool,
  needsAttention : Bool,
  attentionReason : Str,
  final : Bool
}

emptyTexts : [Str]
emptyTexts = []

emptyCapabilityStatuses : [CapabilityStatus]
emptyCapabilityStatuses = []

emptyStatusWaitingReasons : [StatusWaitingReason]
emptyStatusWaitingReasons = []

emptyPlanValidationIssues : [PlanValidationIssue]
emptyPlanValidationIssues = []

emptyTasks : [SwarmTask]
emptyTasks = []

emptyPlannerTasks : [PlannerTaskSpec]
emptyPlannerTasks = []

emptyPlannerTaskSpec : PlannerTaskSpec
emptyPlannerTaskSpec = PlannerTaskSpec {
  taskId = "",
  role = "",
  detail = "",
  dependencies = emptyTexts,
  taskPrompt = "",
  coordinationFocus = emptyTexts
}

emptyBenchmarkSignal : BenchmarkSignal
emptyBenchmarkSignal =
  BenchmarkSignal {
    suite = "",
    summary = "",
    passed = false,
    meetsTarget = false,
    scoreName = "",
    scoreValue = 0,
    targetName = "",
    targetValue = 0
  }

emptySwarmMailboxMessages : [SwarmMailboxMessage]
emptySwarmMailboxMessages = []

foreign runCommandRaw : Str -> [Str] -> Result Str = "runCommandJson"
foreign spawnCommandRaw : Str -> Str -> Str -> Str -> Int -> [Str] -> Result Str = "spawnCommandJson"
foreign reconcileWatchedProcessRaw : Str -> Result Str = "reconcileWatchedProcessJson"
foreign awaitWatchedProcessTimeoutRaw : Str -> Int -> Int -> Result Str = "awaitWatchedProcessTimeoutJson"
foreign sleepMsRaw : Int -> Result Str = "sleepMs"

stateRootPath : Str
stateRootPath =
  if textJoin "" argv == "" then
    "swarm-native-goal-manager-state"
  else
    pathJoin argv

swarmStateRoot : SwarmRoot
swarmStateRoot = swarmRoot stateRootPath

readEnvText : Str -> Str -> Str
readEnvText name fallback = match envVar name {
  Ok raw -> decode Str raw,
  Err message -> fallback
}

readEnvTextList : Str -> [Str] -> [Str]
readEnvTextList name fallback = match envVar name {
  Ok raw -> decode [Str] raw,
  Err message -> fallback
}

readEnvBool : Str -> Bool -> Bool
readEnvBool name fallback = match envVar name {
  Ok raw -> decode Bool raw,
  Err message -> fallback
}

readEnvInt : Str -> Int -> Int
readEnvInt name fallback = match envVar name {
  Ok raw -> decode Int raw,
  Err message -> fallback
}

goalText : Str
goalText =
  readEnvText
    "CLASP_MANAGER_GOAL_JSON"
    "Improve Clasp by planning bounded native compiler/runtime/language tasks and closing them with ordinary Clasp loops."

objectiveId : Str
objectiveId = readEnvText "CLASP_MANAGER_OBJECTIVE_ID_JSON" "improve-clasp"

managerProgramPath : Str
managerProgramPath = readEnvText "CLASP_MANAGER_PROGRAM_JSON" "examples/swarm-native/GoalManager.clasp"

workspaceRoot : Str
workspaceRoot = readEnvText "CLASP_LOOP_WORKSPACE_JSON" "."

codexBin : Str
codexBin = readEnvText "CLASP_LOOP_CODEX_BIN_JSON" "codex"

managerClaspcBin : Str
managerClaspcBin = readEnvText "CLASP_MANAGER_CLASPC_BIN_JSON" "claspc"

currentExecutablePath : Str
currentExecutablePath = readEnvText "CLASP_RT_CURRENT_EXECUTABLE_PATH_JSON" ""

managerXdgCacheHome : Str
managerXdgCacheHome = readEnvText "CLASP_MANAGER_XDG_CACHE_HOME_JSON" (pathJoin [stateRootPath, "manager-xdg-cache"])

childLoopProgramPath : Str
childLoopProgramPath = readEnvText "CLASP_MANAGER_CHILD_LOOP_JSON" "examples/feedback-loop/Main.clasp"

plannerSchemaPath : Str
plannerSchemaPath = readEnvText "CLASP_MANAGER_PLANNER_SCHEMA_JSON" "agents/schemas/planner-report.schema.json"

codexModel : Str
codexModel = readEnvText "CLASP_LOOP_CODEX_MODEL_JSON" "gpt-5.4"

codexReasoning : Str
codexReasoning = readEnvText "CLASP_LOOP_CODEX_REASONING_JSON" "medium"

codexSandbox : Str
codexSandbox = readEnvText "CLASP_LOOP_CODEX_SANDBOX_JSON" "danger-full-access"

childLoopWatchPollMs : Int
childLoopWatchPollMs = match envVar "CLASP_LOOP_WATCH_POLL_MS_JSON" {
  Ok raw -> decode Int raw,
  Err message -> 1000
}

maxTaskLoops : Int
maxTaskLoops = match envVar "CLASP_MANAGER_MAX_TASKS_JSON" {
  Ok raw -> decode Int raw,
  Err message -> 4
}

plannerTaskMaxRuns : Int
plannerTaskMaxRuns = readEnvInt "CLASP_MANAGER_PLANNER_MAX_RUNS_JSON" 3

plannerTimeoutMs : Int
plannerTimeoutMs = readEnvInt "CLASP_MANAGER_PLANNER_TIMEOUT_MS_JSON" 300000

benchmarkCommand : [Str]
benchmarkCommand = match envVar "CLASP_MANAGER_BENCHMARK_COMMAND_JSON" {
  Ok raw -> decode [Str] raw,
  Err message -> emptyTexts
}

benchmarkEnabled : Bool
benchmarkEnabled = length benchmarkCommand > 0

benchmarkCwd : Str
benchmarkCwd = readEnvText "CLASP_MANAGER_BENCHMARK_CWD_JSON" managerProjectRoot

benchmarkWatchPollMs : Int
benchmarkWatchPollMs = match envVar "CLASP_MANAGER_BENCHMARK_POLL_MS_JSON" {
  Ok raw -> decode Int raw,
  Err message -> 250
}

benchmarkTimeoutMs : Int
benchmarkTimeoutMs = match envVar "CLASP_MANAGER_BENCHMARK_TIMEOUT_MS_JSON" {
  Ok raw -> decode Int raw,
  Err message -> 3600000
}

maxWaves : Int
maxWaves = match envVar "CLASP_MANAGER_MAX_WAVES_JSON" {
  Ok raw -> decode Int raw,
  Err message -> 4
}

configuredPlannerWaveCount : Int
configuredPlannerWaveCount =
  if benchmarkEnabled then
    if maxWaves < 1 then
      1
    else
      maxWaves
  else
    1

configuredObjectiveTaskBudget : Int
configuredObjectiveTaskBudget = match envVar "CLASP_MANAGER_OBJECTIVE_MAX_TASKS_JSON" {
  Ok raw -> decode Int raw,
  Err message -> 64
}

configuredObjectiveRunBudget : Int
configuredObjectiveRunBudget = match envVar "CLASP_MANAGER_OBJECTIVE_MAX_RUNS_JSON" {
  Ok raw -> decode Int raw,
  Err message -> 64
}

taskLeaseTimeoutMs : Int
taskLeaseTimeoutMs = match envVar "CLASP_MANAGER_TASK_LEASE_TIMEOUT_JSON" {
  Ok raw -> decode Int raw,
  Err message -> 3600000
}

childMaxAttempts : Int
childMaxAttempts = match envVar "CLASP_MANAGER_CHILD_MAX_ATTEMPTS_JSON" {
  Ok raw -> decode Int raw,
  Err message -> 3
}

childReportSettlePolls : Int
childReportSettlePolls = readEnvInt "CLASP_MANAGER_CHILD_REPORT_SETTLE_POLLS_JSON" 3

maxConcurrentChildren : Int
maxConcurrentChildren = match envVar "CLASP_MANAGER_MAX_CONCURRENT_CHILDREN_JSON" {
  Ok raw -> decode Int raw,
  Err message -> 2
}

taskWorkspaceCacheMaxMb : Int
taskWorkspaceCacheMaxMb = readEnvInt "CLASP_MANAGER_TASK_WORKSPACE_CACHE_MAX_MB_JSON" 4096

taskBaselineCacheMaxMb : Int
taskBaselineCacheMaxMb = readEnvInt "CLASP_MANAGER_TASK_BASELINE_CACHE_MAX_MB_JSON" 2048

feedbackLoopBaselineCacheMaxMb : Int
feedbackLoopBaselineCacheMaxMb = readEnvInt "CLASP_MANAGER_FEEDBACK_LOOP_BASELINE_CACHE_MAX_MB_JSON" 768

childLoopBaselineCacheTotalMaxMb : Int
childLoopBaselineCacheTotalMaxMb = readEnvInt "CLASP_MANAGER_CHILD_LOOP_BASELINE_CACHE_TOTAL_MAX_MB_JSON" 1024

childLoopXdgCacheTotalMaxMb : Int
childLoopXdgCacheTotalMaxMb = readEnvInt "CLASP_MANAGER_CHILD_LOOP_XDG_CACHE_TOTAL_MAX_MB_JSON" 512

managerArtifactsCacheMaxMb : Int
managerArtifactsCacheMaxMb = readEnvInt "CLASP_MANAGER_ARTIFACTS_CACHE_MAX_MB_JSON" 1024

managerXdgCacheMaxMb : Int
managerXdgCacheMaxMb = readEnvInt "CLASP_MANAGER_XDG_CACHE_MAX_MB_JSON" 1024

childFocusedVerifyCommands : Str
childFocusedVerifyCommands =
  readEnvText
    "CLASP_MANAGER_CHILD_FOCUSED_VERIFY_COMMANDS_JSON"
    "bash scripts/test-goal-manager-fast.sh\nbash scripts/test-native-runtime.sh\nbash scripts/test-task-manifest.sh"

childFullVerifyCommand : Str
childFullVerifyCommand = readEnvText "CLASP_MANAGER_CHILD_FULL_VERIFY_COMMAND_JSON" "bash scripts/verify-all.sh"

taskFailureLogTailBytes : Int
taskFailureLogTailBytes = readEnvInt "CLASP_MANAGER_TASK_FAILURE_LOG_TAIL_BYTES_JSON" 12000

retainFailedTaskWorkspaces : Bool
retainFailedTaskWorkspaces = readEnvBool "CLASP_MANAGER_RETAIN_FAILED_TASK_WORKSPACES_JSON" false

mailboxLimit : Int
mailboxLimit = 6

actorName : Str
actorName = match envVar "CLASP_SWARM_ACTOR" {
  Ok raw -> raw,
  Err message -> "manager"
}

commandName : Str
commandName = match envVar "CLASP_MANAGER_COMMAND" {
  Ok raw -> raw,
  Err message ->
    match envVar "CLASP_LOOP_COMMAND" {
      Ok legacy -> legacy,
      Err missing -> "run"
    }
}

managerReadyPath : Str
managerReadyPath = readEnvText "CLASP_MANAGER_READY_PATH_JSON" ""

managerReadyText : Str
managerReadyText = readEnvText "CLASP_MANAGER_READY_TEXT_JSON" "ready"

configuredServiceRoot : Str
configuredServiceRoot =
  match envVar "CLASP_MANAGER_SERVICE_ROOT_JSON" {
    Ok raw -> decode Str raw,
    Err message ->
      match envVar "CLASP_RT_SERVICE_ROOT_JSON" {
        Ok raw -> decode Str raw,
        Err missing -> ""
      }
  }

serviceRoot : Str
serviceRoot =
  if configuredServiceRoot != "" then
    configuredServiceRoot
  else
    pathJoin [stateRootPath, "service"]

configuredServiceId : Str
configuredServiceId =
  match envVar "CLASP_MANAGER_SERVICE_ID_JSON" {
    Ok raw -> decode Str raw,
    Err message ->
      match envVar "CLASP_RT_SERVICE_ID_JSON" {
        Ok raw -> decode Str raw,
        Err missing -> ""
      }
  }

serviceId : Str
serviceId =
  if configuredServiceId != "" then
    configuredServiceId
  else
    "goal-manager"

serviceRestartDelayMs : Int
serviceRestartDelayMs = match envVar "CLASP_MANAGER_SERVICE_RESTART_DELAY_MS_JSON" {
  Ok raw -> decode Int raw,
  Err message -> 250
}

runningUnderServiceSupervisor : Bool
runningUnderServiceSupervisor = match envVar "CLASP_RT_SERVICE_SUPERVISED_JSON" {
  Ok raw -> true,
  Err message -> false
}

upgradeCommandList : [Str]
upgradeCommandList = readEnvTextList "CLASP_MANAGER_UPGRADE_COMMAND_JSON" emptyTexts

upgradeReadyPath : Str
upgradeReadyPath = readEnvText "CLASP_MANAGER_UPGRADE_READY_PATH_JSON" ""

upgradeReadyContains : Str
upgradeReadyContains = readEnvText "CLASP_MANAGER_UPGRADE_READY_CONTAINS_JSON" "ready"

upgradeReadyPollMs : Int
upgradeReadyPollMs = match envVar "CLASP_MANAGER_UPGRADE_READY_POLL_MS_JSON" {
  Ok raw -> decode Int raw,
  Err message -> 50
}

upgradeReadyTimeoutMs : Int
upgradeReadyTimeoutMs = match envVar "CLASP_MANAGER_UPGRADE_READY_TIMEOUT_MS_JSON" {
  Ok raw -> decode Int raw,
  Err message -> 10000
}

upgradeCommitGraceMs : Int
upgradeCommitGraceMs = match envVar "CLASP_MANAGER_UPGRADE_COMMIT_GRACE_MS_JSON" {
  Ok raw -> decode Int raw,
  Err message -> 250
}

restoreSnapshotPath : Str
restoreSnapshotPath = readEnvText "CLASP_RT_UPGRADE_SNAPSHOT_PATH_JSON" ""

restoreServiceRoot : Str
restoreServiceRoot = readEnvText "CLASP_RT_UPGRADE_SERVICE_ROOT_JSON" ""

restoreServiceId : Str
restoreServiceId = readEnvText "CLASP_RT_UPGRADE_SERVICE_ID_JSON" ""

restoreTransactionPath : Str
restoreTransactionPath = readEnvText "CLASP_RT_UPGRADE_TRANSACTION_PATH_JSON" ""

restoreGeneration : Int
restoreGeneration = match envVar "CLASP_RT_UPGRADE_GENERATION_JSON" {
  Ok raw -> decode Int raw,
  Err message -> 0
}

plannerTaskId : Str
plannerTaskId = "planner"

plannerTaskIdForWave : Int -> Str
plannerTaskIdForWave wave =
  if wave == 1 then
    plannerTaskId
  else
    textConcat ["planner-", encode wave]

materializeTaskId : Int -> Str -> Str
materializeTaskId wave taskIdValue =
  if wave == 1 then
    taskIdValue
  else
    textConcat ["wave-", encode wave, "-", taskIdValue]

objectiveRef : ObjectiveHandle
objectiveRef = objectiveHandle swarmStateRoot objectiveId

plannerHandleForWave : Int -> TaskHandle
plannerHandleForWave wave = taskHandle swarmStateRoot (plannerTaskIdForWave wave) actorName

statusPath : Str
statusPath = pathJoin [stateRootPath, "status.json"]

feedbackPath : Str
feedbackPath = pathJoin [stateRootPath, "feedback.json"]

serviceReadyPath : Str
serviceReadyPath = pathJoin [stateRootPath, "service.ready"]

restoredSnapshotPath : Str
restoredSnapshotPath = pathJoin [stateRootPath, "restored-snapshot.json"]

serviceRootRecordPath : Str
serviceRootRecordPath = pathJoin [stateRootPath, "service-root.txt"]

serviceIdRecordPath : Str
serviceIdRecordPath = pathJoin [stateRootPath, "service-id.txt"]

projectRootRecordPath : Str
projectRootRecordPath = pathJoin [stateRootPath, "project-root.txt"]

mailboxPath : Str
mailboxPath = pathJoin [stateRootPath, "mailbox.json"]

plannerReportPathFor : Int -> Str
plannerReportPathFor wave = pathJoin [stateRootPath, textConcat ["planner-", encode wave, ".json"]]

plannerInputPath : Str
plannerInputPath = pathJoin [stateRootPath, "planner-input.json"]

planValidationPath : Str
planValidationPath = pathJoin [stateRootPath, "plan-validation.json"]

benchmarkLatestPath : Str
benchmarkLatestPath = pathJoin [stateRootPath, "benchmark-latest.json"]

benchmarkCheckpointPathFor : Int -> Str
benchmarkCheckpointPathFor wave = pathJoin [stateRootPath, textConcat ["benchmark-", encode wave, ".json"]]

benchmarkStdoutPathFor : Int -> Str
benchmarkStdoutPathFor wave = pathJoin [stateRootPath, textConcat ["benchmark-", encode wave, ".stdout.txt"]]

benchmarkStderrPathFor : Int -> Str
benchmarkStderrPathFor wave = pathJoin [stateRootPath, textConcat ["benchmark-", encode wave, ".stderr.txt"]]

benchmarkHeartbeatPathFor : Int -> Str
benchmarkHeartbeatPathFor wave = pathJoin [stateRootPath, textConcat ["benchmark-", encode wave, ".heartbeat.json"]]

plannerPolicyPath : Str
plannerPolicyPath = pathJoin [stateRootPath, "planner-policy.md"]

defaultPlannerPolicyText : Str
defaultPlannerPolicyText = textJoin "\n" [
  "Decompose the high-level goal into 1-3 bounded implementation tasks.",
  "Prefer compiler/runtime/language changes over docs-only work.",
  "Keep dependencies explicit and acyclic.",
  "Each planned task should be specific enough to hand directly to a builder/verifier loop.",
  "Do not assume a fixed named agent taxonomy beyond the minimal substrate. Let coordination patterns emerge from task structure and the shared mailbox."
]

plannerPolicyText : Str
plannerPolicyText = match envVar "CLASP_MANAGER_PLANNER_POLICY_JSON" {
  Ok raw -> decode Str raw,
  Err message ->
    if fileExists plannerPolicyPath then
      match readFile plannerPolicyPath {
        Ok policyText -> policyText,
        Err readMessage -> defaultPlannerPolicyText
      }
    else
      defaultPlannerPolicyText
}

codexReasoningConfig : Str
codexReasoningConfig = textConcat ["model_reasoning_effort=\"", codexReasoning, "\""]

traceEnabled : Bool
traceEnabled = match envVar "CLASP_MANAGER_TRACE_JSON" {
  Ok raw -> true,
  Err message -> false
}

tracePath : Str
tracePath = pathJoin [stateRootPath, "trace.log"]

appendManagerTrace : Str -> Str
appendManagerTrace label =
  if traceEnabled then
    match appendFile tracePath (textConcat [label, "\n"]) {
      Ok written -> "",
      Err message -> message
    }
  else
    ""

appendBootstrapTrace : Str -> Str
appendBootstrapTrace label = {
  let stateRootError = match mkdirAll stateRootPath {
    Ok created -> "",
    Err message -> message
  } in
  if stateRootError != "" then
    stateRootError
  else
    appendManagerTrace label
}

taskReportStateRoot : Str -> Str
taskReportStateRoot taskId = pathJoin [stateRootPath, textConcat ["loop-", taskId]]

taskWorkspaceRoot : Str -> Str
taskWorkspaceRoot taskId = pathJoin [stateRootPath, textConcat ["workspace-", taskId]]

taskWorkspaceActualRoot : Str -> Str
taskWorkspaceActualRoot taskId =
