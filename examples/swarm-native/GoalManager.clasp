    "--exclude=*/help ",
    "--exclude=src/native-verify-cache ",
    "--exclude=*/src/native-verify-cache "
  ]

processResultError : Str -> Result ProcessResult
processResultError message = Err message

processResult : Result Str -> Result ProcessResult
processResult value = match value {
  Ok raw -> Ok (decode ProcessResult raw),
  Err message -> processResultError message
}

runCommand : Str -> [Str] -> Result ProcessResult
runCommand cwd command = processResult (runCommandRaw cwd command)

plannerReportError : Str -> Result PlannerReport
plannerReportError message = Err message

defaultPlannerTaskRole : Str -> Str -> Str
defaultPlannerTaskRole taskId detail =
  if length (textSplit taskId "benchmark") > 1 then
    "benchmark-operator"
  else if length (textSplit taskId "verify") > 1 then
    "verification-closer"
  else if length (textSplit taskId "planner") > 1 then
    "planner"
  else if length (textSplit taskId "loop") > 1 then
    "control-plane-hardener"
  else if length (textSplit detail "benchmark") > 1 then
    "benchmark-operator"
  else
    "generalist"

legacyPlannerTaskToCurrent : LegacyPlannerTaskSpec -> PlannerTaskSpec
legacyPlannerTaskToCurrent task =
  PlannerTaskSpec {
    taskId = task.taskId,
    role = defaultPlannerTaskRole task.taskId task.detail,
    detail = task.detail,
    dependencies = task.dependencies,
    taskPrompt = task.taskPrompt,
    coordinationFocus = emptyTexts
  }

legacyPlannerReportToCurrent : LegacyPlannerReport -> PlannerReport
legacyPlannerReportToCurrent report = {
  let mut renderedTasks = emptyPlannerTasks;
  for task in report.tasks {
    renderedTasks = append renderedTasks [legacyPlannerTaskToCurrent task];
    renderedTasks
  };
  PlannerReport {
    objectiveSummary = report.objectiveSummary,
    strategy = report.strategy,
    tasks = renderedTasks,
    testsRun = report.testsRun,
    residualRisks = report.residualRisks
  }
}

plannerReportFromRaw : Str -> PlannerReport
plannerReportFromRaw raw = decode PlannerReport raw

readPlannerReportPath : Str -> Result PlannerReport
readPlannerReportPath path = match readFile path {
  Ok raw -> Ok (plannerReportFromRaw raw),
  Err message -> plannerReportError message
}

plannerInputStateError : Str -> Result PlannerInputState
plannerInputStateError message = Err message

legacyPlannerInputStateToCurrent : LegacyPlannerInputState -> PlannerInputState
legacyPlannerInputStateToCurrent state =
  PlannerInputState {
    fingerprint = state.fingerprint,
    goalText = state.goalText,
    plannerPolicy = state.plannerPolicy,
    schemaPath = state.schemaPath,
    workspaceRoot = state.workspaceRoot,
    mailboxSummary = ""
  }

plannerInputStateFromRaw : Str -> PlannerInputState
plannerInputStateFromRaw raw =
  if length (textSplit raw "\"mailboxSummary\":") > 1 then
    decode PlannerInputState raw
  else
    legacyPlannerInputStateToCurrent (decode LegacyPlannerInputState raw)

readPlannerInputStatePath : Str -> Result PlannerInputState
readPlannerInputStatePath path = match readFile path {
  Ok raw -> Ok (plannerInputStateFromRaw raw),
  Err message -> plannerInputStateError message
}

watchedProcessError : Str -> Result WatchedProcess
watchedProcessError message = Err message

watchedProcessResult : Result Str -> Result WatchedProcess
watchedProcessResult value = match value {
  Ok raw -> Ok (decode WatchedProcess raw),
  Err message -> watchedProcessError message
}

awaitWatchedProcessTimeout : Str -> Int -> Int -> Result WatchedProcess
awaitWatchedProcessTimeout heartbeatPath pollMs timeoutMs =
  watchedProcessResult (awaitWatchedProcessTimeoutRaw heartbeatPath pollMs timeoutMs)

reconcileWatchedProcess : Str -> Result WatchedProcess
reconcileWatchedProcess heartbeatPath = watchedProcessResult (reconcileWatchedProcessRaw heartbeatPath)

spawnWatchedProcess : Str -> Str -> Str -> Str -> Int -> [Str] -> Result WatchedProcess
spawnWatchedProcess cwd stdoutPath stderrPath heartbeatPath pollMs command =
  watchedProcessResult (spawnCommandRaw cwd stdoutPath stderrPath heartbeatPath pollMs command)

sleepMsValue : Int -> Result Str
sleepMsValue delayMs = sleepMsRaw delayMs

childLoopStateError : Str -> Result ChildLoopState
childLoopStateError message = Err message

readChildLoopStatePath : Str -> Result ChildLoopState
readChildLoopStatePath path = match readFile path {
  Ok raw -> Ok (decode ChildLoopState raw),
  Err message -> childLoopStateError message
}

syntheticFailureReport : Str -> Str -> VerifierReport
syntheticFailureReport summary detail =
  VerifierReport {
    verdict = "fail",
    summary = summary,
    findings = [detail],
    tests_run = emptyTexts,
    follow_up = ["Inspect the failing manager or child loop artifacts and retry the task."],
    capability_statuses = emptyCapabilityStatuses
  }

readVerifierReportPath : Str -> VerifierReport
readVerifierReportPath path = match readFile path {
  Ok raw -> decode VerifierReport raw,
  Err message ->
    syntheticFailureReport
      (textConcat ["missing verifier report: ", message])
      message
}

builderFeedbackError : Str -> Result BuilderReport
builderFeedbackError message = Err message

readBuilderReportPath : Str -> Result BuilderReport
readBuilderReportPath path = match readFile path {
  Ok raw -> Ok (decode BuilderReport raw),
  Err message -> builderFeedbackError message
}

readMailboxMessagesPath : Str -> [SwarmMailboxMessage]
readMailboxMessagesPath path = match readFile path {
  Ok raw -> decode [SwarmMailboxMessage] raw,
  Err message -> emptySwarmMailboxMessages
}

writeMailboxMessages : [SwarmMailboxMessage] -> Str
writeMailboxMessages messages = match writeFile mailboxPath (encode messages) {
  Ok written -> "",
  Err message -> message
}

appendMailboxMessages : [SwarmMailboxMessage] -> Str
appendMailboxMessages messages =
  if length messages == 0 then
    ""
  else
    writeMailboxMessages (append (readMailboxMessagesPath mailboxPath) messages)

writeFeedback : VerifierReport -> Str
writeFeedback report = match writeFile feedbackPath (encode report) {
  Ok written -> "",
  Err message -> message
}

writePlanValidation : PlanValidationResult -> Str
writePlanValidation result = match writeFile planValidationPath (encode result) {
  Ok written -> "",
  Err message -> message
}

writePlannerInputState : PlannerInputState -> Str
writePlannerInputState state = match writeFile plannerInputPath (encode state) {
  Ok written -> "",
  Err message -> message
}

readTextOrEmpty : Str -> Str
readTextOrEmpty path = match readFile path {
  Ok raw -> raw,
  Err message -> ""
}

currentWorkingDir : Str
currentWorkingDir = match runCommand "." ["pwd"] {
  Ok process -> firstTextOrEmpty (textSplit process.stdout "\n"),
  Err message -> "."
}

recordedServiceRoot : Str
recordedServiceRoot = readTextOrEmpty serviceRootRecordPath

recordedServiceId : Str
recordedServiceId = readTextOrEmpty serviceIdRecordPath

recordedProjectRoot : Str
recordedProjectRoot = readTextOrEmpty projectRootRecordPath

managerProjectRoot : Str
managerProjectRoot = {
  let configured = readEnvText "CLASP_MANAGER_PROJECT_ROOT_JSON" "" in
  if configured != "" then
    configured
  else if recordedProjectRoot != "" then
    recordedProjectRoot
  else
    currentWorkingDir
}

isAbsolutePath : Str -> Bool
isAbsolutePath value = match textPrefix value "/" {
  Ok remainder -> true,
  Err message -> false
}

resolveProjectPath : Str -> Str
resolveProjectPath value =
  if value == "" then
    ""
  else if isAbsolutePath value then
    value
  else
    pathJoin [managerProjectRoot, value]

resolveWorkspacePath : Str -> Str
resolveWorkspacePath value =
  if value == "" then
    ""
  else if isAbsolutePath value then
    value
  else
    pathJoin [currentWorkingDir, value]

resolvedWorkspaceRoot : Str
resolvedWorkspaceRoot = resolveWorkspacePath workspaceRoot

resolvedPlannerSchemaPath : Str
resolvedPlannerSchemaPath = resolveProjectPath plannerSchemaPath

resolvedChildLoopProgramPath : Str
resolvedChildLoopProgramPath = resolveProjectPath childLoopProgramPath

resolvedManagerProgramPath : Str
resolvedManagerProgramPath = resolveProjectPath managerProgramPath

defaultProjectClaspcPath : Str
defaultProjectClaspcPath = pathJoin [managerProjectRoot, "runtime/target/debug/claspc"]

resolvedManagerClaspcBin : Str
resolvedManagerClaspcBin =
  if managerClaspcBin == "" then
    defaultProjectClaspcPath
  else if isAbsolutePath managerClaspcBin then
    managerClaspcBin
  else if managerClaspcBin == "claspc" then
    if fileExists defaultProjectClaspcPath then
      defaultProjectClaspcPath
    else
      managerClaspcBin
  else if length (textSplit managerClaspcBin "/") > 1 then
    resolveProjectPath managerClaspcBin
  else
    managerClaspcBin

readFeedbackSummary : Str
readFeedbackSummary =
  if fileExists feedbackPath then
    (readVerifierReportPath feedbackPath).summary
  else
    ""

taskLatestAttempt : Str -> Int
taskLatestAttempt taskId =
  if fileExists (taskStatusPath taskId) then
    match readChildLoopStatePath (taskStatusPath taskId) {
      Ok state -> state.attempt,
      Err message -> 1
    }
  else
    1

taskLatestBuilderReport : Str -> Result BuilderReport
taskLatestBuilderReport taskId =
  readBuilderReportPath (taskBuilderReportPath taskId (taskLatestAttempt taskId))

taskLatestBuilderReportPath : Str -> Str
taskLatestBuilderReportPath taskId =
  taskBuilderReportPath taskId (taskLatestAttempt taskId)

taskLatestDiffPath : Str -> Str
taskLatestDiffPath taskId =
  taskDiffPath taskId (taskLatestAttempt taskId)

taskPromotionDiffPath : Str -> Str
taskPromotionDiffPath taskId =
  pathJoin [taskReportStateRoot taskId, "promotion-recoverable.diff"]

taskPromotionConflictPath : Str -> Str
taskPromotionConflictPath taskId =
  pathJoin [taskReportStateRoot taskId, "promotion-conflict.marker"]

taskRecoverableDiffDetails : Str -> [Str]
taskRecoverableDiffDetails taskId =
  if fileExists (taskLatestDiffPath taskId) then
    [
      textConcat ["recoverableDiff=", taskLatestDiffPath taskId],
      "recoverableDiffKind=child-loop",
      "recoverableDiffUse=Feed this diff and its verifier report into the next planner wave instead of rediscovering the same branch from scratch."
    ]
  else
    emptyTexts

plannerTaskRoleLabel : PlannerTaskSpec -> Str
plannerTaskRoleLabel spec =
  if spec.role == "" then
    defaultPlannerTaskRole spec.taskId spec.detail
  else
    spec.role

plannerTaskCoordinationFocusValues : PlannerTaskSpec -> [Str]
plannerTaskCoordinationFocusValues spec =
  if length spec.coordinationFocus == 0 then
    [plannerTaskRoleLabel spec]
  else
    spec.coordinationFocus

plannerTaskCoordinationSummary : PlannerTaskSpec -> Str
plannerTaskCoordinationSummary spec = textJoin ", " (plannerTaskCoordinationFocusValues spec)

annotatedPlannerTaskDetail : PlannerTaskSpec -> Str
annotatedPlannerTaskDetail spec =
  textConcat [
    "[role=",
    plannerTaskRoleLabel spec,
    "; focus=",
    plannerTaskCoordinationSummary spec,
    "] ",
    spec.detail
  ]

plannerTaskOverviewLine : PlannerTaskSpec -> Str
plannerTaskOverviewLine spec =
  textConcat [
    "- ",
    spec.taskId,
    " [role ",
    plannerTaskRoleLabel spec,
    "; focus ",
    plannerTaskCoordinationSummary spec,
    "]: ",
    spec.detail
  ]

plannerTaskSiblingSummaryText : PlannerReport -> Str -> Str
plannerTaskSiblingSummaryText report taskId = {
  let mut lines = emptyTexts;
  for taskSpec in report.tasks {
    if taskSpec.taskId == taskId then
      lines
    else {
      lines = append lines [plannerTaskOverviewLine taskSpec];
      lines
    }
  };
  if length lines == 0 then
    "No sibling branches are planned for this wave."
  else
    textJoin "\n" lines
}

benchmarkCheckpointMessages : Int -> [SwarmMailboxMessage]
benchmarkCheckpointMessages wave =
  if wave <= 0 then
    emptySwarmMailboxMessages
  else {
    let previous = benchmarkCheckpointMessages (decrementManagerCounter wave) in
    if fileExists (benchmarkCheckpointPathFor wave) then
      match readBenchmarkCheckpointPath (benchmarkCheckpointPathFor wave) {
        Ok checkpoint ->
          append previous [
            SwarmMailboxMessage {
              source = "benchmark",
              taskId = "",
              wave = wave,
              summary = checkpoint.summary,
              details = [
                textConcat ["suite=", checkpoint.suite],
                textConcat ["score=", checkpoint.scoreName, ":", encode checkpoint.scoreValue],
                textConcat ["target=", checkpoint.targetName, ":", encode checkpoint.targetValue],
                textConcat ["meetsTarget=", encode checkpoint.meetsTarget]
              ]
            }
          ],
        Err message ->
          previous
      }
    else
      previous
  }

appendOptionalMailboxDetail : [Str] -> Str -> Str -> [Str]
appendOptionalMailboxDetail details prefix value =
  if value == "" then
    details
  else
    append details [textConcat [prefix, value]]

appendPrefixedMailboxDetails : [Str] -> Str -> [Str] -> [Str]
appendPrefixedMailboxDetails details prefix values = {
  let mut rendered = details;
  for value in values {
    if value == "" then
      rendered
    else {
      rendered = append rendered [textConcat [prefix, value]];
      rendered
    }
  };
  rendered
}

appendCapabilityMailboxDetails : [Str] -> [CapabilityStatus] -> [Str]
appendCapabilityMailboxDetails details statuses = {
  let mut rendered = details;
  for status in statuses {
    rendered = append rendered [textConcat ["capability=", status.name, ":", status.status]];
    rendered
  };
  rendered
}

builderReportMailboxDetails : PlannerTaskSpec -> BuilderReport -> [Str]
builderReportMailboxDetails spec report = {
  let mut details = [textConcat ["coordination=", plannerTaskCoordinationSummary spec]];
  details = appendPrefixedMailboxDetails details "file=" report.files_touched;
  details = appendPrefixedMailboxDetails details "test=" report.tests_run;
  details = appendPrefixedMailboxDetails details "risk=" report.residual_risks;
  details = appendOptionalMailboxDetail details "feedback=" report.feedback.summary;
  details = appendPrefixedMailboxDetails details "ergonomics=" report.feedback.ergonomics;
  details = appendPrefixedMailboxDetails details "follow-up=" report.feedback.follow_ups;
  details = appendPrefixedMailboxDetails details "warning=" report.feedback.warnings;
  details = append details (taskRecoverableDiffDetails spec.taskId);
  details
}

verifierReportMailboxDetails : PlannerTaskSpec -> VerifierReport -> [Str]
verifierReportMailboxDetails spec report = {
  let mut details = [
    textConcat ["coordination=", plannerTaskCoordinationSummary spec],
    textConcat ["verdict=", report.verdict]
  ];
  details = appendPrefixedMailboxDetails details "finding=" report.findings;
  details = appendPrefixedMailboxDetails details "test=" report.tests_run;
  details = appendPrefixedMailboxDetails details "follow-up=" report.follow_up;
  details = appendCapabilityMailboxDetails details report.capability_statuses;
  details = append details (taskRecoverableDiffDetails spec.taskId);
  details
}

taskBuilderMailboxMessages : Int -> PlannerTaskSpec -> [SwarmMailboxMessage]
taskBuilderMailboxMessages wave spec = {
  let role = plannerTaskRoleLabel spec in
  if fileExists (taskLatestBuilderReportPath spec.taskId) then
    match taskLatestBuilderReport spec.taskId {
      Ok builderReport ->
        [
          SwarmMailboxMessage {
            source = textConcat ["builder-report:", role],
            taskId = spec.taskId,
            wave = wave,
            summary = builderReport.summary,
            details = builderReportMailboxDetails spec builderReport
          }
        ],
      Err message ->
        emptySwarmMailboxMessages
    }
  else
    emptySwarmMailboxMessages
}

taskVerifierMailboxMessages : Int -> PlannerTaskSpec -> VerifierReport -> [SwarmMailboxMessage]
taskVerifierMailboxMessages wave spec report = {
  let role = plannerTaskRoleLabel spec in
  [
    SwarmMailboxMessage {
      source = textConcat ["task-report:", role],
      taskId = spec.taskId,
      wave = wave,
      summary = report.summary,
      details = verifierReportMailboxDetails spec report
    }
  ]
}

taskMailboxMessagesForSpec : Int -> PlannerTaskSpec -> [SwarmMailboxMessage]
taskMailboxMessagesForSpec wave spec = {
  let builderMessages = taskBuilderMailboxMessages wave spec in
  let reportMessages =
    if fileExists (taskFeedbackPath spec.taskId) then
      taskVerifierMailboxMessages wave spec (readVerifierReportPath (taskFeedbackPath spec.taskId))
    else
      emptySwarmMailboxMessages in
  append builderMessages reportMessages
}

taskMailboxMessagesForSpecs : Int -> [PlannerTaskSpec] -> [SwarmMailboxMessage]
taskMailboxMessagesForSpecs wave specs = {
  let mut rendered = emptySwarmMailboxMessages;
  for spec in specs {
    rendered = append rendered (taskMailboxMessagesForSpec wave spec);
    rendered
  };
  rendered
}

taskMailboxMessagesForCompletedSpec : Int -> PlannerTaskSpec -> VerifierReport -> [SwarmMailboxMessage]
taskMailboxMessagesForCompletedSpec wave spec report =
  append
    (taskBuilderMailboxMessages wave spec)
    (taskVerifierMailboxMessages wave spec report)

plannerTaskMailboxMessagesForWave : Int -> [SwarmMailboxMessage]
plannerTaskMailboxMessagesForWave wave =
  if wave <= 0 then
    emptySwarmMailboxMessages
  else if fileExists (plannerReportPathFor wave) then
    match readPlannerReportForWave wave {
      Ok report ->
        taskMailboxMessagesForSpecs wave (materializePlannerReport wave report).tasks,
      Err message ->
        emptySwarmMailboxMessages
    }
  else
    emptySwarmMailboxMessages

taskMailboxMessagesAcrossWaves : Int -> [SwarmMailboxMessage]
taskMailboxMessagesAcrossWaves wave =
  if wave <= 0 then
    emptySwarmMailboxMessages
  else
    append
      (taskMailboxMessagesAcrossWaves (decrementManagerCounter wave))
      (plannerTaskMailboxMessagesForWave wave)

mailboxMessagesForReport : Int -> PlannerReport -> [SwarmMailboxMessage]
mailboxMessagesForReport wave report =
  append
    (benchmarkCheckpointMessages wave)
    (taskMailboxMessagesForSpecs wave (materializePlannerReport wave report).tasks)

mailboxMessageLine : SwarmMailboxMessage -> Str
mailboxMessageLine message =
  if message.taskId == "" then
    textConcat ["[", message.source, " wave ", encode message.wave, "] ", message.summary]
  else
    textConcat ["[", message.source, " ", message.taskId, " wave ", encode message.wave, "] ", message.summary]

mailboxMessageLines : SwarmMailboxMessage -> [Str]
mailboxMessageLines message = {
  let mut rendered = [mailboxMessageLine message];
  for detail in message.details {
    if detail == "" then
      rendered
    else {
      rendered = append rendered [textConcat ["  - ", detail]];
      rendered
    }
  };
  rendered
}

renderMailboxMessages : [SwarmMailboxMessage] -> [Str]
renderMailboxMessages messages = {
  let mut rendered = emptyTexts;
  for message in messages {
    rendered = append rendered (mailboxMessageLines message);
    rendered
  };
  rendered
}

mailboxSummaryText : Int -> Str
mailboxSummaryText wave =
  if fileExists mailboxPath then
    let messages = readMailboxMessagesPath mailboxPath in
    if length messages == 0 then
      "No prior swarm mailbox messages are available yet."
    else
      textJoin "\n" (renderMailboxMessages messages)
  else
    "No prior swarm mailbox messages are available yet."

mailboxSummaryTextForReport : Int -> PlannerReport -> Str
mailboxSummaryTextForReport wave report = mailboxSummaryText wave

refreshMailbox : Int -> Str
refreshMailbox wave =
  writeMailboxMessages
    (append
      (benchmarkCheckpointMessages wave)
      (taskMailboxMessagesAcrossWaves wave))

childLoopUsesVerifierHeartbeat : Str -> Bool
childLoopUsesVerifierHeartbeat phase =
  if phase == "verifier-preparing" then
    true
  else if phase == "verifier-step-ready" then
    true
  else if phase == "verifier-prompt-ready" then
    true
  else if phase == "verifier-command-ready" then
    true
  else if phase == "verifier-launching" then
    true
  else
    phase == "verifier-running"

childLoopHeartbeatPath : Str -> ChildLoopState -> Str
childLoopHeartbeatPath taskId state =
  if childLoopUsesVerifierHeartbeat state.phase then
    taskVerifierHeartbeatPath taskId state.attempt
  else
    taskBuilderHeartbeatPath taskId state.attempt

childLoopLaunchState : Str -> Result WatchedProcess
childLoopLaunchState taskId =
  if fileExists (taskProcessHeartbeatPath taskId) then
    reconcileWatchedProcess (taskProcessHeartbeatPath taskId)
  else
    watchedProcessError "missing launch heartbeat"

childLoopPhaseHeartbeatCompleted : Str -> Bool
childLoopPhaseHeartbeatCompleted taskId =
  if fileExists (taskStatusPath taskId) then
    match readChildLoopStatePath (taskStatusPath taskId) {
      Ok state ->
        if state.final then
          true
        else if state.completed then
          true
        else {
          let heartbeatPath = childLoopHeartbeatPath taskId state in
          if fileExists heartbeatPath then
            match reconcileWatchedProcess heartbeatPath {
              Ok process ->
                if process.running then
                  false
                else
                  process.completed,
              Err message ->
                false
            }
          else
            false
        },
      Err message ->
        false
    }
  else
    false

childLoopLaunchHeartbeatStale : WatchedProcess -> Bool
childLoopLaunchHeartbeatStale process =
  process.updatedAtMs == 0

childLoopLaunchRunning : Str -> Bool
childLoopLaunchRunning taskId =
  match childLoopLaunchState taskId {
    Ok process ->
      if process.running then
        if childLoopLaunchHeartbeatStale process then
          childLoopPhaseHeartbeatCompleted taskId == false
        else
          process.completed == false
      else
        false,
    Err message ->
      false
  }

childLoopLaunchCompleted : Str -> Bool
childLoopLaunchCompleted taskId =
  match childLoopLaunchState taskId {
    Ok process ->
      if process.running then
        if childLoopLaunchHeartbeatStale process then
          childLoopPhaseHeartbeatCompleted taskId
        else
          false
      else if process.completed then
        true
      else
        childLoopPhaseHeartbeatCompleted taskId,
    Err message ->
      childLoopPhaseHeartbeatCompleted taskId
  }

childLoopLaunchPending : Str -> Bool
childLoopLaunchPending taskId =
  if fileExists (taskProcessHeartbeatPath taskId) then
    if childLoopReportReady taskId then
      false
    else
      childLoopLaunchRunning taskId
  else
    false

childLoopTerminal : Str -> Bool
childLoopTerminal taskId =
  if fileExists (taskStatusPath taskId) then
    match readChildLoopStatePath (taskStatusPath taskId) {
      Ok state ->
        if state.final then
          true
        else
          state.completed,
      Err message ->
        false
    }
  else
    false

childLoopReportReady : Str -> Bool
childLoopReportReady taskId =
  if fileExists (taskFeedbackPath taskId) then
    if fileExists (taskStatusPath taskId) then
      if childLoopTerminal taskId then
        true
      else if fileExists (taskProcessHeartbeatPath taskId) then
        childLoopLaunchCompleted taskId
      else
        false
    else
      true
  else
    false

settleChildLoopReportReady : Str -> Int -> Bool
settleChildLoopReportReady taskId remainingPolls =
  if childLoopReportReady taskId then
    true
  else if remainingPolls <= 0 then
    false
  else
    match sleepMsValue childLoopWatchPollMs {
      Ok slept ->
        settleChildLoopReportReady taskId (decrementManagerCounter remainingPolls),
      Err message ->
        false
    }

childLoopRunning : Str -> Bool
childLoopRunning taskId =
  if fileExists (taskStatusPath taskId) then
    match readChildLoopStatePath (taskStatusPath taskId) {
      Ok state ->
        if state.final then
          false
        else if state.completed then
          false
        else {
          let heartbeatPath = childLoopHeartbeatPath taskId state in
          if fileExists heartbeatPath then
            match reconcileWatchedProcess heartbeatPath {
              Ok process ->
                if process.running then
                  process.completed == false
                else
                  false,
              Err message ->
                if fileExists (taskProcessHeartbeatPath taskId) then
                  childLoopLaunchRunning taskId
                else
                  false
            }
          else if fileExists (taskProcessHeartbeatPath taskId) then
            childLoopLaunchRunning taskId
          else
            false
        },
      Err message ->
        false
    }
  else if fileExists (taskProcessHeartbeatPath taskId) then
    childLoopLaunchRunning taskId
  else
    false

writeTaskFeedback : Str -> VerifierReport -> Str
writeTaskFeedback taskId report =
  match mkdirAll (taskReportStateRoot taskId) {
    Err message ->
      message,
    Ok created ->
      match writeFile (taskFeedbackPath taskId) (encode report) {
        Ok written -> "",
        Err writeMessage -> writeMessage
      }
  }

readChildLoopManagerRetries : Str -> Int
readChildLoopManagerRetries taskId =
  if fileExists (taskManagerRetryPath taskId) then
    match readFile (taskManagerRetryPath taskId) {
      Ok raw -> decode Int raw,
      Err message -> 0
    }
  else
    0

writeChildLoopManagerRetries : Str -> Int -> Str
writeChildLoopManagerRetries taskId retryCount =
  match writeFile (taskManagerRetryPath taskId) (encode retryCount) {
    Ok written -> "",
    Err message -> message
  }

childLoopMaxManagerRetries : Int
childLoopMaxManagerRetries =
  if childMaxAttempts <= 1 then
    0
  else
    decrementManagerCounter childMaxAttempts

childLoopManagerRetryAvailable : Str -> Bool
childLoopManagerRetryAvailable taskId =
  readChildLoopManagerRetries taskId < childLoopMaxManagerRetries

resetChildLoopForManagerRetry : Str -> Str
resetChildLoopForManagerRetry taskId =
  match runCommand "." [
    "rm",
    "-rf",
    taskReportStateRoot taskId,
    taskWorkspaceRoot taskId,
    taskWorkspaceActualRoot taskId,
    taskWorkspaceBaselineActualRoot taskId
  ] {
    Err message ->
      message,
    Ok process ->
      if process.exitCode != 0 then
        process.stderr
      else
        ""
  }

childLoopMissingDurableReport : VerifierReport -> Bool
childLoopMissingDurableReport report =
  report.summary == "task child loop finished without a durable report"

cachePruneDoneTrace : Str -> Str
cachePruneDoneTrace root = {
  let traceDone = appendManagerTrace (textConcat ["cache-prune:done:", root]) in
  if traceDone != "" then
    traceDone
  else
    ""
}

intResultError : Str -> Result Int
intResultError message = Err message

textResultError : Str -> Result Str
textResultError message = Err message

cacheDirectoryUsedMb : Str -> Result Int
cacheDirectoryUsedMb root =
  match runCommand "." ["du", "-sm", root] {
    Err message ->
      intResultError message,
    Ok process ->
      if process.exitCode != 0 then
        intResultError process.stderr
      else {
        let firstLine = firstTextOrEmpty (textSplit process.stdout "\n") in
        let firstColumn = firstTextOrEmpty (textSplit firstLine "\t") in
        Ok (decode Int firstColumn)
      }
  }

cachePruneCandidate : Str -> Str -> Result Str
cachePruneCandidate root keepName =
  match runCommand "." [
    "bash",
    "-lc",
    textJoin "\n" [
      "find \"$1\" -mindepth 1 -maxdepth 1 ! -name \"$2\" -printf '%T@ %p\\n' | sort -n | while IFS= read -r row; do",
      "  path=\"${row#* }\"",
      "  name=\"$(basename \"$path\")\"",
      "  state=\"$3/loop-$name/state.json\"",
      "  if [ -f \"$state\" ] && grep -Eq '\"final\"[[:space:]]*:[[:space:]]*false' \"$state\"; then",
      "    continue",
      "  fi",
      "  printf '%s\\n' \"$path\"",
      "  exit 0",
      "done"
    ],
    "cache-prune-candidate",
    root,
    keepName,
    stateRootPath
  ] {
    Err message ->
      textResultError message,
    Ok process ->
      if process.exitCode != 0 then
        textResultError process.stderr
      else
        Ok (firstTextOrEmpty (textSplit process.stdout "\n"))
  }

pruneCacheDirectoryLoop : Str -> Int -> Str -> Int -> Str
pruneCacheDirectoryLoop root maxMb keepName attempts =
  if attempts > 128 then
    textConcat ["cache prune exceeded iteration budget: ", root]
  else
    match cacheDirectoryUsedMb root {
      Err message ->
        message,
      Ok usedMb ->
        if usedMb <= maxMb then
          cachePruneDoneTrace root
        else
          match cachePruneCandidate root keepName {
            Err message ->
              message,
            Ok candidate ->
              if candidate == "" then
                cachePruneDoneTrace root
              else
                match runCommand "." ["rm", "-rf", candidate] {
                  Err message ->
                    message,
                  Ok removed ->
                    if removed.exitCode != 0 then
                      removed.stderr
                    else
                      pruneCacheDirectoryLoop root maxMb keepName (incrementManagerCounter attempts)
                }
          }
    }

pruneCacheDirectory : Str -> Int -> Str -> Str
pruneCacheDirectory root maxMb keepName = {
  let traceStart = appendManagerTrace (textConcat ["cache-prune:start:", root, ":max=", encode maxMb, ":keep=", keepName]) in
  if traceStart != "" then
    traceStart
  else if maxMb <= 0 then
    ""
  else
    match runCommand "." ["mkdir", "-p", root] {
      Err message ->
        message,
      Ok created ->
        if created.exitCode != 0 then
          created.stderr
        else
          pruneCacheDirectoryLoop root maxMb keepName 0
    }
}

childLoopNamedCacheUsedMb : Str -> Result Int
childLoopNamedCacheUsedMb cacheName =
  match runCommand "." [
    "bash",
    "-lc",
    textJoin "\n" [
      "state_root=\"$1\"",
      "cache_name=\"$2\"",
      "find \"$state_root\" -mindepth 2 -maxdepth 2 -type d -name \"$cache_name\" -exec du -sm {} + 2>/dev/null | awk '{sum += $1} END {print sum + 0}'"
    ],
    "child-loop-cache-used",
    stateRootPath,
    cacheName
  ] {
    Err message ->
      intResultError message,
    Ok process ->
      if process.exitCode != 0 then
        intResultError process.stderr
      else {
        let firstLine = firstTextOrEmpty (textSplit process.stdout "\n") in
        Ok (decode Int firstLine)
      }
  }

childLoopNamedCachePruneCandidate : Str -> Result Str
childLoopNamedCachePruneCandidate cacheName =
  match runCommand "." [
    "bash",
    "-lc",
    textJoin "\n" [
      "state_root=\"$1\"",
      "cache_name=\"$2\"",
      "find \"$state_root\" -mindepth 2 -maxdepth 2 -type d -name \"$cache_name\" -printf '%T@ %p\\n' 2>/dev/null | sort -n | while IFS= read -r row; do",
      "  path=\"${row#* }\"",
      "  loop_dir=\"${path%/$cache_name}\"",
      "  state=\"$loop_dir/state.json\"",
      "  if [ -f \"$state\" ] && grep -Eq '\"final\"[[:space:]]*:[[:space:]]*false' \"$state\"; then",
      "    continue",
      "  fi",
      "  printf '%s\\n' \"$path\"",
      "  exit 0",
      "done"
    ],
    "child-loop-cache-prune-candidate",
    stateRootPath,
    cacheName
  ] {
    Err message ->
      textResultError message,
    Ok process ->
      if process.exitCode != 0 then
        textResultError process.stderr
      else
        Ok (firstTextOrEmpty (textSplit process.stdout "\n"))
  }

pruneChildLoopNamedCacheLoop : Str -> Int -> Int -> Str
pruneChildLoopNamedCacheLoop cacheName maxMb attempts =
  if attempts > 128 then
    textConcat ["child loop cache prune exceeded iteration budget: ", cacheName]
  else
    match childLoopNamedCacheUsedMb cacheName {
      Err message ->
        message,
      Ok usedMb ->
        if usedMb <= maxMb then
          cachePruneDoneTrace (textConcat [stateRootPath, "/loop-*/", cacheName])
        else
          match childLoopNamedCachePruneCandidate cacheName {
            Err message ->
              message,
            Ok candidate ->
              if candidate == "" then
                cachePruneDoneTrace (textConcat [stateRootPath, "/loop-*/", cacheName])
              else
                match runCommand "." ["rm", "-rf", candidate] {
                  Err message ->
                    message,
                  Ok removed ->
                    if removed.exitCode != 0 then
                      removed.stderr
                    else
                      pruneChildLoopNamedCacheLoop cacheName maxMb (incrementManagerCounter attempts)
                }
          }
    }

pruneChildLoopNamedCache : Str -> Int -> Str
pruneChildLoopNamedCache cacheName maxMb = {
  let traceStart = appendManagerTrace (textConcat ["child-cache-prune:start:", cacheName, ":max=", encode maxMb]) in
  if traceStart != "" then
    traceStart
  else if maxMb <= 0 then
    ""
  else
    pruneChildLoopNamedCacheLoop cacheName maxMb 0
}

pruneChildLoopCaches : Str
pruneChildLoopCaches = {
  let baselineError = pruneChildLoopNamedCache "baseline-cache" childLoopBaselineCacheTotalMaxMb in
  if baselineError != "" then
    textConcat ["child loop baseline cache retention failed: ", baselineError]
  else {
    let xdgError = pruneChildLoopNamedCache "xdg-cache" childLoopXdgCacheTotalMaxMb in
    if xdgError != "" then
      textConcat ["child loop xdg cache retention failed: ", xdgError]
    else
      ""
  }
}

pruneTaskWorkspaceCaches : Str -> Str
pruneTaskWorkspaceCaches taskId = {
  let workspaceError = pruneCacheDirectory taskWorkspaceCacheRoot taskWorkspaceCacheMaxMb taskId in
  if workspaceError != "" then
    textConcat ["task workspace cache retention failed: ", workspaceError]
  else {
    let baselineError = pruneCacheDirectory taskWorkspaceBaselineCacheRoot taskBaselineCacheMaxMb taskId in
    if baselineError != "" then
      textConcat ["task baseline cache retention failed: ", baselineError]
    else
      ""
  }
}

pruneManagerResourceCaches : Str
pruneManagerResourceCaches = {
  let artifactError = pruneCacheDirectory (pathJoin [stateRootPath, "artifacts"]) managerArtifactsCacheMaxMb "" in
  if artifactError != "" then
    textConcat ["manager artifact cache retention failed: ", artifactError]
  else {
    let xdgError = pruneCacheDirectory managerXdgCacheHome managerXdgCacheMaxMb "" in
    if xdgError != "" then
      textConcat ["manager xdg cache retention failed: ", xdgError]
    else {
      let childLoopError = pruneChildLoopCaches in
      if childLoopError != "" then
        textConcat ["manager child loop cache retention failed: ", childLoopError]
      else
        ""
    }
  }
}

cleanupTaskWorkspace : Str -> Str
cleanupTaskWorkspace taskId = {
  let removedLink =
    match runCommand "." ["rm", "-rf", taskWorkspaceRoot taskId] {
      Ok result -> result,
      Err message -> ProcessResult { exitCode = 1, stdout = "", stderr = message }
    } in
  if removedLink.exitCode != 0 then
    textConcat ["task workspace link cleanup failed: ", taskId, ": ", removedLink.stderr]
  else {
    let removedActual =
      match runCommand "." ["rm", "-rf", taskWorkspaceActualRoot taskId, taskWorkspaceBaselineActualRoot taskId] {
        Ok result -> result,
        Err message -> ProcessResult { exitCode = 1, stdout = "", stderr = message }
      } in
    if removedActual.exitCode != 0 then
      textConcat ["task workspace cleanup failed: ", taskId, ": ", removedActual.stderr]
    else
      pruneTaskWorkspaceCaches taskId
  }
}

cleanupFailedTaskWorkspace : Str -> Str
cleanupFailedTaskWorkspace taskId =
  if retainFailedTaskWorkspaces then
    ""
  else
    cleanupTaskWorkspace taskId

ensureTaskWorkspace : Str -> Str
ensureTaskWorkspace taskId = {
  if fileExists (taskWorkspaceReadyPath taskId) then
    ""
  else {
    let retentionError = pruneTaskWorkspaceCaches taskId in
    if retentionError != "" then
      textConcat ["task workspace retention failed: ", taskId, ": ", retentionError]
    else {
      let removedLink =
        match runCommand "." ["rm", "-rf", taskWorkspaceRoot taskId] {
          Ok result -> result,
          Err message -> ProcessResult { exitCode = 1, stdout = "", stderr = message }
        } in
      if removedLink.exitCode != 0 then
        textConcat ["task workspace link cleanup failed: ", taskId, ": ", removedLink.stderr]
      else {
        let removedActual =
          match runCommand "." ["rm", "-rf", taskWorkspaceActualRoot taskId, taskWorkspaceBaselineActualRoot taskId] {
            Ok result -> result,
            Err message -> ProcessResult { exitCode = 1, stdout = "", stderr = message }
          } in
        if removedActual.exitCode != 0 then
          textConcat ["task workspace cleanup failed: ", taskId, ": ", removedActual.stderr]
        else {
          let created =
            match runCommand "." ["mkdir", "-p", taskWorkspaceActualRoot taskId] {
              Ok result -> result,
              Err message -> ProcessResult { exitCode = 1, stdout = "", stderr = message }
            } in
          if created.exitCode != 0 then
            textConcat ["task workspace mkdir failed: ", taskId, ": ", created.stderr]
          else {
            let copied =
              match runCommand "." [
                "bash",
                "-lc",
                textConcat [
                  "tar -cf - ",
                  workspaceCloneExcludeFlags,
                  "-C ",
                  workspaceRoot,
                  " . | tar -xf - -C ",
                  taskWorkspaceActualRoot taskId
                ]
              ] {
                Ok result -> result,
                Err message -> ProcessResult { exitCode = 1, stdout = "", stderr = message }
              } in
            if copied.exitCode != 0 then
              textConcat ["task workspace snapshot failed: ", taskId, ": ", copied.stderr]
            else {
              let createdBaseline =
                match runCommand "." ["mkdir", "-p", taskWorkspaceBaselineActualRoot taskId] {
                  Ok result -> result,
                  Err message -> ProcessResult { exitCode = 1, stdout = "", stderr = message }
                } in
              if createdBaseline.exitCode != 0 then
                textConcat ["task baseline workspace mkdir failed: ", taskId, ": ", createdBaseline.stderr]
              else {
                let copiedBaseline =
                  match runCommand "." [
                    "bash",
                    "-lc",
                    textConcat [
                      "tar -cf - -C ",
                      taskWorkspaceActualRoot taskId,
                      " . | tar -xf - -C ",
                      taskWorkspaceBaselineActualRoot taskId
                    ]
                  ] {
                    Ok result -> result,
                    Err message -> ProcessResult { exitCode = 1, stdout = "", stderr = message }
                  } in
                if copiedBaseline.exitCode != 0 then
                  textConcat ["task baseline workspace snapshot failed: ", taskId, ": ", copiedBaseline.stderr]
                else {
                  let linked =
                    match runCommand "." ["ln", "-s", taskWorkspaceActualRoot taskId, taskWorkspaceRoot taskId] {
                      Ok result -> result,
                      Err message -> ProcessResult { exitCode = 1, stdout = "", stderr = message }
                    } in
                  if linked.exitCode != 0 then
                    textConcat ["task workspace link failed: ", taskId, ": ", linked.stderr]
                  else
                    match writeFile (taskWorkspaceReadyPath taskId) "ready" {
                      Ok written -> pruneTaskWorkspaceCaches taskId,
                      Err message ->
                        textConcat ["task workspace ready marker failed: ", taskId, ": ", message]
                    }
                }
              }
            }
          }
        }
      }
    }
  }
}

taskWorkspacePromotionScript : Str
taskWorkspacePromotionScript = textJoin "\n" [
  "set -euo pipefail",
  "src=\"$1\"",
  "base=\"$2\"",
  "dest=\"$3\"",
  "conflict_marker=\"$4\"",
  "diff_out=\"$5\"",
  "mkdir -p \"$(dirname \"$conflict_marker\")\" \"$(dirname \"$diff_out\")\"",
  "rm -f \"$conflict_marker\" \"$diff_out\"",
  "if [ ! -d \"$src\" ]; then",
  "  printf 'missing task workspace: %s\n' \"$src\" >&2",
  "  exit 2",
  "fi",
  "if [ ! -d \"$base\" ]; then",
  "  printf 'missing task baseline workspace: %s\n' \"$base\" >&2",
  "  exit 2",
  "fi",
  "mkdir -p \"$dest\"",
  "tmp=\"$(mktemp -d)\"",
  "trap 'rm -rf \"$tmp\"' EXIT",
  "list_files() {",
  "  root=\"$1\"",
  "  (cd \"$root\" && find . -type f -print | while IFS= read -r rel; do",
  "    case \"$rel\" in",
  "      ./.workspace-ready) continue ;;",
  "      ./.git/*|*/.git/*) continue ;;",
  "      ./.clasp-agents/*|*/.clasp-agents/*) continue ;;",
  "      ./.clasp-loops/*|*/.clasp-loops/*) continue ;;",
  "      ./.clasp-swarm/*|*/.clasp-swarm/*) continue ;;",
  "      ./.clasp-task-workspaces/*|*/.clasp-task-workspaces/*) continue ;;",
  "      ./.clasp-task-baselines/*|*/.clasp-task-baselines/*) continue ;;",
  "      ./.clasp-test-tmp/*|*/.clasp-test-tmp/*) continue ;;",
  "      ./.clasp-test-tmp-*/*|*/.clasp-test-tmp-*/*) continue ;;",
  "      ./.clasp-verify-tmp/*|*/.clasp-verify-tmp/*) continue ;;",
  "      ./.clasp-verify-tmp-*/*|*/.clasp-verify-tmp-*/*) continue ;;",
  "      ./benchmarks/workspaces/*|*/benchmarks/workspaces/*) continue ;;",
  "      ./benchmarks/results/*|*/benchmarks/results/*) continue ;;",
  "      ./dist/*|*/dist/*) continue ;;",
  "      ./dist-newstyle/*|*/dist-newstyle/*) continue ;;",
  "      ./result/*|*/result/*) continue ;;",
  "      ./runtime/target/*|*/runtime/target/*) continue ;;",
  "      ./node_modules/*|*/node_modules/*) continue ;;",
  "      ./__serve-native-export-host/*|*/__serve-native-export-host/*) continue ;;",
  "      ./exec-image/*|*/exec-image/*) continue ;;",
  "    esac",
  "    printf '%s\n' \"${rel#./}\"",
  "  done | sort)",
  "}",
  "write_recoverable_diff() {",
  "  tmp_diff=\"$diff_out.tmp.$$\"",
  "  diff -ruN \\",
  "    --exclude=.workspace-ready \\",
  "    --exclude=.git \\",
  "    --exclude=.clasp-agents \\",
  "    --exclude=.clasp-loops \\",
  "    --exclude=.clasp-swarm \\",
  "    --exclude=.clasp-task-workspaces \\",
  "    --exclude=.clasp-task-baselines \\",
  "    --exclude=.clasp-test-tmp \\",
  "    --exclude=.clasp-test-tmp-* \\",
  "    --exclude=.clasp-verify-tmp \\",
  "    --exclude=.clasp-verify-tmp-* \\",
  "    --exclude=workspaces \\",
  "    --exclude=results \\",
  "    --exclude=dist \\",
  "    --exclude=dist-newstyle \\",
  "    --exclude=result \\",
  "    --exclude=target \\",
  "    --exclude=node_modules \\",
  "    --exclude=__serve-native-export-host \\",
  "    --exclude=exec-image \\",
  "    \"$base\" \"$src\" >\"$tmp_diff\" || true",
  "  if [ -s \"$tmp_diff\" ]; then",
  "    mv \"$tmp_diff\" \"$diff_out\"",
  "  else",
  "    rm -f \"$tmp_diff\" \"$diff_out\"",
  "  fi",
  "}",
  "base_files=\"$tmp/base-files\"",
  "src_files=\"$tmp/src-files\"",
  "changed=\"$tmp/changed-files\"",
  "conflicts=\"$tmp/conflicts\"",
  "list_files \"$base\" >\"$base_files\"",
  "list_files \"$src\" >\"$src_files\"",
  "comm -12 \"$base_files\" \"$src_files\" | while IFS= read -r rel; do",
  "  if ! cmp -s \"$base/$rel\" \"$src/$rel\"; then",
  "    printf '%s\n' \"$rel\"",
  "  fi",
  "done >\"$changed\"",
  "comm -13 \"$base_files\" \"$src_files\" >>\"$changed\"",
  "sort -u -o \"$changed\" \"$changed\"",
  ": >\"$conflicts\"",
  "while IFS= read -r rel; do",
  "  [ -n \"$rel\" ] || continue",
  "  if [ -e \"$dest/$rel\" ] && ! cmp -s \"$dest/$rel\" \"$src/$rel\"; then",
  "    if [ -e \"$base/$rel\" ]; then",
  "      if ! cmp -s \"$dest/$rel\" \"$base/$rel\"; then",
  "        printf '%s\n' \"$rel\" >>\"$conflicts\"",
  "      fi",
  "    else",
  "      printf '%s\n' \"$rel\" >>\"$conflicts\"",
  "    fi",
  "  fi",
  "done <\"$changed\"",
  "if [ -s \"$conflicts\" ]; then",
  "  write_recoverable_diff",
  "  {",
  "    printf 'promotion conflict: task workspace would overwrite files changed since snapshot\n'",
  "    cat \"$conflicts\"",
  "  } >\"$conflict_marker\"",
  "  exit 0",
  "fi",
  "while IFS= read -r rel; do",
  "  [ -n \"$rel\" ] || continue",
  "  mkdir -p \"$dest/$(dirname \"$rel\")\"",
  "  cp -p \"$src/$rel\" \"$dest/$rel\"",
  "done <\"$changed\""
]

taskPromotionDiffScript : Str
taskPromotionDiffScript = textJoin "\n" [
  "set +e",
  "src=\"$1\"",
  "base=\"$2\"",
  "out=\"$3\"",
  "if [ ! -d \"$src\" ] || [ ! -d \"$base\" ]; then",
  "  exit 0",
  "fi",
  "mkdir -p \"$(dirname \"$out\")\"",
  "tmp=\"$out.tmp.$$\"",
  "diff -ruN \\",
  "  --exclude=.workspace-ready \\",
  "  --exclude=.git \\",
  "  --exclude=.clasp-agents \\",
  "  --exclude=.clasp-loops \\",
  "  --exclude=.clasp-swarm \\",
  "  --exclude=.clasp-task-workspaces \\",
  "  --exclude=.clasp-task-baselines \\",
  "  --exclude=.clasp-test-tmp \\",
  "  --exclude=.clasp-test-tmp-* \\",
  "  --exclude=.clasp-verify-tmp \\",
  "  --exclude=.clasp-verify-tmp-* \\",
  "  --exclude=workspaces \\",
  "  --exclude=results \\",
  "  --exclude=dist \\",
  "  --exclude=dist-newstyle \\",
  "  --exclude=result \\",
  "  --exclude=target \\",
  "  --exclude=node_modules \\",
  "  --exclude=__serve-native-export-host \\",
  "  --exclude=exec-image \\",
  "  \"$base\" \"$src\" >\"$tmp\"",
  "code=\"$?\"",
  "if [ \"$code\" -eq 0 ]; then",
  "  rm -f \"$tmp\" \"$out\"",
  "  exit 0",
  "fi",
  "if [ \"$code\" -eq 1 ]; then",
  "  mv \"$tmp\" \"$out\"",
  "  exit 0",
  "fi",
  "mv \"$tmp\" \"$out\"",
  "exit 0"
]

writeTaskPromotionDiff : PlannerTaskSpec -> Str
writeTaskPromotionDiff spec =
  match runCommand "." [
    "bash",
    "-lc",
    taskPromotionDiffScript,
    "write-task-promotion-diff",
    taskWorkspaceActualRoot spec.taskId,
    taskWorkspaceBaselineActualRoot spec.taskId,
    taskPromotionDiffPath spec.taskId
  ] {
    Err message ->
      textConcat ["task promotion diff failed: ", spec.taskId, ": ", message],
    Ok process ->
      if process.exitCode == 0 then
        ""
      else
        textConcat ["task promotion diff failed: ", spec.taskId, ": ", process.stderr]
  }

promoteVerifiedTaskWorkspace : PlannerTaskSpec -> Str
promoteVerifiedTaskWorkspace spec =
  match runCommand "." [
    "bash",
    "-lc",
    taskWorkspacePromotionScript,
    "promote-task-workspace",
    taskWorkspaceActualRoot spec.taskId,
    taskWorkspaceBaselineActualRoot spec.taskId,
    workspaceRoot,
    taskPromotionConflictPath spec.taskId,
    taskPromotionDiffPath spec.taskId
  ] {
    Err message ->
      textConcat ["task workspace promotion failed: ", spec.taskId, ": promotion command failed: ", message],
    Ok process ->
      if fileExists (taskPromotionConflictPath spec.taskId) then
        textConcat ["task workspace promotion failed: ", spec.taskId, ": promotion conflict: task workspace would overwrite files changed since snapshot"]
      else if process.exitCode == 0 then
        ""
      else
        textConcat ["task workspace promotion failed: ", spec.taskId, ": promotion command failed: ", process.stderr]
  }

firstTextOrEmpty : [Str] -> Str
firstTextOrEmpty values = {
  let mut first = "";
  let mut found = false;
  for value in values {
    if found then
      found
    else {
      first = value;
      found = true;
      found
    }
  };
  first
}

secondTextOrEmpty : [Str] -> Str
secondTextOrEmpty values = {
  let mut second = "";
  let mut index = 0;
  for value in values {
    if index == 0 then {
      index = 1;
      index
    } else if index == 1 then {
      second = value;
      index = 2;
      index
    } else
      index
  };
  second
}

writeManagerState : ManagerState -> Str
writeManagerState state = match writeFile statusPath (encode state) {
  Ok written -> "",
  Err message -> message
}

emptyManagerState : ManagerState
emptyManagerState =
  ManagerState {
    phase = "needs-planner",
    verdict = "pending",
    completed = false,
    objectiveId = objectiveId,
    plannerTaskId = plannerTaskIdForWave 1,
    activeTaskId = "",
    plannedTaskIds = emptyTexts,
    wave = 1,
    benchmarkRuns = 0,
    final = false
  }

readManagerStatePath : Str -> ManagerState
readManagerStatePath path = match readFile path {
  Ok raw -> decode ManagerState raw,
  Err message -> emptyManagerState
}

readManagerState : ManagerState
readManagerState = readManagerStatePath statusPath

currentUpgradeSnapshot : ManagerUpgradeSnapshot
currentUpgradeSnapshot =
  ManagerUpgradeSnapshot {
    state = readManagerState,
    feedback = readTextOrEmpty feedbackPath,
    projectRoot = managerProjectRoot
  }

restoreManagerSnapshotIfNeeded : Str
restoreManagerSnapshotIfNeeded =
  if restoreSnapshotPath == "" then
    ""
  else if fileExists restoredSnapshotPath then
    ""
  else
    match readFile restoreSnapshotPath {
      Err message ->
        textConcat ["restore-read-error:", message],
      Ok raw ->
        let snapshot = decode ManagerUpgradeSnapshot raw in
        let stateError = writeManagerState snapshot.state in
        if stateError != "" then
          textConcat ["restore-state-error:", stateError]
        else {
          let feedbackError =
            if snapshot.feedback == "" then
              ""
            else
              match writeFile feedbackPath snapshot.feedback {
                Ok written -> "",
                Err message -> message
              } in
          if feedbackError != "" then
            textConcat ["restore-feedback-error:", feedbackError]
          else
            match writeFile serviceRootRecordPath restoreServiceRoot {
              Err message ->
                textConcat ["restore-service-root-error:", message],
              Ok serviceRootWritten ->
                match writeFile serviceIdRecordPath restoreServiceId {
                  Err message ->
                    textConcat ["restore-service-id-error:", message],
                  Ok serviceIdWritten ->
                    match writeFile projectRootRecordPath snapshot.projectRoot {
                      Err message ->
                        textConcat ["restore-project-root-error:", message],
                      Ok projectRootWritten ->
                        match
                          writeFile
                            restoredSnapshotPath
                            (encode
                              (ManagerUpgradeRestoreRecord {
                                serviceRoot = restoreServiceRoot,
                                serviceId = restoreServiceId,
                                generation = restoreGeneration,
                                transactionPath = restoreTransactionPath,
                                projectRoot = snapshot.projectRoot,
                                snapshot = snapshot
                              }))
                        {
                          Ok written -> "",
                          Err message ->
                            textConcat ["restore-marker-error:", message]
                        }
                    }
                }
            }
        }
    }

readPlannerReportForWave : Int -> Result PlannerReport
readPlannerReportForWave wave = readPlannerReportPath (plannerReportPathFor wave)

readPlannerInputState : Result PlannerInputState
readPlannerInputState = readPlannerInputStatePath plannerInputPath

benchmarkCheckpointError : Str -> Result BenchmarkCheckpoint
benchmarkCheckpointError message = Err message

readBenchmarkCheckpointPath : Str -> Result BenchmarkCheckpoint
readBenchmarkCheckpointPath path = match readFile path {
  Ok raw -> Ok (decode BenchmarkCheckpoint raw),
  Err message -> benchmarkCheckpointError message
}

latestBenchmarkSummaryText : Str
latestBenchmarkSummaryText = match readBenchmarkCheckpointPath benchmarkLatestPath {
  Ok checkpoint -> checkpoint.summary,
  Err message -> ""
}

latestBenchmarkTargetMet : Bool
latestBenchmarkTargetMet = match readBenchmarkCheckpointPath benchmarkLatestPath {
  Ok checkpoint -> checkpoint.meetsTarget,
  Err message -> false
}

managerHealthSummaryText : Int -> Str
managerHealthSummaryText wave =
  match runCommand "." [
    "bash",
    "-lc",
    textJoin "\n" [
      "state_root=\"$1\"",
      "workspace_root=\"$2\"",
      "baseline_root=\"$3\"",
      "manager_cache=\"$4\"",
      "printf 'wave=%s\\n' \"$5\"",
      "printf 'stateRootMb='; du -sm \"$state_root\" 2>/dev/null | awk '{print $1}' || printf 'unknown'; printf '\\n'",
      "printf 'taskWorkspacesMb='; du -sm \"$workspace_root\" 2>/dev/null | awk '{print $1}' || printf '0'; printf '\\n'",
      "printf 'taskBaselinesMb='; du -sm \"$baseline_root\" 2>/dev/null | awk '{print $1}' || printf '0'; printf '\\n'",
      "printf 'managerCacheMb='; du -sm \"$manager_cache\" 2>/dev/null | awk '{print $1}' || printf '0'; printf '\\n'",
      "printf 'activeChildStates='; grep -Rsl '\"final\"[[:space:]]*:[[:space:]]*false' \"$state_root\"/loop-*/state.json 2>/dev/null | wc -l | tr -d ' '; printf '\\n'",
      "printf 'failedChildStates='; grep -Rsl '\"verdict\"[[:space:]]*:[[:space:]]*\"fail\"' \"$state_root\"/loop-*/state.json 2>/dev/null | wc -l | tr -d ' '; printf '\\n'",
      "printf 'missingDurableReportFailures='; grep -Rsl 'task child loop finished without a durable report' \"$state_root\"/loop-*/feedback.json 2>/dev/null | wc -l | tr -d ' '; printf '\\n'",
      "printf 'recoverableDiffs='; find \"$state_root\" -maxdepth 2 -name 'changes-*.diff' -type f 2>/dev/null | wc -l | tr -d ' '; printf '\\n'",
      "printf 'diskAvailableKb='; df -Pk \"$state_root\" 2>/dev/null | awk 'NR==2 {print $4}' || printf 'unknown'; printf '\\n'"
    ],
    "manager-health",
    stateRootPath,
    taskWorkspaceCacheRoot,
    taskWorkspaceBaselineCacheRoot,
    managerXdgCacheHome,
    encode wave
  ] {
    Err message ->
      textConcat ["manager health unavailable: ", message],
    Ok process ->
      if process.exitCode == 0 then
        process.stdout
      else
        textConcat ["manager health unavailable: ", process.stderr]
  }

plannerInputFingerprintSourceFor : Int -> Str -> Str
plannerInputFingerprintSourceFor wave benchmarkSummary =
  let mailboxSummary = mailboxSummaryText wave in
  let healthSummary = managerHealthSummaryText wave in
  textJoin "\n" [
    textConcat ["goal:", goalText],
    textConcat ["planner-policy:", plannerPolicyText],
    textConcat ["schema-path:", resolvedPlannerSchemaPath],
    textConcat ["project-root:", managerProjectRoot],
    textConcat ["workspace-root:", workspaceRoot],
    textConcat ["wave:", encode wave],
    textConcat ["benchmark-enabled:", encode benchmarkEnabled],
    textConcat ["benchmark-summary:", benchmarkSummary],
    textConcat ["mailbox-summary:", mailboxSummary],
    textConcat ["health-summary:", healthSummary]
  ]

plannerInputStateFor : Int -> Str -> PlannerInputState
plannerInputStateFor wave benchmarkSummary =
  let mailboxSummary = mailboxSummaryText wave in
  PlannerInputState {
    fingerprint = textFingerprint64Hex (plannerInputFingerprintSourceFor wave benchmarkSummary),
    goalText = goalText,
    plannerPolicy = plannerPolicyText,
    schemaPath = resolvedPlannerSchemaPath,
    workspaceRoot = workspaceRoot,
    mailboxSummary = mailboxSummary
  }

writeBenchmarkCheckpoint : BenchmarkCheckpoint -> Str
writeBenchmarkCheckpoint checkpoint = {
  let checkpointText = encode checkpoint in
  match writeFile (benchmarkCheckpointPathFor checkpoint.wave) checkpointText {
    Ok written ->
      match writeFile benchmarkLatestPath checkpointText {
        Ok latestWritten -> "",
        Err message -> message
      },
    Err message -> message
  }
}

readProcessOutputText : Str -> Str
readProcessOutputText path = match readFile path {
  Ok raw -> raw,
  Err message -> ""
}

readProcessOutputTailText : Str -> Str
readProcessOutputTailText path =
  if fileExists path then
    match runCommand "." ["tail", "-c", encode taskFailureLogTailBytes, path] {
      Ok process ->
        if process.exitCode == 0 then
          process.stdout
        else
          textConcat ["tail failed for ", path, ": ", process.stderr],
      Err message ->
        textConcat ["tail failed for ", path, ": ", message]
    }
  else
    ""

pairedPlannerStdoutArtifactPath : Str -> Str
pairedPlannerStdoutArtifactPath stderrPath = {
  let parts = textSplit (pathBasename stderrPath) ".stderr." in
  let prefix = firstTextOrEmpty parts in
  let suffix = secondTextOrEmpty parts in
  if length parts == 2 then
    pathJoin [pathDirname stderrPath, textConcat [prefix, ".stdout.", suffix]]
  else
    ""
}

plannerRunFailureDetail : SwarmRun -> Str
plannerRunFailureDetail run =
  textJoin "\n" [
    textConcat ["exitCode=", encode run.exitCode],
    textConcat ["stdoutArtifactPath=", run.stdoutArtifactPath],
    textConcat ["stderrArtifactPath=", run.stderrArtifactPath],
    textConcat ["stdoutTail=", readProcessOutputTailText run.stdoutArtifactPath],
    textConcat ["stderrTail=", readProcessOutputTailText run.stderrArtifactPath]
  ]

plannerFailureEvidenceText : Str -> Str
plannerFailureEvidenceText detail =
  if detail == "" then
    ""
  else if fileExists detail then {
    let stdoutPath = pairedPlannerStdoutArtifactPath detail in
    textJoin "\n" [
      textConcat ["stderrArtifactPath=", detail],
      textConcat ["stdoutArtifactPath=", stdoutPath],
      textConcat ["stdoutTail=", readProcessOutputTailText stdoutPath],
      textConcat ["stderrTail=", readProcessOutputTailText detail]
    ]
  } else
    detail

childLoopLaunchSummary : Str -> Str
childLoopLaunchSummary taskId =
  match childLoopLaunchState taskId {
    Ok process ->
      textConcat [
        "launcher pid=",
        encode process.pid,
        " running=",
        encode process.running,
        " completed=",
        encode process.completed,
        " exitCode=",
        encode process.exitCode
      ],
    Err message ->
      textConcat ["launcher state unavailable: ", message]
  }

childLoopStateSummary : Str -> Str
childLoopStateSummary taskId =
  if fileExists (taskStatusPath taskId) then
    readProcessOutputTailText (taskStatusPath taskId)
  else
    "child state file missing"

benchmarkSignalError : Str -> Result BenchmarkSignal
benchmarkSignalError message = Err message

readBenchmarkSignalStdout : Int -> Result BenchmarkSignal
readBenchmarkSignalStdout wave =
  let stdoutPath = benchmarkStdoutPathFor wave in
  if fileExists stdoutPath then
    match runCommand "." [
      "bash",
      "-lc",
      "grep -F '\"suite\"' \"$1\" | tail -n 1",
      "benchmark-signal",
      stdoutPath
    ] {
      Err message ->
        benchmarkSignalError message,
      Ok process ->
        let raw = firstTextOrEmpty (textSplit process.stdout "\n") in
        if raw == "" then
          benchmarkSignalError (textConcat ["missing benchmark signal in ", stdoutPath])
        else
          Ok (decode BenchmarkSignal raw)
    }
  else
    benchmarkSignalError (textConcat ["missing benchmark stdout: ", stdoutPath])

benchmarkResultFromSignal : BenchmarkSignal -> ProcessResult
benchmarkResultFromSignal signal =
  ProcessResult {
    exitCode = 0,
    stdout = encode signal,
    stderr = ""
  }

benchmarkTimeoutResultFromStdout : Int -> Result ProcessResult
benchmarkTimeoutResultFromStdout wave =
  match readBenchmarkSignalStdout wave {
    Err message ->
      processResultError "timeout",
    Ok signal ->
      Ok (benchmarkResultFromSignal signal)
  }

benchmarkResultFromProcess : WatchedProcess -> ProcessResult
benchmarkResultFromProcess process =
  ProcessResult {
    exitCode = process.exitCode,
    stdout = readProcessOutputText process.stdoutPath,
    stderr = readProcessOutputText process.stderrPath
  }

benchmarkResultFromCompletedProcess : Int -> WatchedProcess -> Result ProcessResult
benchmarkResultFromCompletedProcess wave process =
  let raw = benchmarkResultFromProcess process in
  match readBenchmarkSignalStdout wave {
    Ok signal ->
      Ok (
        ProcessResult {
          exitCode = 0,
          stdout = encode signal,
          stderr = raw.stderr
        }
      ),
    Err message ->
      if raw.exitCode != 0 then
        Ok raw
      else
        processResultError message
  }

benchmarkCommandArgs : Int -> Int -> [Str]
benchmarkCommandArgs wave benchmarkRuns =
  append
    [
      "env",
      textConcat ["CLASP_MANAGER_STATE_ROOT=", stateRootPath],
      textConcat ["CLASP_MANAGER_PROJECT_ROOT=", managerProjectRoot],
      textConcat ["CLASP_MANAGER_WORKSPACE_ROOT=", workspaceRoot],
      textConcat ["CLASP_MANAGER_BENCHMARK_WAVE=", encode wave],
      textConcat ["CLASP_MANAGER_BENCHMARK_RUNS=", encode benchmarkRuns]
    ]
    benchmarkCommand

pollWatchedProcess : Str -> Int -> Int -> Result WatchedProcess
pollWatchedProcess heartbeatPath pollMs remainingMs =
  match reconcileWatchedProcess heartbeatPath {
    Err message ->
      watchedProcessError message,
    Ok process ->
      if process.completed then
        Ok process
      else if process.running == false then
        Ok process
      else if remainingMs <= 0 then
        watchedProcessError "timeout"
      else {
        let sleepDelay = if remainingMs < pollMs then remainingMs else pollMs in
        match sleepMsValue sleepDelay {
          Ok slept ->
            pollWatchedProcess heartbeatPath pollMs (subtractManagerCounters remainingMs sleepDelay),
          Err message ->
            watchedProcessError message
        }
      }
  }

runBenchmarkCommand : Int -> Int -> Result ProcessResult
runBenchmarkCommand wave benchmarkRuns =
  match spawnWatchedProcess
    benchmarkCwd
    (benchmarkStdoutPathFor wave)
    (benchmarkStderrPathFor wave)
    (benchmarkHeartbeatPathFor wave)
    benchmarkWatchPollMs
    (benchmarkCommandArgs wave benchmarkRuns) {
    Err message ->
      processResultError message,
    Ok launched ->
      match awaitWatchedProcessTimeout launched.heartbeatPath benchmarkWatchPollMs benchmarkTimeoutMs {
        Err message ->
          if message == "timeout" then
            benchmarkTimeoutResultFromStdout wave
          else
            processResultError message,
        Ok process ->
          benchmarkResultFromCompletedProcess wave process
      }
  }

plannerReportReusableFor : Int -> Str -> Bool
plannerReportReusableFor wave benchmarkSummary =
  if fileExists (plannerReportPathFor wave) then
    match readPlannerInputState {
      Ok storedState -> storedState.fingerprint == (plannerInputStateFor wave benchmarkSummary).fingerprint,
      Err message -> false
    }
  else
    false

taskIdOf : SwarmTask -> Str
taskIdOf task = task.taskId

objectiveIdOf : SwarmObjective -> Str
objectiveIdOf objective = objective.objectiveId

taskCompleted : SwarmTask -> Bool
taskCompleted task = task.status == "completed"

taskFailed : SwarmTask -> Bool
taskFailed task = task.status == "failed"

taskInObjective : SwarmTask -> Bool
taskInObjective task = task.objectiveId == objectiveId

textSearchStep : TextSearch -> Str -> TextSearch
textSearchStep search value =
  if search.found then
    search
  else
    TextSearch {
      wanted = search.wanted,
      found = value == search.wanted
    }

textListHas : Str -> [Str] -> Bool
textListHas wanted values =
  (fold textSearchStep (TextSearch { wanted = wanted, found = false }) values).found

taskListHasId : Str -> [SwarmTask] -> Bool
taskListHasId wanted taskValues = textListHas wanted (map taskIdOf taskValues)

taskStatusLookupStep : TaskStatusLookup -> SwarmTask -> TaskStatusLookup
taskStatusLookupStep state task =
  if state.found then
    state
  else if task.taskId == state.wanted then
    TaskStatusLookup {
      wanted = state.wanted,
      found = true,
      status = task.status
    }
  else
    state

taskStatusFor : [SwarmTask] -> Str -> Str
taskStatusFor taskValues taskId =
  (fold
    taskStatusLookupStep
    (TaskStatusLookup {
      wanted = taskId,
      found = false,
      status = "missing"
    })
    taskValues).status

taskStatusIsTerminal : Str -> Bool
taskStatusIsTerminal status =
  if status == "completed" then
    true
  else
    status == "failed"

taskStatusIsActive : Str -> Bool
taskStatusIsActive status =
  if status == "leased" then
    true
  else
    status == "active"

plannedActiveTaskIds : [Str] -> [Str] -> [SwarmTask] -> [Str]
plannedActiveTaskIds plannedIds heartbeatActiveTaskIds taskValues = {
  let mut activeTaskIds = emptyTexts;
  for taskId in plannedIds {
    let taskStatus = taskStatusFor taskValues taskId in
    if textListHas taskId heartbeatActiveTaskIds then {
      activeTaskIds = append activeTaskIds [taskId];
      activeTaskIds
    } else if taskStatusIsActive taskStatus then {
      activeTaskIds = append activeTaskIds [taskId];
      activeTaskIds
    } else
      activeTaskIds
  };
  activeTaskIds
}

statusWaitingReason : Str -> [Str] -> [Str] -> [Str] -> StatusWaitingReason
statusWaitingReason kind taskIds relatedTaskIds details =
  StatusWaitingReason {
    kind = kind,
    taskIds = taskIds,
    relatedTaskIds = relatedTaskIds,
    details = details
  }

appendUniqueText : [Str] -> Str -> [Str]
appendUniqueText values value =
  if value == "" then
    values
  else if textListHas value values then
    values
  else
    append values [value]

appendUniqueTexts : [Str] -> [Str] -> [Str]
appendUniqueTexts values additions = {
  let mut rendered = values;
  for value in additions {
    rendered = appendUniqueText rendered value;
    rendered
  };
  rendered
}

firstWaitingReasonKind : [StatusWaitingReason] -> Str
firstWaitingReasonKind reasons = {
  let mut kind = "";
  let mut found = false;
  for reason in reasons {
    if found then
      found
    else {
      kind = reason.kind;
      found = true;
      found
    }
  };
  kind
}

firstWaitingReasonTaskIds : [StatusWaitingReason] -> [Str]
firstWaitingReasonTaskIds reasons = {
  let mut taskIds = emptyTexts;
  let mut found = false;
  for reason in reasons {
    if found then
      found
    else {
      taskIds = reason.taskIds;
      found = true;
      found
    }
  };
  taskIds
}

dependencyIdsFromBlocker : Str -> [Str]
dependencyIdsFromBlocker blocker = match textPrefix blocker "waiting on " {
  Ok remainder ->
    if remainder == "" then
      emptyTexts
    else
      textSplit remainder ",",
  Err message ->
    emptyTexts
}

taskDependencyIds : SwarmTask -> [Str]
taskDependencyIds task = {
  let mut dependencyIds = emptyTexts;
  for blocker in task.blockedBy {
    dependencyIds = appendUniqueTexts dependencyIds (dependencyIdsFromBlocker blocker);
    dependencyIds
  };
  dependencyIds
}

taskBudgetBlockers : SwarmTask -> [Str]
taskBudgetBlockers task = {
  let mut blockers = emptyTexts;
  for blocker in task.blockedBy {
    if length (textSplit blocker "budget exhausted") > 1 then {
      blockers = appendUniqueText blockers blocker;
      blockers
    } else if length (textSplit blocker "deadline expired") > 1 then {
      blockers = appendUniqueText blockers blocker;
      blockers
    } else
      blockers
  };
  blockers
}

trackedTasksForStatus : [SwarmTask] -> [Str] -> [SwarmTask]
trackedTasksForStatus objectiveTasks plannedTaskIds = {
  let mut trackedTasks = emptyTasks;
  for task in objectiveTasks {
    if length plannedTaskIds == 0 then {
      trackedTasks = append trackedTasks [task];
      trackedTasks
    } else if textListHas task.taskId plannedTaskIds then {
      trackedTasks = append trackedTasks [task];
      trackedTasks
    } else
      trackedTasks
  };
  trackedTasks
}

plannerWaitingReasons : ManagerState -> [StatusWaitingReason]
plannerWaitingReasons state =
  if state.phase == "planner-running" then
    [statusWaitingReason "planner-execution" [state.plannerTaskId] emptyTexts [textConcat ["wave=", encode state.wave]]]
  else
    emptyStatusWaitingReasons

benchmarkWaitingReasons : ManagerState -> [Str] -> [StatusWaitingReason]
benchmarkWaitingReasons state plannedTaskIds = {
  let details =
    if latestBenchmarkSummaryText == "" then
      [textConcat ["wave=", encode state.wave]]
    else
      [textConcat ["wave=", encode state.wave], latestBenchmarkSummaryText] in
  if state.phase == "benchmark-running" then
    [statusWaitingReason "benchmark-execution" plannedTaskIds emptyTexts details]
  else
    emptyStatusWaitingReasons
}

dependencyWaitingReasons : [SwarmTask] -> [StatusWaitingReason]
dependencyWaitingReasons tasks = {
  let mut taskIds = emptyTexts;
  let mut relatedTaskIds = emptyTexts;
  let mut details = emptyTexts;
  for task in tasks {
    let dependencyIds = taskDependencyIds task in
    if length dependencyIds == 0 then
      details
    else {
      taskIds = appendUniqueText taskIds task.taskId;
      relatedTaskIds = appendUniqueTexts relatedTaskIds dependencyIds;
      details =
        appendUniqueText details (textConcat [task.taskId, ":waiting on ", textJoin "," dependencyIds]);
      details
    }
  };
  if length taskIds == 0 then
    emptyStatusWaitingReasons
  else
    [statusWaitingReason "task-dependencies" taskIds relatedTaskIds details]
}

budgetWaitingReasons : [SwarmTask] -> [StatusWaitingReason]
budgetWaitingReasons tasks = {
  let mut taskIds = emptyTexts;
  let mut details = emptyTexts;
  for task in tasks {
    let blockers = taskBudgetBlockers task in
    if length blockers == 0 then
      details
    else {
      taskIds = appendUniqueText taskIds task.taskId;
      for blocker in blockers {
        details = appendUniqueText details (textConcat [task.taskId, ":", blocker]);
        details
      };
      details
    }
  };
  if length taskIds == 0 then
    emptyStatusWaitingReasons
  else
    [statusWaitingReason "task-budget" taskIds emptyTexts details]
}

childHealthWaitingReasons : [Str] -> [StatusWaitingReason]
childHealthWaitingReasons taskIds = {
  let mut unhealthyTaskIds = emptyTexts;
  let mut details = emptyTexts;
  for taskId in taskIds {
    if fileExists (taskStatusPath taskId) then
      match readChildLoopStatePath (taskStatusPath taskId) {
        Ok childState ->
          if childState.final then
            details
          else if childState.completed then
            details
          else if childState.healthy == false then {
            unhealthyTaskIds = appendUniqueText unhealthyTaskIds taskId;
            details =
              appendUniqueText
                details
                (textConcat [taskId, ":phase=", childState.phase, ":attention=", childState.attentionReason]);
            details
          } else if childState.needsAttention then {
            unhealthyTaskIds = appendUniqueText unhealthyTaskIds taskId;
            details =
              appendUniqueText
                details
                (textConcat [taskId, ":phase=", childState.phase, ":attention=", childState.attentionReason]);
            details
          } else
            details,
        Err message ->
          details
      }
    else
      details
  };
  if length unhealthyTaskIds == 0 then
    emptyStatusWaitingReasons
  else
    [statusWaitingReason "child-health" unhealthyTaskIds emptyTexts details]
}

statusWaitingReasons : ManagerState -> [Str] -> [SwarmTask] -> [StatusWaitingReason]
statusWaitingReasons state plannedTaskIds trackedTasks =
  append
    (append
      (append
        (append
          (plannerWaitingReasons state)
          (benchmarkWaitingReasons state plannedTaskIds))
        (dependencyWaitingReasons trackedTasks))
      (budgetWaitingReasons trackedTasks))
    (childHealthWaitingReasons
      (if length plannedTaskIds == 0 then map taskIdOf trackedTasks else plannedTaskIds))

plannerTaskIdOf : PlannerTaskSpec -> Str
plannerTaskIdOf task = task.taskId

plannerTaskIds : PlannerReport -> [Str]
plannerTaskIds report = map plannerTaskIdOf report.tasks

materializePlannerTask : Int -> PlannerTaskSpec -> PlannerTaskSpec
materializePlannerTask wave spec = {
  let mut renderedDependencies = emptyTexts;
  for dependency in spec.dependencies {
    renderedDependencies = append renderedDependencies [materializeTaskId wave dependency];
    renderedDependencies
  };
  PlannerTaskSpec {
    taskId = materializeTaskId wave spec.taskId,
    role = spec.role,
    detail = spec.detail,
    dependencies = renderedDependencies,
    taskPrompt = spec.taskPrompt,
    coordinationFocus = spec.coordinationFocus
  }
}

materializePlannerReport : Int -> PlannerReport -> PlannerReport
materializePlannerReport wave report = {
  let mut renderedTasks = emptyPlannerTasks;
  for taskSpec in report.tasks {
    renderedTasks = append renderedTasks [materializePlannerTask wave taskSpec];
    renderedTasks
  };
  PlannerReport {
    objectiveSummary = report.objectiveSummary,
    strategy = report.strategy,
    tasks = renderedTasks,
    testsRun = report.testsRun,
    residualRisks = report.residualRisks
  }
}

planValidationIssue : Str -> Str -> Str -> PlanValidationIssue
planValidationIssue code taskId detail =
  PlanValidationIssue {
    code = code,
    taskId = taskId,
    detail = detail
  }

appendPlanValidationIssue : [PlanValidationIssue] -> Str -> Str -> Str -> [PlanValidationIssue]
appendPlanValidationIssue issues code taskId detail =
  append issues [planValidationIssue code taskId detail]

dependencyDeclared : [Str] -> Str -> Bool
dependencyDeclared knownTaskIds dependency =
  textListHas dependency knownTaskIds

dependencyIssueStep : DependencyIssueState -> Str -> DependencyIssueState
dependencyIssueStep state dependency =
  if dependency == "" then
    DependencyIssueState {
      issues = appendPlanValidationIssue state.issues "missing-dependency-id" state.taskId "Planner task dependencies must not be empty strings.",
      taskId = state.taskId,
      knownTaskIds = state.knownTaskIds
    }
  else if dependency == plannerTaskId then
    DependencyIssueState {
      issues = appendPlanValidationIssue state.issues "reserved-dependency" state.taskId "Planner task dependencies must refer only to other planned tasks, not the reserved planner task.",
      taskId = state.taskId,
      knownTaskIds = state.knownTaskIds
    }
  else if dependency == state.taskId then
    DependencyIssueState {
      issues = appendPlanValidationIssue state.issues "self-dependency" state.taskId "Planner task depends on itself.",
      taskId = state.taskId,
      knownTaskIds = state.knownTaskIds
    }
  else if dependencyDeclared state.knownTaskIds dependency then
    state
  else
    DependencyIssueState {
      issues = appendPlanValidationIssue state.issues "missing-dependency" state.taskId (textConcat ["Planner task depends on unknown planned task `", dependency, "`."]),
      taskId = state.taskId,
      knownTaskIds = state.knownTaskIds
    }

planValidationFoldStep : PlanValidationFoldState -> PlannerTaskSpec -> PlanValidationFoldState
planValidationFoldStep state spec = {
  let taskId = spec.taskId in
  let issues0 = state.issues in
  let issues1 =
    if taskId == "" then
      appendPlanValidationIssue issues0 "missing-task-id" taskId "Planner task is missing a taskId."
    else
      issues0 in
  let issues2 =
    if spec.detail == "" then
      appendPlanValidationIssue issues1 "missing-detail" taskId "Planner task detail must not be empty."
    else
      issues1 in
  let issues3 =
    if spec.taskPrompt == "" then
      appendPlanValidationIssue issues2 "missing-prompt" taskId "Planner task prompt must not be empty."
    else
      issues2 in
  let issues4 =
    if taskId != "" then
      if textListHas taskId state.seenTaskIds then
        appendPlanValidationIssue issues3 "duplicate-task-id" taskId "Planner task ids must be unique."
      else
        issues3
    else
      issues3 in
  let issues5 =
    if taskId == plannerTaskId then
      appendPlanValidationIssue issues4 "reserved-task-id" taskId "Planner task must not reuse the reserved planner task id."
    else
      issues4 in
  let dependencyState =
    fold
      dependencyIssueStep
      (DependencyIssueState {
        issues = issues5,
        taskId = taskId,
        knownTaskIds = state.knownTaskIds
      })
      spec.dependencies in
  PlanValidationFoldState {
    issues = dependencyState.issues,
    seenTaskIds = append state.seenTaskIds [taskId],
    knownTaskIds = state.knownTaskIds
  }
}

dependencyResolvedStep : DependencyCheck -> Str -> DependencyCheck
dependencyResolvedStep state dependency =
  if state.allResolved then
    DependencyCheck {
      resolvedTaskIds = state.resolvedTaskIds,
      allResolved = textListHas dependency state.resolvedTaskIds
    }
  else
    state

allDependenciesResolved : [Str] -> [Str] -> Bool
allDependenciesResolved resolvedTaskIds dependencies =
  (fold
    dependencyResolvedStep
    (DependencyCheck {
      resolvedTaskIds = resolvedTaskIds,
      allResolved = true
    })
    dependencies).allResolved

cyclePartitionStep : CyclePartitionState -> PlannerTaskSpec -> CyclePartitionState
cyclePartitionStep state spec =
  if allDependenciesResolved state.resolvedTaskIds spec.dependencies then
    CyclePartitionState {
      remaining = state.remaining,
      resolvedTaskIds = append state.resolvedTaskIds [spec.taskId],
      progressed = true
    }
  else
    CyclePartitionState {
      remaining = append state.remaining [spec],
      resolvedTaskIds = state.resolvedTaskIds,
      progressed = state.progressed
    }

cycleBlockedTaskIds : [PlannerTaskSpec] -> [Str] -> [Str]
cycleBlockedTaskIds pendingSpecs resolvedTaskIds =
  if length pendingSpecs == 0 then
    emptyTexts
  else {
    let partition =
      fold
        cyclePartitionStep
        (CyclePartitionState {
          remaining = emptyPlannerTasks,
          resolvedTaskIds = resolvedTaskIds,
          progressed = false
        })
        pendingSpecs in
    if partition.progressed then
      cycleBlockedTaskIds partition.remaining partition.resolvedTaskIds
    else
      map plannerTaskIdOf partition.remaining
  }

planValidationIssueText : PlanValidationIssue -> Str
planValidationIssueText issue =
  if issue.taskId == "" then
    textConcat [issue.code, ": ", issue.detail]
  else
    textConcat [issue.code, "(", issue.taskId, "): ", issue.detail]

planValidationIssueTexts : [PlanValidationIssue] -> [Str]
planValidationIssueTexts issues = map planValidationIssueText issues

planValidationFailureDetail : PlanValidationResult -> Str
planValidationFailureDetail validation = textJoin "\n" (planValidationIssueTexts validation.issues)

planValidationIssueCodeOf : PlanValidationIssue -> Str
planValidationIssueCodeOf issue = issue.code

planValidationIssueCodeRecoverable : Str -> Bool
planValidationIssueCodeRecoverable code =
  if code == "planned-task-budget" then
    true
  else if code == "objective-task-budget" then
    true
  else
    code == "objective-run-budget"

planValidationOnlyRecoverableIssues : [PlanValidationIssue] -> Bool
planValidationOnlyRecoverableIssues issues = {
  let mut ok = true;
  for issue in issues {
    if ok == false then
      ok
    else if planValidationIssueCodeRecoverable issue.code then
      ok
    else {
      ok = false;
      ok
    }
  };
  ok
}

planValidationHasIssueCode : PlanValidationResult -> Str -> Bool
planValidationHasIssueCode validation wanted =
  textListHas wanted (map planValidationIssueCodeOf validation.issues)

recoverablePlannerValidationFailure : PlanValidationResult -> Bool
recoverablePlannerValidationFailure validation =
  if validation.valid then
    false
  else if planValidationHasIssueCode validation "planned-task-budget" then
    if planValidationOnlyRecoverableIssues validation.issues then
      validation.plannerTaskLimit > 0
    else
      false
  else
    false

planValidationFailureReport : PlanValidationResult -> VerifierReport
planValidationFailureReport validation =
  VerifierReport {
    verdict = "fail",
    summary = "planner validation failed",
    findings = planValidationIssueTexts validation.issues,
    tests_run = ["planner plan validation"],
    follow_up = ["Fix the planner output or manager limits before materializing swarm tasks."],
    capability_statuses = emptyCapabilityStatuses
  }
