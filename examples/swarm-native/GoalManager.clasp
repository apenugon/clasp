addManagerCounters : Int -> Int -> Int
addManagerCounters left right =
  if right == 0 then
    left
  else
    addManagerCounters (incrementManagerCounter left) (decrementManagerCounter right)

subtractManagerCounters : Int -> Int -> Int
subtractManagerCounters left right =
  if right == 0 then
    left
  else if left == 0 then
    0
  else
    subtractManagerCounters (decrementManagerCounter left) (decrementManagerCounter right)

repeatAdd : Int -> Int -> Int
repeatAdd count amount =
  if count == 0 then
    0
  else
    addManagerCounters amount (repeatAdd (decrementManagerCounter count) amount)

minimumObjectiveWaveBudget : Int
minimumObjectiveWaveBudget =
  incrementManagerCounter maxTaskLoops

configuredObjectiveBudgetFloor : Int
configuredObjectiveBudgetFloor =
  repeatAdd configuredPlannerWaveCount minimumObjectiveWaveBudget

objectiveTaskBudget : Int
objectiveTaskBudget = configuredObjectiveTaskBudget

objectiveRunBudget : Int
objectiveRunBudget = configuredObjectiveRunBudget

validatePlannerReport : PlannerReport -> PlanValidationResult
validatePlannerReport report = {
  let requiredTaskBudget =
    configuredObjectiveBudgetFloor in
  let requiredRunBudget =
    configuredObjectiveBudgetFloor in
  let structuralState =
    fold
      planValidationFoldStep
      (PlanValidationFoldState {
        issues = emptyPlanValidationIssues,
        seenTaskIds = emptyTexts,
        knownTaskIds = plannerTaskIds report
      })
      report.tasks in
  let issues0 = structuralState.issues in
  let issues1 =
    if length report.tasks == 0 then
      appendPlanValidationIssue issues0 "empty-plan" "" "Planner produced zero tasks."
    else
      issues0 in
  let issues2 =
    if length report.tasks > maxTaskLoops then
      appendPlanValidationIssue
        issues1
        "planned-task-budget"
        ""
        (textConcat [
          "Planner produced ",
          encode (length report.tasks),
          " planned tasks but CLASP_MANAGER_MAX_TASKS_JSON allows only ",
          encode maxTaskLoops,
          " planned tasks."
        ])
    else
      issues1 in
  let issues3 =
    if objectiveTaskBudget < requiredTaskBudget then
      appendPlanValidationIssue
        issues2
        "objective-task-budget"
        ""
        (textConcat [
          "Objective task budget must allow at least ",
          encode requiredTaskBudget,
          " total tasks for the configured planner/task waves."
        ])
    else
      issues2 in
  let issues4 =
    if objectiveRunBudget < requiredRunBudget then
      appendPlanValidationIssue
        issues3
        "objective-run-budget"
        ""
        (textConcat [
          "Objective run budget must allow at least ",
          encode requiredRunBudget,
          " total runs for the configured planner/task waves."
        ])
    else
      issues3 in
  let cycleIssues =
    if length issues4 == 0 then
      cycleBlockedTaskIds report.tasks emptyTexts
    else
      emptyTexts in
  let issues5 =
    if length cycleIssues == 0 then
      issues4
    else
      appendPlanValidationIssue
        issues4
        "dependency-cycle"
        ""
        (textConcat [
          "Planner task dependencies are cyclic or otherwise impossible to resolve: ",
          textJoin ", " cycleIssues
        ]) in
  PlanValidationResult {
    valid = length issues5 == 0,
    issues = issues5,
    plannedTaskCount = length report.tasks,
    plannerTaskLimit = maxTaskLoops,
    objectiveTaskBudget = objectiveTaskBudget,
    objectiveRunBudget = objectiveRunBudget,
    cycleBlockedTaskIds = cycleIssues
  }
}

pickReadyTask : PlannerTaskPick -> PlannerTaskSpec -> PlannerTaskPick
pickReadyTask state spec =
  if state.found then
    state
  else if taskListHasId spec.taskId state.readyTasks then
    PlannerTaskPick {
      readyTasks = state.readyTasks,
      found = true,
      spec = spec
    }
  else
    state

findReadyTask : [PlannerTaskSpec] -> [SwarmTask] -> PlannerTaskPick
findReadyTask specs readyTasks =
  fold
    pickReadyTask
    (PlannerTaskPick {
      readyTasks = readyTasks,
      found = false,
      spec = emptyPlannerTaskSpec
    })
    specs

ensurePolicyFile : Str -> Str -> Str
ensurePolicyFile path contents =
  if fileExists path then
    ""
  else
    match writeFile path contents {
      Ok written -> "",
      Err message -> message
    }

ensureProjectRootRecord : Str
ensureProjectRootRecord =
  if recordedProjectRoot != "" then
    ""
  else
    match writeFile projectRootRecordPath managerProjectRoot {
      Ok written -> "",
        Err message -> message
    }

ensureRecordedText : Str -> Str -> Str
ensureRecordedText path value =
  if value == "" then
    ""
  else if readTextOrEmpty path == value then
    ""
  else
    match writeFile path value {
      Ok written -> "",
      Err message -> message
    }

ensureServiceIdentityRecord : Str
ensureServiceIdentityRecord = {
  let serviceRootError = ensureRecordedText serviceRootRecordPath serviceRoot in
  if serviceRootError != "" then
    serviceRootError
  else
    ensureRecordedText serviceIdRecordPath serviceId
}

signalManagerReady : Str
signalManagerReady =
  if managerReadyPath == "" then
    ""
  else
    match writeFile managerReadyPath managerReadyText {
      Ok written -> "",
      Err message -> message
    }

ensureManagerReady : Str
ensureManagerReady =
  if workspaceRoot == "" then
    "config-error:missing-workspace-root"
  else if maxTaskLoops < 1 then
    "config-error:max-tasks-must-be-positive"
  else if plannerTaskMaxRuns < 1 then
    "config-error:planner-max-runs-must-be-positive"
  else if childMaxAttempts < 1 then
    "config-error:child-max-attempts-must-be-positive"
  else if maxConcurrentChildren < 1 then
    "config-error:max-concurrent-children-must-be-positive"
  else if objectiveTaskBudget < configuredObjectiveBudgetFloor then
    textConcat [
      "config-error:objective-task-budget-too-small:configured=",
      encode objectiveTaskBudget,
      ":required=",
      encode configuredObjectiveBudgetFloor
    ]
  else if objectiveRunBudget < configuredObjectiveBudgetFloor then
    textConcat [
      "config-error:objective-run-budget-too-small:configured=",
      encode objectiveRunBudget,
      ":required=",
      encode configuredObjectiveBudgetFloor
    ]
  else if benchmarkEnabled then
    if maxWaves < 1 then
      "config-error:benchmark-max-waves-must-be-positive"
    else if benchmarkCwd == "" then
      "config-error:missing-benchmark-cwd"
    else
      match mkdirAll stateRootPath {
        Ok created ->
          let trace0 = appendBootstrapTrace "bootstrap:state-root-ready" in
          if trace0 != "" then
            trace0
          else
          let restoreError = restoreManagerSnapshotIfNeeded in
          if restoreError != "" then
            restoreError
          else
          let projectRootError = ensureProjectRootRecord in
          if projectRootError != "" then
            textConcat ["project-root-error:", projectRootError]
          else
            let serviceIdentityError = ensureServiceIdentityRecord in
            if serviceIdentityError != "" then
              textConcat ["service-identity-error:", serviceIdentityError]
            else
              let resourcePruneError = pruneManagerResourceCaches in
              if resourcePruneError != "" then
                resourcePruneError
              else
              match mkdirAll resolvedWorkspaceRoot {
                Ok workspaceCreated ->
                  let trace1 = appendManagerTrace "bootstrap:workspace-root-ready" in
                  if trace1 != "" then
                    trace1
                  else
                  let policyError = ensurePolicyFile plannerPolicyPath defaultPlannerPolicyText in
                  if policyError != "" then
                    policyError
                  else
                    signalManagerReady,
                Err message ->
                  textConcat ["workspace-root-error:", message]
              },
        Err message ->
          textConcat ["state-root-error:", message]
      }
  else
    match mkdirAll stateRootPath {
      Ok created ->
        let trace0 = appendBootstrapTrace "bootstrap:state-root-ready" in
        if trace0 != "" then
          trace0
        else
        let restoreError = restoreManagerSnapshotIfNeeded in
        if restoreError != "" then
          restoreError
        else
          let projectRootError = ensureProjectRootRecord in
          if projectRootError != "" then
            textConcat ["project-root-error:", projectRootError]
          else
            let serviceIdentityError = ensureServiceIdentityRecord in
            if serviceIdentityError != "" then
              textConcat ["service-identity-error:", serviceIdentityError]
            else
              let resourcePruneError = pruneManagerResourceCaches in
              if resourcePruneError != "" then
                resourcePruneError
              else
              match mkdirAll resolvedWorkspaceRoot {
                Ok workspaceCreated ->
                  let trace1 = appendManagerTrace "bootstrap:workspace-root-ready" in
                  if trace1 != "" then
                    trace1
                  else
                  let policyError = ensurePolicyFile plannerPolicyPath defaultPlannerPolicyText in
                  if policyError != "" then
                    policyError
                  else
                    signalManagerReady,
                Err message ->
                  textConcat ["workspace-root-error:", message]
              },
      Err message ->
        textConcat ["state-root-error:", message]
    }

codexCommand : Str -> Str -> Str -> [Str]
codexCommand schemaPath reportPath prompt = [
  codexBin,
  "exec",
  "--json",
  "--cd",
    resolvedWorkspaceRoot,
  "-m",
  codexModel,
  "-c",
  codexReasoningConfig,
  "--skip-git-repo-check",
  "--sandbox",
  codexSandbox,
  "--ephemeral",
  "--output-schema",
  schemaPath,
  "-o",
  reportPath,
  prompt
]

plannerBenchmarkContextFor : Int -> Str -> Str
plannerBenchmarkContextFor wave benchmarkSummary =
  if benchmarkEnabled then
    if benchmarkSummary == "" then
      textJoin "\n" [
        "Benchmark target is enabled for this manager.",
        textConcat ["Current wave: ", encode wave, " of ", encode maxWaves],
        "No benchmark checkpoint exists yet. Plan the first bounded wave toward beating the benchmark target."
      ]
    else
      textJoin "\n" [
        "Benchmark target is enabled for this manager.",
        textConcat ["Current wave: ", encode wave, " of ", encode maxWaves],
        textConcat ["Latest benchmark summary: ", benchmarkSummary],
        "If the target is still unmet, plan the next bounded wave specifically to improve the benchmark."
      ]
  else
    textConcat ["Current wave: ", encode wave, " of ", encode maxWaves]

plannerPromptFor : Int -> Str -> Str
plannerPromptFor wave benchmarkSummary = textJoin "\n" [
  "You are the planner subagent for the Clasp repository.",
  "Read AGENTS.md first if it exists.",
  "Plan the next bounded tasks needed to improve Clasp autonomously.",
  plannerBenchmarkContextFor wave benchmarkSummary,
  "High-level goal:",
  goalText,
  "Current planner policy:",
  plannerPolicyText,
  "Current shared swarm mailbox context:",
  mailboxSummaryText wave,
  "Current manager health/resource context:",
  managerHealthSummaryText wave,
  "Do not assume a fixed role taxonomy beyond the minimal substrate already present. Let coordination patterns emerge from the work and the shared mailbox.",
  "Use focused verification for ordinary implementation branches. Reserve full verify-all for signoff, verifyall, or integration closure tasks, and treat verifier timeouts as first-class planner input.",
  "If prior failed branches have recoverableDiff details, plan from those artifacts instead of rediscovering the same work from scratch.",
  "Return JSON matching the planner schema.",
  textConcat ["Plan 1-", encode maxTaskLoops, " bounded tasks with explicit dependencies and task prompts."],
  "Each planned task must include an explicit role and a coordinationFocus list.",
  "When tasks are independent, prefer complementary parallel roles instead of serializing all work through one branch."
]

plannerCommandFor : Int -> Str -> SwarmCommand
plannerCommandFor wave benchmarkSummary =
  commandSpec
    managerProjectRoot
    (append
      [
        "bash",
        "-lc",
        textJoin "\n" [
          "if [ \"$1\" -le 0 ]; then",
          "  exec \"${@:2}\"",
          "fi",
          "seconds=$(( ($1 + 999) / 1000 ))",
          "duration=\"${seconds}s\"",
          "exec timeout \"$duration\" \"${@:2}\" < /dev/null"
        ],
        "planner-timeout",
        encode plannerTimeoutMs
      ]
      (codexCommand resolvedPlannerSchemaPath (plannerReportPathFor wave) (plannerPromptFor wave benchmarkSummary)))
ensureObjective : Str
ensureObjective = match objectiveCreate swarmStateRoot objectiveId goalText objectiveTaskBudget objectiveRunBudget {
  Ok created -> "",
  Err message -> message
}

ensureTask : Str -> Str -> [Str] -> Str
ensureTask taskId detail dependencies = match tasks swarmStateRoot {
  Ok taskValues ->
    if taskListHasId taskId taskValues then
      ""
    else
      match taskCreate objectiveRef taskId detail dependencies 1 taskLeaseTimeoutMs {
        Ok created -> "",
        Err message -> message
      },
  Err message ->
    match taskCreate objectiveRef taskId detail dependencies 1 taskLeaseTimeoutMs {
      Ok created -> "",
      Err createMessage -> createMessage
    }
}

ensurePlannerTaskFor : Int -> Str
ensurePlannerTaskFor wave = match tasks swarmStateRoot {
  Ok taskValues ->
    if taskListHasId (plannerTaskIdForWave wave) taskValues then
      ""
    else
      match taskCreate
        objectiveRef
        (plannerTaskIdForWave wave)
        (textConcat ["Plan bounded task DAG wave ", encode wave, " for the high-level objective."])
        emptyTexts
        plannerTaskMaxRuns
        taskLeaseTimeoutMs {
        Ok created -> "",
        Err message -> message
      },
  Err message ->
    match taskCreate
      objectiveRef
      (plannerTaskIdForWave wave)
      (textConcat ["Plan bounded task DAG wave ", encode wave, " for the high-level objective."])
      emptyTexts
      plannerTaskMaxRuns
      taskLeaseTimeoutMs {
      Ok created -> "",
      Err createMessage -> createMessage
    }
}

ensurePlannedTaskStep : EnsurePlanState -> PlannerTaskSpec -> EnsurePlanState
ensurePlannedTaskStep state spec =
  if state.error != "" then
    state
  else {
    let taskError = ensureTask spec.taskId (annotatedPlannerTaskDetail spec) spec.dependencies in
    if taskError != "" then
      EnsurePlanState { error = taskError }
    else {
      let policyError = match policySet (taskHandleFor spec.taskId) "trunk" ["merge-ready"] emptyTexts {
        Ok policyValue -> "",
        Err message -> message
      } in
      EnsurePlanState { error = policyError }
    }
  }

ensurePlannedTasks : PlannerReport -> Str
ensurePlannedTasks report =
  (fold ensurePlannedTaskStep (EnsurePlanState { error = "" }) report.tasks).error

plannerTaskCountError : PlannerReport -> Str
plannerTaskCountError report =
  if length report.tasks > maxTaskLoops then
    textConcat [
      "planner produced ",
      encode (length report.tasks),
      " planned tasks but CLASP_MANAGER_MAX_TASKS_JSON allows only ",
      encode maxTaskLoops,
      " planned tasks."
    ]
  else
    ""

taskPromptText : Int -> PlannerReport -> PlannerTaskSpec -> Str
taskPromptText wave report spec = textJoin "\n" [
  "# Clasp Task",
  "",
  "High-level goal:",
  goalText,
  "",
  textConcat ["Task ID: ", spec.taskId],
  textConcat ["Assigned role: ", plannerTaskRoleLabel spec],
  textConcat ["Coordination focus: ", plannerTaskCoordinationSummary spec],
  textConcat ["Detail: ", spec.detail],
  "",
  "Planner instruction:",
  spec.taskPrompt,
  "",
  "Sibling branches in this wave:",
  plannerTaskSiblingSummaryText report spec.taskId,
  "",
  "Shared swarm mailbox context:",
  mailboxSummaryTextForReport wave report,
  "",
  textConcat ["Shared swarm mailbox path: ", mailboxPath],
  "Use the shared mailbox context as durable coordination memory. Do not assume any special fixed swarm role beyond what the current work requires.",
  "Before you finish, re-read the shared mailbox and leave findings that sibling branches can reuse.",
  "",
  "Complete this task in the current checkout. Keep the slice bounded, update tests, and let the child verifier decide pass/fail."
]

writeTaskPromptFile : Int -> PlannerReport -> PlannerTaskSpec -> Str
writeTaskPromptFile wave report spec = match writeFile (taskPromptPath spec.taskId) (taskPromptText wave report spec) {
  Ok written -> "",
  Err message -> message
}

taskVerificationTier : PlannerTaskSpec -> Str
taskVerificationTier spec =
  if textIncludes spec.taskId "verifyall" then
    "full"
  else if textIncludes spec.taskId "verify-all" then
    "full"
  else if textIncludes spec.taskId "signoff" then
    "full"
  else if textIncludes spec.taskId "integrated-verification" then
    "full"
  else if textIncludes (plannerTaskRoleLabel spec) "verifier" then
    "full"
  else
    "focused"

childLoopCommandArgs : PlannerTaskSpec -> [Str]
childLoopCommandArgs spec =
  [
    "env",
    "-u",
    "CLASP_RT_UPGRADE_SNAPSHOT_PATH_JSON",
    "-u",
    "CLASP_RT_UPGRADE_SERVICE_ROOT_JSON",
    "-u",
    "CLASP_RT_UPGRADE_SERVICE_ID_JSON",
    "-u",
    "CLASP_RT_UPGRADE_TRANSACTION_PATH_JSON",
    "-u",
    "CLASP_RT_UPGRADE_GENERATION_JSON",
    "-u",
    "CLASP_MANAGER_BENCHMARK_COMMAND_JSON",
    "-u",
    "CLASP_MANAGER_BENCHMARK_CWD_JSON",
    "-u",
    "CLASP_MANAGER_BENCHMARK_POLL_MS_JSON",
    "-u",
    "CLASP_MANAGER_BENCHMARK_TIMEOUT_MS_JSON",
    textConcat ["CLASP_LOOP_CODEX_BIN_JSON=", encode codexBin],
    textConcat ["CLASP_LOOP_TASK_FILE_JSON=", encode (taskPromptPath spec.taskId)],
    textConcat ["CLASP_LOOP_WORKSPACE_JSON=", encode (taskWorkspaceActualRoot spec.taskId)],
    textConcat ["CLASP_MANAGER_TASK_ROLE_JSON=", encode (plannerTaskRoleLabel spec)],
    textConcat ["CLASP_MANAGER_TASK_COORDINATION_JSON=", encode (plannerTaskCoordinationSummary spec)],
    textConcat ["CLASP_LOOP_MAX_ATTEMPTS_JSON=", encode childMaxAttempts],
    textConcat ["CLASP_LOOP_WATCH_POLL_MS_JSON=", encode childLoopWatchPollMs],
    textConcat ["CLASP_LOOP_VERIFICATION_TIER_JSON=", encode (taskVerificationTier spec)],
    textConcat ["CLASP_LOOP_FOCUSED_VERIFY_COMMANDS_JSON=", encode childFocusedVerifyCommands],
    textConcat ["CLASP_LOOP_FULL_VERIFY_COMMAND_JSON=", encode childFullVerifyCommand],
    textConcat ["CLASP_LOOP_BASELINE_CACHE_ROOT_JSON=", encode (pathJoin [taskReportStateRoot spec.taskId, "baseline-cache"])],
    textConcat ["CLASP_LOOP_BASELINE_CACHE_MAX_MB_JSON=", encode feedbackLoopBaselineCacheMaxMb],
    textConcat ["XDG_CACHE_HOME=", pathJoin [taskReportStateRoot spec.taskId, "xdg-cache"]],
    "CLASP_VERIFY_LOCK_TIMEOUT_SECS=30",
    "CLASP_VERIFY_ON_LOCK_TIMEOUT=run-nested",
    "CLASP_VERIFY_NESTED_COMMANDS=bash scripts/test-verify-all.sh\nbash scripts/test-task-manifest.sh\nbash scripts/test-native-runtime.sh\nbash scripts/test-goal-manager-fast.sh\n",
    textConcat ["CLASP_VERIFY_LABEL=", textConcat ["swarm-child-verify-", spec.taskId]],
    textConcat ["CLASP_MANAGER_PROJECT_ROOT_JSON=", encode managerProjectRoot],
    resolvedManagerClaspcBin,
    "run",
    resolvedChildLoopProgramPath,
    "--",
    taskReportStateRoot spec.taskId
  ]

childLoopCommand : PlannerTaskSpec -> SwarmCommand
childLoopCommand spec = commandSpec managerProjectRoot (childLoopCommandArgs spec)

taskLaunchRecordCommand : PlannerTaskSpec -> SwarmCommand
taskLaunchRecordCommand spec =
  commandSpec "." [
    "bash",
    "-lc",
    textConcat ["printf launched-child-loop:", spec.taskId]
  ]

taskPassReport : PlannerTaskSpec -> VerifierReport
taskPassReport spec = readVerifierReportPath (taskFeedbackPath spec.taskId)

managerPassReport : PlannerReport -> VerifierReport
managerPassReport report =
  VerifierReport {
    verdict = "pass",
    summary =
      if benchmarkEnabled then
        if latestBenchmarkSummaryText == "" then
          textConcat ["goal manager completed: ", report.objectiveSummary]
        else
          textConcat ["goal manager completed: ", report.objectiveSummary, " / ", latestBenchmarkSummaryText]
      else
        textConcat ["goal manager completed: ", report.objectiveSummary],
    findings = emptyTexts,
    tests_run = report.testsRun,
    follow_up = report.residualRisks,
    capability_statuses = emptyCapabilityStatuses
  }

managerStateFor : Str -> Str -> Bool -> Str -> [Str] -> Int -> Int -> Bool -> ManagerState
managerStateFor phase verdict completed activeTaskId plannedTaskIds wave benchmarkRuns final =
  ManagerState {
    phase = phase,
    verdict = verdict,
    completed = completed,
    objectiveId = objectiveId,
    plannerTaskId = plannerTaskIdForWave wave,
    activeTaskId = activeTaskId,
    plannedTaskIds = plannedTaskIds,
    wave = wave,
    benchmarkRuns = benchmarkRuns,
    final = final
  }

benchmarkFailureReport : BenchmarkCheckpoint -> VerifierReport
benchmarkFailureReport checkpoint =
  VerifierReport {
    verdict = "fail",
    summary = "benchmark target not met",
    findings = [checkpoint.summary],
    tests_run = [textConcat ["benchmark:", checkpoint.suite]],
    follow_up = [
      textConcat [
        "Improve ",
        checkpoint.scoreName,
        " from ",
        encode checkpoint.scoreValue,
        " to at most ",
        encode checkpoint.targetValue,
        "."
      ]
    ],
    capability_statuses = emptyCapabilityStatuses
  }

managerFailureState : [Str] -> Int -> Int -> ManagerState
managerFailureState plannedTaskIds wave benchmarkRuns =
  managerStateFor "failed" "fail" false "" plannedTaskIds wave benchmarkRuns true

plannerSummaryOrEmpty : Int -> Str
plannerSummaryOrEmpty wave = match readPlannerReportForWave wave {
  Ok report -> report.objectiveSummary,
  Err message -> ""
}

statusView : ManagerState -> StatusView
statusView state =
  let plannedTaskIds =
    match readPlannerReportForWave state.wave {
      Ok report -> plannerTaskIds (materializePlannerReport state.wave report),
      Err message -> state.plannedTaskIds
    } in
  let heartbeatActiveTaskIds =
    if length plannedTaskIds == 0 then
      emptyTexts
    else {
      let mut runningIds = emptyTexts;
      for taskId in plannedTaskIds {
        if childLoopRunning taskId then {
          runningIds = append runningIds [taskId];
          runningIds
        } else
          runningIds
      };
      runningIds
    } in
  match tasks swarmStateRoot {
    Ok taskValues ->
      let objectiveTasks = filter taskInObjective taskValues in
      let trackedTasks = trackedTasksForStatus objectiveTasks plannedTaskIds in
      let activeTaskIds = plannedActiveTaskIds plannedTaskIds heartbeatActiveTaskIds objectiveTasks in
      let readyTaskIds = match ready objectiveRef {
        Ok readyTasks -> map taskIdOf readyTasks,
        Err message -> emptyTexts
      } in
      let objectiveProjectedStatus =
        match objectiveStatus objectiveRef {
          Ok objectiveValue -> objectiveValue.projectedStatus,
          Err message -> textConcat ["objective-error:", message]
        } in
      let waitingReasons = statusWaitingReasons state plannedTaskIds trackedTasks in
      StatusView {
        state = state,
        plannerSummary = plannerSummaryOrEmpty state.wave,
        objectiveProjectedStatus = objectiveProjectedStatus,
        plannedTaskIds = plannedTaskIds,
        allTaskIds = map taskIdOf objectiveTasks,
        readyTaskIds = readyTaskIds,
        activeTaskIds = activeTaskIds,
        completedTaskIds = map taskIdOf (filter taskCompleted objectiveTasks),
        failedTaskIds = map taskIdOf (filter taskFailed objectiveTasks),
        waitingReasons = waitingReasons,
        primaryWaitingReason = firstWaitingReasonKind waitingReasons,
        primaryWaitingTaskIds = firstWaitingReasonTaskIds waitingReasons,
        benchmarkSummary = latestBenchmarkSummaryText,
        benchmarkTargetMet = latestBenchmarkTargetMet,
        feedbackSummary = readFeedbackSummary
      },
    Err message ->
      let waitingReasons = statusWaitingReasons state plannedTaskIds emptyTasks in
      StatusView {
        state = state,
        plannerSummary = plannerSummaryOrEmpty state.wave,
        objectiveProjectedStatus = textConcat ["task-error:", message],
        plannedTaskIds = plannedTaskIds,
        allTaskIds = emptyTexts,
        readyTaskIds = emptyTexts,
        activeTaskIds = heartbeatActiveTaskIds,
        completedTaskIds = emptyTexts,
        failedTaskIds = emptyTexts,
        waitingReasons = waitingReasons,
        primaryWaitingReason = firstWaitingReasonKind waitingReasons,
        primaryWaitingTaskIds = firstWaitingReasonTaskIds waitingReasons,
        benchmarkSummary = latestBenchmarkSummaryText,
        benchmarkTargetMet = latestBenchmarkTargetMet,
        feedbackSummary = readFeedbackSummary
      }
  }

finalizeWithReport : ManagerState -> VerifierReport -> Str
finalizeWithReport state report = {
  let feedbackError = writeFeedback report in
  if feedbackError != "" then
    textConcat ["feedback-error:", feedbackError]
  else {
    let stateError = writeManagerState state in
    if stateError != "" then
      textConcat ["state-error:", stateError]
    else
      encode (statusView state)
  }
}

checkpointFromSignal : Int -> BenchmarkSignal -> BenchmarkCheckpoint
checkpointFromSignal wave signal =
  BenchmarkCheckpoint {
    wave = wave,
    suite = signal.suite,
    summary = signal.summary,
    passed = signal.passed,
    meetsTarget = signal.meetsTarget,
    scoreName = signal.scoreName,
    scoreValue = signal.scoreValue,
    targetName = signal.targetName,
    targetValue = signal.targetValue,
    command = benchmarkCommand
  }

plannerFailure : Str -> Str -> Str
plannerFailure summary detail = {
  let state = readManagerState in
  finalizeWithReport
    (managerStateFor "failed" "fail" false (plannerTaskIdForWave state.wave) emptyTexts state.wave state.benchmarkRuns true)
    (syntheticFailureReport summary detail)
}

textIncludes : Str -> Str -> Bool
textIncludes value needle = length (textSplit value needle) > 1

recoverablePlannerLeaseFailure : Str -> Bool
recoverablePlannerLeaseFailure detail =
  if textIncludes detail "task run budget exhausted" then
    true
  else
    textIncludes detail "lease held by `manager`"

plannerFailureSummaryRecoverable : Str -> Bool
plannerFailureSummaryRecoverable summary =
  if summary == "planner run failed" then
    true
  else
    summary == "planner step failed before producing a durable report"

recoverablePlannerTransportFailure : Str -> Bool
recoverablePlannerTransportFailure detail =
  if textIncludes detail "We're currently experiencing high demand" then
    true
  else if textIncludes detail "stream disconnected before completion" then
    true
  else if textIncludes detail "websocket closed by server before response.completed" then
    true
  else if textIncludes detail "websocket closed by server" then
    true
  else if textIncludes detail "turn.failed" then
    true
  else
    textIncludes detail "exitCode=124"

continueAfterPlannerLeaseBlocker : Str -> Str -> Str
continueAfterPlannerLeaseBlocker summary detail = {
  let state = readManagerState in
  if state.wave < maxWaves then {
    let traceError =
      appendManagerTrace
        (textConcat [
          "planner-wave-",
          encode state.wave,
          ":recoverable-lease-blocker:",
          summary,
          ":",
          detail
        ]) in
    if traceError != "" then
      plannerFailure "manager trace write failed" traceError
    else {
      let nextWave = incrementManagerCounter state.wave in
      let nextState =
        managerStateFor "needs-planner" "pending" false "" emptyTexts nextWave state.benchmarkRuns false in
      let stateError = writeManagerState nextState in
      if stateError != "" then
        plannerFailure "planner lease recovery state write failed" stateError
      else
        runPlanner
    }
  } else
    plannerFailure summary detail
}

continueAfterPlannerTransportBlocker : Str -> Str -> Str
continueAfterPlannerTransportBlocker summary detail = {
  let state = readManagerState in
  let traceError =
    appendManagerTrace
      (textConcat [
        "planner-wave-",
        encode state.wave,
        ":recoverable-transport-blocker:",
        summary,
        ":",
        detail
      ]) in
  if traceError != "" then
    plannerFailure "manager trace write failed" traceError
  else
    match fail (plannerHandleForWave state.wave) {
      Err message ->
        plannerFailure "planner transport recovery fail transition failed" message,
      Ok failedValue ->
        match retry (plannerHandleForWave state.wave) {
          Err message ->
            plannerFailure "planner transport recovery retry failed" message,
          Ok retriedValue -> {
            let nextState =
              managerStateFor "needs-planner" "pending" false "" emptyTexts state.wave state.benchmarkRuns false in
            let stateError = writeManagerState nextState in
            if stateError != "" then
              plannerFailure "planner transport recovery state write failed" stateError
            else
              runPlanner
          }
        }
    }
}

continueAfterPlannerValidationBlocker : Str -> Str -> Str
continueAfterPlannerValidationBlocker summary detail = {
  let state = readManagerState in
  let traceError =
    appendManagerTrace
      (textConcat [
        "planner-wave-",
        encode state.wave,
        ":recoverable-validation-blocker:",
        summary,
        ":",
        detail
      ]) in
  if traceError != "" then
    plannerFailure "manager trace write failed" traceError
  else
    match fail (plannerHandleForWave state.wave) {
      Err message ->
        plannerFailure "planner validation recovery fail transition failed" message,
      Ok failedValue ->
        match retry (plannerHandleForWave state.wave) {
          Err message ->
            plannerFailure "planner validation recovery retry failed" message,
          Ok retriedValue -> {
            let nextState =
              managerStateFor "needs-planner" "pending" false "" emptyTexts state.wave state.benchmarkRuns false in
            let stateError = writeManagerState nextState in
            if stateError != "" then
              plannerFailure "planner validation recovery state write failed" stateError
            else
              runPlanner
          }
        }
    }
}
recoverableFinalPlannerLeaseState : ManagerState -> Bool
recoverableFinalPlannerLeaseState state =
  if state.phase == "failed" then
    if state.activeTaskId == plannerTaskIdForWave state.wave then
      readFeedbackSummary == "planner lease failed"
    else
      false
  else
    false

finalPlannerTaskMatchesWave : ManagerState -> Bool
finalPlannerTaskMatchesWave state =
  if state.activeTaskId == state.plannerTaskId then
    true
  else if state.activeTaskId == plannerTaskIdForWave state.wave then
    true
  else
    state.plannerTaskId == plannerTaskIdForWave state.wave

recoverableFinalPlannerTransportDetail : ManagerState -> Str
recoverableFinalPlannerTransportDetail state =
  plannerFailureEvidenceText (firstTextOrEmpty (readVerifierReportPath feedbackPath).findings)

recoverableFinalPlannerTransportState : ManagerState -> Bool
recoverableFinalPlannerTransportState state =
  if state.phase == "failed" then
    if finalPlannerTaskMatchesWave state then {
      let summary = readFeedbackSummary in
      if plannerFailureSummaryRecoverable summary then
        recoverablePlannerTransportFailure (recoverableFinalPlannerTransportDetail state)
      else
        false
    } else
      false
  else
    false

finalizeBenchmarkCheckpoint : PlannerReport -> Int -> Int -> BenchmarkCheckpoint -> Str
finalizeBenchmarkCheckpoint report wave benchmarkRuns checkpoint = {
  let failureState = managerFailureState (plannerTaskIds report) wave benchmarkRuns in
  let checkpointWriteError = writeBenchmarkCheckpoint checkpoint in
  if checkpointWriteError != "" then
    finalizeWithReport failureState (syntheticFailureReport "benchmark checkpoint write failed" checkpointWriteError)
  else {
    let mailboxError = refreshMailbox wave in
    if mailboxError != "" then
      finalizeWithReport failureState (syntheticFailureReport "mailbox write failed" mailboxError)
    else {
      let nextBenchmarkRuns = incrementManagerCounter benchmarkRuns in
      match ready objectiveRef {
        Err message ->
          finalizeWithReport failureState (syntheticFailureReport "benchmark ready queue lookup failed" message),
        Ok readyTasks -> {
          let mut readyPlannedIds = emptyTexts;
          for readyTask in readyTasks {
            let readyTaskId = taskIdOf readyTask in
            if textListHas readyTaskId (plannerTaskIds report) then {
              readyPlannedIds = append readyPlannedIds [readyTaskId];
              readyPlannedIds
            } else
              readyPlannedIds
          };
          if length readyPlannedIds > 0 then
            executeReadyTasks report wave nextBenchmarkRuns
          else if checkpoint.meetsTarget then
            finalizeWithReport
              (managerStateFor "completed" "pass" true "" (plannerTaskIds report) wave nextBenchmarkRuns true)
              (managerPassReport report)
          else if wave < maxWaves then {
            let nextWave = incrementManagerCounter wave in
            let nextState = managerStateFor "needs-planner" "pending" false "" emptyTexts nextWave nextBenchmarkRuns false in
            let nextStateError = writeManagerState nextState in
            if nextStateError != "" then
              finalizeWithReport
                (managerFailureState (plannerTaskIds report) wave nextBenchmarkRuns)
                (syntheticFailureReport "benchmark replan state write failed" nextStateError)
            else
              runPlanner
          } else
            finalizeWithReport
              (managerFailureState (plannerTaskIds report) wave nextBenchmarkRuns)
              (benchmarkFailureReport checkpoint)
        }
      }
    }
  }
}

benchmarkCommandFailure : PlannerReport -> Int -> Int -> Str -> Str
benchmarkCommandFailure report wave benchmarkRuns message =
  finalizeWithReport
    (managerFailureState (plannerTaskIds report) wave benchmarkRuns)
    (syntheticFailureReport "benchmark command failed" message)

benchmarkTimeoutFailure : PlannerReport -> Int -> Int -> Str
benchmarkTimeoutFailure report wave benchmarkRuns =
  finalizeWithReport
    (managerFailureState (plannerTaskIds report) wave benchmarkRuns)
    (syntheticFailureReport
      "benchmark command timed out"
      (textConcat
        ["Benchmark command exceeded ", encode benchmarkTimeoutMs, "ms. See ", benchmarkHeartbeatPathFor wave, " and ", benchmarkStderrPathFor wave, "."]))

runBenchmarkCheckpoint : PlannerReport -> Int -> Int -> Str
runBenchmarkCheckpoint report wave benchmarkRuns = {
  let benchmarkState =
    managerStateFor
      "benchmark-running"
      "pending"
      false
      ""
      (plannerTaskIds report)
      wave
      benchmarkRuns
      false in
  let stateError = writeManagerState benchmarkState in
  if stateError != "" then
    finalizeWithReport
      (managerFailureState (plannerTaskIds report) wave benchmarkRuns)
      (syntheticFailureReport "benchmark state write failed" stateError)
  else {
    let trace0 = appendManagerTrace (textConcat ["benchmark-wave-", encode wave, ":start"]) in
    if trace0 != "" then
      finalizeWithReport
        (managerFailureState (plannerTaskIds report) wave benchmarkRuns)
        (syntheticFailureReport "benchmark trace write failed" trace0)
    else
      match runBenchmarkCommand wave benchmarkRuns {
        Err message ->
          if message == "timeout" then
            benchmarkTimeoutFailure report wave benchmarkRuns
          else
            finalizeWithReport
              (managerFailureState (plannerTaskIds report) wave benchmarkRuns)
              (syntheticFailureReport "benchmark command failed to start" message),
        Ok process -> {
          let trace1 = appendManagerTrace (textConcat ["benchmark-wave-", encode wave, ":command-finished"]) in
          if trace1 != "" then
            finalizeWithReport
              (managerFailureState (plannerTaskIds report) wave benchmarkRuns)
              (syntheticFailureReport "benchmark trace write failed" trace1)
          else if process.exitCode != 0 then
            benchmarkCommandFailure report wave benchmarkRuns process.stderr
          else {
            let signal = decode BenchmarkSignal process.stdout in
            let trace2 = appendManagerTrace (textConcat ["benchmark-wave-", encode wave, ":decoded-signal"]) in
            if trace2 != "" then
              finalizeWithReport
                (managerFailureState (plannerTaskIds report) wave benchmarkRuns)
                (syntheticFailureReport "benchmark trace write failed" trace2)
            else {
              let checkpoint = checkpointFromSignal wave signal in
              let trace3 = appendManagerTrace (textConcat ["benchmark-wave-", encode wave, ":checkpoint-created"]) in
              if trace3 != "" then
                finalizeWithReport
                  (managerFailureState (plannerTaskIds report) wave benchmarkRuns)
                  (syntheticFailureReport "benchmark trace write failed" trace3)
              else
                finalizeBenchmarkCheckpoint report wave benchmarkRuns checkpoint
            }
          }
        }
      }
  }
}

resumeBenchmarkCheckpoint : Int -> Int -> Str
resumeBenchmarkCheckpoint wave benchmarkRuns =
  match readPlannerReportForWave wave {
    Err message ->
      plannerFailure "planner report missing during benchmark recovery" message,
    Ok report ->
      if fileExists (benchmarkCheckpointPathFor wave) then
        match readBenchmarkCheckpointPath (benchmarkCheckpointPathFor wave) {
          Err message ->
            finalizeWithReport
              (managerFailureState (plannerTaskIds report) wave benchmarkRuns)
              (syntheticFailureReport "benchmark checkpoint decode failed" message),
          Ok checkpoint ->
            finalizeBenchmarkCheckpoint report wave benchmarkRuns checkpoint
        }
      else if fileExists (benchmarkHeartbeatPathFor wave) then
        match awaitWatchedProcessTimeout (benchmarkHeartbeatPathFor wave) benchmarkWatchPollMs benchmarkTimeoutMs {
          Err message ->
            if message == "timeout" then
              match readBenchmarkSignalStdout wave {
                Err signalMessage ->
                  benchmarkTimeoutFailure report wave benchmarkRuns,
                Ok signal ->
                  finalizeBenchmarkCheckpoint
                    report
                    wave
                    benchmarkRuns
                    (checkpointFromSignal wave signal)
              }
            else
              finalizeWithReport
                (managerFailureState (plannerTaskIds report) wave benchmarkRuns)
                (syntheticFailureReport "benchmark recovery failed" message),
          Ok process ->
            match benchmarkResultFromCompletedProcess wave process {
              Err signalMessage ->
                finalizeWithReport
                  (managerFailureState (plannerTaskIds report) wave benchmarkRuns)
                  (syntheticFailureReport "benchmark signal missing" signalMessage),
              Ok result ->
                if result.exitCode != 0 then
                  benchmarkCommandFailure report wave benchmarkRuns result.stderr
                else
                  finalizeBenchmarkCheckpoint
                    report
                    wave
                    benchmarkRuns
                    (checkpointFromSignal wave (decode BenchmarkSignal result.stdout))
            }
        }
      else
        runBenchmarkCheckpoint report wave benchmarkRuns
  }

resumeCurrentWave : ManagerState -> Str
resumeCurrentWave state =
  if fileExists (plannerReportPathFor state.wave) then
    continueWithPlanResolved state.wave state.benchmarkRuns latestBenchmarkSummaryText (readPlannerReportForWave state.wave)
  else
    finalizeWithReport
      (managerFailureState state.plannedTaskIds state.wave state.benchmarkRuns)
      (syntheticFailureReport
        "planner report missing during task recovery"
        (textConcat ["Missing planner report for wave ", encode state.wave, " while resuming task execution."]))

resumePlannerWave : ManagerState -> Str
resumePlannerWave state =
  if fileExists (plannerReportPathFor state.wave) then
    continueWithPlanResolved state.wave state.benchmarkRuns latestBenchmarkSummaryText (readPlannerReportForWave state.wave)
  else
    runPlanner

completePlannerTaskIfNeeded : Int -> Str
completePlannerTaskIfNeeded wave =
  match tasks swarmStateRoot {
    Err message ->
      textConcat ["planner task lookup failed: ", message],
    Ok taskValues ->
      let plannerTaskStatus = taskStatusFor (filter taskInObjective taskValues) (plannerTaskIdForWave wave) in
      if plannerTaskStatus == "completed" then
        ""
      else
        match complete (plannerHandleForWave wave) {
          Err message ->
            message,
          Ok completedValue ->
            ""
        }
  }

runPlanner : Str
runPlanner = {
  let state = readManagerState in
  let wave = state.wave in
  let benchmarkSummary = latestBenchmarkSummaryText in
  let reusablePlannerReport = plannerReportReusableFor wave benchmarkSummary in
  let trace0 = appendBootstrapTrace (textConcat ["run-planner:wave-", encode wave, ":start"]) in
  if trace0 != "" then
    plannerFailure "manager bootstrap trace failed" trace0
  else
  let prepError = ensureManagerReady in
  if prepError != "" then
    plannerFailure "manager setup failed" prepError
  else {
    let trace1 = appendManagerTrace (textConcat ["run-planner:wave-", encode wave, ":manager-ready"]) in
    if trace1 != "" then
      plannerFailure "manager trace write failed" trace1
    else {
    let objectiveError = ensureObjective in
    if objectiveError != "" then
      plannerFailure "objective creation failed" objectiveError
    else {
      let trace2 = appendManagerTrace (textConcat ["run-planner:wave-", encode wave, ":objective-ready"]) in
      if trace2 != "" then
        plannerFailure "manager trace write failed" trace2
      else {
      let plannerTaskError = ensurePlannerTaskFor wave in
      if plannerTaskError != "" then
        plannerFailure "planner task creation failed" plannerTaskError
      else {
        let trace3 = appendManagerTrace (textConcat ["run-planner:wave-", encode wave, ":planner-task-ready"]) in
        if trace3 != "" then
          plannerFailure "manager trace write failed" trace3
        else {
        let plannerState =
          managerStateFor "planner-running" "pending" false (plannerTaskIdForWave wave) emptyTexts wave state.benchmarkRuns false in
        let stateError = writeManagerState plannerState in
        if stateError != "" then
          plannerFailure "planner state write failed" stateError
        else if reusablePlannerReport then
          {
            let traceError = appendManagerTrace (textConcat ["planner-wave-", encode wave, ":reuse-existing-report"]) in
            if traceError != "" then
              plannerFailure "manager trace write failed" traceError
            else
              continueWithPlan
          }
        else
          match lease (plannerHandleForWave wave) {
            Err message ->
              if recoverablePlannerLeaseFailure message then
                continueAfterPlannerLeaseBlocker "planner lease failed" message
              else
                plannerFailure "planner lease failed" message,
            Ok leaseValue ->
              match toolRun (plannerHandleForWave wave) (plannerCommandFor wave benchmarkSummary) {
                Err message ->
                  if recoverablePlannerTransportFailure message then
                    continueAfterPlannerTransportBlocker "planner run failed" message
                  else
                    plannerFailure "planner run failed" message,
                Ok runValue ->
                  if fileExists (plannerReportPathFor wave) then
                    {
                      let traceError = appendManagerTrace (textConcat ["planner-wave-", encode wave, ":report-ready"]) in
                      if traceError != "" then
                        plannerFailure "manager trace write failed" traceError
                      else
                        continueWithPlan
                    }
                  else {
                    let detail = plannerRunFailureDetail runValue in
                    if recoverablePlannerTransportFailure detail then
                      continueAfterPlannerTransportBlocker "planner step failed before producing a durable report" detail
                    else {
                      let failed = fail (plannerHandleForWave wave) in
                      plannerFailure "planner step failed before producing a durable report" detail
                    }
                  }
              }
          }
      }
    }
  }
    }
      }
    }
}

plannedTaskFailureReport : [Str] -> VerifierReport
plannedTaskFailureReport failedTaskIds =
  syntheticFailureReport
    "one or more planned tasks failed"
    (textConcat ["Failed planned tasks: ", textJoin ", " failedTaskIds])

plannedTaskStalledReport : PlannerReport -> VerifierReport
plannedTaskStalledReport report =
  syntheticFailureReport
    "planned task execution stalled"
    (textConcat ["No running or ready planned task remained for ", report.objectiveSummary, "."])

continueAfterPlannedTaskBlocker : PlannerReport -> Int -> Int -> VerifierReport -> Str
continueAfterPlannedTaskBlocker report wave benchmarkRuns blockerReport =
  if wave < maxWaves then {
    let mailboxError = refreshMailbox wave in
    if mailboxError != "" then
      finalizeWithReport
        (managerFailureState (plannerTaskIds report) wave benchmarkRuns)
        (syntheticFailureReport "mailbox write failed" mailboxError)
    else {
      let nextWave = incrementManagerCounter wave in
      let nextState = managerStateFor "needs-planner" "pending" false "" emptyTexts nextWave benchmarkRuns false in
      let nextStateError = writeManagerState nextState in
      if nextStateError != "" then
        finalizeWithReport
          (managerFailureState (plannerTaskIds report) wave benchmarkRuns)
          (syntheticFailureReport "planned task replan state write failed" nextStateError)
      else
        runPlanner
    }
  } else
    finalizeWithReport
      (managerFailureState (plannerTaskIds report) wave benchmarkRuns)
      blockerReport

childLoopMissingReport : PlannerTaskSpec -> VerifierReport
childLoopMissingReport spec =
  syntheticFailureReport
    "task child loop finished without a durable report"
    (textJoin "\n"
      (append
        [
          textConcat ["task=", spec.taskId],
          textConcat ["role=", plannerTaskRoleLabel spec],
          textConcat ["reportSettlePolls=", encode childReportSettlePolls],
          textConcat ["reportSettlePollMs=", encode childLoopWatchPollMs],
          childLoopLaunchSummary spec.taskId,
          textConcat ["state=", childLoopStateSummary spec.taskId],
          textConcat ["stderr_tail=", readProcessOutputTailText (taskProcessStderrPath spec.taskId)],
          textConcat ["stdout_tail=", readProcessOutputTailText (taskProcessStdoutPath spec.taskId)]
        ]
        (taskRecoverableDiffDetails spec.taskId)))

childLoopMissingLaunchHeartbeatReport : PlannerTaskSpec -> VerifierReport
childLoopMissingLaunchHeartbeatReport spec =
  syntheticFailureReport
    "task child loop failed to establish a durable launch heartbeat"
    (textJoin "\n"
      [
        textConcat ["task=", spec.taskId],
        textConcat ["role=", plannerTaskRoleLabel spec],
        childLoopLaunchSummary spec.taskId,
        textConcat ["state=", childLoopStateSummary spec.taskId],
        textConcat ["stderr_tail=", readProcessOutputTailText (taskProcessStderrPath spec.taskId)],
        textConcat ["stdout_tail=", readProcessOutputTailText (taskProcessStdoutPath spec.taskId)]
      ])

promotionFailureReport : PlannerTaskSpec -> Str -> VerifierReport
promotionFailureReport spec message =
  syntheticFailureReport
    "task promotion failed"
    (if fileExists (taskPromotionDiffPath spec.taskId) then
      textConcat [
        message,
        "\nrecoverableDiff=",
        taskPromotionDiffPath spec.taskId,
        "\nrecoverableDiffKind=promotion-workspace",
        "\nrecoverableDiffUse=Feed this diff and its verifier report into the next planner wave instead of rediscovering the same branch from scratch."
      ]
    else
      message)

promotionFailureFinding : PlannerTaskSpec -> Str
promotionFailureFinding spec =
  textConcat [
    "task workspace promotion failed: ",
    spec.taskId,
    ": promotion conflict: task workspace would overwrite files changed since snapshot"
  ]

promotionFailureFindingsJson : PlannerTaskSpec -> Str
promotionFailureFindingsJson spec =
  if fileExists (taskPromotionDiffPath spec.taskId) then
    textConcat [
      encode (promotionFailureFinding spec),
      ",",
      encode (textConcat ["recoverableDiff=", taskPromotionDiffPath spec.taskId]),
      ",",
      encode "recoverableDiffKind=promotion-workspace",
      ",",
      encode "recoverableDiffUse=Feed this diff and its verifier report into the next planner wave instead of rediscovering the same branch from scratch."
    ]
  else
    encode (promotionFailureFinding spec)

promotionFailureJson : PlannerTaskSpec -> Str
promotionFailureJson spec =
  textConcat [
    "{\"verdict\":\"fail\",\"summary\":\"task promotion failed\",\"findings\":[",
    promotionFailureFindingsJson spec,
    "],\"tests_run\":[],\"follow_up\":[",
    encode "Resolve the promotion conflict or replan from the recoverable diff artifact instead of discarding useful work.",
    "],\"capability_statuses\":[]}"
  ]

writePromotionFailureFeedback : PlannerTaskSpec -> Str
writePromotionFailureFeedback spec =
  match mkdirAll (taskReportStateRoot spec.taskId) {
    Err message -> textConcat ["task feedback directory create failed: ", spec.taskId, ": ", message],
    Ok created ->
      match writeFile (taskFeedbackPath spec.taskId) (promotionFailureJson spec) {
        Ok written -> "",
        Err message -> textConcat ["task feedback write failed: ", spec.taskId, ": ", message]
      }
  }

recordPromotionFailure : PlannerTaskSpec -> Str
recordPromotionFailure spec = {
  let feedbackError = writePromotionFailureFeedback spec in
  if feedbackError != "" then
    feedbackError
  else
    match fail (taskHandleFor spec.taskId) {
      Err message ->
        textConcat ["task failure recording failed: ", spec.taskId, ": ", message],
      Ok failedValue -> {
        let cleanupError = cleanupFailedTaskWorkspace spec.taskId in
        if cleanupError != "" then
          appendManagerTrace (textConcat ["task-cleanup:error:", spec.taskId, ":", cleanupError])
        else
          ""
      }
    }
}

completePlannedTask : PlannerTaskSpec -> Str
completePlannedTask spec =
  let promotionError = promoteVerifiedTaskWorkspace spec in
  if promotionError != "" then
    recordPromotionFailure spec
  else
    match complete (taskHandleFor spec.taskId) {
      Err message ->
        textConcat ["task completion failed: ", spec.taskId, ": ", message],
      Ok completedValue ->
        match approveAndMerge (taskHandleFor spec.taskId) "merge-ready" "trunk" emptyTexts mailboxLimit {
          Err message ->
            textConcat ["task review failed: ", spec.taskId, ": ", message],
          Ok reviewValue ->
            ""
        }
    }

recordPlannedTaskFailure : PlannerTaskSpec -> VerifierReport -> Str
recordPlannedTaskFailure spec report = {
  let feedbackError = writeTaskFeedback spec.taskId report in
  if feedbackError != "" then
    textConcat ["task feedback write failed: ", spec.taskId, ": ", feedbackError]
  else
    match fail (taskHandleFor spec.taskId) {
      Err message ->
        textConcat ["task failure recording failed: ", spec.taskId, ": ", message],
      Ok failedValue -> {
        let cleanupError = cleanupFailedTaskWorkspace spec.taskId in
        if cleanupError != "" then
          appendManagerTrace (textConcat ["task-cleanup:error:", spec.taskId, ":", cleanupError])
        else
          ""
      }
    }
}

launchReadyTask : Int -> PlannerReport -> PlannerTaskSpec -> Str
launchReadyTask wave report spec = {
  let promptError = writeTaskPromptFile wave report spec in
  if promptError != "" then
    textConcat ["task prompt write failed: ", spec.taskId, ": ", promptError]
  else {
    let workspaceError = ensureTaskWorkspace spec.taskId in
    if workspaceError != "" then
      textConcat ["task workspace setup failed: ", spec.taskId, ": ", workspaceError]
    else
      match lease (taskHandleFor spec.taskId) {
        Err message ->
          recordPlannedTaskFailure spec (syntheticFailureReport "task lease failed" message),
        Ok leaseValue ->
          match toolRun (taskHandleFor spec.taskId) (taskLaunchRecordCommand spec) {
            Err message ->
              recordPlannedTaskFailure spec (syntheticFailureReport "task launch run failed" message),
            Ok runValue ->
              match launchChildLoop spec {
                Err message ->
                  recordPlannedTaskFailure spec (syntheticFailureReport "task child loop failed to start" message),
                Ok launched ->
                  ""
              }
          }
      }
  }
}

launchChildLoop : PlannerTaskSpec -> Result WatchedProcess
launchChildLoop spec =
  spawnWatchedProcess
    managerProjectRoot
    (taskProcessStdoutPath spec.taskId)
    (taskProcessStderrPath spec.taskId)
    (taskProcessHeartbeatPath spec.taskId)
    childLoopWatchPollMs
    (childLoopCommandArgs spec)

retryChildLoopMissingReport : PlannerTaskSpec -> VerifierReport -> Str
retryChildLoopMissingReport spec report =
  if childLoopManagerRetryAvailable spec.taskId == false then
    recordPlannedTaskFailure spec report
  else {
    let nextRetry = incrementManagerCounter (readChildLoopManagerRetries spec.taskId) in
    let retryWriteError = writeChildLoopManagerRetries spec.taskId nextRetry in
    if retryWriteError != "" then
      textConcat ["task child loop retry count write failed: ", spec.taskId, ": ", retryWriteError]
    else {
      let traceError =
        appendManagerTrace
          (textConcat [
            "child-loop-retry:",
            spec.taskId,
            ":missing-durable-report:retry=",
            encode nextRetry
          ]) in
      if traceError != "" then
        traceError
      else {
        let resetError = resetChildLoopForManagerRetry spec.taskId in
        if resetError != "" then
          textConcat ["task child loop retry reset failed: ", spec.taskId, ": ", resetError]
        else {
          let workspaceError = ensureTaskWorkspace spec.taskId in
          if workspaceError != "" then
            textConcat ["task child loop retry workspace setup failed: ", spec.taskId, ": ", workspaceError]
          else
            match launchChildLoop spec {
              Err message ->
                recordPlannedTaskFailure spec (syntheticFailureReport "task child loop retry failed to start" message),
              Ok launched ->
                ""
            }
        }
      }
    }
  }

requeueTaskForManagerRetry : Str -> Str -> Str
requeueTaskForManagerRetry taskId failureSummary =
  match retry (taskHandleFor taskId) {
    Err message ->
      textConcat [failureSummary, ": ", taskId, ": ", message],
    Ok retriedValue ->
      ""
  }

retryChildLoopMissingLaunchHeartbeat : Int -> PlannerReport -> PlannerTaskSpec -> VerifierReport -> Str
retryChildLoopMissingLaunchHeartbeat wave report spec failureReport =
  if childLoopManagerRetryAvailable spec.taskId == false then
    recordPlannedTaskFailure spec failureReport
  else {
    let nextRetry = incrementManagerCounter (readChildLoopManagerRetries spec.taskId) in
    let retryWriteError = writeChildLoopManagerRetries spec.taskId nextRetry in
    if retryWriteError != "" then
      textConcat ["task child loop retry count write failed: ", spec.taskId, ": ", retryWriteError]
    else {
      let traceError =
        appendManagerTrace
          (textConcat [
            "child-loop-retry:",
            spec.taskId,
            ":missing-launch-heartbeat:retry=",
            encode nextRetry
          ]) in
      if traceError != "" then
        traceError
      else {
        let requeueError =
          requeueTaskForManagerRetry spec.taskId "task child loop retry requeue failed" in
        if requeueError != "" then
          requeueError
        else {
          let resetError = resetChildLoopForManagerRetry spec.taskId in
          if resetError != "" then
            textConcat ["task child loop retry reset failed: ", spec.taskId, ": ", resetError]
          else
            launchReadyTask wave report spec
        }
      }
    }
  }

continueWithPlanResolved : Int -> Int -> Str -> Result PlannerReport -> Str
continueWithPlanResolved wave benchmarkRuns benchmarkSummary reportResult =
  match reportResult {
  Err message ->
    plannerFailure "planner report decode failed" message,
  Ok rawReport -> {
    let trace0 = appendManagerTrace (textConcat ["planner-wave-", encode wave, ":continue-with-plan:start"]) in
    if trace0 != "" then
      plannerFailure "manager trace write failed" trace0
    else {
    let mailboxError = refreshMailbox wave in
    if mailboxError != "" then
      plannerFailure "mailbox write failed" mailboxError
    else {
    let validation = validatePlannerReport rawReport in
    let trace1 = appendManagerTrace (textConcat ["planner-wave-", encode wave, ":continue-with-plan:validated"]) in
    if trace1 != "" then
      plannerFailure "manager trace write failed" trace1
    else {
    let report = materializePlannerReport wave rawReport in
    let trace2 = appendManagerTrace (textConcat ["planner-wave-", encode wave, ":continue-with-plan:materialized"]) in
    if trace2 != "" then
      plannerFailure "manager trace write failed" trace2
    else {
    let failureState = managerStateFor "failed" "fail" false "" (plannerTaskIds report) wave benchmarkRuns true in
    let validationWriteError = writePlanValidation validation in
    if validationWriteError != "" then
      finalizeWithReport failureState (syntheticFailureReport "plan validation write failed" validationWriteError)
    else {
      let trace3 = appendManagerTrace (textConcat ["planner-wave-", encode wave, ":continue-with-plan:validation-written"]) in
      if trace3 != "" then
        plannerFailure "manager trace write failed" trace3
      else {
      let plannerState = readManagerState in
      if validation.valid == false then
        if plannerState.phase == "planner-running" then
          if recoverablePlannerValidationFailure validation then
            continueAfterPlannerValidationBlocker "planner validation failed" (planValidationFailureDetail validation)
          else
            finalizeWithReport failureState (planValidationFailureReport validation)
        else
          finalizeWithReport failureState (planValidationFailureReport validation)
      else {
        let plannerCompletionError =
          if plannerState.phase == "planner-running" then
            completePlannerTaskIfNeeded wave
          else
            "" in
        if plannerCompletionError != "" then
          finalizeWithReport failureState (syntheticFailureReport "planner completion failed" plannerCompletionError)
        else {
          let trace4 = appendManagerTrace (textConcat ["planner-wave-", encode wave, ":continue-with-plan:planner-completed"]) in
          if trace4 != "" then
            plannerFailure "manager trace write failed" trace4
          else {
            let plannerInputWriteError = writePlannerInputState (plannerInputStateFor wave benchmarkSummary) in
            if plannerInputWriteError != "" then
              finalizeWithReport failureState (syntheticFailureReport "planner input state write failed" plannerInputWriteError)
            else {
              let trace5 = appendManagerTrace (textConcat ["planner-wave-", encode wave, ":continue-with-plan:planner-input-written"]) in
              if trace5 != "" then
                plannerFailure "manager trace write failed" trace5
              else {
              let ensureTasksError = ensurePlannedTasks report in
              if ensureTasksError != "" then
                finalizeWithReport failureState (syntheticFailureReport "planned task setup failed" ensureTasksError)
              else
                {
                  let trace6 = appendManagerTrace (textConcat ["planner-wave-", encode wave, ":continue-with-plan:tasks-ready"]) in
                  if trace6 != "" then
                    plannerFailure "manager trace write failed" trace6
                  else
                    executeReadyTasks report wave benchmarkRuns
                }
              }
            }
          }
        }
      }
      }
    }
  }
  }
    }
    }
  }
}

continueWithPlan : Str
continueWithPlan = {
  let state = readManagerState in
  continueWithPlanResolved state.wave state.benchmarkRuns latestBenchmarkSummaryText (readPlannerReportForWave state.wave)
}

executeReadyTasks : PlannerReport -> Int -> Int -> Str
executeReadyTasks report wave benchmarkRuns = {
  let plannedIds = plannerTaskIds report in
  let failureState = managerStateFor "failed" "fail" false "" plannedIds wave benchmarkRuns true in
  let mailboxError = refreshMailbox wave in
  if mailboxError != "" then
    finalizeWithReport failureState (syntheticFailureReport "mailbox write failed" mailboxError)
  else
  match tasks swarmStateRoot {
    Err message ->
      finalizeWithReport failureState (syntheticFailureReport "task lookup failed" message),
    Ok rawTaskValues -> {
      let mut objectiveTasks = filter taskInObjective rawTaskValues;
      let mut schedulerError = "";
      let mut runningTaskIds = emptyTexts;
      for spec in report.tasks {
        let taskStatus = taskStatusFor objectiveTasks spec.taskId in
        if childLoopReportReady spec.taskId then {
          let childReport = taskPassReport spec in
          let taskError =
            if childReport.verdict == "pass" then
              if taskStatus == "completed" then
                ""
              else
                completePlannedTask spec
            else if taskStatus == "failed" then
              ""
            else if childLoopMissingDurableReport childReport then
              retryChildLoopMissingReport spec childReport
            else
              recordPlannedTaskFailure spec childReport in
          let mailboxWriteError =
            if taskError != "" then
              ""
            else if taskStatusIsTerminal taskStatus then
              ""
            else
              appendMailboxMessages (taskMailboxMessagesForCompletedSpec wave spec childReport) in
          if taskError != "" then
            {
              schedulerError = taskError;
              schedulerError
            }
          else if mailboxWriteError != "" then
            {
              schedulerError = mailboxWriteError;
              schedulerError
            }
          else
            schedulerError
        } else if childLoopRunning spec.taskId then {
          runningTaskIds = append runningTaskIds [spec.taskId];
          schedulerError
        } else if fileExists (taskProcessHeartbeatPath spec.taskId) then
          if childLoopLaunchRunning spec.taskId then {
            runningTaskIds = append runningTaskIds [spec.taskId];
            schedulerError
          } else if childLoopLaunchCompleted spec.taskId then {
            let settled = settleChildLoopReportReady spec.taskId childReportSettlePolls in
            if settled then
              schedulerError
            else {
              let retryAvailable =
                if taskStatus == "failed" then
                  false
                else
                  childLoopManagerRetryAvailable spec.taskId in
              let taskError =
                if taskStatus == "failed" then
                  ""
                else
                  retryChildLoopMissingReport spec (childLoopMissingReport spec) in
              if taskError != "" then
                {
                  schedulerError = taskError;
                  schedulerError
                }
              else if retryAvailable then {
                runningTaskIds = append runningTaskIds [spec.taskId];
                schedulerError
              }
              else
                schedulerError
            }
          } else {
            let retryAvailable =
              if taskStatus == "failed" then
                false
              else
                childLoopManagerRetryAvailable spec.taskId in
            let taskError =
              if taskStatus == "failed" then
                ""
              else
                retryChildLoopMissingLaunchHeartbeat
                  wave
                  report
                  spec
                  (childLoopMissingLaunchHeartbeatReport spec) in
            if taskError != "" then
              {
                schedulerError = taskError;
                schedulerError
              }
            else if retryAvailable then {
              runningTaskIds = append runningTaskIds [spec.taskId];
              schedulerError
            }
            else
              schedulerError
          }
        else
          schedulerError
      };
      if schedulerError != "" then
        finalizeWithReport failureState (syntheticFailureReport "planned task reconciliation failed" schedulerError)
      else
        match tasks swarmStateRoot {
          Err message ->
            finalizeWithReport failureState (syntheticFailureReport "task refresh failed" message),
          Ok refreshedRawTaskValues ->
            let refreshedTasks = filter taskInObjective refreshedRawTaskValues in
            match ready objectiveRef {
              Err message ->
                finalizeWithReport failureState (syntheticFailureReport "ready queue lookup failed" message),
              Ok readyTasks -> {
                let mut activeTaskIds = runningTaskIds;
                let mut launchSlots = subtractManagerCounters maxConcurrentChildren (length runningTaskIds);
                let mut launchError = "";
                for spec in report.tasks {
                  let taskStatus = taskStatusFor refreshedTasks spec.taskId in
                  if launchError != "" then
                    launchError
                  else if launchSlots == 0 then
                    launchError
                  else if taskStatusIsTerminal taskStatus then
                    launchError
                  else if taskStatus == "leased" then
                    launchError
                  else if taskStatus == "active" then
                    launchError
                  else if textListHas spec.taskId activeTaskIds then
                    launchError
                  else if fileExists (taskProcessHeartbeatPath spec.taskId) then
                    launchError
                  else if childLoopReportReady spec.taskId then
                    launchError
                  else if taskListHasId spec.taskId readyTasks then {
                    let taskError = launchReadyTask wave report spec in
                    if taskError != "" then
                      {
                        launchError = taskError;
                        launchError
                      }
                    else
                      {
                        activeTaskIds = append activeTaskIds [spec.taskId];
                        launchSlots = decrementManagerCounter launchSlots;
                        launchError
                      }
                  } else
                    launchError
                };
                if launchError != "" then
                  finalizeWithReport failureState (syntheticFailureReport "planned task launch failed" launchError)
                else {
                  let runningState =
                    managerStateFor
                      "task-running"
                      "pending"
                      false
                      (firstTextOrEmpty activeTaskIds)
                      plannedIds
                      wave
                      benchmarkRuns
                      false in
                  let stateError = writeManagerState runningState in
                  if stateError != "" then
                    finalizeWithReport failureState (syntheticFailureReport "manager state write failed" stateError)
                  else if length activeTaskIds > 0 then
                    match awaitWatchedProcessTimeout
                      (taskProcessHeartbeatPath (firstTextOrEmpty activeTaskIds))
                      childLoopWatchPollMs
                      taskLeaseTimeoutMs {
                      Err message ->
                        executeReadyTasks report wave benchmarkRuns,
                      Ok process ->
                        executeReadyTasks report wave benchmarkRuns
                    }
                  else
                    match tasks swarmStateRoot {
                      Err message ->
                        finalizeWithReport failureState (syntheticFailureReport "final task refresh failed" message),
                      Ok finalRawTaskValues -> {
                        let finalTasks = filter taskInObjective finalRawTaskValues;
                        let mut readyReportIds = emptyTexts;
                        for spec in report.tasks {
                          let taskStatus = taskStatusFor finalTasks spec.taskId in
                          if taskStatusIsTerminal taskStatus then
                            readyReportIds
                          else if childLoopReportReady spec.taskId then {
                            readyReportIds = append readyReportIds [spec.taskId];
                            readyReportIds
                          } else
                            readyReportIds
                        };
                        if length readyReportIds > 0 then
                          executeReadyTasks report wave benchmarkRuns
                        else {
                        let mut completedIds = emptyTexts;
                        let mut failedIds = emptyTexts;
                        for spec in report.tasks {
                          let taskStatus = taskStatusFor finalTasks spec.taskId in
                          if taskStatus == "completed" then {
                            completedIds = append completedIds [spec.taskId];
                            completedIds
                          } else if taskStatus == "failed" then {
                            failedIds = append failedIds [spec.taskId];
                            failedIds
                          } else
                            completedIds
                        };
                        match ready objectiveRef {
                          Err message ->
                            finalizeWithReport failureState (syntheticFailureReport "final ready queue lookup failed" message),
                          Ok finalReadyTasks -> {
                            let mut readyPlannedIds = emptyTexts;
                            for readyTask in finalReadyTasks {
                              let readyTaskId = taskIdOf readyTask in
                              if textListHas readyTaskId plannedIds then {
                                readyPlannedIds = append readyPlannedIds [readyTaskId];
                                readyPlannedIds
                              } else
                                readyPlannedIds
                            };
                            if length readyPlannedIds > 0 then
                              executeReadyTasks report wave benchmarkRuns
                            else if benchmarkEnabled then
                              runBenchmarkCheckpoint report wave benchmarkRuns
                            else if length completedIds == length report.tasks then
                              finalizeWithReport
                                (managerStateFor "completed" "pass" true "" plannedIds wave benchmarkRuns true)
                                (managerPassReport report)
                            else if length failedIds > 0 then
                              continueAfterPlannedTaskBlocker report wave benchmarkRuns (plannedTaskFailureReport failedIds)
                            else {
                              let mut pendingLaunchIds = emptyTexts;
                              for spec in report.tasks {
                                let taskStatus = taskStatusFor finalTasks spec.taskId in
                                if taskStatusIsTerminal taskStatus then
                                  pendingLaunchIds
                                else if childLoopLaunchPending spec.taskId then {
                                  pendingLaunchIds = append pendingLaunchIds [spec.taskId];
                                  pendingLaunchIds
                                } else
                                  pendingLaunchIds
                              };
                              if length pendingLaunchIds > 0 then
                                match sleepMsValue childLoopWatchPollMs {
                                  Err message ->
                                    finalizeWithReport failureState (syntheticFailureReport "task poll sleep failed" message),
                                  Ok slept ->
                                    executeReadyTasks report wave benchmarkRuns
                                }
                              else
                                continueAfterPlannedTaskBlocker report wave benchmarkRuns (plannedTaskStalledReport report)
                            }
                          }
                        }
                        }
                      }
                    }
                }
              }
            }
        }
    }
  }
}

serviceStatusOutputForRoot : Str -> Str
serviceStatusOutputForRoot root =
  match readServiceStatus root {
    Ok service -> encode service,
    Err message -> textConcat ["error:", message]
  }

serviceStatusOutput : Str
serviceStatusOutput =
  if recordedServiceRoot != "" then
    if fileExists (serviceStatusPath recordedServiceRoot) then
      serviceStatusOutputForRoot recordedServiceRoot
    else if fileExists (serviceStatusPath serviceRoot) then
      serviceStatusOutputForRoot serviceRoot
    else
      "error:missing-service-status"
  else if fileExists (serviceStatusPath serviceRoot) then
    serviceStatusOutputForRoot serviceRoot
  else
    "error:missing-service-status"

managerServiceConfigArgs : [Str]
managerServiceConfigArgs =
  [
    textConcat ["CLASP_MANAGER_READY_PATH_JSON=", encode serviceReadyPath],
    textConcat ["CLASP_MANAGER_READY_TEXT_JSON=", encode managerReadyText],
    textConcat ["CLASP_MANAGER_GOAL_JSON=", encode goalText],
    textConcat ["CLASP_MANAGER_OBJECTIVE_ID_JSON=", encode objectiveId],
    textConcat ["CLASP_MANAGER_PROGRAM_JSON=", encode managerProgramPath],
    textConcat ["CLASP_LOOP_WORKSPACE_JSON=", encode workspaceRoot],
    textConcat ["CLASP_LOOP_CODEX_BIN_JSON=", encode codexBin],
    textConcat ["CLASP_MANAGER_CLASPC_BIN_JSON=", encode resolvedManagerClaspcBin],
    textConcat ["CLASP_MANAGER_XDG_CACHE_HOME_JSON=", encode managerXdgCacheHome],
    textConcat ["XDG_CACHE_HOME=", managerXdgCacheHome],
    textConcat ["CLASP_MANAGER_CHILD_LOOP_JSON=", encode childLoopProgramPath],
    textConcat ["CLASP_MANAGER_PLANNER_SCHEMA_JSON=", encode plannerSchemaPath],
    textConcat ["CLASP_LOOP_CODEX_MODEL_JSON=", encode codexModel],
    textConcat ["CLASP_LOOP_CODEX_REASONING_JSON=", encode codexReasoning],
    textConcat ["CLASP_LOOP_CODEX_SANDBOX_JSON=", encode codexSandbox],
    textConcat ["CLASP_LOOP_WATCH_POLL_MS_JSON=", encode childLoopWatchPollMs],
    textConcat ["CLASP_MANAGER_MAX_TASKS_JSON=", encode maxTaskLoops],
    textConcat ["CLASP_MANAGER_PLANNER_MAX_RUNS_JSON=", encode plannerTaskMaxRuns],
    textConcat ["CLASP_MANAGER_PLANNER_TIMEOUT_MS_JSON=", encode plannerTimeoutMs],
    textConcat ["CLASP_MANAGER_MAX_WAVES_JSON=", encode maxWaves],
    textConcat ["CLASP_MANAGER_OBJECTIVE_MAX_TASKS_JSON=", encode objectiveTaskBudget],
    textConcat ["CLASP_MANAGER_OBJECTIVE_MAX_RUNS_JSON=", encode objectiveRunBudget],
    textConcat ["CLASP_MANAGER_TASK_LEASE_TIMEOUT_JSON=", encode taskLeaseTimeoutMs],
    textConcat ["CLASP_MANAGER_CHILD_MAX_ATTEMPTS_JSON=", encode childMaxAttempts],
    textConcat ["CLASP_MANAGER_MAX_CONCURRENT_CHILDREN_JSON=", encode maxConcurrentChildren],
    textConcat ["CLASP_MANAGER_TASK_WORKSPACE_CACHE_MAX_MB_JSON=", encode taskWorkspaceCacheMaxMb],
    textConcat ["CLASP_MANAGER_TASK_BASELINE_CACHE_MAX_MB_JSON=", encode taskBaselineCacheMaxMb],
    textConcat ["CLASP_MANAGER_FEEDBACK_LOOP_BASELINE_CACHE_MAX_MB_JSON=", encode feedbackLoopBaselineCacheMaxMb],
    textConcat ["CLASP_MANAGER_CHILD_LOOP_BASELINE_CACHE_TOTAL_MAX_MB_JSON=", encode childLoopBaselineCacheTotalMaxMb],
    textConcat ["CLASP_MANAGER_CHILD_LOOP_XDG_CACHE_TOTAL_MAX_MB_JSON=", encode childLoopXdgCacheTotalMaxMb],
    textConcat ["CLASP_MANAGER_ARTIFACTS_CACHE_MAX_MB_JSON=", encode managerArtifactsCacheMaxMb],
    textConcat ["CLASP_MANAGER_XDG_CACHE_MAX_MB_JSON=", encode managerXdgCacheMaxMb],
    textConcat ["CLASP_MANAGER_CHILD_FOCUSED_VERIFY_COMMANDS_JSON=", encode childFocusedVerifyCommands],
    textConcat ["CLASP_MANAGER_CHILD_FULL_VERIFY_COMMAND_JSON=", encode childFullVerifyCommand],
    textConcat ["CLASP_MANAGER_TASK_FAILURE_LOG_TAIL_BYTES_JSON=", encode taskFailureLogTailBytes],
    textConcat ["CLASP_MANAGER_RETAIN_FAILED_TASK_WORKSPACES_JSON=", encode retainFailedTaskWorkspaces],
    textConcat ["CLASP_MANAGER_BENCHMARK_COMMAND_JSON=", encode benchmarkCommand],
    textConcat ["CLASP_MANAGER_BENCHMARK_CWD_JSON=", encode benchmarkCwd],
    textConcat ["CLASP_MANAGER_BENCHMARK_POLL_MS_JSON=", encode benchmarkWatchPollMs],
    textConcat ["CLASP_MANAGER_BENCHMARK_TIMEOUT_MS_JSON=", encode benchmarkTimeoutMs],
    textConcat ["CLASP_MANAGER_SERVICE_ROOT_JSON=", encode serviceRoot],
    textConcat ["CLASP_MANAGER_SERVICE_ID_JSON=", encode serviceId],
    textConcat ["CLASP_MANAGER_SERVICE_RESTART_DELAY_MS_JSON=", encode serviceRestartDelayMs]
  ]

managerServiceCommandArgs : [Str]
managerServiceCommandArgs =
  if currentExecutablePath != "" then
    append
      (append ["env"] managerServiceConfigArgs)
      [currentExecutablePath, stateRootPath]
  else
    append
      (append ["env"] managerServiceConfigArgs)
      [
        resolvedManagerClaspcBin,
        "run",
        resolvedManagerProgramPath,
        "--",
        stateRootPath
      ]

managedServiceSupervisorSpec : ServiceSupervisorSpec
managedServiceSupervisorSpec =
  serviceSupervisorSpec
    managerProjectRoot
    serviceRoot
    serviceId
    serviceReadyPath
    managerReadyText
    childLoopWatchPollMs
    upgradeReadyPollMs
    upgradeReadyTimeoutMs
    serviceRestartDelayMs
    managerServiceCommandArgs

recoverManagedService : ServiceStatus -> Str
recoverManagedService service = {
  let state = readManagerState in
  if state.final then
    statusOutput
  else if state.phase == "completed" then
    statusOutput
  else if state.phase == "failed" then
    statusOutput
  else if service.status == "completed" then
    resumeManager
  else {
    let traceRecovery =
      appendManagerTrace
        (textConcat
          [
            "service-final-before-manager-final:status=",
            service.status,
            ":wave=",
            encode state.wave,
            ":benchmark-runs=",
            encode state.benchmarkRuns
          ]) in
    if traceRecovery != "" then
      textConcat ["error:", traceRecovery]
    else
      runManagedServiceBootstrap
  }
}

waitForManagedServiceCompletion : Str
waitForManagedServiceCompletion = {
  let state = readManagerState in
  if state.final then
    statusOutput
  else if state.phase == "completed" then
    statusOutput
  else if state.phase == "failed" then
    statusOutput
  else
    match readServiceStatus serviceRoot {
      Ok service ->
        if service.status == "completed" then
          recoverManagedService service
        else if service.status == "failed" then
          recoverManagedService service
        else
          match sleepMsValue childLoopWatchPollMs {
            Err message -> textConcat ["error:", message],
            Ok slept -> waitForManagedServiceCompletion
          },
      Err message ->
        match sleepMsValue childLoopWatchPollMs {
          Err sleepMessage -> textConcat ["error:", sleepMessage],
          Ok slept -> waitForManagedServiceCompletion
        }
    }
}

runManagedServiceBootstrap : Str
runManagedServiceBootstrap =
  match superviseService managedServiceSupervisorSpec {
    Ok service ->
      if service.status == "completed" then
        recoverManagedService service
      else if service.status == "failed" then
        recoverManagedService service
      else
        waitForManagedServiceCompletion,
    Err message -> textConcat ["error:", message]
  }

runManagedServiceResume : Str
runManagedServiceResume = {
  let prepError = ensureManagerReady in
  if prepError != "" then
    textConcat ["error:", prepError]
  else {
    let traceResume = appendManagerTrace "service-resume:start" in
    if traceResume != "" then
      textConcat ["error:", traceResume]
    else
      resumeManager
  }
}

runManagerUpgrade : Str
runManagerUpgrade = {
  let prepError = ensureManagerReady in
  if prepError != "" then
    prepError
  else if textJoin "" upgradeCommandList == "" then
    "error:missing-upgrade-command"
  else if serviceRoot == "" then
    "error:missing-service-root"
  else if serviceId == "" then
    "error:missing-service-id"
  else if upgradeReadyPath == "" then
    "error:missing-upgrade-ready-path"
  else
    match
      upgradeService (
        serviceUpgradeSpec
          "."
          serviceRoot
          serviceId
          (encode currentUpgradeSnapshot)
          upgradeReadyPath
          upgradeReadyContains
          childLoopWatchPollMs
          upgradeReadyPollMs
          upgradeReadyTimeoutMs
          upgradeCommitGraceMs
          upgradeCommandList
      )
    {
      Ok transaction -> encode transaction,
      Err message -> textConcat ["error:", message]
    }
}

statusOutput : Str
statusOutput = encode (statusView readManagerState)

continueManagedResume : Str -> Str
continueManagedResume result = {
  let state = readManagerState in
  if state.final then
    statusOutput
  else if state.phase == "completed" then
    statusOutput
  else if state.phase == "failed" then
    statusOutput
  else if state.phase == "needs-planner" then
    resumeManager
  else
    result
}

resumeManagerOnce : Str
resumeManagerOnce = {
  let state = readManagerState in
  let traceState =
    appendManagerTrace
      (textConcat
        ["resume-manager:phase=", state.phase, ":wave=", encode state.wave, ":benchmark-runs=", encode state.benchmarkRuns]) in
  if traceState != "" then
    textConcat ["error:", traceState]
  else if state.final then
    if recoverableFinalPlannerLeaseState state then
      continueAfterPlannerLeaseBlocker "planner lease failed" "recovering final failed planner lease state"
    else if recoverableFinalPlannerTransportState state then
      continueAfterPlannerTransportBlocker readFeedbackSummary (recoverableFinalPlannerTransportDetail state)
    else
      statusOutput
  else if state.phase == "completed" then
    statusOutput
  else if state.phase == "failed" then
    statusOutput
  else if state.phase == "task-running" then
    resumeCurrentWave state
  else if state.phase == "benchmark-running" then
    resumeBenchmarkCheckpoint state.wave state.benchmarkRuns
  else if state.phase == "planner-running" then
    resumePlannerWave state
  else if state.phase == "needs-planner" then
    if plannerReportReusableFor state.wave latestBenchmarkSummaryText then
      continueWithPlan
    else
      runPlanner
  else if length state.plannedTaskIds > 0 then
    resumeCurrentWave state
  else if plannerReportReusableFor state.wave latestBenchmarkSummaryText then
    continueWithPlan
  else
    runPlanner
}

resumeManager : Str
resumeManager = continueManagedResume resumeManagerOnce

main : Str
main =
  if commandName == "status" then
    statusOutput
  else if commandName == "service-status" then
    serviceStatusOutput
  else if commandName == "upgrade" then
    runManagerUpgrade
  else if runningUnderServiceSupervisor == false then
    runManagedServiceBootstrap
  else
    runManagedServiceResume
