addManagerCounters : Int -> Int -> Int
addManagerCounters left right =
  if right == 0 then
    left
  else
    addManagerCounters (incrementManagerCounter left) (decrementManagerCounter right)

subtractManagerCounters : Int -> Int -> Int
subtractManagerCounters left right =
  if right == 0 then
    left
  else if left == 0 then
    0
  else
    subtractManagerCounters (decrementManagerCounter left) (decrementManagerCounter right)

repeatAdd : Int -> Int -> Int
repeatAdd count amount =
  if count == 0 then
    0
  else
    addManagerCounters amount (repeatAdd (decrementManagerCounter count) amount)

validatePlannerReport : PlannerReport -> PlanValidationResult
validatePlannerReport report = {
  let requiredTaskBudget =
    if benchmarkEnabled then
      repeatAdd maxWaves (incrementManagerCounter maxTaskLoops)
    else
      incrementManagerCounter (length report.tasks) in
  let requiredRunBudget =
    if benchmarkEnabled then
      repeatAdd maxWaves (incrementManagerCounter maxTaskLoops)
    else
      incrementManagerCounter (length report.tasks) in
  let structuralState =
    fold
      planValidationFoldStep
      (PlanValidationFoldState {
        issues = emptyPlanValidationIssues,
        seenTaskIds = emptyTexts,
        knownTaskIds = plannerTaskIds report
      })
      report.tasks in
  let issues0 = structuralState.issues in
  let issues1 =
    if length report.tasks == 0 then
      appendPlanValidationIssue issues0 "empty-plan" "" "Planner produced zero tasks."
    else
      issues0 in
  let issues2 =
    if length report.tasks > maxTaskLoops then
      appendPlanValidationIssue
        issues1
        "planned-task-budget"
        ""
        (textConcat [
          "Planner produced ",
          encode (length report.tasks),
          " planned tasks but CLASP_MANAGER_MAX_TASKS_JSON allows only ",
          encode maxTaskLoops,
          " planned tasks."
        ])
    else
      issues1 in
  let issues3 =
    if objectiveTaskBudget < requiredTaskBudget then
      appendPlanValidationIssue
        issues2
        "objective-task-budget"
        ""
        (textConcat [
          "Objective task budget must allow at least ",
          encode requiredTaskBudget,
          " total tasks for the configured planner/task waves."
        ])
    else
      issues2 in
  let issues4 =
    if objectiveRunBudget < requiredRunBudget then
      appendPlanValidationIssue
        issues3
        "objective-run-budget"
        ""
        (textConcat [
          "Objective run budget must allow at least ",
          encode requiredRunBudget,
          " total runs for the configured planner/task waves."
        ])
    else
      issues3 in
  let cycleIssues =
    if length issues4 == 0 then
      cycleBlockedTaskIds report.tasks emptyTexts
    else
      emptyTexts in
  let issues5 =
    if length cycleIssues == 0 then
      issues4
    else
      appendPlanValidationIssue
        issues4
        "dependency-cycle"
        ""
        (textConcat [
          "Planner task dependencies are cyclic or otherwise impossible to resolve: ",
          textJoin ", " cycleIssues
        ]) in
  PlanValidationResult {
    valid = length issues5 == 0,
    issues = issues5,
    plannedTaskCount = length report.tasks,
    plannerTaskLimit = maxTaskLoops,
    objectiveTaskBudget = objectiveTaskBudget,
    objectiveRunBudget = objectiveRunBudget,
    cycleBlockedTaskIds = cycleIssues
  }
}

pickReadyTask : PlannerTaskPick -> PlannerTaskSpec -> PlannerTaskPick
pickReadyTask state spec =
  if state.found then
    state
  else if taskListHasId spec.taskId state.readyTasks then
    PlannerTaskPick {
      readyTasks = state.readyTasks,
      found = true,
      spec = spec
    }
  else
    state

findReadyTask : [PlannerTaskSpec] -> [SwarmTask] -> PlannerTaskPick
findReadyTask specs readyTasks =
  fold
    pickReadyTask
    (PlannerTaskPick {
      readyTasks = readyTasks,
      found = false,
      spec = emptyPlannerTaskSpec
    })
    specs

ensurePolicyFile : Str -> Str -> Str
ensurePolicyFile path contents =
  if fileExists path then
    ""
  else
    match writeFile path contents {
      Ok written -> "",
      Err message -> message
    }

ensureProjectRootRecord : Str
ensureProjectRootRecord =
  if recordedProjectRoot != "" then
    ""
  else
    match writeFile projectRootRecordPath managerProjectRoot {
      Ok written -> "",
      Err message -> message
    }

signalManagerReady : Str
signalManagerReady =
  if managerReadyPath == "" then
    ""
  else
    match writeFile managerReadyPath managerReadyText {
      Ok written -> "",
      Err message -> message
    }

ensureManagerReady : Str
ensureManagerReady =
  if workspaceRoot == "" then
    "config-error:missing-workspace-root"
  else if maxConcurrentChildren < 1 then
    "config-error:max-concurrent-children-must-be-positive"
  else if benchmarkEnabled then
    if maxWaves < 1 then
      "config-error:benchmark-max-waves-must-be-positive"
    else if benchmarkCwd == "" then
      "config-error:missing-benchmark-cwd"
    else
      match mkdirAll stateRootPath {
        Ok created ->
          let restoreError = restoreManagerSnapshotIfNeeded in
          if restoreError != "" then
            restoreError
          else
            let projectRootError = ensureProjectRootRecord in
            if projectRootError != "" then
              textConcat ["project-root-error:", projectRootError]
            else
              match mkdirAll workspaceRoot {
                Ok workspaceCreated ->
                  let policyError = ensurePolicyFile plannerPolicyPath defaultPlannerPolicyText in
                  if policyError != "" then
                    policyError
                  else
                    signalManagerReady,
                Err message ->
                  textConcat ["workspace-root-error:", message]
              },
        Err message ->
          textConcat ["state-root-error:", message]
      }
  else
    match mkdirAll stateRootPath {
      Ok created ->
        let restoreError = restoreManagerSnapshotIfNeeded in
        if restoreError != "" then
          restoreError
        else
          let projectRootError = ensureProjectRootRecord in
          if projectRootError != "" then
            textConcat ["project-root-error:", projectRootError]
          else
            match mkdirAll workspaceRoot {
              Ok workspaceCreated ->
                let policyError = ensurePolicyFile plannerPolicyPath defaultPlannerPolicyText in
                if policyError != "" then
                  policyError
                else
                  signalManagerReady,
              Err message ->
                textConcat ["workspace-root-error:", message]
            },
      Err message ->
        textConcat ["state-root-error:", message]
    }

codexCommand : Str -> Str -> Str -> [Str]
codexCommand schemaPath reportPath prompt = [
  codexBin,
  "exec",
  "--json",
  "--cd",
  workspaceRoot,
  "-m",
  codexModel,
  "-c",
  codexReasoningConfig,
  "--skip-git-repo-check",
  "--sandbox",
  codexSandbox,
  "--ephemeral",
  "--output-schema",
  schemaPath,
  "-o",
  reportPath,
  prompt
]

plannerBenchmarkContextFor : Int -> Str -> Str
plannerBenchmarkContextFor wave benchmarkSummary =
  if benchmarkEnabled then
    if benchmarkSummary == "" then
      textJoin "\n" [
        "Benchmark target is enabled for this manager.",
        textConcat ["Current wave: ", encode wave, " of ", encode maxWaves],
        "No benchmark checkpoint exists yet. Plan the first bounded wave toward beating the benchmark target."
      ]
    else
      textJoin "\n" [
        "Benchmark target is enabled for this manager.",
        textConcat ["Current wave: ", encode wave, " of ", encode maxWaves],
        textConcat ["Latest benchmark summary: ", benchmarkSummary],
        "If the target is still unmet, plan the next bounded wave specifically to improve the benchmark."
      ]
  else
    textConcat ["Current wave: ", encode wave, " of ", encode maxWaves]

plannerPromptFor : Int -> Str -> Str
plannerPromptFor wave benchmarkSummary = textJoin "\n" [
  "You are the planner subagent for the Clasp repository.",
  "Read AGENTS.md first if it exists.",
  "Plan the next bounded tasks needed to improve Clasp autonomously.",
  plannerBenchmarkContextFor wave benchmarkSummary,
  "High-level goal:",
  goalText,
  "Current planner policy:",
  plannerPolicyText,
  "Current shared swarm mailbox context:",
  mailboxSummaryText wave,
  "Do not assume a fixed role taxonomy beyond the minimal substrate already present. Let coordination patterns emerge from the work and the shared mailbox.",
  "Return JSON matching the planner schema.",
  "Plan 1-3 bounded tasks with explicit dependencies and task prompts."
]

plannerCommandFor : Int -> Str -> SwarmCommand
plannerCommandFor wave benchmarkSummary =
  commandSpec managerProjectRoot (codexCommand resolvedPlannerSchemaPath (plannerReportPathFor wave) (plannerPromptFor wave benchmarkSummary))

ensureObjective : Str
ensureObjective = match objectives swarmStateRoot {
  Ok objectiveValues ->
    if textListHas objectiveId (map objectiveIdOf objectiveValues) then
      ""
    else
      match objectiveCreate swarmStateRoot objectiveId goalText objectiveTaskBudget objectiveRunBudget {
        Ok created -> "",
        Err message -> message
      },
  Err message ->
    match objectiveCreate swarmStateRoot objectiveId goalText objectiveTaskBudget objectiveRunBudget {
      Ok created -> "",
      Err createMessage -> createMessage
    }
}

ensureTask : Str -> Str -> [Str] -> Str
ensureTask taskId detail dependencies = match tasks swarmStateRoot {
  Ok taskValues ->
    if taskListHasId taskId taskValues then
      ""
    else
      match taskCreate objectiveRef taskId detail dependencies 1 taskLeaseTimeoutMs {
        Ok created -> "",
        Err message -> message
      },
  Err message ->
    match taskCreate objectiveRef taskId detail dependencies 1 taskLeaseTimeoutMs {
      Ok created -> "",
      Err createMessage -> createMessage
    }
}

ensurePlannerTaskFor : Int -> Str
ensurePlannerTaskFor wave =
  ensureTask
    (plannerTaskIdForWave wave)
    (textConcat ["Plan bounded task DAG wave ", encode wave, " for the high-level objective."])
    emptyTexts

ensurePlannedTaskStep : EnsurePlanState -> PlannerTaskSpec -> EnsurePlanState
ensurePlannedTaskStep state spec =
  if state.error != "" then
    state
  else {
    let taskError = ensureTask spec.taskId spec.detail spec.dependencies in
    if taskError != "" then
      EnsurePlanState { error = taskError }
    else {
      let policyError = match policySet (taskHandleFor spec.taskId) "trunk" ["merge-ready"] emptyTexts {
        Ok policyValue -> "",
        Err message -> message
      } in
      EnsurePlanState { error = policyError }
    }
  }

ensurePlannedTasks : PlannerReport -> Str
ensurePlannedTasks report =
  (fold ensurePlannedTaskStep (EnsurePlanState { error = "" }) report.tasks).error

plannerTaskCountError : PlannerReport -> Str
plannerTaskCountError report =
  if length report.tasks > maxTaskLoops then
    textConcat [
      "planner produced ",
      encode (length report.tasks),
      " planned tasks but CLASP_MANAGER_MAX_TASKS_JSON allows only ",
      encode maxTaskLoops,
      " planned tasks."
    ]
  else
    ""

taskPromptText : Int -> PlannerTaskSpec -> Str
taskPromptText wave spec = textJoin "\n" [
  "# Clasp Task",
  "",
  "High-level goal:",
  goalText,
  "",
  textConcat ["Task ID: ", spec.taskId],
  textConcat ["Detail: ", spec.detail],
  "",
  "Planner instruction:",
  spec.taskPrompt,
  "",
  "Shared swarm mailbox context:",
  mailboxSummaryText wave,
  "",
  textConcat ["Shared swarm mailbox path: ", mailboxPath],
  "Use the shared mailbox context as durable coordination memory. Do not assume any special fixed swarm role beyond what the current work requires.",
  "",
  "Complete this task in the current checkout. Keep the slice bounded, update tests, and let the child verifier decide pass/fail."
]

writeTaskPromptFile : Int -> PlannerTaskSpec -> Str
writeTaskPromptFile wave spec = match writeFile (taskPromptPath spec.taskId) (taskPromptText wave spec) {
  Ok written -> "",
  Err message -> message
}

childLoopCommandArgs : PlannerTaskSpec -> [Str]
childLoopCommandArgs spec =
  [
    "env",
    "-u",
    "CLASP_RT_UPGRADE_SNAPSHOT_PATH_JSON",
    "-u",
    "CLASP_RT_UPGRADE_SERVICE_ROOT_JSON",
    "-u",
    "CLASP_RT_UPGRADE_SERVICE_ID_JSON",
    "-u",
    "CLASP_RT_UPGRADE_TRANSACTION_PATH_JSON",
    "-u",
    "CLASP_RT_UPGRADE_GENERATION_JSON",
    textConcat ["CLASP_LOOP_CODEX_BIN_JSON=", encode codexBin],
    textConcat ["CLASP_LOOP_TASK_FILE_JSON=", encode (taskPromptPath spec.taskId)],
    textConcat ["CLASP_LOOP_WORKSPACE_JSON=", encode (taskWorkspaceRoot spec.taskId)],
    textConcat ["CLASP_LOOP_MAX_ATTEMPTS_JSON=", encode childMaxAttempts],
    textConcat ["CLASP_LOOP_WATCH_POLL_MS_JSON=", encode childLoopWatchPollMs],
    textConcat ["CLASP_MANAGER_PROJECT_ROOT_JSON=", encode managerProjectRoot],
    managerClaspcBin,
    "run",
    resolvedChildLoopProgramPath,
    "--",
    taskReportStateRoot spec.taskId
  ]

childLoopCommand : PlannerTaskSpec -> SwarmCommand
childLoopCommand spec = commandSpec managerProjectRoot (childLoopCommandArgs spec)

taskLaunchRecordCommand : PlannerTaskSpec -> SwarmCommand
taskLaunchRecordCommand spec =
  commandSpec "." [
    "bash",
    "-lc",
    textConcat ["printf launched-child-loop:", spec.taskId]
  ]

taskPassReport : PlannerTaskSpec -> VerifierReport
taskPassReport spec = readVerifierReportPath (taskFeedbackPath spec.taskId)

managerPassReport : PlannerReport -> VerifierReport
managerPassReport report =
  VerifierReport {
    verdict = "pass",
    summary =
      if benchmarkEnabled then
        if latestBenchmarkSummaryText == "" then
          textConcat ["goal manager completed: ", report.objectiveSummary]
        else
          textConcat ["goal manager completed: ", report.objectiveSummary, " / ", latestBenchmarkSummaryText]
      else
        textConcat ["goal manager completed: ", report.objectiveSummary],
    findings = emptyTexts,
    tests_run = report.testsRun,
    follow_up = report.residualRisks,
    capability_statuses = emptyCapabilityStatuses
  }

managerStateFor : Str -> Str -> Bool -> Str -> [Str] -> Int -> Int -> Bool -> ManagerState
managerStateFor phase verdict completed activeTaskId plannedTaskIds wave benchmarkRuns final =
  ManagerState {
    phase = phase,
    verdict = verdict,
    completed = completed,
    objectiveId = objectiveId,
    plannerTaskId = plannerTaskIdForWave wave,
    activeTaskId = activeTaskId,
    plannedTaskIds = plannedTaskIds,
    wave = wave,
    benchmarkRuns = benchmarkRuns,
    final = final
  }

benchmarkFailureReport : BenchmarkCheckpoint -> VerifierReport
benchmarkFailureReport checkpoint =
  VerifierReport {
    verdict = "fail",
    summary = "benchmark target not met",
    findings = [checkpoint.summary],
    tests_run = [textConcat ["benchmark:", checkpoint.suite]],
    follow_up = [
      textConcat [
        "Improve ",
        checkpoint.scoreName,
        " from ",
        encode checkpoint.scoreValue,
        " to at most ",
        encode checkpoint.targetValue,
        "."
      ]
    ],
    capability_statuses = emptyCapabilityStatuses
  }

plannerSummaryOrEmpty : Int -> Str
plannerSummaryOrEmpty wave = match readPlannerReportForWave wave {
  Ok report -> report.objectiveSummary,
  Err message -> ""
}

statusView : ManagerState -> StatusView
statusView state =
  let activeTaskIds =
    if length state.plannedTaskIds == 0 then
      emptyTexts
    else {
      let mut runningIds = emptyTexts;
      for taskId in state.plannedTaskIds {
        if childLoopRunning taskId then {
          runningIds = append runningIds [taskId];
          runningIds
        } else
          runningIds
      };
      runningIds
    } in
  match tasks swarmStateRoot {
    Ok taskValues ->
      let objectiveTasks = filter taskInObjective taskValues in
      let readyTaskIds = match ready objectiveRef {
        Ok readyTasks -> map taskIdOf readyTasks,
        Err message -> emptyTexts
      } in
      let objectiveProjectedStatus =
        match objectiveStatus objectiveRef {
          Ok objectiveValue -> objectiveValue.projectedStatus,
          Err message -> textConcat ["objective-error:", message]
        } in
      StatusView {
        state = state,
        plannerSummary = plannerSummaryOrEmpty state.wave,
        objectiveProjectedStatus = objectiveProjectedStatus,
        plannedTaskIds =
          match readPlannerReportForWave state.wave {
            Ok report -> plannerTaskIds report,
            Err message -> state.plannedTaskIds
          },
        allTaskIds = map taskIdOf objectiveTasks,
        readyTaskIds = readyTaskIds,
        activeTaskIds = activeTaskIds,
        completedTaskIds = map taskIdOf (filter taskCompleted objectiveTasks),
        failedTaskIds = map taskIdOf (filter taskFailed objectiveTasks),
        benchmarkSummary = latestBenchmarkSummaryText,
        benchmarkTargetMet = latestBenchmarkTargetMet,
        feedbackSummary = readFeedbackSummary
      },
    Err message ->
      StatusView {
        state = state,
        plannerSummary = plannerSummaryOrEmpty state.wave,
        objectiveProjectedStatus = textConcat ["task-error:", message],
        plannedTaskIds = state.plannedTaskIds,
        allTaskIds = emptyTexts,
        readyTaskIds = emptyTexts,
        activeTaskIds = activeTaskIds,
        completedTaskIds = emptyTexts,
        failedTaskIds = emptyTexts,
        benchmarkSummary = latestBenchmarkSummaryText,
        benchmarkTargetMet = latestBenchmarkTargetMet,
        feedbackSummary = readFeedbackSummary
      }
  }

finalizeWithReport : ManagerState -> VerifierReport -> Str
finalizeWithReport state report = {
  let feedbackError = writeFeedback report in
  if feedbackError != "" then
    textConcat ["feedback-error:", feedbackError]
  else {
    let stateError = writeManagerState state in
    if stateError != "" then
      textConcat ["state-error:", stateError]
    else
      encode (statusView state)
  }
}

checkpointFromSignal : Int -> BenchmarkSignal -> BenchmarkCheckpoint
checkpointFromSignal wave signal =
  BenchmarkCheckpoint {
    wave = wave,
    suite = signal.suite,
    summary = signal.summary,
    passed = signal.passed,
    meetsTarget = signal.meetsTarget,
    scoreName = signal.scoreName,
    scoreValue = signal.scoreValue,
    targetName = signal.targetName,
    targetValue = signal.targetValue,
    command = benchmarkCommand
  }

plannerFailure : Str -> Str -> Str
plannerFailure summary detail = {
  let state = readManagerState in
  finalizeWithReport
    (managerStateFor "failed" "fail" false (plannerTaskIdForWave state.wave) emptyTexts state.wave state.benchmarkRuns true)
    (syntheticFailureReport summary detail)
}

runBenchmarkCheckpoint : PlannerReport -> Int -> Int -> Str
runBenchmarkCheckpoint report wave benchmarkRuns = {
  let benchmarkState =
    managerStateFor
      "benchmark-running"
      "pending"
      false
      ""
      (plannerTaskIds report)
      wave
      benchmarkRuns
      false in
  let stateError = writeManagerState benchmarkState in
  if stateError != "" then
    finalizeWithReport
      (managerStateFor "failed" "fail" false "" (plannerTaskIds report) wave benchmarkRuns true)
      (syntheticFailureReport "benchmark state write failed" stateError)
  else {
    let trace0 = appendManagerTrace (textConcat ["benchmark-wave-", encode wave, ":start"]) in
    if trace0 != "" then
      finalizeWithReport
        (managerStateFor "failed" "fail" false "" (plannerTaskIds report) wave benchmarkRuns true)
        (syntheticFailureReport "benchmark trace write failed" trace0)
    else
    match runBenchmarkCommand wave benchmarkRuns {
      Err message ->
        if message == "timeout" then
          finalizeWithReport
            (managerStateFor "failed" "fail" false "" (plannerTaskIds report) wave benchmarkRuns true)
            (syntheticFailureReport
              "benchmark command timed out"
              (textConcat
                ["Benchmark command exceeded ", encode benchmarkTimeoutMs, "ms. See ", benchmarkHeartbeatPathFor wave, " and ", benchmarkStderrPathFor wave, "."]))
        else
          finalizeWithReport
            (managerStateFor "failed" "fail" false "" (plannerTaskIds report) wave benchmarkRuns true)
            (syntheticFailureReport "benchmark command failed to start" message),
      Ok process -> {
        let trace1 = appendManagerTrace (textConcat ["benchmark-wave-", encode wave, ":command-finished"]) in
        if trace1 != "" then
          finalizeWithReport
            (managerStateFor "failed" "fail" false "" (plannerTaskIds report) wave benchmarkRuns true)
            (syntheticFailureReport "benchmark trace write failed" trace1)
        else
        if process.exitCode != 0 then
          finalizeWithReport
            (managerStateFor "failed" "fail" false "" (plannerTaskIds report) wave benchmarkRuns true)
            (syntheticFailureReport "benchmark command failed" process.stderr)
        else {
          let signal = decode BenchmarkSignal process.stdout in
          let trace2 = appendManagerTrace (textConcat ["benchmark-wave-", encode wave, ":decoded-signal"]) in
          if trace2 != "" then
            finalizeWithReport
              (managerStateFor "failed" "fail" false "" (plannerTaskIds report) wave benchmarkRuns true)
              (syntheticFailureReport "benchmark trace write failed" trace2)
          else {
          let checkpoint = checkpointFromSignal wave signal in
          let trace3 = appendManagerTrace (textConcat ["benchmark-wave-", encode wave, ":checkpoint-created"]) in
          if trace3 != "" then
            finalizeWithReport
              (managerStateFor "failed" "fail" false "" (plannerTaskIds report) wave benchmarkRuns true)
              (syntheticFailureReport "benchmark trace write failed" trace3)
          else {
          let checkpointWriteError = writeBenchmarkCheckpoint checkpoint in
          if checkpointWriteError != "" then
            finalizeWithReport
              (managerStateFor "failed" "fail" false "" (plannerTaskIds report) wave benchmarkRuns true)
              (syntheticFailureReport "benchmark checkpoint write failed" checkpointWriteError)
          else {
            let mailboxError = refreshMailbox wave in
            if mailboxError != "" then
              finalizeWithReport
                (managerStateFor "failed" "fail" false "" (plannerTaskIds report) wave benchmarkRuns true)
                (syntheticFailureReport "mailbox write failed" mailboxError)
            else {
            let trace4 = appendManagerTrace (textConcat ["benchmark-wave-", encode wave, ":checkpoint-written"]) in
            if trace4 != "" then
              finalizeWithReport
                (managerStateFor "failed" "fail" false "" (plannerTaskIds report) wave benchmarkRuns true)
                (syntheticFailureReport "benchmark trace write failed" trace4)
            else {
            let nextBenchmarkRuns = incrementManagerCounter benchmarkRuns in
            if signal.meetsTarget then
              finalizeWithReport
                (managerStateFor "completed" "pass" true "" (plannerTaskIds report) wave nextBenchmarkRuns true)
                (managerPassReport report)
            else if wave < maxWaves then {
              let nextWave = incrementManagerCounter wave in
              let nextState = managerStateFor "needs-planner" "pending" false "" emptyTexts nextWave nextBenchmarkRuns false in
              let nextStateError = writeManagerState nextState in
              if nextStateError != "" then
                finalizeWithReport
                  (managerStateFor "failed" "fail" false "" (plannerTaskIds report) wave nextBenchmarkRuns true)
                  (syntheticFailureReport "benchmark replan state write failed" nextStateError)
              else
                runPlanner
            }
              else
                finalizeWithReport
                  (managerStateFor "failed" "fail" false "" (plannerTaskIds report) wave nextBenchmarkRuns true)
                  (benchmarkFailureReport checkpoint)
            }
            }
            }
          }
          }
          }
        }
      }
    }
  }
}

runPlanner : Str
runPlanner = {
  let state = readManagerState in
  let wave = state.wave in
  let benchmarkSummary = latestBenchmarkSummaryText in
  let reusablePlannerReport = plannerReportReusableFor wave benchmarkSummary in
  let prepError = ensureManagerReady in
  if prepError != "" then
    plannerFailure "manager setup failed" prepError
  else {
    let objectiveError = ensureObjective in
    if objectiveError != "" then
      plannerFailure "objective creation failed" objectiveError
    else {
      let plannerTaskError = ensurePlannerTaskFor wave in
      if plannerTaskError != "" then
        plannerFailure "planner task creation failed" plannerTaskError
      else {
        let plannerState =
          managerStateFor "planner-running" "pending" false (plannerTaskIdForWave wave) emptyTexts wave state.benchmarkRuns false in
        let stateError = writeManagerState plannerState in
        if stateError != "" then
          plannerFailure "planner state write failed" stateError
        else if reusablePlannerReport then
          {
            let traceError = appendManagerTrace (textConcat ["planner-wave-", encode wave, ":reuse-existing-report"]) in
            if traceError != "" then
              plannerFailure "manager trace write failed" traceError
            else
              continueWithPlan
          }
        else
          match lease (plannerHandleForWave wave) {
            Err message ->
              plannerFailure "planner lease failed" message,
            Ok leaseValue ->
              match toolRun (plannerHandleForWave wave) (plannerCommandFor wave benchmarkSummary) {
                Err message ->
                  plannerFailure "planner run failed" message,
                Ok runValue ->
                  if fileExists (plannerReportPathFor wave) then
                    match complete (plannerHandleForWave wave) {
                      Err message ->
                        plannerFailure "planner completion failed" message,
                      Ok completedValue -> {
                        let traceError = appendManagerTrace (textConcat ["planner-wave-", encode wave, ":completed-report-ready"]) in
                        if traceError != "" then
                          plannerFailure "manager trace write failed" traceError
                        else
                          continueWithPlan
                      }
                    }
                  else {
                    let failed = fail (plannerHandleForWave wave) in
                    plannerFailure "planner step failed before producing a durable report" runValue.stderrArtifactPath
                  }
              }
          }
      }
    }
  }
}

plannedTaskFailureReport : [Str] -> VerifierReport
plannedTaskFailureReport failedTaskIds =
  syntheticFailureReport
    "one or more planned tasks failed"
    (textConcat ["Failed planned tasks: ", textJoin ", " failedTaskIds])

plannedTaskStalledReport : PlannerReport -> VerifierReport
plannedTaskStalledReport report =
  syntheticFailureReport
    "planned task execution stalled"
    (textConcat ["No running or ready planned task remained for ", report.objectiveSummary, "."])

childLoopMissingReport : PlannerTaskSpec -> VerifierReport
childLoopMissingReport spec =
  syntheticFailureReport
    "task child loop finished without a durable report"
    (readProcessOutputText (taskProcessStderrPath spec.taskId))

completePlannedTask : PlannerTaskSpec -> Str
completePlannedTask spec =
  match complete (taskHandleFor spec.taskId) {
    Err message ->
      textConcat ["task completion failed: ", spec.taskId, ": ", message],
    Ok completedValue ->
      match approveAndMerge (taskHandleFor spec.taskId) "merge-ready" "trunk" emptyTexts mailboxLimit {
        Err message ->
          textConcat ["task review failed: ", spec.taskId, ": ", message],
        Ok reviewValue ->
          ""
      }
  }

recordPlannedTaskFailure : PlannerTaskSpec -> VerifierReport -> Str
recordPlannedTaskFailure spec report = {
  let feedbackError = writeTaskFeedback spec.taskId report in
  if feedbackError != "" then
    textConcat ["task feedback write failed: ", spec.taskId, ": ", feedbackError]
  else
    match fail (taskHandleFor spec.taskId) {
      Err message ->
        textConcat ["task failure recording failed: ", spec.taskId, ": ", message],
      Ok failedValue ->
        ""
    }
}

launchReadyTask : Int -> PlannerTaskSpec -> Str
launchReadyTask wave spec = {
  let promptError = writeTaskPromptFile wave spec in
  if promptError != "" then
    textConcat ["task prompt write failed: ", spec.taskId, ": ", promptError]
  else {
    let workspaceError = ensureTaskWorkspace spec.taskId in
    if workspaceError != "" then
      textConcat ["task workspace setup failed: ", spec.taskId, ": ", workspaceError]
    else
      match lease (taskHandleFor spec.taskId) {
        Err message ->
          recordPlannedTaskFailure spec (syntheticFailureReport "task lease failed" message),
        Ok leaseValue ->
          match toolRun (taskHandleFor spec.taskId) (taskLaunchRecordCommand spec) {
            Err message ->
              recordPlannedTaskFailure spec (syntheticFailureReport "task launch run failed" message),
            Ok runValue ->
              match launchChildLoop spec {
                Err message ->
                  recordPlannedTaskFailure spec (syntheticFailureReport "task child loop failed to start" message),
                Ok launched ->
                  ""
              }
          }
      }
  }
}

launchChildLoop : PlannerTaskSpec -> Result WatchedProcess
launchChildLoop spec =
  spawnWatchedProcess
    managerProjectRoot
    (taskProcessStdoutPath spec.taskId)
    (taskProcessStderrPath spec.taskId)
    (taskProcessHeartbeatPath spec.taskId)
    childLoopWatchPollMs
    (childLoopCommandArgs spec)

continueWithPlanResolved : Int -> Int -> Str -> Result PlannerReport -> Str
continueWithPlanResolved wave benchmarkRuns benchmarkSummary reportResult =
  match reportResult {
  Err message ->
    plannerFailure "planner report decode failed" message,
  Ok rawReport -> {
    let trace0 = appendManagerTrace (textConcat ["planner-wave-", encode wave, ":continue-with-plan:start"]) in
    if trace0 != "" then
      plannerFailure "manager trace write failed" trace0
    else {
    let mailboxError = refreshMailbox wave in
    if mailboxError != "" then
      plannerFailure "mailbox write failed" mailboxError
    else {
    let validation = validatePlannerReport rawReport in
    let trace1 = appendManagerTrace (textConcat ["planner-wave-", encode wave, ":continue-with-plan:validated"]) in
    if trace1 != "" then
      plannerFailure "manager trace write failed" trace1
    else {
    let report = materializePlannerReport wave rawReport in
    let trace2 = appendManagerTrace (textConcat ["planner-wave-", encode wave, ":continue-with-plan:materialized"]) in
    if trace2 != "" then
      plannerFailure "manager trace write failed" trace2
    else {
    let failureState = managerStateFor "failed" "fail" false "" (plannerTaskIds report) wave benchmarkRuns true in
    let validationWriteError = writePlanValidation validation in
    if validationWriteError != "" then
      finalizeWithReport failureState (syntheticFailureReport "plan validation write failed" validationWriteError)
    else {
      let trace3 = appendManagerTrace (textConcat ["planner-wave-", encode wave, ":continue-with-plan:validation-written"]) in
      if trace3 != "" then
        plannerFailure "manager trace write failed" trace3
      else {
      if validation.valid == false then
        finalizeWithReport failureState (planValidationFailureReport validation)
      else {
        let plannerInputWriteError = writePlannerInputState (plannerInputStateFor wave benchmarkSummary) in
        if plannerInputWriteError != "" then
          finalizeWithReport failureState (syntheticFailureReport "planner input state write failed" plannerInputWriteError)
        else {
          let trace4 = appendManagerTrace (textConcat ["planner-wave-", encode wave, ":continue-with-plan:planner-input-written"]) in
          if trace4 != "" then
            plannerFailure "manager trace write failed" trace4
          else {
          let ensureTasksError = ensurePlannedTasks report in
          if ensureTasksError != "" then
            finalizeWithReport failureState (syntheticFailureReport "planned task setup failed" ensureTasksError)
          else
            {
              let trace5 = appendManagerTrace (textConcat ["planner-wave-", encode wave, ":continue-with-plan:tasks-ready"]) in
              if trace5 != "" then
                plannerFailure "manager trace write failed" trace5
              else
                executeReadyTasks report wave benchmarkRuns
            }
          }
        }
      }
      }
    }
  }
  }
    }
    }
  }
}

continueWithPlan : Str
continueWithPlan = {
  let state = readManagerState in
  continueWithPlanResolved state.wave state.benchmarkRuns latestBenchmarkSummaryText (readPlannerReportForWave state.wave)
}

executeReadyTasks : PlannerReport -> Int -> Int -> Str
executeReadyTasks report wave benchmarkRuns = {
  let plannedIds = plannerTaskIds report in
  let failureState = managerStateFor "failed" "fail" false "" plannedIds wave benchmarkRuns true in
  let mailboxError = refreshMailbox wave in
  if mailboxError != "" then
    finalizeWithReport failureState (syntheticFailureReport "mailbox write failed" mailboxError)
  else
  match tasks swarmStateRoot {
    Err message ->
      finalizeWithReport failureState (syntheticFailureReport "task lookup failed" message),
    Ok rawTaskValues -> {
      let mut objectiveTasks = filter taskInObjective rawTaskValues;
      let mut schedulerError = "";
      let mut runningTaskIds = emptyTexts;
      for spec in report.tasks {
        let taskStatus = taskStatusFor objectiveTasks spec.taskId in
        if childLoopReportReady spec.taskId then {
          let childReport = taskPassReport spec in
          let taskError =
            if childReport.verdict == "pass" then
              if taskStatus == "completed" then
                ""
              else
                completePlannedTask spec
            else if taskStatus == "failed" then
              ""
            else
              recordPlannedTaskFailure spec childReport in
          if taskError != "" then
            {
              schedulerError = taskError;
              schedulerError
            }
          else
            schedulerError
        } else if childLoopRunning spec.taskId then {
          runningTaskIds = append runningTaskIds [spec.taskId];
          schedulerError
        } else if fileExists (taskProcessHeartbeatPath spec.taskId) then
          if childLoopLaunchRunning spec.taskId then {
            runningTaskIds = append runningTaskIds [spec.taskId];
            schedulerError
          } else if childLoopLaunchCompleted spec.taskId then {
            let taskError =
              if taskStatus == "failed" then
                ""
              else
                recordPlannedTaskFailure spec (childLoopMissingReport spec) in
            if taskError != "" then
              {
                schedulerError = taskError;
                schedulerError
              }
            else
              schedulerError
          } else
            schedulerError
        else
          schedulerError
      };
      if schedulerError != "" then
        finalizeWithReport failureState (syntheticFailureReport "planned task reconciliation failed" schedulerError)
      else
        match tasks swarmStateRoot {
          Err message ->
            finalizeWithReport failureState (syntheticFailureReport "task refresh failed" message),
          Ok refreshedRawTaskValues ->
            let refreshedTasks = filter taskInObjective refreshedRawTaskValues in
            match ready objectiveRef {
              Err message ->
                finalizeWithReport failureState (syntheticFailureReport "ready queue lookup failed" message),
              Ok readyTasks -> {
                let mut activeTaskIds = runningTaskIds;
                let mut launchSlots = subtractManagerCounters maxConcurrentChildren (length runningTaskIds);
                let mut launchError = "";
                for spec in report.tasks {
                  let taskStatus = taskStatusFor refreshedTasks spec.taskId in
                  if launchError != "" then
                    launchError
                  else if launchSlots == 0 then
                    launchError
                  else if taskStatusIsTerminal taskStatus then
                    launchError
                  else if textListHas spec.taskId activeTaskIds then
                    launchError
                  else if fileExists (taskFeedbackPath spec.taskId) then
                    launchError
                  else if taskListHasId spec.taskId readyTasks then {
                    let taskError = launchReadyTask wave spec in
                    if taskError != "" then
                      {
                        launchError = taskError;
                        launchError
                      }
                    else
                      {
                        activeTaskIds = append activeTaskIds [spec.taskId];
                        launchSlots = decrementManagerCounter launchSlots;
                        launchError
                      }
                  } else
                    launchError
                };
                if launchError != "" then
                  finalizeWithReport failureState (syntheticFailureReport "planned task launch failed" launchError)
                else {
                  let runningState =
                    managerStateFor
                      "task-running"
                      "pending"
                      false
                      (firstTextOrEmpty activeTaskIds)
                      plannedIds
                      wave
                      benchmarkRuns
                      false in
                  let stateError = writeManagerState runningState in
                  if stateError != "" then
                    finalizeWithReport failureState (syntheticFailureReport "manager state write failed" stateError)
                  else if length activeTaskIds > 0 then
                    match sleepMsValue childLoopWatchPollMs {
                      Err message ->
                        finalizeWithReport failureState (syntheticFailureReport "task poll sleep failed" message),
                      Ok slept ->
                        executeReadyTasks report wave benchmarkRuns
                    }
                  else
                    match tasks swarmStateRoot {
                      Err message ->
                        finalizeWithReport failureState (syntheticFailureReport "final task refresh failed" message),
                      Ok finalRawTaskValues -> {
                        let finalTasks = filter taskInObjective finalRawTaskValues;
                        let mut completedIds = emptyTexts;
                        let mut failedIds = emptyTexts;
                        for spec in report.tasks {
                          let taskStatus = taskStatusFor finalTasks spec.taskId in
                          if taskStatus == "completed" then {
                            completedIds = append completedIds [spec.taskId];
                            completedIds
                          } else if taskStatus == "failed" then {
                            failedIds = append failedIds [spec.taskId];
                            failedIds
                          } else
                            completedIds
                        };
                        let mut readyPlannedIds = emptyTexts;
                        for readyTask in readyTasks {
                          let readyTaskId = taskIdOf readyTask in
                          if textListHas readyTaskId plannedIds then {
                            readyPlannedIds = append readyPlannedIds [readyTaskId];
                            readyPlannedIds
                          } else
                            readyPlannedIds
                        };
                        if benchmarkEnabled then
                          runBenchmarkCheckpoint report wave benchmarkRuns
                        else if length completedIds == length report.tasks then
                          finalizeWithReport
                            (managerStateFor "completed" "pass" true "" plannedIds wave benchmarkRuns true)
                            (managerPassReport report)
                        else if length failedIds > 0 then
                          finalizeWithReport failureState (plannedTaskFailureReport failedIds)
                        else if length readyPlannedIds > 0 then
                          executeReadyTasks report wave benchmarkRuns
                        else
                          finalizeWithReport failureState (plannedTaskStalledReport report)
                      }
                    }
                }
              }
            }
        }
    }
  }
}

serviceStatusOutput : Str
serviceStatusOutput =
  if fileExists (serviceStatusPath serviceRoot) then
    readTextOrEmpty (serviceStatusPath serviceRoot)
  else if recordedServiceRoot != "" then
    if fileExists (serviceStatusPath recordedServiceRoot) then
      readTextOrEmpty (serviceStatusPath recordedServiceRoot)
    else
      "error:missing-service-status"
  else
    "error:missing-service-status"

runManagerUpgrade : Str
runManagerUpgrade = {
  let prepError = ensureManagerReady in
  if prepError != "" then
    prepError
  else if textJoin "" upgradeCommandList == "" then
    "error:missing-upgrade-command"
  else if serviceRoot == "" then
    "error:missing-service-root"
  else if serviceId == "" then
    "error:missing-service-id"
  else if upgradeReadyPath == "" then
    "error:missing-upgrade-ready-path"
  else
    match
      upgradeService (
        serviceUpgradeSpec
          "."
          serviceRoot
          serviceId
          (encode currentUpgradeSnapshot)
          upgradeReadyPath
          upgradeReadyContains
          childLoopWatchPollMs
          upgradeReadyPollMs
          upgradeReadyTimeoutMs
          upgradeCommitGraceMs
          upgradeCommandList
      )
    {
      Ok transaction -> encode transaction,
      Err message -> textConcat ["error:", message]
    }
}

statusOutput : Str
statusOutput = encode (statusView readManagerState)

resumeManager : Str
resumeManager = {
  let state = readManagerState in
  if state.final then
    statusOutput
  else
    if plannerReportReusableFor state.wave latestBenchmarkSummaryText then
      continueWithPlan
    else
      runPlanner
}

main : Str
main =
  if commandName == "status" then
    statusOutput
  else if commandName == "service-status" then
    serviceStatusOutput
  else if commandName == "upgrade" then
    runManagerUpgrade
  else
    resumeManager
