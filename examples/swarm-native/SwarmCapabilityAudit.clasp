managedSpeedReportPassedRaw : Str -> Bool
managedSpeedReportPassedRaw raw =
  if jsonStringFieldEquals raw "scenario" "selfhost-body-change" then
    if jsonBoolFieldTrue raw "matchesExpectations" then
      if jsonStringFieldEquals raw "buildPlan" "hit" then
        if textIncludes raw "checkBodyChange" then
          textIncludes raw "imageBodyChange"
        else
          false
      else
        false
    else
      false
  else
    false

managedSpeedEvidenceFromRaw : Str -> Str -> ManagedVerificationEvidence
managedSpeedEvidenceFromRaw path raw =
  if managedSpeedReportPassedRaw raw then
    ManagedVerificationEvidence {
      proven = true,
      evidence = [
        textConcat [
          "Selfhost incremental speed report passed from ",
          path,
          ": body-change check/image paths are guarded and the selfhost image buildPlan is a hit."
        ],
        "The speed evidence confirms the old ~20s selfhost body-change image cliff is covered by the normal selfhost gate."
      ],
      blocking_gaps = emptyTexts,
      required_closure = emptyTexts,
      verification_notes = [
        textConcat ["Selfhost iteration-speed report consumed: ", path]
      ]
    }
  else
    ManagedVerificationEvidence {
      proven = false,
      evidence = [
        textConcat [
          "Selfhost incremental speed report was present at ",
          path,
          " but did not prove scenario=selfhost-body-change, matchesExpectations=true, and buildPlan=hit."
        ]
      ],
      blocking_gaps = [
        "Selfhost incremental speed report exists but does not clear the compiler rebuild latency blocker."
      ],
      required_closure = [
        "Re-run scripts/measure-native-incremental.sh --scenario selfhost-body-change through scripts/run-managed-job.sh and provide the passing report path."
      ],
      verification_notes = [
        textConcat ["Selfhost iteration-speed report consumed but rejected: ", path]
      ]
    }

