standaloneClosureReportPassed : StandaloneClosureReport -> Bool
standaloneClosureReportPassed report =
  if report.schemaVersion == 1 then
    if report.kind == "standalone-swarm-verifier-report" then
      if report.mode == "closure" then
        if report.status == "closed" then
          if report.requiredSurfaceCount == 8 then
            if report.workspaceRoot != "" then
              if report.builderReport != "" then
                if report.verifierReport != "" then
                  if report.proofPath != "" then
                    if report.workspaceFingerprintManifest != "" then
                      if report.workspaceFingerprintManifestSha256 != "" then
                        if textListIncludes report.evidence "fixed-standalone-swarm-markers" then
                          if textListIncludes report.evidence "direct-source-edit-proof" then
                            if textListIncludes report.evidence "workspace-fingerprint-manifest" then
                              if textListIncludes report.evidence "local-agent-builder-report" then
                                if textListIncludes report.evidence "local-agent-verifier-report" then
                                  textListIncludes report.evidence "typed-local-verifier-gate"
                                else
                                  false
                              else
                                false
                            else
                              false
                          else
                            false
                        else
                          false
                      else
                        false
                    else
                      false
                  else
                    false
                else
                  false
              else
                false
            else
              false
          else
            false
        else
          false
      else
        false
    else
      false
  else
    false

standaloneClosureEvidenceFromReport : Str -> StandaloneClosureReport -> ManagedVerificationEvidence
standaloneClosureEvidenceFromReport path report =
  if standaloneClosureReportPassed report then
    ManagedVerificationEvidence {
      proven = true,
      evidence = [
        textConcat [
          "Standalone closure report passed from ",
          path,
          " with requiredSurfaceCount=",
          encode report.requiredSurfaceCount,
          "."
        ],
        "The closure report proves fixed standalone-swarm markers, direct-source-edit proof, local builder/verifier reports, and typed local verifier gate evidence."
      ],
      blocking_gaps = emptyTexts,
      required_closure = emptyTexts,
      verification_notes = [
        textConcat ["Standalone closure report consumed: ", path]
      ]
    }
  else
    ManagedVerificationEvidence {
      proven = false,
      evidence = [
        textConcat ["Standalone closure report was present at ", path, " but did not satisfy the closure report contract."]
      ],
      blocking_gaps = [
        "Standalone closure report exists but does not prove fixed markers, source-edit proof, builder/verifier reports, and typed local verifier gate evidence."
      ],
      required_closure = [
        "Re-run scripts/standalone-swarm-verify.sh --closure --json with the fixed workspace and local-agent reports, then provide the passing report path."
      ],
      verification_notes = [
        textConcat ["Standalone closure report consumed but rejected: ", path]
      ]
    }

