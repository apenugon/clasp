      Ok raw ->
        match tryDecode ManagedSwarmProofReport raw {
          Ok report -> managedSwarmProofEvidenceFromReport path report,
          Err message ->
            ManagedVerificationEvidence {
              proven = false,
              evidence = [
                textConcat ["Managed swarm proof report could not be decoded at ", path, ": ", message]
