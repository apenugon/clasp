managedCompilerModuleSpeedReportPassedRaw : Str -> Bool
managedCompilerModuleSpeedReportPassedRaw raw =
  if jsonStringFieldEquals raw "scenario" "selfhost-compiler-module-body-change" then
    if jsonBoolFieldTrue raw "matchesExpectations" then
      if textIncludes raw "Compiler.Ast" then
        if textIncludes raw "validated-hit" then
          if textIncludes raw "compilerCheckBodyChange" then
            jsonStringFieldEquals raw "compilerModuleImageProbe" "skipped"
          else
            false
        else
          false
      else
        false
    else
      false
  else
    false

managedCompilerModuleSpeedEvidenceFromRaw : Str -> Str -> ManagedVerificationEvidence
managedCompilerModuleSpeedEvidenceFromRaw path raw =
  if managedCompilerModuleSpeedReportPassedRaw raw then
    ManagedVerificationEvidence {
      proven = true,
      evidence = [
        textConcat [
          "Large compiler-module speed report passed from ",
          path,
          ": Compiler.Ast body-change check was a validated-hit and the full native-image diagnostic was explicitly skipped."
        ],
        "The large compiler-module proof keeps the default gate bounded while proving real self-host compiler edit reuse."
      ],
      blocking_gaps = emptyTexts,
      required_closure = emptyTexts,
      verification_notes = [
        textConcat ["Large compiler-module speed report consumed: ", path]
      ]
    }
  else
    ManagedVerificationEvidence {
      proven = false,
      evidence = [
        textConcat [
          "Large compiler-module speed report was present at ",
          path,
          " but did not prove scenario=selfhost-compiler-module-body-change, matchesExpectations=true, Compiler.Ast validated-hit, and compilerModuleImageProbe=skipped."
        ]
      ],
      blocking_gaps = [
        "Large compiler-module speed report exists but does not clear the large compiler edit blocker."
      ],
      required_closure = [
        "Re-run scripts/measure-native-incremental.sh --scenario selfhost-compiler-module-body-change with CLASP_NATIVE_INCREMENTAL_COMPILER_MODULE_IMAGE_PROBE=0 through scripts/run-managed-job.sh and provide the passing report path."
      ],
      verification_notes = [
        textConcat ["Large compiler-module speed report consumed but rejected: ", path]
      ]
    }

