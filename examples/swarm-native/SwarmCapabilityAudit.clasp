module Main

record CapabilityStatus = {
  name : Str,
  status : Str,
  evidence : [Str],
  blocking_gaps : [Str],
  required_closure : [Str]
}

record SwarmCapabilityAudit = {
  schema_version : Int,
  kind : Str,
  objective : Str,
  overall_status : Str,
  default_agent_model : Str,
  default_agent_reasoning : Str,
  capability_statuses : [CapabilityStatus],
  blocking_gaps : [Str],
  required_closure : [Str],
  verification_notes : [Str]
}

record ManagedVerifyAllReport = {
  finalVerdict : Str,
  exitStatus : Int,
  elapsedMs : Int,
  commandCount : Int
}

record ManagedVerificationEvidence = {
  proven : Bool,
  evidence : [Str],
  blocking_gaps : [Str],
  required_closure : [Str],
  verification_notes : [Str]
}

record ManagedSwarmProofReport = {
  schemaVersion : Int,
  kind : Str,
  verdict : Str,
  managerCompleted : Bool,
  managerFinal : Bool,
  plannerBackendKind : Str,
  plannerBackendTransport : Str,
  codexFallbackInvoked : Bool,
  taskCount : Int,
  completedTaskCount : Int,
  dependencyOrdered : Bool,
  localPlannerBackend : Bool,
  localAgentCommandPropagated : Bool,
  sourceEditPlanDelivered : Bool,
  sourcePatchPlanDelivered : Bool,
  dependencyEvidenceDelivered : Bool
}

record StandaloneClosureReport = {
  schemaVersion : Int,
  kind : Str,
  mode : Str,
  status : Str,
  workspaceRoot : Str,
  builderReport : Str,
  verifierReport : Str,
  proofPath : Str,
  workspaceFingerprintManifest : Str,
  workspaceFingerprintManifestSha256 : Str,
  requiredSurfaceCount : Int,
  evidence : [Str]
}

emptyTexts : [Str]
emptyTexts = []

textIncludes : Str -> Str -> Bool
textIncludes value needle = length (textSplit value needle) > 1

textListIncludes : [Str] -> Str -> Bool
textListIncludes values needle = {
  let mut found = false;
  for value in values {
    if found then
      found
    else if value == needle then {
      found = true;
      found
    } else
      found
  };
  found
}

jsonTextOrRaw : Str -> Str
jsonTextOrRaw raw = match textPrefix raw "\"" {
  Ok quotedTail -> decode Str raw,
  Err notQuoted -> raw
}

readEnvText : Str -> Str -> Str
readEnvText name fallback = match envVar name {
  Ok raw -> if raw == "" then fallback else jsonTextOrRaw raw,
  Err message -> fallback
}

capabilityStatus : Str -> Str -> [Str] -> [Str] -> [Str] -> CapabilityStatus
capabilityStatus name status evidence blockingGaps requiredClosure =
  CapabilityStatus {
    name = name,
    status = status,
    evidence = evidence,
    blocking_gaps = blockingGaps,
    required_closure = requiredClosure
  }

managedVerifyReportPath : Str
managedVerifyReportPath = readEnvText "CLASP_SWARM_CAPABILITY_VERIFY_REPORT_JSON" ""

managedSwarmProofReportPath : Str
managedSwarmProofReportPath = readEnvText "CLASP_SWARM_CAPABILITY_SWARM_PROOF_JSON" ""

standaloneClosureReportPath : Str
standaloneClosureReportPath = readEnvText "CLASP_SWARM_CAPABILITY_STANDALONE_CLOSURE_REPORT_JSON" ""

managedSpeedReportPath : Str
managedSpeedReportPath = readEnvText "CLASP_SWARM_CAPABILITY_SPEED_REPORT_JSON" ""

managedCompilerModuleSpeedReportPath : Str
managedCompilerModuleSpeedReportPath = readEnvText "CLASP_SWARM_CAPABILITY_COMPILER_MODULE_SPEED_REPORT_JSON" ""

jsonStringFieldEquals : Str -> Str -> Str -> Bool
jsonStringFieldEquals raw field expected =
  if textIncludes raw (textConcat ["\"", field, "\":\"", expected, "\""]) then
    true
  else
    textIncludes raw (textConcat ["\"", field, "\": \"", expected, "\""])

jsonBoolFieldTrue : Str -> Str -> Bool
jsonBoolFieldTrue raw field =
  if textIncludes raw (textConcat ["\"", field, "\":true"]) then
    true
  else
    textIncludes raw (textConcat ["\"", field, "\": true"])

managedVerifyEvidenceFromReport : Str -> ManagedVerifyAllReport -> ManagedVerificationEvidence
managedVerifyEvidenceFromReport path report =
  if report.finalVerdict == "passed" && report.exitStatus == 0 then
    ManagedVerificationEvidence {
      proven = true,
      evidence = [
        textConcat [
          "Managed verify-all passed from ",
          path,
          " with commandCount=",
          encode report.commandCount,
          " elapsedMs=",
          encode report.elapsedMs,
          "."
        ],
        "The verification proof came from an existing report artifact; this audit did not launch heavyweight work."
      ],
      blocking_gaps = emptyTexts,
      required_closure = emptyTexts,
      verification_notes = [
        textConcat ["Managed verification report consumed: ", path]
      ]
    }
  else
    ManagedVerificationEvidence {
      proven = false,
      evidence = [
        textConcat [
          "Managed verify-all report was present at ",
          path,
          " but did not pass: finalVerdict=",
          report.finalVerdict,
          " exitStatus=",
          encode report.exitStatus,
          "."
        ]
      ],
      blocking_gaps = [
        "Managed verify-all report exists but does not prove a passing current tree."
      ],
      required_closure = [
        "Re-run bash scripts/verify-all.sh through scripts/run-managed-job.sh and provide the passing report path."
      ],
      verification_notes = [
        textConcat ["Managed verification report consumed but rejected: ", path]
      ]
    }

missingManagedVerifyEvidence : ManagedVerificationEvidence
missingManagedVerifyEvidence =
  ManagedVerificationEvidence {
    proven = false,
    evidence = [
      "No managed verify-all report path was provided to this lightweight audit."
    ],
    blocking_gaps = [
      "bash scripts/verify-all.sh has not been proven for the current dirty tree in this audit."
    ],
    required_closure = [
      "Run bash scripts/verify-all.sh only through scripts/run-managed-job.sh with explicit memory, disk, and low-parallelism settings."
    ],
    verification_notes = [
      "Set CLASP_SWARM_CAPABILITY_VERIFY_REPORT_JSON to a managed verify-all report artifact to let this audit consume current verification evidence."
    ]
  }

readManagedVerifyEvidence : Str -> ManagedVerificationEvidence
readManagedVerifyEvidence path =
  if path == "" then
    missingManagedVerifyEvidence
  else
    match readFile path {
      Err message ->
        ManagedVerificationEvidence {
          proven = false,
          evidence = [
            textConcat ["Managed verify-all report could not be read at ", path, ": ", message]
          ],
          blocking_gaps = [
            "Managed verify-all report path was configured but unreadable."
          ],
          required_closure = [
            "Provide a readable managed verify-all report artifact."
          ],
          verification_notes = [
            textConcat ["Managed verification report read failed: ", path]
          ]
        },
      Ok raw ->
        match tryDecode ManagedVerifyAllReport raw {
          Ok report -> managedVerifyEvidenceFromReport path report,
          Err message ->
            ManagedVerificationEvidence {
              proven = false,
              evidence = [
                textConcat ["Managed verify-all report could not be decoded at ", path, ": ", message]
              ],
              blocking_gaps = [
                "Managed verify-all report exists but does not match the expected report schema."
              ],
              required_closure = [
                "Provide an unmodified scripts/verify-all.sh JSON report artifact."
              ],
              verification_notes = [
                textConcat ["Managed verification report decode failed: ", path]
              ]
            }
        }
    }

managedVerifyEvidence : ManagedVerificationEvidence
managedVerifyEvidence = readManagedVerifyEvidence managedVerifyReportPath

managedSwarmProofReportPassed : ManagedSwarmProofReport -> Bool
managedSwarmProofReportPassed report =
  if report.kind == "clasp-managed-swarm-proof" then
    if report.verdict == "pass" then
      if report.managerCompleted && report.managerFinal then
        if report.plannerBackendKind == "template" && report.plannerBackendTransport == "prompt-path" then
          if report.codexFallbackInvoked == false then
            if report.taskCount >= 3 && report.completedTaskCount >= report.taskCount then
              if report.dependencyOrdered && report.localPlannerBackend then
                if report.localAgentCommandPropagated then
                  if report.sourceEditPlanDelivered && report.sourcePatchPlanDelivered then
                    report.dependencyEvidenceDelivered
                  else
                    false
                else
                  false
              else
                false
            else
              false
          else
            false
        else
          false
      else
        false
    else
      false
  else
    false

managedSwarmProofEvidenceFromReport : Str -> ManagedSwarmProofReport -> ManagedVerificationEvidence
managedSwarmProofEvidenceFromReport path report =
  if managedSwarmProofReportPassed report then
    ManagedVerificationEvidence {
      proven = true,
      evidence = [
        textConcat [
          "Managed swarm proof passed from ",
          path,
          " with taskCount=",
          encode report.taskCount,
          " completedTaskCount=",
          encode report.completedTaskCount,
          "."
        ],
        "The proof used a template planner backend, prompt-path transport, local planner routing, propagated local child-agent commands, dependency-ordered child launch, and no Codex fallback.",
        "The proof delivered standalone source-edit and source-patch plans plus dependency completion evidence to the final child task."
      ],
      blocking_gaps = emptyTexts,
      required_closure = emptyTexts,
      verification_notes = [
        textConcat ["Managed swarm proof consumed: ", path]
      ]
    }
  else
    ManagedVerificationEvidence {
      proven = false,
      evidence = [
        textConcat [
          "Managed swarm proof report was present at ",
          path,
          " but did not satisfy the multi-task non-Codex manager proof contract."
        ]
      ],
      blocking_gaps = [
        "Managed swarm proof report exists but does not prove a passing multi-task non-Codex manager run."
      ],
      required_closure = [
        "Run scripts/test-goal-manager-agent-command-template.sh through scripts/run-managed-job.sh with CLASP_GOAL_MANAGER_SWARM_PROOF_REPORT_JSON set."
      ],
      verification_notes = [
        textConcat ["Managed swarm proof consumed but rejected: ", path]
      ]
    }

