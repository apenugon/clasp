module Main

import AgentBackend
import Swarm
import AttemptLoop

record CapabilityStatus = {
  name : Str,
  status : Str,
  evidence : [Str],
  blocking_gaps : [Str],
  required_closure : [Str]
}

record VerifierReport = {
  verdict : Str,
  summary : Str,
  findings : [Str],
  tests_run : [Str],
  follow_up : [Str],
  capability_statuses : [CapabilityStatus]
}

record StatusView = {
  state : AttemptStatus,
  agentBackend : AgentBackendSummary,
  agentBackendPolicy : AgentBackendPolicySummary,
  agentBackendCapability : AgentBackendCapabilitySummary,
  objectiveProjectedStatus : Str,
  taskCount : Int,
  allTaskIds : [Str],
  completedTaskIds : [Str],
  readyTaskIds : [Str],
  approvalCount : Int,
  mergeDecisionDetail : Str,
  mergeGateSatisfied : Bool,
  feedbackSummary : Str,
  previousVerifierFeedback : PreviousVerifierFeedback,
  retryDecision : AttemptRetryDecision,
  terminalOutcome : AttemptTerminalOutcome
}

emptyTexts : [Str]
emptyTexts = []

emptyCapabilityStatuses : [CapabilityStatus]
emptyCapabilityStatuses = []

stateRootPath : Str
stateRootPath =
  if textJoin "" argv == "" then
    "swarm-native-feedback-loop-state"
  else
    pathJoin argv

swarmStateRoot : SwarmRoot
swarmStateRoot = swarmRoot stateRootPath

objectiveId : Str
objectiveId = "autonomous-confidence"

objectiveRef : ObjectiveHandle
objectiveRef = objectiveHandle swarmStateRoot objectiveId

readEnvText : Str -> Str -> Str
readEnvText name fallback = match envVar name {
  Ok raw -> decode Str raw,
  Err message -> fallback
}

readEnvTextList : Str -> [Str] -> [Str]
readEnvTextList name fallback = match envVar name {
  Ok raw -> if raw == "" then fallback else decode [Str] raw,
  Err message -> fallback
}

readEnvInt : Str -> Int -> Int
readEnvInt name fallback = match envVar name {
  Ok raw -> if raw == "" then fallback else decode Int raw,
  Err message -> fallback
}

readEnvBool : Str -> Bool -> Bool
readEnvBool name fallback = match envVar name {
  Ok raw -> if raw == "" then fallback else decode Bool raw,
  Err message -> fallback
}

envPresent : Str -> Bool
envPresent name = match envVar name {
  Ok raw -> raw != "",
  Err message -> false
}

nonEmptyText : Str -> Bool
nonEmptyText value = value != ""

truthyText : Str -> Bool
truthyText value =
  if value == "1" then
    true
  else if value == "true" then
    true
  else if value == "yes" then
    true
  else
    value == "on"

allowUnmanagedAgentRuntime : Bool
allowUnmanagedAgentRuntime = match envVar "CLASP_ALLOW_UNMANAGED_AGENT_RUNTIME" {
  Ok raw ->
    if raw == "dangerous" then
      truthyText (readEnvText "CLASP_UNMANAGED_AGENT_RUNTIME_DANGER_ACCEPTED" "false")
    else if truthyText raw then
      envPresent "CLASP_TEST_CODEX_MODE"
    else
      false,
  Err message -> false
}

managedAgentRuntimeReady : Bool
managedAgentRuntimeReady =
  if envPresent "CLASP_MANAGED_JOB_ID" then
    true
  else
    allowUnmanagedAgentRuntime

taskFile : Str
taskFile = readEnvText "CLASP_LOOP_TASK_FILE_JSON" "agents/tasks/0012-autonomous-swarm-confidence.md"

workspaceRoot : Str
workspaceRoot = readEnvText "CLASP_LOOP_WORKSPACE_JSON" "."

codexBin : Str
codexBin = readEnvText "CLASP_LOOP_CODEX_BIN_JSON" (readEnvText "CLASP_LOOP_AGENT_BIN_JSON" "codex")

builderSchemaPath : Str
builderSchemaPath = readEnvText "CLASP_LOOP_BUILDER_SCHEMA_JSON" "agents/schemas/builder-report.schema.json"

verifierSchemaPath : Str
verifierSchemaPath = readEnvText "CLASP_LOOP_VERIFIER_SCHEMA_JSON" "agents/schemas/verifier-report.schema.json"

codexModel : Str
codexModel = readEnvText "CLASP_LOOP_CODEX_MODEL_JSON" (readEnvText "CLASP_LOOP_AGENT_MODEL_JSON" "gpt-5.5")

codexReasoning : Str
codexReasoning = readEnvText "CLASP_LOOP_CODEX_REASONING_JSON" (readEnvText "CLASP_LOOP_AGENT_REASONING_JSON" "xhigh")

codexSandbox : Str
codexSandbox = readEnvText "CLASP_LOOP_CODEX_SANDBOX_JSON" (readEnvText "CLASP_LOOP_AGENT_SANDBOX_JSON" "danger-full-access")

agentBin : Str
agentBin = readEnvText "CLASP_LOOP_AGENT_BIN_JSON" codexBin

agentModel : Str
agentModel = readEnvText "CLASP_LOOP_AGENT_MODEL_JSON" codexModel

agentReasoning : Str
agentReasoning = readEnvText "CLASP_LOOP_AGENT_REASONING_JSON" codexReasoning

agentSandbox : Str
agentSandbox = readEnvText "CLASP_LOOP_AGENT_SANDBOX_JSON" codexSandbox

agentCommandTemplate : [Str]
agentCommandTemplate = readEnvTextList "CLASP_LOOP_AGENT_COMMAND_JSON" emptyTexts

agentCapabilityProfileName : Str
agentCapabilityProfileName = readEnvText "CLASP_LOOP_AGENT_CAPABILITY_PROFILE_JSON" ""

requireStandaloneAgentBackend : Bool
requireStandaloneAgentBackend =
  readEnvBool
    "CLASP_LOOP_REQUIRE_STANDALONE_AGENT_BACKEND_JSON"
    (readEnvBool "CLASP_REQUIRE_STANDALONE_AGENT_BACKEND_JSON" false)

maxAttempts : Int
maxAttempts = readEnvInt "CLASP_LOOP_MAX_ATTEMPTS_JSON" 20

agentTimeoutMs : Int
agentTimeoutMs = readEnvInt "CLASP_LOOP_AGENT_TIMEOUT_MS_JSON" 0

agentMemoryLimitMb : Int
agentMemoryLimitMb = readEnvInt "CLASP_LOOP_AGENT_MEMORY_MB_JSON" 8192

builderTimeoutMs : Int
builderTimeoutMs = readEnvInt "CLASP_LOOP_BUILDER_TIMEOUT_MS_JSON" agentTimeoutMs

verifierTimeoutMs : Int
verifierTimeoutMs = readEnvInt "CLASP_LOOP_VERIFIER_TIMEOUT_MS_JSON" agentTimeoutMs

builderMemoryLimitMb : Int
builderMemoryLimitMb = readEnvInt "CLASP_LOOP_BUILDER_MEMORY_MB_JSON" agentMemoryLimitMb

verifierMemoryLimitMb : Int
verifierMemoryLimitMb = readEnvInt "CLASP_LOOP_VERIFIER_MEMORY_MB_JSON" agentMemoryLimitMb

affectedVerificationPlanInlineJson : Str
affectedVerificationPlanInlineJson = readEnvText "CLASP_LOOP_AFFECTED_VERIFICATION_PLAN_JSON" ""

affectedVerificationPlanPath : Str
affectedVerificationPlanPath = readEnvText "CLASP_LOOP_AFFECTED_VERIFICATION_PLAN_PATH_JSON" ""

affectedVerificationPlanJson : Str
affectedVerificationPlanJson =
  affectedVerificationPlanInlineJson

affectedVerificationLaunchPolicyInlineJson : Str
affectedVerificationLaunchPolicyInlineJson = readEnvText "CLASP_LOOP_AFFECTED_VERIFICATION_LAUNCH_POLICY_JSON" ""

affectedVerificationLaunchPolicyPath : Str
affectedVerificationLaunchPolicyPath = readEnvText "CLASP_LOOP_AFFECTED_VERIFICATION_LAUNCH_POLICY_PATH_JSON" ""

affectedVerificationLaunchPolicyJson : Str
affectedVerificationLaunchPolicyJson =
  affectedVerificationLaunchPolicyInlineJson

actorName : Str
actorName = match envVar "CLASP_SWARM_ACTOR" {
  Ok raw -> raw,
  Err message -> "manager"
}

commandName : Str
commandName = match envVar "CLASP_LOOP_COMMAND" {
  Ok raw -> raw,
  Err message ->
    match envVar "CLASP_AUTONOMOUS_LOOP_COMMAND" {
      Ok legacy -> legacy,
      Err missing -> "run"
    }
}

builderPolicyPath : Str
builderPolicyPath = pathJoin [stateRootPath, "builder-policy.md"]

verifierPolicyPath : Str
verifierPolicyPath = pathJoin [stateRootPath, "verifier-policy.md"]

approvalName : Str
approvalName = "merge-ready"

mergegateName : Str
mergegateName = "autonomous-confidence"

requiredApprovals : [Str]
requiredApprovals = [approvalName]

requiredVerifiers : [Str]
requiredVerifiers = [mergegateName]

loopSpec : AttemptSpec
loopSpec =
  attemptSpec
    swarmStateRoot
    objectiveId
    "Run the configured builder/verifier agent loop directly from ordinary Clasp code on the native swarm substrate."
    40
    40
    stateRootPath
    maxAttempts
    actorName
    approvalName
    mergegateName
    requiredApprovals
    requiredVerifiers

feedbackPath : Str
feedbackPath = loopSpec.feedbackPath

builderReportPath : Int -> Str
builderReportPath attempt = pathJoin [stateRootPath, textConcat ["builder-", encode attempt, ".json"]]

verifierReportPath : Int -> Str
verifierReportPath attempt = pathJoin [stateRootPath, textConcat ["verifier-", encode attempt, ".json"]]

builderPromptPath : Int -> Str
builderPromptPath attempt = pathJoin [stateRootPath, textConcat ["builder-", encode attempt, ".prompt.md"]]

verifierPromptPath : Int -> Str
verifierPromptPath attempt = pathJoin [stateRootPath, textConcat ["verifier-", encode attempt, ".prompt.md"]]

builderTaskId : Int -> Str
builderTaskId attempt = attemptBuilderTaskId attempt

verifierTaskId : Int -> Str
verifierTaskId attempt = attemptVerifierTaskId attempt

builderHandle : Int -> TaskHandle
builderHandle attempt = attemptBuilderHandle loopSpec attempt

verifierHandle : Int -> TaskHandle
verifierHandle attempt = attemptVerifierHandle loopSpec attempt

defaultBuilderPolicyText : Str
defaultBuilderPolicyText = textJoin "\n" [
  "Close whole blocking capability categories rather than single complaint lines.",
  "Prefer code/runtime/compiler/example/test changes over docs-only movement.",
  "Use the previous verifier report as the primary steering input for the next attempt.",
  "Do not broaden backend-native swarm/runtime work into JavaScript-emitter parity unless the frontend compile target actually requires it.",
  "Treat Compiler.Emit.JavaScript as the frontend/client emitter, not as a backend execution path."
]

defaultVerifierPolicyText : Str
defaultVerifierPolicyText = textJoin "\n" [
  "Judge the whole repository, not only the latest diff.",
  "Group failures by capability category.",
  "Do not fail merely because legacy helper scripts remain in the repo if the ordinary-program path is complete and not required.",
  "Do not demand JavaScript-emitter parity for backend-native swarm/runtime capabilities unless the task explicitly requires frontend/client support."
]

capabilityChecklistText : Str
capabilityChecklistText = textJoin "\n" [
  "- ordinary_program_execution: the live builder/verifier loop runs as a normal Clasp program via claspc run, invokes a configured agent backend from Clasp (Codex by default), and persists durable final state/status in ordinary runtime storage.",
  "- durable_native_substrate: objective/run/task/event/artifact persistence, DAG edges, projected status, leases, approvals, merge-policy state, tool/process execution, and monitoring/state inspection are durably available.",
  "- clasp_native_control_api: ordinary Clasp programs can use the orchestration substrate directly without requiring shell wrapper orchestration or external claspc swarm subprocesses as the primary model.",
  "- orchestration_viability: builder/verifier/planner-style programs are realistically implementable in Clasp itself without obvious missing runtime/control-plane substrate.",
  "- ergonomics: Dict state, empty lists, polymorphic collections, and record update/destructuring are usable enough for state-heavy orchestration code.",
  "- verification_gate: scenario-level coverage exists for the ordinary-program loop path and new runtime/workflow/control-plane behavior, and bash scripts/verify-all.sh passes."
]

readPolicyText : Str -> Str -> Str
readPolicyText path fallback = match readFile path {
  Ok raw -> raw,
  Err message -> fallback
}

ensurePolicyFile : Str -> Str -> Str
ensurePolicyFile path fallback =
  if fileExists path then
    ""
  else
    match writeFile path fallback {
      Ok written -> "",
      Err message -> message
    }

ensurePolicies : Str
ensurePolicies = {
  let builderError = ensurePolicyFile builderPolicyPath defaultBuilderPolicyText in
  if builderError != "" then
    builderError
  else
    ensurePolicyFile verifierPolicyPath defaultVerifierPolicyText
}

builderFeedbackSection : Str
builderFeedbackSection =
  attemptFeedbackPromptSection loopSpec "No previous verifier feedback is present yet."

builderPolicySection : Str
builderPolicySection = textJoin "\n" [
  textConcat ["Current builder policy from ", builderPolicyPath, ":"],
  readPolicyText builderPolicyPath defaultBuilderPolicyText
]

verifierPolicySection : Str
verifierPolicySection = textJoin "\n" [
  textConcat ["Current verifier policy from ", verifierPolicyPath, ":"],
  readPolicyText verifierPolicyPath defaultVerifierPolicyText
]

taskFileContentSection : Str
taskFileContentSection = match readFile taskFile {
  Ok raw -> textJoin "\n" [
    "Task file content:",
    raw
  ],
  Err message -> textJoin "\n" [
    "Task file content unavailable:",
    message
  ]
}

promptBoolText : Bool -> Str
promptBoolText value = if value then "true" else "false"

promptPolicyListText : [Str] -> Str
promptPolicyListText values =
  if length values == 0 then
    "none"
  else
    textJoin " | " values

memorySearchPromptLine : SwarmMemorySearchResult -> Str
memorySearchPromptLine item =
  textConcat [
    "- score=",
    encode item.score,
    " key=",
    item.memory.key,
    " actor=",
    item.memory.actor,
    " value=",
    item.memory.value,
    " matched=",
    item.matchedText
  ]

runTracePromptLine : VerificationTraceEntry -> Str
runTracePromptLine entry =
  textConcat [
    "- verifier=",
    entry.verifierName,
    " status=",
    entry.status,
    " exit=",
    encode entry.exitCode,
    " timedOut=",
    promptBoolText entry.timedOut,
    " class=",
    entry.failedVerifierClassification,
    " stdout=",
    entry.stdoutArtifactPath,
    " stderr=",
    entry.stderrArtifactPath
  ]

artifactExcerptPromptLine : SwarmArtifactContent -> Str
artifactExcerptPromptLine excerpt =
  textConcat [
    "- id=",
    encode excerpt.artifactId,
    " kind=",
    excerpt.kind,
    " bytes=",
    encode excerpt.bytesRead,
    "/",
    encode excerpt.totalBytes,
    " truncated=",
    promptBoolText excerpt.truncated,
    " text=",
    excerpt.text
  ]

promptListSection : Str -> [Str] -> Str
promptListSection title values =
  if length values == 0 then
    textJoin "\n" [title, "- none"]
  else
    textJoin "\n" [title, textJoin "\n" values]

memorySearchPromptSection : Str -> [SwarmMemorySearchResult] -> Str
memorySearchPromptSection title matches =
  promptListSection title (map memorySearchPromptLine matches)

runTracePromptSection : Str -> [VerificationTraceEntry] -> Str
runTracePromptSection title trace =
  promptListSection title (map runTracePromptLine trace)

artifactExcerptPromptSection : Str -> [SwarmArtifactContent] -> Str
artifactExcerptPromptSection title excerpts =
  promptListSection title (map artifactExcerptPromptLine excerpts)

artifactSearchPromptLine : SwarmArtifactSearchResult -> Str
artifactSearchPromptLine item =
  textConcat [
    "- artifact#",
    encode item.artifact.artifactId,
    " task=",
    item.artifact.taskId,
    " kind=",
    item.artifact.kind,
    " score=",
    encode item.score,
    " matched=",
    item.matchedText,
    " excerpt=",
    item.excerpt.text
  ]

artifactSearchPromptSection : Str -> [SwarmArtifactSearchResult] -> Str
artifactSearchPromptSection title matches =
  promptListSection title (map artifactSearchPromptLine matches)

renderContextPackPrompt : SwarmContextPack -> Str
renderContextPackPrompt pack =
  textJoin "\n" [
    "Swarm context pack:",
    textConcat [
      "task: ",
      pack.task.taskId,
      " status=",
      pack.task.status,
      " ready=",
      promptBoolText pack.task.ready,
      " attempts=",
      encode pack.task.attempts
    ],
    textConcat [
      "objective: ",
      pack.task.objectiveId,
      " manager-action=",
      pack.managerAction.action,
      " manager-task=",
      pack.managerAction.taskId,
      " manager-task-status=",
      pack.managerAction.taskStatus
    ],
    textConcat [
      "spawn policy: parent=",
      pack.task.parentTaskId,
      " depth=",
      encode pack.task.spawnDepth,
      "/",
      encode pack.task.maxSpawnDepth,
      " children=",
      encode pack.task.childTaskCount,
      "/",
      encode pack.task.maxChildTasks,
      " remaining-child-budget=",
      encode pack.task.remainingChildTaskBudget
    ],
    promptListSection "child task ids:" pack.task.childTaskIds,
    textConcat ["ready tasks: ", textJoin ", " pack.readyTaskIds],
    promptListSection "dependency task ids:" pack.dependencyTaskIds,
    promptListSection "dependency task statuses:" pack.dependencyTaskStatuses,
    promptListSection "dependency task ready:" (map promptBoolText pack.dependencyTaskReady),
    textConcat [
      "mailbox: runs=",
      encode pack.mailboxSummary.runCount,
      " artifacts=",
      encode pack.mailboxSummary.artifactCount,
      " memory=",
      encode pack.mailboxSummary.memoryCount,
      " latest-run=",
      pack.mailboxSummary.latestRunName,
      "/",
      pack.mailboxSummary.latestRunStatus,
      " latest-verifier=",
      pack.mailboxSummary.latestVerifier,
      "/",
      pack.mailboxSummary.latestVerifierStatus
    ],
    memorySearchPromptSection "task memory matches:" pack.taskMemoryMatches,
    memorySearchPromptSection "objective memory matches:" pack.objectiveMemoryMatches,
    memorySearchPromptSection "benchmark history matches:" pack.benchmarkMemoryMatches,
    artifactSearchPromptSection "artifact search matches:" pack.artifactSearchMatches,
    artifactSearchPromptSection "semantic index artifact matches:" pack.semanticArtifactMatches,
    promptListSection "semantic index entry ids:" pack.semanticIndexEntryIds,
    promptListSection "semantic index edit files:" pack.semanticIndexEditFiles,
    promptListSection "semantic index artifact refs:" pack.semanticIndexArtifactRefs,
    promptListSection "semantic index surface ids:" pack.semanticIndexSurfaceIds,
    promptListSection "semantic index query texts:" pack.semanticIndexQueryTexts,
    runTracePromptSection "run trace:" pack.runTrace,
    promptListSection "artifact kinds:" pack.artifactKinds,
    promptListSection "artifact paths:" pack.artifactPaths,
    artifactExcerptPromptSection "artifact excerpts:" pack.artifactExcerpts
  ]

taskContextPromptSection : TaskHandle -> Str -> Int -> Str
taskContextPromptSection handle query limit =
  match taskContextPack handle query limit {
    Ok pack -> renderContextPackPrompt pack,
    Err message -> textConcat ["Swarm context pack unavailable: ", message]
  }

contextPackQuery : Str
contextPackQuery = "autonomous swarm verifier feedback capability evidence"

contextPackLimit : Int
contextPackLimit = 8

builderContextSection : Int -> Str
builderContextSection attempt =
  taskContextPromptSection (builderHandle attempt) contextPackQuery contextPackLimit

verifierContextSection : Int -> Str
verifierContextSection attempt =
  taskContextPromptSection (verifierHandle attempt) contextPackQuery contextPackLimit

promptJsonBlockOrEmpty : Str -> Str -> Str -> Str
promptJsonBlockOrEmpty header footer raw =
  if raw == "" then
    ""
  else
    textJoin "\n" [header, raw, footer]

promptPathBlockOrEmpty : Str -> Str -> Str -> Str
promptPathBlockOrEmpty header footer path =
  if path == "" then
    ""
  else
    textJoin "\n" [header, path, footer]

affectedVerificationPlanPromptBlock : Str
affectedVerificationPlanPromptBlock =
  promptJsonBlockOrEmpty
    "Affected verification plan JSON:"
    "End affected verification plan JSON."
    affectedVerificationPlanJson

affectedVerificationPlanPathPromptBlock : Str
affectedVerificationPlanPathPromptBlock =
  promptPathBlockOrEmpty
    "Affected verification plan path:"
    "End affected verification plan path."
    affectedVerificationPlanPath

affectedVerificationLaunchPolicyPromptBlock : Str
affectedVerificationLaunchPolicyPromptBlock =
  promptJsonBlockOrEmpty
    "Affected verification launch policy JSON:"
    "End affected verification launch policy JSON."
    affectedVerificationLaunchPolicyJson

affectedVerificationLaunchPolicyPathPromptBlock : Str
affectedVerificationLaunchPolicyPathPromptBlock =
  promptPathBlockOrEmpty
    "Affected verification launch policy path:"
    "End affected verification launch policy path."
    affectedVerificationLaunchPolicyPath

affectedVerificationVerifierPromptSection : Str
affectedVerificationVerifierPromptSection =
  textJoin
    "\n"
    (filter nonEmptyText [
      affectedVerificationPlanPromptBlock,
      affectedVerificationPlanPathPromptBlock,
      affectedVerificationLaunchPolicyPromptBlock,
      affectedVerificationLaunchPolicyPathPromptBlock
    ])

loopAgentBackendPolicyPromptSection : Str
loopAgentBackendPolicyPromptSection =
  textJoin "\n" [
    "Agent backend policy repair:",
    textConcat [
      "policyName=",
      loopAgentBackendPolicySummary.policyName,
      " backendKind=",
      loopAgentBackendPolicySummary.backendKind,
      " promptTransport=",
      loopAgentBackendPolicySummary.promptTransport,
      " policyValid=",
      if loopAgentBackendPolicySummary.valid then "true" else "false",
      " policyMessage=",
      loopAgentBackendPolicySummary.validationMessage
    ],
    textConcat [
      "policyBlockingGaps=",
      promptPolicyListText loopAgentBackendPolicySummary.blockingGaps
    ],
    textConcat [
      "policyMessages=",
      promptPolicyListText loopAgentBackendPolicySummary.validationMessages
    ],
    textConcat [
      "policyRequiredClosure=",
      promptPolicyListText loopAgentBackendPolicySummary.requiredClosure
    ],
    textConcat [
      "policyMissingPlaceholders=",
      promptPolicyListText loopAgentBackendPolicySummary.missingPlaceholders
    ],
    textConcat [
      "policyRecommendedTemplate=",
      promptPolicyListText loopAgentBackendPolicySummary.recommendedTemplate
    ]
  ]

loopAgentBackendCapabilityPromptSection : Str
loopAgentBackendCapabilityPromptSection =
  textJoin "\n" [
    "Agent backend capability repair:",
    textConcat [
      "capabilityProfile=",
      loopAgentBackendCapabilitySummary.profileName,
      " backendKind=",
      loopAgentBackendCapabilitySummary.backendKind,
      " promptTransport=",
      loopAgentBackendCapabilitySummary.promptTransport,
      " standaloneReady=",
      if loopAgentBackendCapabilitySummary.standaloneReady then "true" else "false",
      " roleCoverage=",
      promptPolicyListText loopAgentBackendCapabilitySummary.roleCoverage
    ],
    textConcat [
      "capabilitySupports=planner:",
      if loopAgentBackendCapabilitySummary.supportsPlannerRole then "true" else "false",
      " builder:",
      if loopAgentBackendCapabilitySummary.supportsBuilderRole then "true" else "false",
      " verifier:",
      if loopAgentBackendCapabilitySummary.supportsVerifierRole then "true" else "false",
      " workspaceEdits:",
      if loopAgentBackendCapabilitySummary.supportsWorkspaceEdits then "true" else "false",
      " childTaskPlanning:",
      if loopAgentBackendCapabilitySummary.supportsChildTaskPlanning then "true" else "false",
      " structuredReports:",
      if loopAgentBackendCapabilitySummary.supportsStructuredReports then "true" else "false",
      " externalModel:",
      if loopAgentBackendCapabilitySummary.requiresExternalModel then "true" else "false"
    ],
    textConcat [
      "capabilityMessages=",
      promptPolicyListText loopAgentBackendCapabilitySummary.validationMessages
    ],
    textConcat [
      "capabilityBlockingGaps=",
      promptPolicyListText loopAgentBackendCapabilitySummary.blockingGaps
    ],
    textConcat [
      "capabilityRequiredClosure=",
      promptPolicyListText loopAgentBackendCapabilitySummary.requiredClosure
    ]
  ]

loopAgentBackendConfigRepairReport : Str -> Str
loopAgentBackendConfigRepairReport backendError =
  textJoin "\n" [
    textConcat ["config-error:", backendError],
    "backendConfigRepair=agent-backend",
    loopAgentBackendPolicyPromptSection,
    loopAgentBackendCapabilityPromptSection
  ]

builderPrompt : Int -> Str
builderPrompt attempt = textJoin "\n" [
  "You are the builder subagent for the Clasp repository.",
  "Read AGENTS.md first if it exists.",
  textConcat ["Read the task file at ", taskFile, "."],
  taskFileContentSection,
  "Drive the repository toward the full task goal. Prefer coherent capability-closing changes over tiny local patches.",
  "Work only in the current checkout. Add or update tests. Run the narrowest checks that cover your changes. Do not run bash scripts/verify-all.sh.",
  "Capability categories to close:",
  capabilityChecklistText,
  "Prefer closing at least one whole failing capability category this attempt, not just one complaint line.",
  builderPolicySection,
  builderFeedbackSection,
  loopAgentBackendPolicyPromptSection,
  loopAgentBackendCapabilityPromptSection,
  builderContextSection attempt,
  "Return JSON matching the provided output schema.",
  "Include the required feedback object in your final JSON.",
  textConcat ["Attempt: ", encode attempt]
]

verifierPrompt : Int -> Str
verifierPrompt attempt = textJoin "\n" [
  "You are the verifier subagent for the Clasp repository.",
  "Read AGENTS.md first if it exists.",
  textConcat ["Read the task file at ", taskFile, "."],
  taskFileContentSection,
  "Evaluate the whole repository against the autonomous swarm confidence goal and required capability categories.",
  verifierPolicySection,
  loopAgentBackendPolicyPromptSection,
  loopAgentBackendCapabilityPromptSection,
  affectedVerificationVerifierPromptSection,
  verifierContextSection attempt,
  textConcat ["Attempt: ", encode attempt]
]

writeLoopState : AttemptStatus -> Str
writeLoopState state = attemptWriteStatus loopSpec state

readLoopState : AttemptStatus
readLoopState = attemptReadStatus loopSpec

syntheticFailureReport : Str -> Str -> VerifierReport
syntheticFailureReport summary detail =
  VerifierReport {
    verdict = "fail",
    summary = summary,
    findings = [detail],
    tests_run = emptyTexts,
    follow_up = ["Retry the failed step after inspecting the persisted swarm run artifacts."],
    capability_statuses = emptyCapabilityStatuses
  }

readVerifierReportPath : Str -> VerifierReport
readVerifierReportPath path = match readFile path {
  Ok raw ->
    match tryDecode VerifierReport raw {
      Ok report -> report,
      Err message ->
        syntheticFailureReport
          (textConcat ["invalid verifier report: ", message])
          message
    },
  Err message ->
    syntheticFailureReport
      (textConcat ["missing verifier report: ", message])
      message
}

readVerifierReport : Int -> VerifierReport
readVerifierReport attempt = readVerifierReportPath (verifierReportPath attempt)

writeFeedback : VerifierReport -> Str
writeFeedback report = match writeFile feedbackPath (encode report) {
  Ok written -> "",
  Err message -> message
}

verifierReportMemoryValue : Int -> VerifierReport -> Str
verifierReportMemoryValue attempt report =
  textJoin "\n" [
    textConcat ["attempt=", encode attempt, " verdict=", report.verdict],
    report.summary,
    textJoin "\n" report.findings,
    textJoin "\n" report.follow_up
  ]

rememberVerifierFeedback : Int -> VerifierReport -> Str
rememberVerifierFeedback attempt report =
  match memoryPut swarmStateRoot objectiveId "" actorName "verifier-feedback" (verifierReportMemoryValue attempt report) {
    Ok memoryValue -> "",
    Err message -> message
  }

writeFeedbackAndMemory : Int -> VerifierReport -> Str
writeFeedbackAndMemory attempt report = {
  let feedbackError = writeFeedback report in
  if feedbackError != "" then
    feedbackError
  else
    rememberVerifierFeedback attempt report
}

writePromptFile : Str -> Str -> Str
writePromptFile path prompt =
  match writeFile path prompt {
    Ok written -> "",
    Err message -> textConcat ["prompt-write-error:", message]
  }

taskInObjective : SwarmTask -> Bool
taskInObjective task = task.objectiveId == objectiveId

taskCompleted : SwarmTask -> Bool
taskCompleted task = task.status == "completed"

taskIdOf : SwarmTask -> Str
taskIdOf task = task.taskId

objectiveProjectedStatusFrom : Str -> SwarmObjective -> Str
objectiveProjectedStatusFrom current objective =
  if objective.objectiveId == objectiveId then
    objective.projectedStatus
  else
    current

mergeDecisionDetailFrom : Str -> SwarmEvent -> Str
mergeDecisionDetailFrom current event =
  if event.kind == "mergegate_decision" then
    event.detail
  else
    current

statusVerifierTaskId : AttemptStatus -> Str
statusVerifierTaskId state =
  if state.lastVerifierTaskId == "" then
    verifierTaskId state.attempt
  else
    state.lastVerifierTaskId

statusApprovalCount : AttemptStatus -> Int
statusApprovalCount state =
  if state.lastVerifierTaskId == "" then
    0
  else
    match approvals (taskHandle swarmStateRoot (statusVerifierTaskId state) actorName) {
      Ok approvalValues -> length approvalValues,
      Err message -> 0
    }

statusMergeDecisionDetail : AttemptStatus -> Str
statusMergeDecisionDetail state =
  if state.lastVerifierTaskId == "" then
    ""
  else
    match tail (taskHandle swarmStateRoot (statusVerifierTaskId state) actorName) 20 {
      Ok eventValues -> fold mergeDecisionDetailFrom "" eventValues,
      Err message -> ""
    }

statusFeedbackSummary : Str
statusFeedbackSummary =
  if fileExists feedbackPath then
    (readVerifierReportPath feedbackPath).summary
  else
    ""

loopAgentBackend : AgentBackendSpec
loopAgentBackend =
  agentBackendSpec agentBin agentModel agentReasoning agentSandbox workspaceRoot agentCommandTemplate

loopAgentBackendValidationMessage : Str
loopAgentBackendValidationMessage =
  if requireStandaloneAgentBackend then
    agentBackendPolicyValidationMessage agentBackendStandalonePolicy loopAgentBackend
  else
    agentBackendValidationMessage loopAgentBackend

loopAgentBackendPolicySummary : AgentBackendPolicySummary
loopAgentBackendPolicySummary =
  if requireStandaloneAgentBackend then
    agentBackendStandalonePolicySummary loopAgentBackend
  else
    agentBackendPolicySummary "default" agentBackendDefaultPolicy loopAgentBackend

loopAgentBackendCapabilityProfile : AgentBackendCapabilityProfile
loopAgentBackendCapabilityProfile =
  agentBackendCapabilityProfileForBackend agentCapabilityProfileName loopAgentBackend

loopAgentBackendCapabilitySummary : AgentBackendCapabilitySummary
loopAgentBackendCapabilitySummary =
  agentBackendStandaloneCapabilitySummary loopAgentBackendCapabilityProfile loopAgentBackend

statusView : AttemptStatus -> StatusView
statusView state =
  match objectives swarmStateRoot {
    Ok objectiveValues ->
      match tasks swarmStateRoot {
        Ok taskValues ->
          let scopedTasks = filter taskInObjective taskValues in
          let readyTaskIds = match ready objectiveRef {
            Ok readyTasks -> map taskIdOf readyTasks,
            Err message -> emptyTexts
          } in
          let approvalCountValue = statusApprovalCount state in
          let mergeDecisionDetailValue = statusMergeDecisionDetail state in
          let projectedStatusValue = fold objectiveProjectedStatusFrom "missing" objectiveValues in
          StatusView {
            state = state,
            agentBackend = agentBackendSummary loopAgentBackend,
            agentBackendPolicy = loopAgentBackendPolicySummary,
            agentBackendCapability = loopAgentBackendCapabilitySummary,
            objectiveProjectedStatus = projectedStatusValue,
            taskCount = length scopedTasks,
            allTaskIds = map taskIdOf scopedTasks,
            completedTaskIds = map taskIdOf (filter taskCompleted scopedTasks),
            readyTaskIds = readyTaskIds,
            approvalCount = approvalCountValue,
            mergeDecisionDetail = mergeDecisionDetailValue,
            mergeGateSatisfied =
              if approvalCountValue == 0 then
                false
              else
                if mergeDecisionDetailValue == "" then
                  false
                else
                  projectedStatusValue == "completed",
            feedbackSummary = statusFeedbackSummary,
            previousVerifierFeedback = attemptPreviousVerifierFeedback loopSpec,
            retryDecision = attemptRetryDecisionFromStatus loopSpec state,
            terminalOutcome = attemptOutcomeFromStatus loopSpec state
          },
        Err message ->
          let approvalCountValue = statusApprovalCount state in
          let mergeDecisionDetailValue = statusMergeDecisionDetail state in
          StatusView {
            state = state,
            agentBackend = agentBackendSummary loopAgentBackend,
            agentBackendPolicy = loopAgentBackendPolicySummary,
            agentBackendCapability = loopAgentBackendCapabilitySummary,
            objectiveProjectedStatus = textConcat ["task-error:", message],
            taskCount = 0,
            allTaskIds = emptyTexts,
            completedTaskIds = emptyTexts,
            readyTaskIds = emptyTexts,
            approvalCount = approvalCountValue,
            mergeDecisionDetail = mergeDecisionDetailValue,
            mergeGateSatisfied = false,
            feedbackSummary = statusFeedbackSummary,
            previousVerifierFeedback = attemptPreviousVerifierFeedback loopSpec,
            retryDecision = attemptRetryDecisionFromStatus loopSpec state,
            terminalOutcome = attemptOutcomeFromStatus loopSpec state
          }
      },
    Err message ->
      let approvalCountValue = statusApprovalCount state in
      let mergeDecisionDetailValue = statusMergeDecisionDetail state in
      StatusView {
        state = state,
        agentBackend = agentBackendSummary loopAgentBackend,
        agentBackendPolicy = loopAgentBackendPolicySummary,
        agentBackendCapability = loopAgentBackendCapabilitySummary,
        objectiveProjectedStatus = textConcat ["objective-error:", message],
        taskCount = 0,
        allTaskIds = emptyTexts,
        completedTaskIds = emptyTexts,
        readyTaskIds = emptyTexts,
        approvalCount = approvalCountValue,
        mergeDecisionDetail = mergeDecisionDetailValue,
        mergeGateSatisfied = false,
        feedbackSummary = statusFeedbackSummary,
        previousVerifierFeedback = attemptPreviousVerifierFeedback loopSpec,
        retryDecision = attemptRetryDecisionFromStatus loopSpec state,
        terminalOutcome = attemptOutcomeFromStatus loopSpec state
      }
  }

statusOutput : Str
statusOutput = encode (statusView readLoopState)

codexReasoningConfig : Str
codexReasoningConfig = agentBackendReasoningConfig loopAgentBackend

templateReplace : Str -> Str -> Str -> Str
templateReplace value needle replacement = agentBackendTemplateReplace value needle replacement

renderAgentCommandArg : Str -> Str -> Str -> Str -> Str -> Str -> Str
renderAgentCommandArg role schemaPath reportPath promptPath prompt value = {
  let request = agentCommandRequest role schemaPath reportPath promptPath prompt in
  agentBackendRenderArg loopAgentBackend request value
}

renderAgentCommand : Str -> Str -> Str -> Str -> Str -> [Str]
renderAgentCommand role schemaPath reportPath promptPath prompt = {
  let request = agentCommandRequest role schemaPath reportPath promptPath prompt in
  agentBackendRenderTemplate loopAgentBackend request
}

codexCommandDefault : Str -> Str -> Str -> [Str]
codexCommandDefault schemaPath reportPath prompt =
  agentBackendCodexCommand loopAgentBackend (agentCommandRequest "agent" schemaPath reportPath "" prompt)

agentCommand : Str -> Str -> Str -> Str -> Str -> [Str]
agentCommand role schemaPath reportPath promptPath prompt =
  agentBackendCommand loopAgentBackend (agentCommandRequest role schemaPath reportPath promptPath prompt)

codexCommand : Str -> Str -> Str -> [Str]
codexCommand schemaPath reportPath prompt = agentCommand "agent" schemaPath reportPath "" prompt

builderCommand : Int -> SwarmCommand
builderCommand attempt = commandSpec "." (agentCommand "builder" builderSchemaPath (builderReportPath attempt) (builderPromptPath attempt) (builderPrompt attempt))

verifierCommand : Int -> SwarmCommand
verifierCommand attempt = commandSpec "." (agentCommand "verifier" verifierSchemaPath (verifierReportPath attempt) (verifierPromptPath attempt) (verifierPrompt attempt))

runBuilderCommand : Int -> Result SwarmRun
runBuilderCommand attempt =
  toolRunWithOptionalLimits (builderHandle attempt) (builderCommand attempt) builderTimeoutMs builderMemoryLimitMb

runVerifierCommand : Int -> Result SwarmRun
runVerifierCommand attempt =
  verifierRunWithOptionalLimits (verifierHandle attempt) "autonomous-confidence" (verifierCommand attempt) verifierTimeoutMs verifierMemoryLimitMb

runFailureDetail : Str -> SwarmRun -> Str
runFailureDetail role run =
  textConcat [
    role,
    " run failed: status=",
    run.status,
    " exit=",
    encode run.exitCode,
    " timedOut=",
    promptBoolText run.timedOut,
    " memoryLimitMb=",
    encode run.memoryLimitMb,
    " stdout=",
    run.stdoutArtifactPath,
    " stderr=",
    run.stderrArtifactPath
  ]

ensureLoopReady : Str
ensureLoopReady =
  if taskFile == "" then
    "config-error:missing-task-file"
  else if workspaceRoot == "" then
    "config-error:missing-workspace-root"
  else if managedAgentRuntimeReady == false then
    "config-error:managed-job-required"
  else {
    let backendError = loopAgentBackendValidationMessage in
    if backendError != "" then
      loopAgentBackendConfigRepairReport backendError
    else {
      let rootError = attemptEnsureRoot loopSpec in
      if rootError != "" then
        rootError
      else
        match mkdirAll workspaceRoot {
          Ok workspaceCreated ->
            ensurePolicies,
          Err message ->
            textConcat ["workspace-root-error:", message]
        }
    }
}

ensureAttemptTasks : Int -> Str
ensureAttemptTasks attempt =
  attemptEnsureAttemptTasks
    loopSpec
    attempt
    (textConcat ["Run builder attempt ", encode attempt, " directly from ordinary Clasp code."])
    (textConcat ["Run verifier attempt ", encode attempt, " directly from ordinary Clasp code."])

finalizeWithReport : Int -> Str -> Bool -> VerifierReport -> Str
finalizeWithReport attempt verdict completed report = {
  let feedbackError = writeFeedbackAndMemory attempt report in
  if feedbackError != "" then
    textConcat ["feedback-error:", feedbackError]
  else {
    let outcome = attemptTerminalOutcome loopSpec attempt verdict completed in
    let finalState = attemptStatusFromTerminalOutcome loopSpec outcome in
    let stateError = attemptPersistTerminalOutcome loopSpec outcome in
    if stateError != "" then
      textConcat ["state-error:", stateError]
    else
      encode (statusView finalState)
  }
}

continueAfterFailure : Int -> VerifierReport -> Str
continueAfterFailure attempt report = {
  let feedbackError = writeFeedbackAndMemory attempt report in
  if feedbackError != "" then
    textConcat ["feedback-error:", feedbackError]
  else {
    let decision = attemptRetryDecision loopSpec attempt report.summary in
    if decision.terminal then
      finalizeWithReport attempt "fail" false report
    else
      let retryState = attemptRetryStatus loopSpec decision in
      let stateError = writeLoopState retryState in
      if stateError != "" then
        textConcat ["state-error:", stateError]
      else
        runAttempt retryState
  }
}

finishAfterApproval : Int -> VerifierReport -> Str
finishAfterApproval attempt report =
  match policySet (verifierHandle attempt) mergegateName requiredApprovals requiredVerifiers {
    Err message ->
      continueAfterFailure attempt (syntheticFailureReport "merge policy setup failed" message),
    Ok policy ->
      match approve (verifierHandle attempt) approvalName {
        Err message ->
          continueAfterFailure attempt (syntheticFailureReport "approval failed" message),
        Ok approvalValue ->
          match mergegateDecide (verifierHandle attempt) mergegateName requiredVerifiers {
            Err message ->
              continueAfterFailure attempt (syntheticFailureReport "mergegate decision failed" message),
            Ok decision ->
              if decision.verdict == "pass" then
                finalizeWithReport attempt "pass" true report
              else
                continueAfterFailure attempt (syntheticFailureReport "mergegate did not pass" decision.verdict)
          }
      }
  }

verifyTaskReady : Int -> Str
verifyTaskReady attempt = match ready objectiveRef {
  Ok readyTasks ->
    if attemptTaskListHasId (verifierTaskId attempt) readyTasks then
      ""
    else
      textConcat ["verifier-not-ready:", verifierTaskId attempt],
  Err message ->
    message
}

runVerifierAttempt : Int -> Str
runVerifierAttempt attempt = {
  let stateError =
    writeLoopState
      (attemptStatusForPhase loopSpec attempt "verifier-running" "pending" false false) in
  if stateError != "" then
    textConcat ["state-error:", stateError]
  else
    match lease (verifierHandle attempt) {
      Err message ->
        continueAfterFailure attempt (syntheticFailureReport "verifier lease failed" message),
      Ok leaseValue ->
        let promptError = writePromptFile (verifierPromptPath attempt) (verifierPrompt attempt) in
        if promptError != "" then
          continueAfterFailure attempt (syntheticFailureReport "verifier prompt write failed" promptError)
        else
          match runVerifierCommand attempt {
            Err message ->
              continueAfterFailure attempt (syntheticFailureReport "verifier run failed" message),
            Ok runValue ->
              match finishToolRun (verifierHandle attempt) runValue {
                Err message ->
                  continueAfterFailure attempt (syntheticFailureReport "verifier task status update failed" message),
                Ok statusValue ->
                  if runPassed runValue then
                    if fileExists (verifierReportPath attempt) then {
                      let report = readVerifierReport attempt in
                      if report.verdict == "pass" then
                        finishAfterApproval attempt report
                      else
                        continueAfterFailure attempt report
                    } else
                      continueAfterFailure
                        attempt
                        (syntheticFailureReport
                          "verifier step failed before producing a durable report"
                          runValue.stderrArtifactPath)
                  else
                    continueAfterFailure
                      attempt
                      (syntheticFailureReport
                        "verifier run failed"
                        (runFailureDetail "verifier" runValue))
              }
          }
    }
}

runBuilderAttempt : Int -> Str
runBuilderAttempt attempt = {
  let prepError = ensureLoopReady in
  if prepError != "" then
    prepError
  else {
    let taskError = ensureAttemptTasks attempt in
    if taskError != "" then
      textConcat ["task-error:", taskError]
    else {
      let stateError =
        writeLoopState
          (attemptStatusForPhase loopSpec attempt "builder-running" "pending" false false) in
      if stateError != "" then
        textConcat ["state-error:", stateError]
      else
        match lease (builderHandle attempt) {
          Err message ->
            continueAfterFailure attempt (syntheticFailureReport "builder lease failed" message),
          Ok leaseValue ->
            let promptError = writePromptFile (builderPromptPath attempt) (builderPrompt attempt) in
            if promptError != "" then
              continueAfterFailure attempt (syntheticFailureReport "builder prompt write failed" promptError)
            else
              match runBuilderCommand attempt {
                Err message ->
                  continueAfterFailure attempt (syntheticFailureReport "builder run failed" message),
                Ok runValue ->
                  match finishToolRun (builderHandle attempt) runValue {
                    Err message ->
                      continueAfterFailure attempt (syntheticFailureReport "builder task status update failed" message),
                    Ok statusValue ->
                      if runPassed runValue then
                        if fileExists (builderReportPath attempt) then {
                          let readyError = verifyTaskReady attempt in
                          if readyError != "" then
                            continueAfterFailure attempt (syntheticFailureReport "verifier task did not become ready" readyError)
                          else
                            runVerifierAttempt attempt
                        } else
                          continueAfterFailure
                            attempt
                            (syntheticFailureReport
                              "builder step failed before producing a durable report"
                              runValue.stderrArtifactPath)
                      else
                        continueAfterFailure
                          attempt
                          (syntheticFailureReport
                            "builder run failed"
                            (runFailureDetail "builder" runValue))
                  }
              }
        }
    }
  }
}
attemptLimitForState : AttemptStatus -> Int
attemptLimitForState state =
  if state.maxAttempts == 0 then
    maxAttempts
  else
    state.maxAttempts

runAttempt : AttemptStatus -> Str
runAttempt state =
  if state.attempt > attemptLimitForState state then
    finalizeWithReport state.attempt "fail" false (syntheticFailureReport "attempt limit reached" "No verifier pass report was produced before the configured attempt limit.")
  else
    runBuilderAttempt state.attempt

resumeLoop : AttemptStatus -> Str
resumeLoop state =
  if state.final then
    encode (statusView state)
  else
    runAttempt state

main : Str
main =
  if commandName == "status" then
    statusOutput
  else
    resumeLoop readLoopState
