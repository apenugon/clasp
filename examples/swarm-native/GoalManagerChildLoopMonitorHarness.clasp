module Main

import GoalManagerChildLoopMonitor
import GoalManagerStateView
import GoalManagerTaskStatusRuntime
import GoalManagerMonitoredLoop
import GoalManagerPrelude
import GoalManagerTypes
import Swarm

writeTextFile : Str -> Str -> Str
writeTextFile path contents =
  match writeFile path contents {
    Ok written -> "",
    Err message -> message
  }

writeWatchedHeartbeat : Str -> Bool -> Bool -> Int -> Int -> Str
writeWatchedHeartbeat path running completed exitCode updatedAtMs =
  writeTextFile
    path
    (encode
      (WatchedProcess {
        pid = 123,
        running = running,
        completed = completed,
        exitCode = exitCode,
        status = "",
        timedOut = false,
        error = "",
        outputLimitBytes = 0,
        stdoutTruncated = false,
        stderrTruncated = false,
        stdoutPath = textConcat [path, ".stdout"],
        stderrPath = textConcat [path, ".stderr"],
        heartbeatPath = path,
        updatedAtMs = updatedAtMs
      }))

writeChildState : Str -> Str -> Bool -> Bool -> Str
writeChildState taskId phase completed final =
  writeTextFile
    (taskStatusPath taskId)
    (encode
      (ChildLoopState {
        attempt = 1,
        phase = phase,
        verdict = if completed then "pass" else "pending",
        completed = completed,
        builderRuns = 1,
        verifierRuns = 0,
        healthy = true,
        needsAttention = false,
        attentionReason = "",
        final = final
      }))

prepareTaskRoot : Str -> Str
prepareTaskRoot taskId =
  match mkdirAll (taskReportStateRoot taskId) {
    Ok made -> "",
    Err message -> message
  }

statusLine : Str -> MonitoredLoopOutcome -> Str
statusLine label outcome =
  textConcat [label, "=", outcome.status]

boolLine : Str -> Bool -> Str
boolLine label value =
  textConcat [label, "=", encode value]

intLine : Str -> Int -> Str
intLine label value =
  textConcat [label, "=", encode value]

textIncludes : Str -> Str -> Bool
textIncludes value needle = length (textSplit value needle) > 1

textListIncludes : [Str] -> Str -> Bool
textListIncludes values needle = {
  let mut found = false;
  for value in values {
    if found then
      found
    else if textIncludes value needle then {
      found = true;
      found
    } else
      found
  };
  found
}

waitingReasonsIncludeKind : [StatusWaitingReason] -> Str -> Bool
waitingReasonsIncludeKind reasons kind = {
  let mut found = false;
  for reason in reasons {
    if found then
      found
    else if reason.kind == kind then {
      found = true;
      found
    } else
      found
  };
  found
}

waitingReasonsIncludeDetail : [StatusWaitingReason] -> Str -> Bool
waitingReasonsIncludeDetail reasons needle = {
  let mut found = false;
  for reason in reasons {
    if found then
      found
    else if textListIncludes reason.details needle then {
      found = true;
      found
    } else
      found
  };
  found
}

firstError : [Str] -> Str
firstError errors =
  textJoin "" errors

ensureLeaseTask : Str -> Str
ensureLeaseTask taskId =
  match objectiveCreate swarmStateRoot objectiveId "Exercise manager child loop lease heartbeats." 4 4 {
    Err message ->
      message,
    Ok objective ->
      match taskCreate objectiveRef taskId "Keep a live child task lease fresh while awaiting." emptyTexts 1 5000 {
        Err createMessage ->
          createMessage,
        Ok task ->
          match lease (taskHandleFor taskId) {
            Err leaseMessage -> leaseMessage,
            Ok leased -> ""
          }
      }
  }

spawnLeaseChild : Str -> MonitoredLoopOutcome
spawnLeaseChild taskId =
  monitoredLoopSpawn
    (monitoredLoopSpec
      "."
      (taskProcessStdoutPath taskId)
      (taskProcessStderrPath taskId)
      (taskProcessHeartbeatPath taskId)
      childLoopWatchPollMs
      childLoopAwaitTimeoutMs
      0
      2
      64
      ["bash", "-c", "sleep 0.25"])

taskHeartbeatSeen : Str -> Bool
taskHeartbeatSeen taskId =
  match status (taskHandleFor taskId) {
    Ok task -> task.heartbeatSeen,
    Err message -> false
  }

writeHarnessRetryRecord : Str -> Str
writeHarnessRetryRecord taskId =
  appendRetryRecoveryRecord
    (retryRecoveryRecord
      2
      taskId
      "child-loop"
      "retrying"
      "timeout waiting for child"
      [taskFeedbackPath taskId, taskStatusPath taskId]
      ["claspc", "run", "examples/feedback-loop/Main.clasp"]
      "timeout"
      124
      (taskProcessStdoutPath taskId)
      (taskProcessStderrPath taskId)
      (taskProcessHeartbeatPath taskId)
      ["managerRetryCount=1", "launchOutcome=timeout"])

writeHarnessPlannerRecord : Str
writeHarnessPlannerRecord =
  appendRetryRecoveryRecord
    (retryRecoveryRecord
      1
      (plannerTaskIdForWave 1)
      "planner"
      "retrying"
      "lease blocker"
      [plannerReportPathFor 1, plannerStdoutPathFor 1, plannerStderrPathFor 1]
      ["codex", "exec"]
      "retry"
      0
      (plannerStdoutPathFor 1)
      (plannerStderrPathFor 1)
      ""
      ["wave=1"])

writeHarnessResourceActionRecord : Str -> Str
writeHarnessResourceActionRecord taskId =
  appendRetryRecoveryRecord
    (retryRecoveryRecord
      1
      taskId
      "resource-guard"
      "external-resource-blocker"
      "managed child loop resource action"
      [taskFeedbackPath taskId]
      ["claspc", "run", "examples/swarm-native/GoalManagerServiceMain.clasp"]
      "blocked"
      0
      (taskProcessStdoutPath taskId)
      (taskProcessStderrPath taskId)
      (taskProcessHeartbeatPath taskId)
      [
        "{\"recommendedAction\":{\"type\":\"repair-memory-enforcer\",\"reason\":\"systemd-scope-required-unavailable\"}}",
        "managedJobStatus=memory-enforcer-unavailable"
      ])

runHarness : Str
runHarness = {
  let missingTask = "missing-launch" in
  let malformedTask = "malformed-launch" in
  let unresolvedTask = "unresolved-launch" in
  let liveTask = "stale-live-launch" in
  let completedTask = "stale-completed-launch" in
  let leaseTask = "lease-fresh" in
  let retryTask = "retry-record-task" in
  let resourceActionTask = "resource-action-record" in
  let setupError =
    firstError [
      prepareTaskRoot missingTask,
      prepareTaskRoot malformedTask,
      prepareTaskRoot unresolvedTask,
      prepareTaskRoot liveTask,
      prepareTaskRoot completedTask,
      prepareTaskRoot leaseTask,
      prepareTaskRoot retryTask,
      prepareTaskRoot resourceActionTask,
      ensureLeaseTask leaseTask,
      writeTextFile (taskProcessHeartbeatPath malformedTask) "{",
      writeTextFile (taskProcessHeartbeatPath unresolvedTask) "{}",
      writeWatchedHeartbeat (taskProcessHeartbeatPath liveTask) true false 1 0,
      writeChildState liveTask "builder-running" false false,
      writeWatchedHeartbeat (taskBuilderHeartbeatPath liveTask 1) true false 1 123,
      writeWatchedHeartbeat (taskProcessHeartbeatPath completedTask) true false 1 0,
      writeChildState completedTask "builder-running" false false,
      writeWatchedHeartbeat (taskBuilderHeartbeatPath completedTask 1) false true 0 124,
      writeHarnessRetryRecord retryTask,
      writeHarnessResourceActionRecord resourceActionTask,
      writeHarnessPlannerRecord
    ] in
  if setupError != "" then
    textConcat ["error:", setupError]
  else
    let leaseSpawnOutcome = spawnLeaseChild leaseTask in
    let leaseAwaitOutcome = awaitChildLoopOutcome [leaseTask] in
    let latestRetryRecord = latestRetryRecoveryRecord retryTask in
    let plannerRetryRecord = latestRetryRecoveryRecord (plannerTaskIdForWave 1) in
    let retryMailboxDetails = retryRecoveryMailboxDetails retryTask in
    let retryWaitingReasons = retryRecoveryWaitingReasonForTask retryTask in
    let resourceActionRecord = latestRetryRecoveryRecord resourceActionTask in
    let resourceActionMailboxDetails = retryRecoveryMailboxDetails resourceActionTask in
    let resourceActionWaitingReasons = retryRecoveryWaitingReasonForTask resourceActionTask in
    textJoin
      "\n"
      [
        statusLine "missing-launch" (childLoopLaunchOutcome missingTask),
        statusLine "malformed-launch" (childLoopLaunchOutcome malformedTask),
        statusLine "unresolved-launch" (childLoopLaunchOutcome unresolvedTask),
        boolLine "stale-live-running" (childLoopLaunchRunning liveTask),
        boolLine "stale-live-completed" (childLoopLaunchCompleted liveTask),
        boolLine "stale-inner-completed-running" (childLoopLaunchRunning completedTask),
        boolLine "stale-inner-completed-completed" (childLoopLaunchCompleted completedTask),
        statusLine "lease-spawn" leaseSpawnOutcome,
        statusLine "lease-await" leaseAwaitOutcome,
        boolLine "lease-heartbeat-seen" (taskHeartbeatSeen leaseTask),
        intLine "retry-record-count" (length (readRetryRecoveryRecords retryTask)),
        textConcat ["retry-record-latest=", retryRecoverySummaryText latestRetryRecord],
        boolLine "retry-record-mailbox-has-path" (textListIncludes retryMailboxDetails "retryRecordPath="),
        boolLine "retry-record-mailbox-has-review" (textListIncludes retryMailboxDetails "retryRecordRecoveryTask=retry-recovery-review"),
        boolLine "retry-record-status-has-kind" (waitingReasonsIncludeKind retryWaitingReasons "retry-recovery-records"),
        boolLine "retry-record-status-has-review" (waitingReasonsIncludeDetail retryWaitingReasons "retry-recovery-review"),
        textConcat ["resource-action-summary=", retryRecoveryActionSummaryText resourceActionRecord],
        boolLine "resource-action-mailbox-has-task" (textListIncludes resourceActionMailboxDetails "retryRecordRecoveryTask=resource-memory-enforcer-recovery"),
        boolLine "resource-action-mailbox-has-guidance" (textListIncludes resourceActionMailboxDetails "do not bypass memory enforcement"),
        boolLine "resource-action-status-has-task" (waitingReasonsIncludeDetail resourceActionWaitingReasons "resource-memory-enforcer-recovery"),
        textConcat ["planner-record-latest=", retryRecoverySummaryText plannerRetryRecord]
      ]
}

main : Str
main = runHarness
