module GoalManagerTypes

import AgentBackend
import Swarm

record WatchedProcess = {
  pid : Int,
  running : Bool,
  completed : Bool,
  exitCode : Int,
  status : Str,
  timedOut : Bool,
  error : Str,
  outputLimitBytes : Int,
  stdoutTruncated : Bool,
  stderrTruncated : Bool,
  stdoutPath : Str,
  stderrPath : Str,
  heartbeatPath : Str,
  updatedAtMs : Int
}

record LegacyWatchedProcess = {
  pid : Int,
  running : Bool,
  completed : Bool,
  exitCode : Int,
  stdoutPath : Str,
  stderrPath : Str,
  heartbeatPath : Str,
  updatedAtMs : Int
}

legacyWatchedProcessStatus : LegacyWatchedProcess -> Str
legacyWatchedProcessStatus process =
  if process.running then
    "running"
  else if process.completed then
    if process.exitCode == 0 then
      "completed-pass"
    else if process.exitCode == 124 then
      "timeout"
    else
      "completed-fail"
  else
    ""

watchedProcessFromLegacy : LegacyWatchedProcess -> WatchedProcess
watchedProcessFromLegacy process =
  WatchedProcess {
    pid = process.pid,
    running = process.running,
    completed = process.completed,
    exitCode = process.exitCode,
    status = legacyWatchedProcessStatus process,
    timedOut = process.exitCode == 124,
    error = if process.exitCode == 124 then "timeout" else "",
    outputLimitBytes = 0,
    stdoutTruncated = false,
    stderrTruncated = false,
    stdoutPath = process.stdoutPath,
    stderrPath = process.stderrPath,
    heartbeatPath = process.heartbeatPath,
    updatedAtMs = process.updatedAtMs
  }

