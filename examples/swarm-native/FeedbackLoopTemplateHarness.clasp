secondBuilderPrompt =
  textJoin "\n" [
    "You are the builder subagent.",
    "Verifier feedback from the previous attempt:",
    "force-close-category",
    "Agent backend policy repair:",
    "policyMessages=",
    "- agent-backend-policy-requires-prompt-path",
    "policyMissingPlaceholders=",
    "- {prompt_path}",
    "policyRecommendedTemplate=",
    "- {agent_bin} --role {role} --schema {schema_path} --report {report_path} --prompt-path {prompt_path} --workspace {workspace_root}",
    "Agent backend capability repair:",
    "capabilityMessages=",
    "- none",
    "capabilitySupports=planner:true builder:true verifier:true workspaceEdits:true childTaskPlanning:true structuredReports:true externalModel:false",
    "capabilityRequiredClosure=",
    "- none",
    "Swarm context pack:",
    "task: builder-2 status=ready ready=true attempts=1",
    "artifact search matches:",
    "- verifier feedback exists",
    "semantic index artifact matches:",
    "- compiler checker",
    "semantic index edit files:",
    "src/Compiler/Checker.clasp",
    "semantic index surface ids:",
    "compiler:checker",
    "benchmark history matches:",
    "- prior run closed",
    "dependency task ids:",
    "- iteration-speed-loop",
    "dependency task statuses:",
    "- completed",
    "dependency task ready:",
    "- false",
    "verifier-feedback",
    "Task file content:",
    taskFileContent
  ]

secondVerifierPrompt : Str
secondVerifierPrompt =
  textJoin "\n" [
    "You are the verifier subagent.",
    "Agent backend policy repair:",
    "policyMessages=",
    "- agent-backend-policy-requires-prompt-path",
    "policyMissingPlaceholders=",
    "- {prompt_path}",
    "policyRecommendedTemplate=",
    "- {agent_bin} --role {role} --schema {schema_path} --report {report_path} --prompt-path {prompt_path} --workspace {workspace_root}",
    "Agent backend capability repair:",
    "capabilityMessages=",
    "- none",
    "capabilitySupports=planner:true builder:true verifier:true workspaceEdits:true childTaskPlanning:true structuredReports:true externalModel:false",
    "capabilityRequiredClosure=",
    "- none",
    "Swarm context pack:",
    "task: verifier-2 status=ready ready=true attempts=1",
    "artifact search matches:",
    "- builder output exists",
    "semantic index artifact matches:",
    "- compiler checker",
    "semantic index edit files:",
    "src/Compiler/Checker.clasp",
    "semantic index surface ids:",
    "compiler:checker",
    "benchmark history matches:",
    "- prior run closed",
    "dependency task ids:",
    "- builder-2",
    "dependency task statuses:",
    "- completed",
    "dependency task ready:",
    "- false",
    "builder-2",
    "task: verifier-2",
    "run trace:",
    "- builder-2 completed",
    "Task file content:",
    taskFileContent
  ]

runLocalClaspTemplate : Str
runLocalClaspTemplate = {
  let workspaceTextPath = pathJoin [workspaceRoot, "workspace.txt"];
  let workspaceError = writeText workspaceTextPath "fixed-after-feedback\n";
  if workspaceError != "" then
    textConcat ["workspace-error:", workspaceError]
  else {
    let builderReportError = writeText builderTwoReportPath (encode localBuilderReport);
    let firstVerifierError = writeText verifierOneReportPath (encode firstLocalVerifierReport);
    let secondVerifierError = writeText verifierTwoReportPath (encode secondLocalVerifierReport);
    let secondBuilderPromptError = writeText builderTwoPromptPath secondBuilderPrompt;
    let secondVerifierPromptError = writeText verifierTwoPromptPath secondVerifierPrompt;
    let report = feedbackLoopTemplateReport 2 true;
    let reportError = writeReport report;
    if builderReportError != "" then
      textConcat ["builder-report-error:", builderReportError]
    else if firstVerifierError != "" then
      textConcat ["verifier-report-error:", firstVerifierError]
    else if secondVerifierError != "" then
      textConcat ["verifier-report-error:", secondVerifierError]
    else if secondBuilderPromptError != "" then
      textConcat ["builder-prompt-error:", secondBuilderPromptError]
    else if secondVerifierPromptError != "" then
      textConcat ["verifier-prompt-error:", secondVerifierPromptError]
    else if reportError != "" then
      textConcat ["report-error:", reportError]
    else
      encode report
  }
}

runHarness : Str
runHarness =
  if backendSummary.valid then
    match mkdirAll stateRoot {
      Err message ->
        textConcat ["state-error:", message],
      Ok created ->
        match mkdirAll workspaceRoot {
          Err message ->
            textConcat ["workspace-error:", message],
          Ok workspaceCreated ->
            if promptTransport == "inline-prompt" then
              runProviderNeutralTemplate
            else
              runLocalClaspTemplate
        }
    }
  else
    "config-error:agent-backend-template-missing-prompt-input"

main : Str
main =
  if commandName == "status" then
    readReport
  else
    runHarness
