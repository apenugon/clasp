module LocalSourceEdit

foreign localSourceEditWorkspaceReadFileRaw : Str -> Str -> Result Str = "workspaceReadFile"
foreign localSourceEditWorkspaceWriteFileRaw : Str -> Str -> Str -> Result Str = "workspaceWriteFile"
foreign localSourceEditWorkspaceMkdirAllRaw : Str -> Str -> Result Str = "workspaceMkdirAll"
foreign localSourceEditWorkspaceReplaceTextRaw : Str -> Str -> Str -> Str -> Int -> Int -> Result Int = "workspaceReplaceText"

record SourceEditPatch = {
  target : Str,
  findText : Str,
  replaceText : Str
}

type SourceEditPatchParseResult = ParsedSourceEditPatch SourceEditPatch | MissingSourceEditPatch Str

localSourceEditEmptyTexts : [Str]
localSourceEditEmptyTexts = []

localSourceEditEmptyPatches : [SourceEditPatch]
localSourceEditEmptyPatches = []

standaloneSwarmSourceEditExampleTargets : [Str]
standaloneSwarmSourceEditExampleTargets =
  ["src/StandaloneSwarmReadiness.clasp", "src/StandaloneSwarmVerifier.clasp"]

sourceEditPlanHeading : Str
sourceEditPlanHeading = "Source edit plan:"

sourceEditPatchesHeading : Str
sourceEditPatchesHeading = "Source edit patches:"

sourceEditPatchTargetSeparator : Str
sourceEditPatchTargetSeparator = " :: "

sourceEditPatchReplacementSeparator : Str
sourceEditPatchReplacementSeparator = " => "

standaloneSwarmSourceEditPlanTargets : [Str]
standaloneSwarmSourceEditPlanTargets =
  [
    "src/StandaloneSwarmReadiness.clasp",
    "src/StandaloneSwarmVerifier.clasp",
    "examples/swarm-native/StandaloneSwarmHarness.clasp",
    "examples/swarm-native/StandaloneSwarmRouting.clasp",
    "scripts/standalone-swarm-readiness.sh",
    "scripts/standalone-swarm-verify.sh",
    "docs/standalone-swarm-readiness.md",
    "runtime/standalone_swarm_probe.rs"
  ]

