plannerPolicyPath : Str
plannerPolicyPath = pathJoin [stateRootPath, "planner-policy.md"]

defaultPlannerPolicyText : Str
defaultPlannerPolicyText = textJoin "\n" [
  "Decompose the high-level goal into 1-3 bounded implementation tasks.",
  "Prefer compiler/runtime/language changes over docs-only work.",
  "Keep dependencies explicit and acyclic.",
  "Each planned task should be specific enough to hand directly to a builder/verifier loop.",
  "Do not assume a fixed named agent taxonomy beyond the minimal substrate. Let coordination patterns emerge from task structure and the shared mailbox."
]

plannerPolicyFallbackText : Str
plannerPolicyFallbackText =
  if fileExists plannerPolicyPath then
    match readFile plannerPolicyPath {
      Ok policyText -> policyText,
      Err readMessage -> defaultPlannerPolicyText
    }
  else
    defaultPlannerPolicyText

plannerPolicyText : Str
plannerPolicyText = match envVar "CLASP_MANAGER_PLANNER_POLICY_JSON" {
  Ok raw -> if raw == "" then plannerPolicyFallbackText else decode Str raw,
  Err message -> plannerPolicyFallbackText
}

codexReasoningConfig : Str
codexReasoningConfig = textConcat ["model_reasoning_effort=\"", agentReasoning, "\""]

templateReplace : Str -> Str -> Str -> Str
templateReplace value needle replacement = textJoin replacement (textSplit value needle)

renderAgentCommandArg : Str -> Str -> Str -> Str -> Str -> Str -> Str
renderAgentCommandArg role schemaPath reportPath promptPath workspacePath value = {
  let rendered0 = templateReplace value "{role}" role in
  let rendered1 = templateReplace rendered0 "{schema_path}" schemaPath in
  let rendered2 = templateReplace rendered1 "{report_path}" reportPath in
  let rendered3 = templateReplace rendered2 "{prompt_path}" promptPath in
  let rendered4 = templateReplace rendered3 "{workspace_root}" workspacePath in
  let rendered5 = templateReplace rendered4 "{agent_bin}" agentBin in
  let rendered6 = templateReplace rendered5 "{model}" agentModel in
  let rendered7 = templateReplace rendered6 "{reasoning}" agentReasoning in
  templateReplace rendered7 "{sandbox}" agentSandbox
}

renderAgentCommand : [Str] -> Str -> Str -> Str -> Str -> Str -> [Str]
renderAgentCommand template role schemaPath reportPath promptPath workspacePath = {
  let mut rendered = emptyTexts;
  for arg in template {
    rendered = append rendered [renderAgentCommandArg role schemaPath reportPath promptPath workspacePath arg];
    rendered
  };
  rendered
}

traceEnabled : Bool
traceEnabled = match envVar "CLASP_MANAGER_TRACE_JSON" {
  Ok raw -> true,
  Err message -> false
}

tracePath : Str
tracePath = pathJoin [stateRootPath, "trace.log"]

appendManagerTrace : Str -> Str
appendManagerTrace label =
  if traceEnabled then
    match appendFile tracePath (textConcat [label, "\n"]) {
      Ok written -> "",
      Err message -> message
    }
  else
    ""

appendBootstrapTrace : Str -> Str
appendBootstrapTrace label = {
  let stateRootError = match mkdirAll stateRootPath {
    Ok created -> "",
    Err message -> message
  } in
  if stateRootError != "" then
    stateRootError
  else
    appendManagerTrace label
}

