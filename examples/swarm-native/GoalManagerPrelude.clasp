processResultError : Str -> Result ProcessResult
processResultError message = Err message

processResult : Result Str -> Result ProcessResult
processResult value = match value {
  Ok raw -> Ok (decode ProcessResult raw),
  Err message -> processResultError message
}

runCommand : Str -> [Str] -> Result ProcessResult
runCommand cwd command = processResult (runCommandRaw cwd command)

promotedNativeWorkspaceArtifactRepairScript : Str
promotedNativeWorkspaceArtifactRepairScript = textJoin "\n" [
  "set -euo pipefail",
  "src=\"$1\"",
  "dst=\"$2\"",
  "if [ ! -f \"$src/runtime/claspc.rs\" ]; then",
  "  exit 0",
  "fi",
  "required_artifacts=(",
  "  src/stage1.native.image.json",
  "  src/stage1.compiler.native.image.json",
  "  src/embedded.native.image.json",
  "  src/embedded.compiler.native.image.json",
  "  src/stage1.native.native.image.json",
  "  src/stage1.hello.native.image.json",
  "  src/stage1.goal-manager.native.image.json",
  "  src/stage1.task-workspace-runtime-harness.native.image.json",
  "  src/stage1.compiler.source-export-cache-v1.json",
  "  src/stage1.compiler.module-summary-cache-v2.json",
  ")",
  "for rel in \"${required_artifacts[@]}\"; do",
  "  if [ ! -f \"$src/$rel\" ]; then",
  "    printf 'missing required promoted native artifact in source workspace: %s\n' \"$rel\" >&2",
  "    exit 3",
  "  fi",
  "  mkdir -p \"$dst/$(dirname -- \"$rel\")\"",
  "  cp -p \"$src/$rel\" \"$dst/$rel\"",
  "  if [ ! -f \"$dst/$rel\" ]; then",
  "    printf 'failed to materialize required promoted native artifact: %s\n' \"$rel\" >&2",
  "    exit 3",
  "  fi",
  "done"
]

repairPromotedNativeWorkspaceArtifacts : Str -> Str -> Str
repairPromotedNativeWorkspaceArtifacts sourceRoot destinationRoot =
  match runCommand "." [
    "bash",
    "-c",
    promotedNativeWorkspaceArtifactRepairScript,
    "repair-promoted-native-artifacts",
    sourceRoot,
    destinationRoot
  ] {
    Err message -> message,
    Ok result ->
      if result.exitCode == 0 then
        ""
      else if result.stderr != "" then
        result.stderr
      else
        result.stdout
  }

workspaceGitInitScript : Str
workspaceGitInitScript = textJoin "\n" [
  "set -euo pipefail",
  "root=\"$1\"",
  "if [ ! -d \"$root\" ]; then",
  "  printf 'missing workspace root: %s\n' \"$root\" >&2",
  "  exit 2",
  "fi",
  "if [ -e \"$root/.git\" ]; then",
  "  exit 0",
  "fi",
  "if ! command -v git >/dev/null 2>&1; then",
  "  mkdir -p \"$root/.git\"",
  "  printf 'git unavailable; boundary only\n' >\"$root/.git/CLASP_BOUNDARY\"",
  "  exit 0",
  "fi",
  "git -C \"$root\" init -q",
  "git -C \"$root\" config user.name 'Clasp Swarm'",
  "git -C \"$root\" config user.email 'clasp-swarm@example.invalid'",
  "git -C \"$root\" add -A",
  "git -C \"$root\" commit -q -m 'workspace baseline' >/dev/null 2>&1 || true"
]

initializeWorkspaceGitRepo : Str -> Str
initializeWorkspaceGitRepo root =
  match runCommand "." ["bash", "-c", workspaceGitInitScript, "init-workspace-git", root] {
    Err message ->
      message,
    Ok process ->
      if process.exitCode == 0 then
        ""
      else if process.stderr != "" then
        process.stderr
      else
        process.stdout
  }
