watchPollMs : Int
watchPollMs = readEnvInt "CLASP_LOOP_WATCH_POLL_MS_JSON" 1000

watchModeEnabled : Bool
watchModeEnabled = match envVar "CLASP_LOOP_WATCH_POLL_MS_JSON" {
  Ok raw -> true,
  Err message -> false
}

