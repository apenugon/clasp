baselineDiffScript : Int -> Str
baselineDiffScript attempt = {
  let diffPath = baselineDiffPath attempt in
  textConcat [
    "set +e\n",
    "out=", encode diffPath, "\n",
    "tmp=\"${out}.tmp.$$\"\n",
    "rm -f \"$tmp\"\n",
    "diff -ruN ",
    baselineExcludeFlags,
    encode baselineWorkspace,
    " ",
    encode workspaceRoot,
    " >\"$tmp\"\n",
    "status=$?\n",
    "if [ \"$status\" -gt 1 ]; then printf 'diff failed with status %s\\n' \"$status\" >&2; rm -f \"$tmp\"; exit \"$status\"; fi\n",
    "if [ -s \"$tmp\" ]; then mv \"$tmp\" \"$out\"; else : >\"$out\"; rm -f \"$tmp\"; fi\n"
  ]
}

refreshBaselineDiff : Int -> Str
refreshBaselineDiff attempt = {
  let tracedStart = tracePoint (textConcat ["diff:start:", encode attempt]) in
  let diffPath = baselineDiffPath attempt in
  let result =
    runProcess launcherCwd [
      "bash",
      "-lc",
      baselineDiffScript attempt
    ] in
  if result.exitCode == 0 then
    if fileExists diffPath then
      let tracedWrite = tracePoint (textConcat ["diff:write-ok:", encode attempt]) in
      ""
    else
      let tracedWriteMissing = tracePoint (textConcat ["diff:write-missing:", encode attempt]) in
      textConcat ["diff artifact missing: ", diffPath]
  else
    let tracedWriteError = tracePoint (textConcat ["diff:write-err:", result.stderr]) in
    result.stderr
}

textIncludes : Str -> Str -> Bool
textIncludes value needle = length (textSplit value needle) > 1

