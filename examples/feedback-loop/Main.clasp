handoffCommandList : [Str]
handoffCommandList = readEnvTextList "CLASP_LOOP_HANDOFF_COMMAND_JSON" emptyTexts

handoffReadyPath : Str
handoffReadyPath = readEnvText "CLASP_LOOP_HANDOFF_READY_PATH_JSON" ""

handoffReadyContains : Str
handoffReadyContains = readEnvText "CLASP_LOOP_HANDOFF_READY_CONTAINS_JSON" "ready"

handoffReadyPollMs : Int
handoffReadyPollMs = readEnvInt "CLASP_LOOP_HANDOFF_READY_POLL_MS_JSON" 50

handoffReadyTimeoutMs : Int
handoffReadyTimeoutMs = readEnvInt "CLASP_LOOP_HANDOFF_READY_TIMEOUT_MS_JSON" 10000

serviceRoot : Str
serviceRoot = readEnvText "CLASP_LOOP_SERVICE_ROOT_JSON" (pathJoin [stateRoot, "service"])

serviceId : Str
serviceId = readEnvText "CLASP_LOOP_SERVICE_ID_JSON" "feedback-loop"

upgradeCommandList : [Str]
upgradeCommandList = readEnvTextList "CLASP_LOOP_UPGRADE_COMMAND_JSON" emptyTexts

upgradeReadyPath : Str
upgradeReadyPath = readEnvText "CLASP_LOOP_UPGRADE_READY_PATH_JSON" ""

upgradeReadyContains : Str
upgradeReadyContains = readEnvText "CLASP_LOOP_UPGRADE_READY_CONTAINS_JSON" "ready"

upgradeReadyPollMs : Int
upgradeReadyPollMs = readEnvInt "CLASP_LOOP_UPGRADE_READY_POLL_MS_JSON" 50

upgradeReadyTimeoutMs : Int
upgradeReadyTimeoutMs = readEnvInt "CLASP_LOOP_UPGRADE_READY_TIMEOUT_MS_JSON" 10000

upgradeCommitGraceMs : Int
