emptyDiffFocusedState : DiffFocusedState
emptyDiffFocusedState =
  DiffFocusedState {
    changed = false,
    broad = false,
    unknown = false,
    loop = false,
    nativeScenario = false,
    compilerSpeed = false,
    controlPlane = false,
    verifyHarness = false
  }

diffLinePathText : Str -> Str
diffLinePathText line =
  match textPrefix line "+++ " {
    Ok tail ->
      tail,
    Err notPlus ->
      match textPrefix line "--- " {
        Ok tail ->
          tail,
        Err notMinus ->
          ""
      }
  }

diffPathTouchesBroadCompilerRuntime : Str -> Bool
diffPathTouchesBroadCompilerRuntime pathText =
  if textIncludes pathText "/src/" then
    true
  else
    textIncludes pathText "/runtime/"

diffPathIsGeneratedRuntimeTarget : Str -> Bool
diffPathIsGeneratedRuntimeTarget pathText =
  if textIncludes pathText "/runtime/target/" then
    true
  else
    textIncludes pathText "/runtime/target"

diffPathTouchesLoop : Str -> Bool
diffPathTouchesLoop pathText =
  if textIncludes pathText "/examples/feedback-loop/" then
    true
  else if textIncludes pathText "/scripts/test-feedback-loop-resume.sh" then
    true
  else
    textIncludes pathText "/scripts/test-swarm-ready-gate.sh"

diffPathTouchesControlPlane : Str -> Bool
diffPathTouchesControlPlane pathText =
  if textIncludes pathText "/examples/swarm-native/GoalManager" then
    true
  else if textIncludes pathText "/examples/swarm-native/Service.clasp" then
    true
  else if textIncludes pathText "/examples/swarm-native/FeedbackLoop.clasp" then
    true
  else if textIncludes pathText "/scripts/test-goal-manager-fast.sh" then
    true
  else
    false

diffPathTouchesNativeScenario : Str -> Bool
diffPathTouchesNativeScenario pathText =
  if textIncludes pathText "/examples/swarm-native/Swarm.clasp" then
    true
  else if textIncludes pathText "/examples/swarm-native/Main.clasp" then
    true
  else
    textIncludes pathText "/scripts/test-native-claspc.sh"

diffPathTouchesCompilerSpeed : Str -> Bool
diffPathTouchesCompilerSpeed pathText =
  if textIncludes pathText "/scripts/measure-native-incremental.sh" then
    true
  else if textIncludes pathText "/scripts/native-incremental-guard.mjs" then
    true
  else if textIncludes pathText "/scripts/test-native-incremental-guard.sh" then
    true
  else
    textIncludes pathText "/scripts/test-selfhost.sh"

diffPathTouchesVerifyHarness : Str -> Bool
diffPathTouchesVerifyHarness pathText =
  if textIncludes pathText "/scripts/verify-fast.sh" then
    true
  else if textIncludes pathText "/scripts/verify-all.sh" then
    true
  else
    textIncludes pathText "/scripts/test-verify-all.sh"

markDiffBroad : DiffFocusedState -> DiffFocusedState
markDiffBroad state =
  DiffFocusedState {
    changed = true,
    broad = true,
    unknown = state.unknown,
    loop = state.loop,
    nativeScenario = state.nativeScenario,
    compilerSpeed = state.compilerSpeed,
    controlPlane = state.controlPlane,
    verifyHarness = state.verifyHarness
  }

markDiffUnknown : DiffFocusedState -> DiffFocusedState
markDiffUnknown state =
  DiffFocusedState {
    changed = true,
    broad = state.broad,
    unknown = true,
    loop = state.loop,
    nativeScenario = state.nativeScenario,
    compilerSpeed = state.compilerSpeed,
    controlPlane = state.controlPlane,
    verifyHarness = state.verifyHarness
  }

markDiffLoop : DiffFocusedState -> DiffFocusedState
markDiffLoop state =
  DiffFocusedState {
    changed = true,
    broad = state.broad,
    unknown = state.unknown,
    loop = true,
    nativeScenario = state.nativeScenario,
    compilerSpeed = state.compilerSpeed,
    controlPlane = state.controlPlane,
    verifyHarness = state.verifyHarness
  }

markDiffNativeScenario : DiffFocusedState -> DiffFocusedState
markDiffNativeScenario state =
  DiffFocusedState {
    changed = true,
    broad = state.broad,
    unknown = state.unknown,
    loop = state.loop,
    nativeScenario = true,
    compilerSpeed = state.compilerSpeed,
    controlPlane = state.controlPlane,
    verifyHarness = state.verifyHarness
  }

markDiffCompilerSpeed : DiffFocusedState -> DiffFocusedState
markDiffCompilerSpeed state =
  DiffFocusedState {
    changed = true,
    broad = state.broad,
    unknown = state.unknown,
    loop = state.loop,
    nativeScenario = state.nativeScenario,
    compilerSpeed = true,
    controlPlane = state.controlPlane,
    verifyHarness = state.verifyHarness
  }

markDiffControlPlane : DiffFocusedState -> DiffFocusedState
markDiffControlPlane state =
  DiffFocusedState {
    changed = true,
    broad = state.broad,
    unknown = state.unknown,
    loop = state.loop,
    nativeScenario = state.nativeScenario,
    compilerSpeed = state.compilerSpeed,
    controlPlane = true,
    verifyHarness = state.verifyHarness
  }

markDiffVerifyHarness : DiffFocusedState -> DiffFocusedState
markDiffVerifyHarness state =
  DiffFocusedState {
    changed = true,
    broad = state.broad,
    unknown = state.unknown,
    loop = state.loop,
    nativeScenario = state.nativeScenario,
    compilerSpeed = state.compilerSpeed,
    controlPlane = state.controlPlane,
    verifyHarness = true
  }

classifyDiffLine : DiffFocusedState -> Str -> DiffFocusedState
classifyDiffLine state line = {
  let pathText = diffLinePathText line in
  if pathText == "" then
    state
  else if textIncludes pathText "/dev/null" then
    state
  else if diffPathIsGeneratedRuntimeTarget pathText then
    state
  else if diffPathTouchesBroadCompilerRuntime pathText then
    markDiffBroad state
  else if diffPathTouchesLoop pathText then
    markDiffLoop state
  else if diffPathTouchesNativeScenario pathText then
    markDiffNativeScenario state
  else if diffPathTouchesCompilerSpeed pathText then
    markDiffCompilerSpeed state
  else if diffPathTouchesControlPlane pathText then
    markDiffControlPlane state
  else if diffPathTouchesVerifyHarness pathText then
    markDiffVerifyHarness state
  else
    markDiffUnknown state
}

classifyDiffText : Str -> DiffFocusedState
classifyDiffText diffText = fold classifyDiffLine emptyDiffFocusedState (textSplit diffText "\n")

knownDiffFocusedCommands : DiffFocusedState -> [Str]
knownDiffFocusedCommands state = {
  let loopCommands = if state.loop then feedbackLoopFocusedCommands else emptyTexts in
  let nativeCommands = if state.nativeScenario then nativeScenarioFocusedCommands else emptyTexts in
  let speedCommands = if state.compilerSpeed then compilerSpeedFocusedCommands else emptyTexts in
  let controlCommands = if state.controlPlane then controlPlaneFocusedCommands else emptyTexts in
  let verifyCommands = if state.verifyHarness then verifyHarnessFocusedCommands else emptyTexts in
  let combined = append (append (append (append loopCommands nativeCommands) speedCommands) controlCommands) verifyCommands in
  if length combined == 0 then
    noDiffFocusedCommands
  else
    combined
}

focusedCommandsForDiffState : DiffFocusedState -> [Str]
focusedCommandsForDiffState state =
  if state.changed then
    if state.broad then
      verifyFastFocusedCommands
    else if state.unknown then
      verifyFastFocusedCommands
    else
      knownDiffFocusedCommands state
  else
    noDiffFocusedCommands

focusedReasonForDiffState : DiffFocusedState -> Str
focusedReasonForDiffState state =
  if state.changed then
    if state.broad then
      "diff touched compiler/runtime substrate; selected conservative verify-fast"
    else if state.unknown then
      "diff included unknown paths; selected conservative verify-fast"
    else
      "diff touched only known feedback-loop/native-scenario/compiler-speed/control-plane/verification harness paths; selected narrow focused checks"
  else
    "baseline diff was empty; selected a lightweight feedback-loop check"

focusedFallbackReasonForDiffState : DiffFocusedState -> Str
focusedFallbackReasonForDiffState state =
  if state.changed then
    if state.broad then
      "compiler/runtime changes can invalidate the compiler, native runtime, cache, or promoted self-hosting gates; focused selection falls back to verify-fast"
    else if state.unknown then
      "one or more changed paths did not match a known narrow surface; focused selection falls back to verify-fast"
    else
      ""
  else
    ""

managerFallbackReasonForDiffState : DiffFocusedState -> Str
managerFallbackReasonForDiffState state =
  if state.broad then
    "manager supplied focused commands, so the compiler/runtime diff fallback was recorded but not applied"
  else if state.unknown then
    "manager supplied focused commands, so the unknown-path diff fallback was recorded but not applied"
  else
    ""

surfaceCategoriesForDiffState : DiffFocusedState -> [Str]
surfaceCategoriesForDiffState state = {
  let broadCategories = if state.broad then ["compiler_runtime_broad"] else emptyTexts in
  let loopCategories = if state.loop then ["feedback_loop"] else emptyTexts in
  let nativeCategories = if state.nativeScenario then ["native_scenario"] else emptyTexts in
  let speedCategories = if state.compilerSpeed then ["compiler_speed"] else emptyTexts in
  let controlCategories = if state.controlPlane then ["control_plane"] else emptyTexts in
  let verifyCategories = if state.verifyHarness then ["verification_harness"] else emptyTexts in
  let unknownCategories = if state.unknown then ["unknown_path"] else emptyTexts in
  let combined =
    append
      (append (append (append (append broadCategories loopCategories) nativeCategories) speedCategories) (append controlCategories verifyCategories))
      unknownCategories in
  if state.changed then
    if length combined == 0 then
      ["unknown_path"]
    else
      combined
  else
    ["no_diff"]
}

cacheReportEvidenceForPath : Str -> Str
cacheReportEvidenceForPath path =
  if fileExists path then {
    let raw = readTextOrEmpty path in
    let matches =
      if textIncludes raw "\"matchesExpectations\":true" then
        "matchesExpectations=true"
      else if textIncludes raw "\"matchesExpectations\": true" then
        "matchesExpectations=true"
      else if textIncludes raw "\"matchesExpectations\":false" then
        "matchesExpectations=false"
      else if textIncludes raw "\"matchesExpectations\": false" then
        "matchesExpectations=false"
      else
        "matchesExpectations=unknown" in
    let observed =
      if textIncludes raw "\"observedChangedModules\"" then
        "observedChangedModules=present"
      else
        "observedChangedModules=missing" in
    textConcat ["native-cache-report:", path, ":", matches, ":", observed]
  } else
    ""

nativeCacheReportEvidence : [Str]
nativeCacheReportEvidence = filter nonEmptyText (map cacheReportEvidenceForPath nativeCacheReportPaths)

nativeCacheEvidenceForDiffState : DiffFocusedState -> [Str]
nativeCacheEvidenceForDiffState state = {
  let staticEvidence = [
    "runtime/claspc.rs emits [claspc-cache] native-image/build-plan/decl-module/module-summary/source-export traces",
    "scripts/native-incremental-guard.mjs validates native-cli-body-change and selfhost-body-change cache behavior",
    "scripts/test-selfhost.sh preserves promoted module-summary cache gates and selfhost incremental cache checks"
  ] in
  let broadEvidence =
    if state.broad then
      ["broad compiler/runtime selection uses bash scripts/verify-fast.sh, which includes selfhost and native claspc checks"]
    else
      emptyTexts in
  let optionalReports =
    if length nativeCacheReportEvidence == 0 then
      ["native-cache-report:none-found"]
    else
      nativeCacheReportEvidence in
  append (append staticEvidence broadEvidence) optionalReports
}

checkEvidenceForDiffState : Int -> DiffFocusedState -> [Str]
checkEvidenceForDiffState attempt state =
  append
    [
      textConcat ["baseline-diff:", baselineDiffPath attempt],
      textConcat ["diff-changed:", encode state.changed],
      textConcat ["diff-broad:", encode state.broad],
      textConcat ["diff-unknown:", encode state.unknown]
    ]
    (surfaceCategoriesForDiffState state)

focusedVerifySelectionFromDiffText : Int -> Str -> FocusedVerifySelection
focusedVerifySelectionFromDiffText attempt diffText = {
  let state = classifyDiffText diffText in
  FocusedVerifySelection {
    source = "diff-derived",
    diffPath = baselineDiffPath attempt,
    changedSurfaceCategories = surfaceCategoriesForDiffState state,
    commands = focusedCommandsForDiffState state,
    reason = focusedReasonForDiffState state,
    fallbackReason = focusedFallbackReasonForDiffState state,
    cacheEvidence = nativeCacheEvidenceForDiffState state,
    checkEvidence = checkEvidenceForDiffState attempt state
  }
}

focusedVerifySelectionFromDiff : Int -> FocusedVerifySelection
focusedVerifySelectionFromDiff attempt =
  match readFile (baselineDiffPath attempt) {
    Ok raw ->
      focusedVerifySelectionFromDiffText attempt raw,
    Err message ->
      FocusedVerifySelection {
        source = "diff-derived",
        diffPath = baselineDiffPath attempt,
        changedSurfaceCategories = ["unknown_path"],
        commands = verifyFastFocusedCommands,
        reason = textConcat ["diff artifact could not be read; selected conservative verify-fast: ", message],
        fallbackReason = "diff artifact could not be read; focused selection falls back to verify-fast",
        cacheEvidence = nativeCacheEvidenceForDiffState (markDiffUnknown emptyDiffFocusedState),
        checkEvidence = [
          textConcat ["baseline-diff:", baselineDiffPath attempt],
          textConcat ["diff-read-error:", message],
          "unknown_path"
        ]
      }
  }

focusedVerifySelectionFromManager : Int -> FocusedVerifySelection
focusedVerifySelectionFromManager attempt = {
  let state = match readFile (baselineDiffPath attempt) {
    Ok raw -> classifyDiffText raw,
    Err message -> markDiffUnknown emptyDiffFocusedState
  } in
  FocusedVerifySelection {
    source = "manager-env",
    diffPath = baselineDiffPath attempt,
    changedSurfaceCategories = append ["manager_env_override"] (surfaceCategoriesForDiffState state),
    commands = focusedVerifyCommands,
    reason = "CLASP_LOOP_FOCUSED_VERIFY_COMMANDS_JSON supplied non-empty focused commands",
    fallbackReason = managerFallbackReasonForDiffState state,
    cacheEvidence = nativeCacheEvidenceForDiffState state,
    checkEvidence = checkEvidenceForDiffState attempt state
  }
}

selectedFocusedVerifySelection : Int -> FocusedVerifySelection
selectedFocusedVerifySelection attempt =
  if length focusedVerifyCommands == 0 then
    focusedVerifySelectionFromDiff attempt
  else
    focusedVerifySelectionFromManager attempt

persistFocusedVerifySelection : Int -> Str
persistFocusedVerifySelection attempt =
  if isFullVerificationTier then
    ""
  else
    match writeFile (focusedVerifySelectionPath attempt) (encode (selectedFocusedVerifySelection attempt)) {
      Ok written ->
        "",
      Err message ->
        message
    }

prepareFocusedVerifySelection : Int -> Str
prepareFocusedVerifySelection attempt =
  if isFullVerificationTier then
    ""
  else {
    let diffError = refreshBaselineDiff attempt in
    let tracedDiffError =
      if diffError == "" then
        ""
      else
        tracePoint (textConcat ["focused-verify-diff-error:", diffError]) in
    let auditError = persistFocusedVerifySelection attempt in
    if auditError == "" then
      ""
    else
      textConcat ["focused-verify-selection-error:", auditError]
  }

builderPrompt : Int -> Str
builderPrompt attempt =
  textJoin "\n" [
    "You are the builder subagent for the Clasp repository.",
    "Read AGENTS.md first if it exists.",
    textConcat ["Read the task file at ", taskFile, "."],
    "Drive the repository toward the full task goal. Prefer coherent capability-closing changes over tiny local patches.",
    "Work only in the current checkout. Add or update tests. Run the narrowest checks that cover your changes. Do not run bash scripts/verify-all.sh.",
    "Capability categories to close:",
    capabilityChecklistText,
    builderEscalationText attempt,
    builderPolicySection attempt,
    builderFeedbackSection attempt,
    "Return JSON matching the provided output schema.",
    "Include the required feedback object in your final JSON.",
    textConcat ["Attempt: ", encode attempt]
  ]

verifierPrompt : Int -> Str
verifierPrompt attempt =
  textJoin "\n" [
    "You are the verifier subagent for the Clasp repository.",
    "Read AGENTS.md first if it exists.",
    textConcat ["Read the task file at ", taskFile, "."],
    "Evaluate the whole repository against the autonomous swarm confidence goal and required capability categories.",
    verifierPolicySection attempt,
    verifierVerificationInstructions attempt,
    textConcat ["Attempt: ", encode attempt]
  ]

verifierShellCommand : Int -> [Str]
verifierShellCommand attempt =
  append
    [
      "bash",
      "-lc",
      textConcat [
        "set +e\n",
        "state_path=", encode loopStatePath, "\n",
        "feedback_path=", encode feedbackPath, "\n",
        "report_path=", encode (verifierReportPath attempt), "\n",
        "stdout_path=", encode (verifierStdoutPath attempt), "\n",
        "stderr_path=", encode (verifierStderrPath attempt), "\n",
        "heartbeat_path=", encode (verifierHeartbeatPath attempt), "\n",
        "timeout_ms=", encode verifierTimeoutMs, "\n",
        "command_state=", encode (pendingVerifierStateJson attempt "verifier-command-ready"), "\n",
        "running_state=", encode (pendingVerifierStateJson attempt "verifier-running"), "\n",
        "completed_state=", encode (completedPassStateJson attempt), "\n",
        "failed_state=", encode (verifierFailureStateJson attempt "verifier did not pass"), "\n",
        "no_report_state=", encode (verifierFailureStateJson attempt "verifier step failed before producing a durable report"), "\n",
        "write_synthetic_feedback() {\n",
        "  node - \"$feedback_path\" \"$1\" \"${2:-}\" \"$report_path\" \"$stdout_path\" \"$stderr_path\" <<'NODE'\n",
        "const fs = require('fs');\n",
        "const [feedbackPath, summary, status, reportPath, stdoutPath, stderrPath] = process.argv.slice(2);\n",
        "const tail = (path) => {\n",
        "  try { return fs.readFileSync(path, 'utf8').slice(-4000); } catch { return ''; }\n",
        "};\n",
        "const detail = [\n",
        "  `exit_status=${status}`,\n",
        "  `report_path=${reportPath}`,\n",
        "  `stderr_tail=${tail(stderrPath)}`,\n",
        "  `stdout_tail=${tail(stdoutPath)}`,\n",
        "].join('\\n');\n",
        "fs.writeFileSync(feedbackPath, JSON.stringify({\n",
        "  verdict: 'fail',\n",
        "  summary,\n",
        "  findings: [detail],\n",
        "  tests_run: [],\n",
        "  follow_up: ['Retry the failed step after inspecting its stderr/stdout artifacts and persisted heartbeat.'],\n",
        "  capability_statuses: []\n",
        "}) + '\\n');\n",
        "NODE\n",
        "}\n",
        "mkdir -p \"$(dirname \"$report_path\")\" \"$(dirname \"$stdout_path\")\" \"$(dirname \"$stderr_path\")\" \"$(dirname \"$heartbeat_path\")\" || exit $?\n",
        "if [ -f \"$report_path\" ]; then status=0; else\n",
        "  printf '%s' \"$command_state\" > \"$state_path\" || exit $?\n",
        baselineDiffScript attempt,
        "  diff_status=$?\n",
        "  if [ \"$diff_status\" -ne 0 ]; then printf '%s' \"$no_report_state\" > \"$state_path\"; write_synthetic_feedback \"verifier preflight failed before producing a durable report\" \"$diff_status\"; exit \"$diff_status\"; fi\n",
        "  printf '%s' \"$running_state\" > \"$state_path\" || exit $?\n",
        "  : >\"$stdout_path\"\n",
        "  : >\"$stderr_path\"\n",
        "  if [ \"$timeout_ms\" -gt 0 ]; then secs=$(( (timeout_ms + 999) / 1000 )); timeout \"$secs\" \"$@\" >\"$stdout_path\" 2>\"$stderr_path\"; status=$?; else \"$@\" >\"$stdout_path\" 2>\"$stderr_path\"; status=$?; fi\n",
        "fi\n",
        "if [ -f \"$report_path\" ]; then\n",
        "  cp \"$report_path\" \"$feedback_path\"\n",
        "  if grep -Eq '\"verdict\"[[:space:]]*:[[:space:]]*\"pass\"' \"$report_path\"; then printf '%s' \"$completed_state\" > \"$state_path\"; status=0; else printf '%s' \"$failed_state\" > \"$state_path\"; status=70; fi\n",
        "else\n",
        "  printf '%s' \"$no_report_state\" > \"$state_path\"\n",
        "  write_synthetic_feedback \"verifier step failed before producing a durable report\" \"$status\"\n",
        "  if [ \"$status\" -eq 0 ]; then status=71; fi\n",
        "fi\n",
        "now_ms=$(date +%s%3N 2>/dev/null || printf '0')\n",
        "printf '{\"pid\":0,\"running\":false,\"completed\":true,\"exitCode\":%s,\"stdoutPath\":", encode (verifierStdoutPath attempt), ",\"stderrPath\":", encode (verifierStderrPath attempt), ",\"heartbeatPath\":", encode (verifierHeartbeatPath attempt), ",\"updatedAtMs\":%s}' \"$status\" \"$now_ms\" > \"$heartbeat_path\"\n",
        "exit \"$status\"\n"
      ],
      "clasp-feedback-loop-verifier"
    ]
    (codexCommand verifierSchemaPath (verifierReportPath attempt) (verifierPrompt attempt))

markBaselineReady : ProcessResult
markBaselineReady =
  match writeFile baselineReadyPath "ready" {
    Ok written ->
      ProcessResult { exitCode = 0, stdout = baselineWorkspace, stderr = "" },
    Err message ->
      ProcessResult { exitCode = 1, stdout = "", stderr = message }
  }

createBaselineSnapshot : ProcessResult
createBaselineSnapshot = {
  let removed = runProcess launcherCwd ["rm", "-rf", baselineWorkspace, baselineArchivePath] in
  if removed.exitCode != 0 then
    removed
  else {
    let created = runProcess launcherCwd ["mkdir", "-p", baselineWorkspace] in
    if created.exitCode != 0 then
      created
    else {
      let streamed = runProcess launcherCwd [
        "bash",
        "-lc",
        textConcat [
          "tar -cf - ",
          baselineExcludeFlags,
          "-C ",
          workspaceRoot,
          " . | ",
          "tar -xf - -C ",
          baselineWorkspace
        ]
      ] in
      if streamed.exitCode != 0 then
        streamed
      else
        markBaselineReady
    }
  }
}

baselineCanBeSnapshottedFromWorkspace : Bool
baselineCanBeSnapshottedFromWorkspace = {
  let state = readLoopState in
  if state.builderRuns > 0 then
    false
  else if state.verifierRuns > 0 then
    false
  else if fileExists (builderReportPath state.attempt) then
    false
  else if fileExists (baselineDiffPath state.attempt) then
    false
  else
    true
}

providedBaselineMissing : ProcessResult
providedBaselineMissing =
  ProcessResult {
    exitCode = 1,
    stdout = "",
    stderr =
      textConcat [
        "provided baseline workspace is missing; refusing to recreate it from a workspace that may contain builder changes: ",
        baselineWorkspace
      ]
  }

ensureBaseline : ProcessResult
ensureBaseline =
  if baselineWorkspaceProvided then
    if fileExists baselineWorkspace then
      markBaselineReady
    else if baselineCanBeSnapshottedFromWorkspace then
      createBaselineSnapshot
    else
      providedBaselineMissing
  else if fileExists baselineReadyPath then
    if fileExists baselineWorkspace then
      ProcessResult { exitCode = 0, stdout = baselineWorkspace, stderr = "" }
    else
      createBaselineSnapshot
  else
    createBaselineSnapshot

runStepDirect : StepHandle -> [Str] -> LoopState -> LoopState -> ProcessResult
runStepDirect step command launchingState runningState = {
  let launchingStateError = writeLoopState launchingState in
  if launchingStateError != "" then
    failedProcessResult launchingStateError
  else {
    let runningStateError = writeLoopState runningState in
    if runningStateError != "" then
      failedProcessResult runningStateError
    else {
      let result = runProcess launcherCwd command in
      let artifactError = writeProcessArtifacts step result in
      if artifactError != "" then
        failedProcessResult artifactError
      else {
        let heartbeatError = writeProcessHeartbeat step result in
        if heartbeatError != "" then
          failedProcessResult heartbeatError
        else
          result
      }
    }
  }
}

ensureLoopReady : Str
ensureLoopReady =
  if taskFile == "" then
    "config-error:missing-task-file"
  else if workspaceRoot == "" then
    "config-error:missing-workspace-root"
  else {
    match mkdirAll stateRoot {
      Err message ->
        textConcat ["state-root-error:", message],
      Ok created ->
        let restoreError = restoreSnapshotIfNeeded in
        if restoreError != "" then
          restoreError
        else {
          let baselineResult = ensureBaseline in
          if baselineResult.exitCode != 0 then
            textConcat ["baseline-error:", baselineResult.stderr]
          else {
            let policyError = ensurePolicies in
            if policyError != "" then
              textConcat ["policy-error:", policyError]
            else {
              let readyError = signalLoopReady in
              if readyError != "" then
                textConcat ["ready-error:", readyError]
              else
                ""
            }
          }
        }
    }
  }

persistFailureAndContinue : Int -> VerifierReport -> Str
persistFailureAndContinue attempt report = {
  let isFinalAttempt = attempt == maxAttempts;
  let nextState =
    if isFinalAttempt then
      loopState attempt "failed" "fail" false attempt attempt false true report.summary true
    else
      loopState (incrementAttempt attempt) "needs-builder" "retry" false attempt attempt false true report.summary false;
  let stateError = writeLoopState nextState in
  if stateError != "" then
    textConcat ["state-error:", stateError]
  else
    match writeFile feedbackPath (encode report) {
      Ok written ->
        if isFinalAttempt then
          textConcat ["fail:", encode attempt]
        else
          runAttempt (incrementAttempt attempt),
      Err message ->
        textConcat ["feedback-error:", message]
    }
}

finishPass : Int -> VerifierReport -> Str
finishPass attempt report =
  match writeFile feedbackPath (encode report) {
    Err message ->
      textConcat ["feedback-error:", message],
    Ok written ->
      let stateError = writeLoopState (loopState attempt "completed" "pass" true attempt attempt true false "" true) in
      if stateError != "" then
        textConcat ["state-error:", stateError]
      else
        textConcat ["pass:", encode attempt]
  }

persistFinalFailure : Int -> VerifierReport -> Str
persistFinalFailure attempt report = {
  let stateError = writeLoopState (loopState attempt "failed" "fail" false attempt attempt false true report.summary true) in
  if stateError != "" then
    textConcat ["state-error:", stateError]
  else
    match writeFile feedbackPath (encode report) {
      Ok written ->
        textConcat ["fail:", encode attempt],
      Err message ->
        textConcat ["feedback-error:", message]
    }
}

missingVerifierReportFailure : Int -> ProcessResult -> VerifierReport
missingVerifierReportFailure attempt result =
  syntheticFailureReport
    "verifier step failed before producing a durable report"
    (textJoin "\n" [
      textConcat ["exit_status=", encode result.exitCode],
      textConcat ["report_path=", verifierReportPath attempt],
      textConcat ["stderr_tail=", result.stderr],
      textConcat ["stdout_tail=", result.stdout]
    ])

finalizeVerifierRun : Int -> ProcessResult -> Str
finalizeVerifierRun attempt result =
  if fileExists (verifierReportPath attempt) then {
    let report = readVerifierReport attempt in
    if report.verdict == "pass" then
      finishPass attempt report
    else
      persistFailureAndContinue attempt report
  } else if result.exitCode == 0 then
    persistFinalFailure attempt (missingVerifierReportFailure attempt result)
  else
    persistFailureAndContinue attempt (missingVerifierReportFailure attempt result)

runVerifierPhase : Int -> Str
runVerifierPhase attempt =
  if attempt > maxAttempts then
    textConcat ["fail:", encode maxAttempts]
  else {
    let prepError = ensureLoopReady in
    if prepError != "" then
      prepError
    else {
      let selectionError = prepareFocusedVerifySelection attempt in
      if selectionError != "" then
        selectionError
      else {
        let tracedStart = tracePoint (textConcat ["verifier:start:", encode attempt]) in
        let verifierStep = stepHandle "verifier" attempt in
        let verifierRun = ensureStepReportWithTimeoutNoState verifierStep (verifierShellCommand attempt) verifierTimeoutMs in
        finalizeVerifierRun attempt verifierRun
      }
    }
  }

runBuilderPhase : Int -> Str
runBuilderPhase attempt =
  if attempt > maxAttempts then
    textConcat ["fail:", encode maxAttempts]
  else {
    let prepError = ensureLoopReady in
    if prepError != "" then
      prepError
    else {
      let builderStep = stepHandle "builder" attempt in
      if fileExists builderStep.reportPath then
        runVerifierPhase attempt
      else {
        let builderRun =
          if watchModeEnabled then
            ensureStepReport
              builderStep
              (codexCommand builderSchemaPath builderStep.reportPath (builderPrompt attempt))
              (loopState attempt "builder-launching" "pending" false attempt 0 true false "" false)
              (loopState attempt "builder-running" "pending" false attempt 0 true false "" false)
          else
            runStepDirect
              builderStep
              (codexCommand builderSchemaPath builderStep.reportPath (builderPrompt attempt))
              (loopState attempt "builder-launching" "pending" false attempt 0 true false "" false)
              (loopState attempt "builder-running" "pending" false attempt 0 true false "" false) in
        if fileExists builderStep.reportPath then
          runVerifierPhase attempt
        else
          persistFailureAndContinue
            attempt
            (syntheticFailureReport
              "builder step failed before producing a durable report"
              builderRun.stderr)
      }
    }
  }

runAttempt : Int -> Str
runAttempt attempt = runBuilderPhase attempt

runLoopHandoff : Str
runLoopHandoff =
  match mkdirAll stateRoot {
    Err message ->
      textConcat ["error:", message],
    Ok created ->
      if textJoin "" handoffCommandList == "" then
        "error:missing-handoff-command"
      else if handoffReadyPath == "" then
        "error:missing-handoff-ready-path"
      else
        match
          handoff (
            handoffCommandSpec
              launcherCwd
              handoffStdoutPath
              handoffStderrPath
              handoffHeartbeatPath
              watchPollMs
              handoffReadyPath
              handoffReadyContains
              handoffReadyPollMs
              handoffReadyTimeoutMs
              handoffCommandList
          )
        {
          Ok process -> encode process,
          Err message -> textConcat ["error:", message]
        }
  }

runLoopUpgrade : Str
runLoopUpgrade = {
  let prepError = ensureLoopReady in
  if prepError != "" then
    prepError
  else if textJoin "" upgradeCommandList == "" then
    "error:missing-upgrade-command"
  else if serviceRoot == "" then
    "error:missing-service-root"
  else if serviceId == "" then
    "error:missing-service-id"
  else if upgradeReadyPath == "" then
    "error:missing-upgrade-ready-path"
  else
    match
      upgrade (
        upgradeCommandSpec
          launcherCwd
          serviceRoot
          serviceId
          (encode currentUpgradeSnapshot)
          upgradeReadyPath
          upgradeReadyContains
          watchPollMs
          upgradeReadyPollMs
          upgradeReadyTimeoutMs
          upgradeCommitGraceMs
          upgradeCommandList
      )
    {
      Ok transaction ->
        encode transaction,
      Err message ->
        textConcat ["error:", message]
    }
}

resumeLoop : LoopState -> Str
resumeLoop state =
  if state.final then
    if state.verdict == "pass" then
      textConcat ["pass:", encode state.attempt]
    else if state.verdict == "fail" then
      textConcat ["fail:", encode state.attempt]
    else
      runAttempt state.attempt
  else if state.phase == "builder-running" then
    runBuilderPhase state.attempt
  else if state.phase == "builder-launching" then
    runBuilderPhase state.attempt
  else if state.phase == "verifier-running" then
    runVerifierPhase state.attempt
  else if state.phase == "verifier-launching" then
    runVerifierPhase state.attempt
  else if state.phase == "verifier-command-ready" then
    runVerifierPhase state.attempt
  else if state.phase == "verifier-prompt-ready" then
    runVerifierPhase state.attempt
  else if state.phase == "verifier-step-ready" then
    runVerifierPhase state.attempt
  else if state.phase == "verifier-preparing" then
    runVerifierPhase state.attempt
  else if state.attempt == 0 then
    runAttempt 1
  else
    runAttempt state.attempt

main : Str
main =
  if commandName == "status" then
    encode readLoopState
  else if commandName == "handoff" then
    runLoopHandoff
  else if commandName == "upgrade" then
    runLoopUpgrade
  else
    resumeLoop readLoopState
