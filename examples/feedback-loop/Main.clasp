module Main

import Process

record CapabilityStatus = {
  name : Str,
  status : Str,
  evidence : [Str],
  blocking_gaps : [Str],
  required_closure : [Str]
}
record VerifierReport = {
  verdict : Str,
  summary : Str,
  findings : [Str],
  tests_run : [Str],
  follow_up : [Str],
  capability_statuses : [CapabilityStatus]
}
record LoopState = {
  attempt : Int,
  phase : Str,
  verdict : Str,
  completed : Bool,
  builderRuns : Int,
  verifierRuns : Int,
  healthy : Bool,
  needsAttention : Bool,
  attentionReason : Str,
  final : Bool
}
record StepHandle = {
  prefix : Str,
  attempt : Int,
  reportPath : Str,
  stdoutPath : Str,
  stderrPath : Str,
  heartbeatPath : Str
}
record FocusedVerifySelection = {
  source : Str,
  diffPath : Str,
  changedSurfaceCategories : [Str],
  commands : [Str],
  reason : Str,
  fallbackReason : Str,
  cacheEvidence : [Str],
  checkEvidence : [Str]
}
record DiffFocusedState = {
  changed : Bool,
  broad : Bool,
  unknown : Bool,
  loop : Bool,
  nativeScenario : Bool,
  compilerSpeed : Bool,
  controlPlane : Bool,
  verifyHarness : Bool
}
record LoopUpgradeSnapshot = { state : LoopState, feedback : Str }
record LoopUpgradeRestoreRecord = {
  serviceRoot : Str,
  serviceId : Str,
  generation : Int,
  transactionPath : Str,
  snapshot : LoopUpgradeSnapshot
}

stateRoot : Str
stateRoot = if textJoin "" argv == "" then "feedback-loop-state" else pathJoin argv

emptyTexts : [Str]
emptyTexts = []

emptyCapabilityStatuses : [CapabilityStatus]
emptyCapabilityStatuses = []

readEnvText : Str -> Str -> Str
readEnvText name fallback = match envVar name {
  Ok raw -> decode Str raw,
  Err message -> fallback
}

readEnvInt : Str -> Int -> Int
readEnvInt name fallback = match envVar name {
  Ok raw -> decode Int raw,
  Err message -> fallback
}

readEnvTextList : Str -> [Str] -> [Str]
readEnvTextList name fallback = match envVar name {
  Ok raw -> match textPrefix raw "[" {
    Ok arrayTail -> decode [Str] raw,
    Err notArray -> fallback
  },
  Err message -> fallback
}

jsonTextOrRaw : Str -> Str
jsonTextOrRaw raw = match textPrefix raw "\"" {
  Ok quotedTail -> decode Str raw,
  Err notQuoted -> raw
}

nonEmptyText : Str -> Bool
nonEmptyText value = value != ""

readEnvCommandTextList : Str -> [Str] -> [Str]
readEnvCommandTextList name fallback = match envVar name {
  Ok raw -> match textPrefix raw "[" {
    Ok arrayTail -> decode [Str] raw,
    Err notArray -> filter nonEmptyText (textSplit (jsonTextOrRaw raw) "\n")
  },
  Err message -> fallback
}

