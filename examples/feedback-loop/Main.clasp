builderHeartbeatPath attempt = pathJoin [stateRoot, textConcat ["builder-", encode attempt, ".heartbeat.json"]]

verifierHeartbeatPath : Int -> Str
verifierHeartbeatPath attempt = pathJoin [stateRoot, textConcat ["verifier-", encode attempt, ".heartbeat.json"]]

handoffStdoutPath : Str
handoffStdoutPath = pathJoin [stateRoot, "handoff.stdout.log"]

handoffStderrPath : Str
handoffStderrPath = pathJoin [stateRoot, "handoff.stderr.log"]

handoffHeartbeatPath : Str
handoffHeartbeatPath = pathJoin [stateRoot, "handoff.heartbeat.json"]

restoredSnapshotPath : Str
restoredSnapshotPath = pathJoin [stateRoot, "restored-snapshot.json"]

processStdoutPath : Str -> Int -> Str
processStdoutPath prefix attempt =
  if prefix == "builder" then
    builderStdoutPath attempt
  else
    verifierStdoutPath attempt

processStderrPath : Str -> Int -> Str
processStderrPath prefix attempt =
  if prefix == "builder" then
    builderStderrPath attempt
  else
    verifierStderrPath attempt

processHeartbeatPath : Str -> Int -> Str
processHeartbeatPath prefix attempt =
  if prefix == "builder" then
    builderHeartbeatPath attempt
  else
    verifierHeartbeatPath attempt

processReportPath : Str -> Int -> Str
processReportPath prefix attempt =
  if prefix == "builder" then
    builderReportPath attempt
  else
    verifierReportPath attempt

stepHandle : Str -> Int -> StepHandle
stepHandle prefix attempt =
  StepHandle {
    prefix = prefix,
    attempt = attempt,
    reportPath = processReportPath prefix attempt,
    stdoutPath = processStdoutPath prefix attempt,
    stderrPath = processStderrPath prefix attempt,
    heartbeatPath = processHeartbeatPath prefix attempt
  }

runProcess : Str -> [Str] -> ProcessResult
runProcess cwd command = match runCommandJson cwd command {
  Ok raw ->
    decode ProcessResult raw,
  Err message ->
    ProcessResult {
      exitCode = 1,
      stdout = "",
      stderr = message
    }
}

launcherCwd : Str
launcherCwd = "."

readTextOrEmpty : Str -> Str
readTextOrEmpty path = match readFile path {
  Ok raw ->
    raw,
  Err message ->
    ""
}

watchedProcessOk : WatchedProcess -> Result WatchedProcess
watchedProcessOk process = Ok process

watchedProcessError : Str -> Result WatchedProcess
watchedProcessError message = Err message

successProcessResult : StepHandle -> ProcessResult
successProcessResult step =
  ProcessResult {
    exitCode = 0,
    stdout = readTextOrEmpty step.stdoutPath,
    stderr = readTextOrEmpty step.stderrPath
  }

failedProcessResult : Str -> ProcessResult
failedProcessResult message =
  ProcessResult {
    exitCode = 1,
    stdout = "",
    stderr = message
  }

writeProcessArtifact : Str -> Str -> Str
writeProcessArtifact path contents = match writeFile path contents {
  Ok written ->
    "",
  Err message ->
    message
}

tracePoint : Str -> Str
tracePoint label =
  if traceEnabled then
    match appendFile tracePath (textConcat [label, "\n"]) {
      Ok written ->
        "",
      Err message ->
        ""
    }
  else
    ""

writeProcessArtifacts : StepHandle -> ProcessResult -> Str
writeProcessArtifacts step result = {
  let stdoutError = writeProcessArtifact step.stdoutPath result.stdout in
  if stdoutError != "" then
    stdoutError
  else
    writeProcessArtifact step.stderrPath result.stderr
}

writeProcessHeartbeat : StepHandle -> ProcessResult -> Str
writeProcessHeartbeat step result =
  writeProcessArtifact
    step.heartbeatPath
    (encode
      (WatchedProcess {
        pid = 0,
        running = false,
        completed = true,
        exitCode = result.exitCode,
        stdoutPath = step.stdoutPath,
        stderrPath = step.stderrPath,
        heartbeatPath = step.heartbeatPath,
        updatedAtMs = timeUnixMs
      }))

processResultFromStep : StepHandle -> Int -> ProcessResult
processResultFromStep step exitCode =
  ProcessResult {
    exitCode = exitCode,
    stdout = readTextOrEmpty step.stdoutPath,
    stderr = readTextOrEmpty step.stderrPath
  }

spawnStep : StepHandle -> [Str] -> Result WatchedProcess
spawnStep step command =
  spawn (watchedCommandSpec launcherCwd step.stdoutPath step.stderrPath step.heartbeatPath watchPollMs command)

reconcileStep : StepHandle -> Result WatchedProcess
reconcileStep step = reconcile step.heartbeatPath

awaitStep : StepHandle -> Result WatchedProcess
awaitStep step = await step.heartbeatPath watchPollMs

resumeStep : StepHandle -> ProcessResult
resumeStep step = match awaitStep step {
  Ok process ->
    processResultFromStep step process.exitCode,
  Err message ->
    failedProcessResult message
}

terminateWatchedProcess : WatchedProcess -> Str
terminateWatchedProcess process =
  if process.pid < 1 then
    ""
  else {
    let killed = runProcess launcherCwd [
      "bash",
      "-lc",
      textConcat [
        "kill -TERM ",
        encode process.pid,
        " 2>/dev/null || true; pkill -TERM -P ",
        encode process.pid,
        " 2>/dev/null || true"
      ]
    ] in
    if killed.exitCode == 0 then
      ""
    else
      killed.stderr
  }

resumeStepWithTimeout : StepHandle -> Int -> ProcessResult
resumeStepWithTimeout step timeoutMs =
  if timeoutMs < 1 then
    resumeStep step
  else
    match awaitTimeout step.heartbeatPath watchPollMs timeoutMs {
      Ok process ->
        processResultFromStep step process.exitCode,
      Err message ->
        let reconciled = reconcileStep step in
        let killed = match reconciled {
          Ok process -> terminateWatchedProcess process,
          Err reconcileMessage -> reconcileMessage
        } in
        ProcessResult {
          exitCode = 124,
          stdout = readTextOrEmpty step.stdoutPath,
          stderr = textJoin "\n" [
            textConcat ["timed out after ", encode timeoutMs, "ms"],
            message,
            killed,
            readTextOrEmpty step.stderrPath
          ]
        }
    }

launchStepAndAwait : StepHandle -> [Str] -> LoopState -> ProcessResult
launchStepAndAwait step command runningState =
  match spawnStep step command {
    Err message ->
      failedProcessResult message,
    Ok process ->
      let stateError = writeLoopState runningState in
      if stateError != "" then
        failedProcessResult stateError
      else
        resumeStep step
  }

launchStepAndAwaitWithTimeout : StepHandle -> [Str] -> LoopState -> Int -> ProcessResult
launchStepAndAwaitWithTimeout step command runningState timeoutMs =
  match spawnStep step command {
    Err message ->
      failedProcessResult message,
    Ok process ->
      let stateError = writeLoopState runningState in
      if stateError != "" then
        failedProcessResult stateError
      else
        resumeStepWithTimeout step timeoutMs
  }

ensureStepReport : StepHandle -> [Str] -> LoopState -> LoopState -> ProcessResult
ensureStepReport step command launchingState runningState =
  if fileExists step.reportPath then
    successProcessResult step
  else if fileExists step.heartbeatPath then {
    let reconciled = reconcileStep step in
    let resumed = resumeStep step in
    if fileExists step.reportPath then
      successProcessResult step
    else
      launchStepAndAwait step command runningState
  } else {
    let launchingStateError = writeLoopState launchingState in
    if launchingStateError != "" then
      failedProcessResult launchingStateError
    else {
      let launched = launchStepAndAwait step command runningState in
      if fileExists step.reportPath then
        successProcessResult step
      else
        launched
    }
  }

ensureStepReportWithTimeout : StepHandle -> [Str] -> LoopState -> LoopState -> Int -> ProcessResult
ensureStepReportWithTimeout step command launchingState runningState timeoutMs =
  if fileExists step.reportPath then
    successProcessResult step
  else if fileExists step.heartbeatPath then {
    let reconciled = reconcileStep step in
    let resumed = resumeStepWithTimeout step timeoutMs in
    if fileExists step.reportPath then
      successProcessResult step
    else
      resumed
  } else {
    let launchingStateError = writeLoopState launchingState in
    if launchingStateError != "" then
      failedProcessResult launchingStateError
    else {
      let launched = launchStepAndAwaitWithTimeout step command runningState timeoutMs in
      if fileExists step.reportPath then
        successProcessResult step
      else
        launched
    }
  }

launchStepAndAwaitWithTimeoutNoState : StepHandle -> [Str] -> Int -> ProcessResult
launchStepAndAwaitWithTimeoutNoState step command timeoutMs =
  match spawnStep step command {
    Err message ->
      failedProcessResult message,
    Ok process ->
      resumeStepWithTimeout step timeoutMs
  }

ensureStepReportWithTimeoutNoState : StepHandle -> [Str] -> Int -> ProcessResult
ensureStepReportWithTimeoutNoState step command timeoutMs =
  if fileExists step.reportPath then
    successProcessResult step
  else if fileExists step.heartbeatPath then {
    let reconciled = reconcileStep step in
    let resumed = resumeStepWithTimeout step timeoutMs in
    if fileExists step.reportPath then
      successProcessResult step
    else
      resumed
  } else {
    let launched = launchStepAndAwaitWithTimeoutNoState step command timeoutMs in
    if fileExists step.reportPath then
      successProcessResult step
    else
      launched
  }

readVerifierReport : Int -> VerifierReport
readVerifierReport attempt = match readFile (verifierReportPath attempt) {
  Ok raw ->
    decode VerifierReport raw,
  Err message ->
    VerifierReport {
      verdict = "fail",
      summary = textConcat ["missing verifier report: ", message],
      findings = [message],
      tests_run = emptyTexts,
      follow_up = ["leave a verifier report at the configured path"],
      capability_statuses = emptyCapabilityStatuses
    }
}

readFeedbackText : Int -> Str
readFeedbackText attempt = match readFile feedbackPath {
  Ok raw ->
    raw,
  Err message ->
    ""
}

syntheticFailureReport : Str -> Str -> VerifierReport
syntheticFailureReport summary detail =
  VerifierReport {
    verdict = "fail",
    summary = summary,
    findings = [detail],
    tests_run = emptyTexts,
    follow_up = ["Retry the failed step after inspecting its stderr artifact and persisted heartbeat."],
    capability_statuses = emptyCapabilityStatuses
  }

defaultBuilderPolicyText : Str
defaultBuilderPolicyText = textJoin "\n" [
  "Close whole blocking capability categories rather than single complaint lines.",
  "Prefer code/runtime/compiler/example/test changes over docs-only movement.",
  "Use the previous verifier report as the primary steering input for the next attempt.",
  "Do not broaden backend-native swarm/runtime work into JavaScript-emitter parity unless the frontend compile target actually requires it.",
  "Treat Compiler.Emit.JavaScript as the frontend/client emitter, not as a backend execution path."
]

defaultVerifierPolicyText : Str
defaultVerifierPolicyText = textJoin "\n" [
  "Judge the whole repository, not only the latest diff.",
  "Group failures by capability category.",
  "Do not fail merely because legacy helper scripts remain in the repo if the ordinary-program path is complete and not required.",
  "Do not demand JavaScript-emitter parity for backend-native swarm/runtime capabilities unless the task explicitly requires frontend/client support."
]

readPolicyText : Str -> Str -> Str
readPolicyText path fallback = match readFile path {
  Ok raw ->
    raw,
  Err message ->
    fallback
}

ensurePolicyFile : Str -> Str -> Str
ensurePolicyFile path fallback =
  if fileExists path then
    ""
  else
    match writeFile path fallback {
      Ok written ->
        "",
      Err message ->
        message
    }

ensurePolicies : Str
ensurePolicies = {
  let builderError = ensurePolicyFile builderPolicyPath defaultBuilderPolicyText in
  if builderError != "" then
    builderError
  else
    ensurePolicyFile verifierPolicyPath defaultVerifierPolicyText
}

signalLoopReady : Str
signalLoopReady =
  if readySignalPath == "" then
    ""
  else
    match writeFile readySignalPath readySignalText {
      Ok written ->
        "",
      Err message ->
        message
    }

capabilityChecklist : [Str]
capabilityChecklist = [
  "ordinary_program_execution: the live builder/verifier loop runs as a normal Clasp program via claspc run, invokes Codex directly from Clasp, and persists durable final state/status in ordinary runtime storage.",
  "durable_native_substrate: objective/run/task/event/artifact persistence, DAG edges, projected status, leases, approvals, merge-policy state, tool/process execution, and monitoring/state inspection are durably available.",
  "clasp_native_control_api: ordinary Clasp programs can use the orchestration substrate directly without requiring shell wrapper orchestration or external claspc swarm subprocesses as the primary model.",
  "orchestration_viability: builder/verifier/planner-style programs are realistically implementable in Clasp itself without obvious missing runtime/control-plane substrate.",
  "ergonomics: Dict state, empty lists, polymorphic collections, and record update/destructuring are usable enough for state-heavy orchestration code.",
  "verification_gate: scenario-level coverage exists for the ordinary-program loop path and new runtime/workflow/control-plane behavior, and bash scripts/verify-all.sh passes."
]

capabilityChecklistText : Str
capabilityChecklistText = textJoin "\n" [
  "- ordinary_program_execution: the live builder/verifier loop runs as a normal Clasp program via claspc run, invokes Codex directly from Clasp, and persists durable final state/status in ordinary runtime storage.",
  "- durable_native_substrate: objective/run/task/event/artifact persistence, DAG edges, projected status, leases, approvals, merge-policy state, tool/process execution, and monitoring/state inspection are durably available.",
  "- clasp_native_control_api: ordinary Clasp programs can use the orchestration substrate directly without requiring shell wrapper orchestration or external claspc swarm subprocesses as the primary model.",
  "- orchestration_viability: builder/verifier/planner-style programs are realistically implementable in Clasp itself without obvious missing runtime/control-plane substrate.",
  "- ergonomics: Dict state, empty lists, polymorphic collections, and record update/destructuring are usable enough for state-heavy orchestration code.",
  "- verification_gate: scenario-level coverage exists for the ordinary-program loop path and new runtime/workflow/control-plane behavior, and bash scripts/verify-all.sh passes."
]

builderEscalationText : Int -> Str
builderEscalationText attempt =
  if attempt < 3 then
    "Prefer closing at least one whole failing capability category this attempt, not just one complaint line."
  else
    textJoin "\n" [
      "You have already seen multiple verifier failures.",
      "Escalate to closing an entire blocking capability category even if that requires coordinated compiler/runtime/example/test/doc changes in one slice.",
      "Do not spend this attempt on docs-only, wrapper-only, or single-harness-only fixes unless the previous verifier report makes clear that such a fix is the only remaining blocker."
    ]

builderFeedbackSection : Int -> Str
builderFeedbackSection attempt =
  if readFeedbackText attempt == "" then
    "No previous verifier feedback is present yet."
  else
    textJoin "\n" [
      "Verifier feedback from the previous attempt:",
      readFeedbackText attempt
    ]

builderPolicySection : Int -> Str
builderPolicySection attempt =
  textJoin "\n" [
    textConcat ["Current builder policy from ", builderPolicyPath, ":"],
    readPolicyText builderPolicyPath defaultBuilderPolicyText
  ]

verifierPolicySection : Int -> Str
verifierPolicySection attempt =
  textJoin "\n" [
    textConcat ["Current verifier policy from ", verifierPolicyPath, ":"],
    readPolicyText verifierPolicyPath defaultVerifierPolicyText
  ]

isFullVerificationTier : Bool
isFullVerificationTier =
  if verificationTier == "full" then
    true
  else
    false

verifierTimeoutMs : Int
verifierTimeoutMs =
  if isFullVerificationTier then
    fullVerifierTimeoutMs
  else
    focusedVerifierTimeoutMs

focusedVerifyCommandText : Int -> Str
focusedVerifyCommandText attempt = {
  let selection = selectedFocusedVerifySelection attempt in
  textConcat ["- ", textJoin "\n- " selection.commands]
}

focusedVerifyAuditText : Int -> Str
focusedVerifyAuditText attempt = {
  let selection = selectedFocusedVerifySelection attempt in
  textJoin "\n" [
    textConcat ["Focused verification command source: ", selection.source],
    textConcat ["Focused verification changed surface categories: ", textJoin "," selection.changedSurfaceCategories],
    textConcat ["Focused verification selection reason: ", selection.reason],
    textConcat [
      "Focused verification fallback reason: ",
      if selection.fallbackReason == "" then "none" else selection.fallbackReason
    ],
    textConcat ["Focused verification audit path: ", focusedVerifySelectionPath attempt],
    textConcat ["Baseline diff path: ", selection.diffPath],
    "Focused verification commands selected for this attempt:",
    focusedVerifyCommandText attempt
  ]
}

verifierVerificationInstructions : Int -> Str
verifierVerificationInstructions attempt =
  if isFullVerificationTier then
    textJoin "\n" [
      "Verification tier: full.",
      textConcat ["Run the full signoff command before reporting pass: ", fullVerifyCommand],
      "If full signoff fails or times out, return a fail report with the failing surface and the last useful output.",
      textConcat ["Verifier timeout budget ms: ", encode verifierTimeoutMs, " (0 means no loop-enforced timeout)."]
    ]
  else
    textJoin "\n" [
      "Verification tier: focused.",
      "Do not run `bash scripts/verify-all.sh` for this focused branch. Full verify-all is reserved for integration/signoff tasks.",
      "Run bounded task-focused checks and return a durable verifier report even if confidence is incomplete.",
      "Prefer fast, local evidence over broad repository-wide signoff; classify any skipped slow checks as follow-up.",
      textConcat ["Verifier timeout budget ms: ", encode verifierTimeoutMs, "."],
      focusedVerifyAuditText attempt
    ]

loopState : Int -> Str -> Str -> Bool -> Int -> Int -> Bool -> Bool -> Str -> Bool -> LoopState
loopState attempt phase verdict completed builderRuns verifierRuns healthy needsAttention attentionReason final =
  LoopState {
    attempt = attempt,
    phase = phase,
    verdict = verdict,
    completed = completed,
    builderRuns = builderRuns,
    verifierRuns = verifierRuns,
    healthy = healthy,
    needsAttention = needsAttention,
    attentionReason = attentionReason,
    final = final
  }

emptyLoopState : LoopState
emptyLoopState = loopState 1 "needs-builder" "pending" false 0 0 true false "" false

writeLoopState : LoopState -> Str
writeLoopState state = match writeFile loopStatePath (encode state) {
  Ok written ->
    "",
  Err message ->
    message
}

loopStateJsonFields : Int -> Str -> Str -> Bool -> Int -> Int -> Bool -> Bool -> Str -> Bool -> Str
loopStateJsonFields attempt phase verdict completed builderRuns verifierRuns healthy needsAttention attentionReason final =
  textConcat [
    "{\"attempt\":",
    encode attempt,
    ",\"phase\":",
    encode phase,
    ",\"verdict\":",
    encode verdict,
    ",\"completed\":",
    encode completed,
    ",\"builderRuns\":",
    encode builderRuns,
    ",\"verifierRuns\":",
    encode verifierRuns,
    ",\"healthy\":",
    encode healthy,
    ",\"needsAttention\":",
    encode needsAttention,
    ",\"attentionReason\":",
    encode attentionReason,
    ",\"final\":",
    encode final,
    "}"
  ]

pendingVerifierStateJson : Int -> Str -> Str
pendingVerifierStateJson attempt phase =
  loopStateJsonFields attempt phase "pending" false attempt attempt true false "" false

completedPassStateJson : Int -> Str
completedPassStateJson attempt =
  loopStateJsonFields attempt "completed" "pass" true attempt attempt true false "" true

failedFinalStateJson : Int -> Str -> Str
failedFinalStateJson attempt reason =
  loopStateJsonFields attempt "failed" "fail" false attempt attempt false true reason true

retryBuilderStateJson : Int -> Int -> Str -> Str
retryBuilderStateJson nextAttempt completedAttempt reason =
  loopStateJsonFields nextAttempt "needs-builder" "retry" false completedAttempt completedAttempt false true reason false

verifierFailureStateJson : Int -> Str -> Str
verifierFailureStateJson attempt reason =
  if attempt == maxAttempts then
    failedFinalStateJson attempt reason
  else
    retryBuilderStateJson (incrementAttempt attempt) attempt reason

readLoopState : LoopState
readLoopState = match readFile loopStatePath {
  Ok raw ->
    decode LoopState raw,
  Err message ->
    emptyLoopState
}

currentUpgradeSnapshot : LoopUpgradeSnapshot
currentUpgradeSnapshot =
  LoopUpgradeSnapshot {
    state = readLoopState,
    feedback = readTextOrEmpty feedbackPath
  }

restoreSnapshotIfNeeded : Str
restoreSnapshotIfNeeded =
  if restoreSnapshotPath == "" then
    ""
  else if fileExists loopStatePath then
    ""
  else
    match readFile restoreSnapshotPath {
      Err message ->
        textConcat ["restore-read-error:", message],
      Ok raw ->
        let snapshot = decode LoopUpgradeSnapshot raw in
        let stateError = writeLoopState snapshot.state in
        if stateError != "" then
          textConcat ["restore-state-error:", stateError]
        else {
          let feedbackError =
            if snapshot.feedback == "" then
              ""
            else
              match writeFile feedbackPath snapshot.feedback {
                Ok written ->
                  "",
                Err message ->
                  message
              } in
          if feedbackError != "" then
            textConcat ["restore-feedback-error:", feedbackError]
          else
            match
              writeFile
                restoredSnapshotPath
                (encode
                  (LoopUpgradeRestoreRecord {
                    serviceRoot = restoreServiceRoot,
                    serviceId = restoreServiceId,
                    generation = restoreGeneration,
                    transactionPath = restoreTransactionPath,
                    snapshot = snapshot
                  }))
            {
              Ok written ->
                "",
              Err message ->
                textConcat ["restore-marker-error:", message]
            }
        }
    }

incrementAttempt : Int -> Int
incrementAttempt value =
  if value == 0 then
    1
  else if value == 1 then
    2
  else if value == 2 then
    3
  else if value == 3 then
    4
  else if value == 4 then
    5
  else if value == 5 then
    6
  else if value == 6 then
    7
  else if value == 7 then
    8
  else if value == 8 then
    9
  else if value == 9 then
    10
  else if value == 10 then
    11
  else if value == 11 then
    12
  else if value == 12 then
    13
  else if value == 13 then
    14
  else if value == 14 then
    15
  else if value == 15 then
    16
  else if value == 16 then
    17
  else if value == 17 then
    18
  else if value == 18 then
    19
  else if value == 19 then
    20
  else
    value

