module Main

import Process

record CapabilityStatus = {
  name : Str,
  status : Str,
  evidence : [Str],
  blocking_gaps : [Str],
  required_closure : [Str]
}
record VerifierReport = {
  verdict : Str,
  summary : Str,
  findings : [Str],
  tests_run : [Str],
  follow_up : [Str],
  capability_statuses : [CapabilityStatus]
}
record LoopState = {
  attempt : Int,
  phase : Str,
  verdict : Str,
  completed : Bool,
  builderRuns : Int,
  verifierRuns : Int,
  healthy : Bool,
  needsAttention : Bool,
  attentionReason : Str,
  final : Bool
}
record StepHandle = {
  prefix : Str,
  attempt : Int,
  reportPath : Str,
  stdoutPath : Str,
  stderrPath : Str,
  heartbeatPath : Str
}
record LoopUpgradeSnapshot = { state : LoopState, feedback : Str }
record LoopUpgradeRestoreRecord = {
  serviceRoot : Str,
  serviceId : Str,
  generation : Int,
  transactionPath : Str,
  snapshot : LoopUpgradeSnapshot
}

stateRoot : Str
stateRoot = if textJoin "" argv == "" then "feedback-loop-state" else pathJoin argv

emptyTexts : [Str]
emptyTexts = []

emptyCapabilityStatuses : [CapabilityStatus]
emptyCapabilityStatuses = []

readEnvText : Str -> Str -> Str
readEnvText name fallback = match envVar name {
  Ok raw -> decode Str raw,
  Err message -> fallback
}

readEnvInt : Str -> Int -> Int
readEnvInt name fallback = match envVar name {
  Ok raw -> decode Int raw,
  Err message -> fallback
}

readEnvTextList : Str -> [Str] -> [Str]
readEnvTextList name fallback = match envVar name {
  Ok raw -> decode [Str] raw,
  Err message -> fallback
}

taskFile : Str
taskFile = readEnvText "CLASP_LOOP_TASK_FILE_JSON" "agents/tasks/0011-swarm-ready-full-goal.md"

workspaceRoot : Str
workspaceRoot = readEnvText "CLASP_LOOP_WORKSPACE_JSON" "."

defaultBaselineWorkspace : Str
defaultBaselineWorkspace = {
  let candidate = pathJoin [stateRoot, "baseline-workspace"] in
  if length candidate < 96 then
    candidate
  else
    pathJoin ["/tmp", "clasp-feedback-loop-baselines", textFingerprint64Hex stateRoot]
}

baselineWorkspace : Str
baselineWorkspace = readEnvText "CLASP_LOOP_BASELINE_WORKSPACE_JSON" defaultBaselineWorkspace

builderSchemaPath : Str
builderSchemaPath = readEnvText "CLASP_LOOP_BUILDER_SCHEMA_JSON" "agents/schemas/builder-report.schema.json"

verifierSchemaPath : Str
