maxAttempts = readEnvInt "CLASP_LOOP_MAX_ATTEMPTS_JSON" 20

commandName : Str
commandName = match envVar "CLASP_LOOP_COMMAND" {
  Ok raw -> raw,
  Err message -> "run"
}

readySignalPath : Str
readySignalPath = readEnvText "CLASP_LOOP_READY_PATH_JSON" ""

readySignalText : Str
