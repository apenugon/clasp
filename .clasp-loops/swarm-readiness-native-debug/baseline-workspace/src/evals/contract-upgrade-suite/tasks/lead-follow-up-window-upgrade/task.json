{
  "id": "lead-follow-up-window-upgrade",
  "title": "Upgrade the lead summary flow to a LeadFollowUpDigest contract",
  "overview": "The lead follow-up slice needs a scheduling-oriented contract upgrade that should propagate through the API, workflow state, and downstream lookup request.",
  "requirements": [
    "Introduce a new record type named `LeadFollowUpDigest` with this exact schema: `company : Str`, `priorityLabel : Str`, `followUpWindowDays : Int`, `escalationOwner : Str`.",
