type HostedPackageImportKindAst = HostedPackageImportNpm | HostedPackageImportTypeScript
type HostedForeignSourceAst = HostedForeignRuntime | HostedForeignPackageImport HostedPackageImportKindAst Str Str
type HostedExprAst = HostedName Str | HostedString Str | HostedInt Str | HostedBool Bool | HostedList [HostedExprAst] | HostedCall Str [HostedExprAst] | HostedConstructor Str [HostedExprAst] | HostedMatch HostedExprAst [HostedMatchBranchAst] | HostedRecord Str [HostedRecordFieldExprAst] | HostedFieldAccess HostedExprAst Str | HostedLet Str HostedExprAst HostedExprAst | HostedMutableLet Str HostedExprAst HostedExprAst | HostedAssign Str HostedExprAst HostedExprAst | HostedFor Str HostedExprAst HostedExprAst HostedExprAst | HostedReturn HostedExprAst | HostedIf HostedExprAst HostedExprAst HostedExprAst | HostedEqual HostedExprAst HostedExprAst | HostedNotEqual HostedExprAst HostedExprAst | HostedLessThan HostedExprAst HostedExprAst | HostedLessThanOrEqual HostedExprAst HostedExprAst | HostedGreaterThan HostedExprAst HostedExprAst | HostedGreaterThanOrEqual HostedExprAst HostedExprAst
type HostedRecordFieldExprAst = HostedRecordFieldExprAst Str HostedExprAst
type HostedRecordFieldDeclAst = HostedRecordFieldDeclAst Str HostedTypeAst Str
type HostedRecordDeclAst = HostedRecordDeclAst Str [Str] [HostedRecordFieldDeclAst]
type HostedConstructorDeclAst = HostedConstructorDeclAst Str [HostedTypeAst]
