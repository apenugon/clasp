renderHostedAtomicType : HostedTypeAst -> Str
renderHostedAtomicType typeAst = match typeAst {
  HostedTypeFunction input result ->
    textConcat ["(", renderHostedType typeAst, ")"],
  HostedTypeList itemType ->
    textConcat ["[", renderHostedType itemType, "]"],
  HostedTypeApply name args ->
    textConcat ["(", renderHostedType typeAst, ")"],
  HostedTypeVar name ->
    name,
  HostedTypeName name ->
    name
}

renderHostedType : HostedTypeAst -> Str
renderHostedType typeAst = match typeAst {
  HostedTypeName name ->
    name,
  HostedTypeApply name args ->
    textConcat [name, " ", textJoin " " (renderHostedTypeList args)],
  HostedTypeVar name ->
    name,
  HostedTypeList itemType ->
    textConcat ["[", renderHostedType itemType, "]"],
  HostedTypeFunction input result ->
    textConcat [renderHostedAtomicType input, " -> ", renderHostedType result]
}

missingAnnotation : HostedAnnotationAst
missingAnnotation = MissingAnnotation

presentAnnotation : HostedTypeAst -> HostedAnnotationAst
presentAnnotation typeAst = PresentAnnotation typeAst

annotationTypeAst : HostedAnnotationAst -> HostedTypeAst
annotationTypeAst annotation = match annotation {
  MissingAnnotation ->
    HostedTypeName "",
  PresentAnnotation typeAst ->
    typeAst
}

hasAnnotationAst : HostedAnnotationAst -> Bool
hasAnnotationAst annotation = match annotation {
  MissingAnnotation ->
    false,
  PresentAnnotation typeAst ->
    true
}

renderAnnotationAst : HostedAnnotationAst -> Str
renderAnnotationAst annotation = match annotation {
  MissingAnnotation ->
    "",
  PresentAnnotation typeAst ->
    renderHostedType typeAst
}

