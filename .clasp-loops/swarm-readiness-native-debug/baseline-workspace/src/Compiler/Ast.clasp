stepParserDefinition : ParserState -> [Str] -> ParserState
stepParserDefinition state words = match splitTokensAt "=" words {
  FoundTokenSplit definitionLhsTokens definitionRhsTokens ->
    if firstText definitionLhsTokens == "main" then appendMainDefinition state (textJoin " " definitionRhsTokens) else appendDefinition state (textJoin " " definitionLhsTokens) (textJoin " " definitionRhsTokens),
  MissingTokenSplit ->
    state
}

stepParserAnnotationOrDefinition : ParserState -> [Str] -> ParserState
stepParserAnnotationOrDefinition state words = match splitTokensAt ":" words {
  FoundTokenSplit lhsTokens rhsTokens ->
    if firstText (remainingTexts lhsTokens) == "" then parserState (stateModuleName state) (stateImports state) (stateTypeDeclarations state) (stateRecordDeclarations state) (stateForeignDeclarations state) (stateDeclarations state) (stateGuideDeclarations state) (statePolicyDeclarations state) (stateProjectionDeclarations state) (stateAgentRoleDeclarations state) (stateAgentDeclarations state) (stateWorkflowDeclarations state) (stateRouteDeclarations state) (stateHookDeclarations state) (stateToolServerDeclarations state) (stateToolDeclarations state) (stateVerifierDeclarations state) (stateMergeGateDeclarations state) (presentAnnotation (parseHostedType (textJoin " " rhsTokens))) (stateMainExprSummary state) else stepParserDefinition state words,
  MissingTokenSplit ->
    stepParserDefinition state words
}

stepParserPlain : ParserState -> Str -> ParserState
stepParserPlain state line = stepParserAnnotationOrDefinition state (splitWords line)

stepParserHostedSignature : ParserState -> Str -> ParserState
stepParserHostedSignature state line = match textPrefix line "hosted foreign-signature " {
  Ok signatureBody ->
    appendForeignSignatureDefinition state signatureBody,
  Err notHostedSignature ->
    stepParserPlain state line
}

stepParserForeign : ParserState -> Str -> ParserState
stepParserForeign state line = match textPrefix line "foreign " {
  Ok foreignBody ->
    appendForeignDefinition state foreignBody,
  Err notForeign ->
    stepParserHostedSignature state line
}

