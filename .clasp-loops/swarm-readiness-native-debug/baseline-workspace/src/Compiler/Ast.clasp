type HostedForeignDeclAst = HostedForeignDeclAst Str Bool HostedTypeAst Str HostedForeignSourceAst Str
type HostedGuideEntryAst = HostedGuideEntryAst Str Str
type HostedGuideDeclAst = HostedGuideDeclAst Str Str [HostedGuideEntryAst]
type HostedPolicyPermissionKindAst = HostedPolicyPermissionFile | HostedPolicyPermissionNetwork | HostedPolicyPermissionProcess | HostedPolicyPermissionSecret
type HostedPolicyPermissionAst = HostedPolicyPermissionAst HostedPolicyPermissionKindAst Str
type HostedPolicyDeclAst = HostedPolicyDeclAst Str [Str] [HostedPolicyPermissionAst]
type HostedProjectionFieldDeclAst = HostedProjectionFieldDeclAst Str
type HostedProjectionDeclAst = HostedProjectionDeclAst Str Str Str [HostedProjectionFieldDeclAst]
type HostedAgentRoleDeclAst = HostedAgentRoleDeclAst Str Str Str Str Str
type HostedAgentDeclAst = HostedAgentDeclAst Str Str
type HostedWorkflowDeclAst = HostedWorkflowDeclAst Str Str HostedTypeAst
type HostedRouteDeclAst = HostedRouteDeclAst Str Str Str Str Str Str Str
