stepParserImport : ParserState -> Str -> ParserState
stepParserImport state line = match textPrefix line "import " {
  Ok importName ->
    parserState (stateModuleName state) (prepend importName (stateImports state)) (stateTypeDeclarations state) (stateRecordDeclarations state) (stateForeignDeclarations state) (stateDeclarations state) (stateGuideDeclarations state) (statePolicyDeclarations state) (stateProjectionDeclarations state) (stateAgentRoleDeclarations state) (stateAgentDeclarations state) (stateWorkflowDeclarations state) (stateRouteDeclarations state) (stateHookDeclarations state) (stateToolServerDeclarations state) (stateToolDeclarations state) (stateVerifierDeclarations state) (stateMergeGateDeclarations state) (statePendingAnnotation state) (stateMainExprSummary state),
  Err importMiss ->
    stepParserType state line
}

stepParser : ParserState -> Str -> ParserState
stepParser state line = match textPrefix line "module " {
  Ok moduleName ->
    parserState moduleName (stateImports state) (stateTypeDeclarations state) (stateRecordDeclarations state) (stateForeignDeclarations state) (stateDeclarations state) (stateGuideDeclarations state) (statePolicyDeclarations state) (stateProjectionDeclarations state) (stateAgentRoleDeclarations state) (stateAgentDeclarations state) (stateWorkflowDeclarations state) (stateRouteDeclarations state) (stateHookDeclarations state) (stateToolServerDeclarations state) (stateToolDeclarations state) (stateVerifierDeclarations state) (stateMergeGateDeclarations state) (statePendingAnnotation state) (stateMainExprSummary state),
  Err moduleMiss ->
    stepParserImport state line
}

parseModuleAst : Str -> HostedModuleAst
parseModuleAst source = {
  let mut state = parserState "Main" emptyRenderedTexts emptyHostedTypeDecls emptyHostedRecordDecls emptyHostedForeignDecls emptyHostedDecls emptyHostedGuideDecls emptyHostedPolicyDecls emptyHostedProjectionDecls emptyHostedAgentRoleDecls emptyHostedAgentDecls emptyHostedWorkflowDecls emptyHostedRouteDecls emptyHostedHookDecls emptyHostedToolServerDecls emptyHostedToolDecls emptyHostedVerifierDecls emptyHostedMergeGateDecls missingAnnotation "<missing>";
  for line in logicalLines source {
    state = stepParser state line;
    state
  };
  hostedModuleAst (stateModuleName state) (reverse (stateImports state)) (reverse (stateTypeDeclarations state)) (reverse (stateRecordDeclarations state)) (reverse (stateForeignDeclarations state)) (reverse (stateDeclarations state)) (reverse (stateGuideDeclarations state)) (reverse (statePolicyDeclarations state)) (reverse (stateProjectionDeclarations state)) (reverse (stateAgentRoleDeclarations state)) (reverse (stateAgentDeclarations state)) (reverse (stateWorkflowDeclarations state)) (reverse (stateRouteDeclarations state)) (reverse (stateHookDeclarations state)) (reverse (stateToolServerDeclarations state)) (reverse (stateToolDeclarations state)) (reverse (stateVerifierDeclarations state)) (reverse (stateMergeGateDeclarations state)) (stateMainExprSummary state)
}

declNames : HostedModuleAst -> [Str]
declNames modl = {
  let mut names = emptyRenderedTexts;
  for decl in moduleDeclarations modl {
    names = appendRenderedText names (declName decl);
    names
  };
  names
}

recordDeclNames : HostedModuleAst -> [Str]
recordDeclNames modl = {
  let mut names = emptyRenderedTexts;
  for decl in moduleRecordDeclarations modl {
    names = appendRenderedText names (recordDeclName decl);
    names
  };
  names
}

firstRecordDecl : HostedModuleAst -> HostedRecordDeclAst
firstRecordDecl modl = {
  for decl in moduleRecordDeclarations modl {
    return decl
  };
  hostedRecordDeclAst "" emptyHostedRecordFieldDecls
}

typeDeclNames : HostedModuleAst -> [Str]
typeDeclNames modl = {
  let mut names = emptyRenderedTexts;
  for decl in moduleTypeDeclarations modl {
    names = appendRenderedText names (typeDeclName decl);
    names
  };
  names
}

firstTypeDecl : HostedModuleAst -> HostedTypeDeclAst
firstTypeDecl modl = {
  for decl in moduleTypeDeclarations modl {
    return decl
  };
  hostedTypeDeclAst "" emptyHostedConstructorDecls
}

declAnnotationTextByName : HostedModuleAst -> Str -> Str
declAnnotationTextByName modl targetName = {
  for decl in moduleDeclarations modl {
    if declName decl == targetName then {
      return renderAnnotationAst (declAnnotation decl)
    } else {
      ""
    }
  };
  ""
}

renderMainExpr : HostedModuleAst -> Str
renderMainExpr modl = moduleMainExprSummary modl
