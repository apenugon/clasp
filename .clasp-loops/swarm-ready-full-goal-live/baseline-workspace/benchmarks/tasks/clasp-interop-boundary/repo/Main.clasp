module Main

record LeadRequest = {
  company : Str,
  budget : Int
}

record LeadVerdict = {
  accepted : Bool,
  reason : Str
}

record LeadInspection = {
  label : Str,
  verdict : LeadVerdict
}

foreign inspectLead : LeadRequest -> LeadInspection = "inspectLead"

assessLead : LeadRequest -> LeadInspection
assessLead request = inspectLead request

main : Str
main = "ok"
