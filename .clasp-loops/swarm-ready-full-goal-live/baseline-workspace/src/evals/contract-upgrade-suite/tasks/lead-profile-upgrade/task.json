{
  "id": "lead-profile-upgrade",
  "title": "Upgrade the lead summary flow to a LeadProfile contract",
  "overview": "The lead follow-up slice needs a profile-oriented contract upgrade that should propagate through the API, workflow state, and downstream lookup request.",
  "requirements": [
    "Introduce a new record type named `LeadProfile` with this exact schema: `company : Str`, `segment : Str`, `plan : Str`, `ownerTeam : Str`.",
    "Update the downstream playbook lookup request so it carries `segment : Str` and `ownerTeam : Str` instead of a single status string.",
    "Update the workflow state so it stores `profile : LeadProfile`.",
    "Update the lead summary API route so it returns `LeadProfile`.",
    "Keep the program compiling.",
    "Keep `main` working. After the change, `main` should evaluate to `\"enterprise\"`."
  ],
  "fileHints": [
    "Main.clasp",
    "Shared/Lead.clasp"
  ],
  "oracleHints": [
    "Exact edit surfaces: `Main.clasp`, `Shared/Lead.clasp`.",
    "Relevant declarations: `LeadSummary`, `LeadPlaybookLookup`, `LeadFollowUpState`, `summarizeLeadApi`, `lookupLeadPlaybook`, `main`."
  ],
  "expectedMain": "enterprise",
  "semanticFocus": {
    "schemaNames": [
      "LeadIntake",
      "LeadSummary",
      "LeadPlaybookLookup",
      "LeadPlaybook",
      "LeadFollowUpState"
    ],
    "routeNames": [
      "summarizeLeadApi"
    ],
    "toolNames": [
      "lookupLeadPlaybook"
    ],
    "workflowNames": [
      "LeadFollowUpFlow"
    ],
    "declNames": [
      "summarizeLead",
      "playbookRequest",
      "main"
    ]
  },
  "assertions": {
    "schemas": {
      "present": [
        {
          "name": "LeadProfile",
          "fields": [
            { "name": "company", "type": "Str" },
            { "name": "ownerTeam", "type": "Str" },
            { "name": "plan", "type": "Str" },
            { "name": "segment", "type": "Str" }
          ]
        },
        {
          "name": "LeadFollowUpState",
          "fields": [
            { "name": "profile", "type": "LeadProfile" }
          ]
        }
      ],
      "absent": [
        "LeadSummary"
      ]
    },
    "tool": {
      "name": "lookupLeadPlaybook",
      "requestType": "LeadPlaybookLookup",
      "responseType": "LeadPlaybook",
      "requestFields": [
        { "name": "ownerTeam", "type": "Str" },
        { "name": "segment", "type": "Str" }
      ]
    },
    "route": {
      "name": "summarizeLeadApi",
      "responseType": "LeadProfile"
    },
    "workflow": {
      "name": "LeadFollowUpFlow",
      "stateType": "LeadFollowUpState",
      "stateField": "profile",
      "stateFieldType": "LeadProfile"
    },
    "context": {
      "requiredNodes": [
        "schema:LeadProfile",
        "route:summarizeLeadApi",
        "tool:lookupLeadPlaybook"
      ],
      "absentNodes": [
        "schema:LeadSummary"
      ],
      "routeResponseEdge": {
        "routeId": "route:summarizeLeadApi",
        "schemaId": "schema:LeadProfile"
      }
    },
    "air": {
      "requiredRoots": [
        "record:LeadProfile",
        "route:summarizeLeadApi",
        "tool:lookupLeadPlaybook"
      ],
      "absentRoots": [
        "record:LeadSummary"
      ]
    }
  }
}
