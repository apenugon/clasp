emitHostedRecordFieldLayoutImage : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> Str -> HostedRecordFieldDeclAst -> Str
emitHostedRecordFieldLayoutImage typeDecls recordDecls wordOffset fieldDecl =
  jsonObject [
    jsonFieldText "name" (recordFieldDeclName fieldDecl),
    jsonFieldText "type" (renderHostedType (recordFieldDeclType fieldDecl)),
    jsonFieldText "storage" (nativeLayoutStorageForType typeDecls recordDecls (recordFieldDeclType fieldDecl)),
    jsonFieldRaw "wordOffset" wordOffset,
    jsonFieldRaw "wordCount" "1"
  ]

emitHostedRecordFieldLayoutImages : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [HostedRecordFieldDeclAst] -> [Str]
emitHostedRecordFieldLayoutImages typeDecls recordDecls fields = {
  let mut rendered = emptyRenderedTexts;
  let mut wordOffset = "0";
  for fieldDecl in fields {
    rendered = appendNativeRenderedText rendered (emitHostedRecordFieldLayoutImage typeDecls recordDecls wordOffset fieldDecl);
    wordOffset = incrementNativeNumber wordOffset;
    rendered
  };
  rendered
}

emitHostedRecordLayoutImages : HostedModuleAst -> [Str]
emitHostedRecordLayoutImages modl = {
  let typeDecls = effectiveModuleTypeDecls modl;
  let recordDecls = moduleRecordDeclarations modl;
  let mut rendered = emptyRenderedTexts;
  for recordDecl in recordDecls {
    rendered = appendNativeRenderedText rendered (jsonObject [
      jsonFieldText "name" (recordDeclName recordDecl),
      jsonFieldRaw "words" (countHostedRecordFields (recordDeclFields recordDecl)),
      jsonFieldArray "fields" (emitHostedRecordFieldLayoutImages typeDecls recordDecls (recordDeclFields recordDecl))
    ]);
    rendered
  };
  rendered
}

emitHostedPayloadLayoutImage : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> Str -> HostedTypeAst -> Str
emitHostedPayloadLayoutImage typeDecls recordDecls wordOffset payloadType =
  jsonObject [
    jsonFieldText "name" (textConcat ["$", decrementNativeNumber wordOffset]),
    jsonFieldText "type" (renderHostedType payloadType),
    jsonFieldText "storage" (nativeLayoutStorageForType typeDecls recordDecls payloadType),
    jsonFieldRaw "wordOffset" wordOffset,
    jsonFieldRaw "wordCount" "1"
  ]

emitHostedPayloadLayoutImages : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [HostedTypeAst] -> [Str]
emitHostedPayloadLayoutImages typeDecls recordDecls payloadTypes = {
  let mut rendered = emptyRenderedTexts;
  let mut wordOffset = "1";
  for payloadType in payloadTypes {
    rendered = appendNativeRenderedText rendered (emitHostedPayloadLayoutImage typeDecls recordDecls wordOffset payloadType);
    wordOffset = incrementNativeNumber wordOffset;
    rendered
  };
  rendered
}

emitHostedConstructorLayoutImage : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> HostedConstructorDeclAst -> Str
emitHostedConstructorLayoutImage typeDecls recordDecls constructorDecl = {
  let payloadTypes = constructorDeclPayloadTypes constructorDecl;
  let payloadWords = countHostedTypes payloadTypes;
  let totalWords = incrementNativeNumber payloadWords;
  jsonObject [
    jsonFieldText "name" (constructorDeclName constructorDecl),
    jsonFieldRaw "tagWord" "0",
    jsonFieldRaw "payloadWords" payloadWords,
    jsonFieldRaw "words" totalWords,
    jsonFieldArray "payloads" (emitHostedPayloadLayoutImages typeDecls recordDecls payloadTypes)
  ]
}

emitHostedVariantLayoutImages : HostedModuleAst -> [Str]
emitHostedVariantLayoutImages modl = {
  let typeDecls = effectiveModuleTypeDecls modl;
  let emittedTypeDecls = nativeEmittedTypeDecls modl;
  let recordDecls = moduleRecordDeclarations modl;
  let mut rendered = emptyRenderedTexts;
  for typeDecl in emittedTypeDecls {
    let maxPayloadWords = countHostedTypes (maxConstructorPayloadTypes typeDecl);
    let mut constructorLayouts = emptyRenderedTexts;
    for constructorDecl in typeDeclConstructors typeDecl {
      constructorLayouts = appendNativeRenderedText constructorLayouts (emitHostedConstructorLayoutImage typeDecls recordDecls constructorDecl);
      constructorLayouts
    };
    rendered = appendNativeRenderedText rendered (jsonObject [
      jsonFieldText "name" (typeDeclName typeDecl),
      jsonFieldRaw "tagWord" "0",
      jsonFieldRaw "maxPayloadWords" maxPayloadWords,
      jsonFieldRaw "words" (incrementNativeNumber maxPayloadWords),
      jsonFieldArray "constructors" constructorLayouts
    ]);
    rendered
  };
  rendered
}

emitHostedRecordObjectLayoutImages : HostedModuleAst -> [Str]
emitHostedRecordObjectLayoutImages modl = {
  let typeDecls = effectiveModuleTypeDecls modl;
  let recordDecls = moduleRecordDeclarations modl;
  let mut rendered = emptyRenderedTexts;
  for recordDecl in recordDecls {
    let fieldCount = countHostedRecordFields (recordDeclFields recordDecl);
    rendered = appendNativeRenderedText rendered (jsonObject [
      jsonFieldText "name" (recordDeclName recordDecl),
      jsonFieldText "kind" "record",
      jsonFieldRaw "headerWords" "2",
      jsonFieldRaw "words" (headerAdjustedOffset fieldCount),
      jsonFieldArray "roots" (emitNativeJsonNumberList (emitHostedRecordRootOffsets typeDecls recordDecls (recordDeclFields recordDecl)))
    ]);
    rendered
  };
  rendered
}

emitHostedVariantObjectLayoutImages : HostedModuleAst -> [Str]
emitHostedVariantObjectLayoutImages modl = {
  let typeDecls = effectiveModuleTypeDecls modl;
  let emittedTypeDecls = nativeEmittedTypeDecls modl;
  let recordDecls = moduleRecordDeclarations modl;
  let mut rendered = emptyRenderedTexts;
  for typeDecl in emittedTypeDecls {
    for constructorDecl in typeDeclConstructors typeDecl {
      let payloadTypes = constructorDeclPayloadTypes constructorDecl;
      let totalWords = incrementNativeNumber (countHostedTypes payloadTypes);
      rendered = appendNativeRenderedText rendered (jsonObject [
        jsonFieldText "name" (textConcat [typeDeclName typeDecl, ".", constructorDeclName constructorDecl]),
        jsonFieldText "kind" "variant",
        jsonFieldRaw "headerWords" "2",
        jsonFieldRaw "words" (headerAdjustedOffset totalWords),
        jsonFieldArray "roots" (emitNativeJsonNumberList (emitHostedVariantRootOffsets typeDecls recordDecls payloadTypes))
      ]);
      rendered
    };
    rendered
  };
  rendered
}

emitNativeCompatibilitySurfaceImage : HostedModuleAst -> [LowerDeclText] -> Str
emitNativeCompatibilitySurfaceImage modl decls = {
  let moduleName = moduleNameOf modl;
  let ignored = decls;
  let exports = collectNativeExportNamesFromModule modl;
  let entrypoints = append (emitNativeConstructorEntrypointJsons moduleName modl) (emitNativeEntrypointJsonsFromModule moduleName modl);
  jsonObject [
    jsonFieldText "module" moduleName,
    jsonFieldArray "exports" (emitNativeJsonStringList exports),
    jsonFieldArray "entrypoints" entrypoints,
    jsonFieldRaw "abi" (emitNativeAbiImage modl),
    jsonFieldRaw "runtime" (emitNativeRuntimeImage modl)
  ]
}

nativeDeclName : LowerDeclText -> Str
nativeDeclName decl = match decl {
  LowerConst name body ->
    name,
  LowerFn name params body ->
    name
}

renderNativeDecls : [LowerDeclText] -> [Str]
renderNativeDecls decls = {
  let mut rendered = emptyRenderedTexts;
  for decl in decls {
    rendered = appendNativeRenderedText rendered (emitNativeDecl decl);
    rendered
  };
  rendered
}

nativeAbiRecordLayoutLines : [Str]
nativeAbiRecordLayoutLines = {
  let mut lines = emptyRenderedTexts;
  lines = appendNativeRenderedText lines "  record_layout Principal { words = 1, fields = [id:Str@word0/handle] }";
  lines = appendNativeRenderedText lines "  record_layout Tenant { words = 1, fields = [id:Str@word0/handle] }";
  lines = appendNativeRenderedText lines "  record_layout ResourceIdentity { words = 2, fields = [resourceType:Str@word0/handle, resourceId:Str@word1/handle] }";
  lines = appendNativeRenderedText lines "  record_layout AuditActor { words = 2, fields = [actorType:Str@word0/handle, actorId:Str@word1/handle] }";
  lines = appendNativeRenderedText lines "  record_layout AuditAction { words = 2, fields = [actionType:Str@word0/handle, summary:Str@word1/handle] }";
  lines = appendNativeRenderedText lines "  record_layout AuditProvenance { words = 3, fields = [source:Str@word0/handle, requestId:Str@word1/handle, traceId:Str@word2/handle] }";
  lines = appendNativeRenderedText lines "  record_layout SqliteConnection { words = 4, fields = [id:Str@word0/handle, databasePath:Str@word1/handle, readOnly:Bool@word2/immediate, memory:Bool@word3/immediate] }";
  lines = appendNativeRenderedText lines "  record_layout AuthSession { words = 4, fields = [sessionId:Str@word0/handle, principal:Principal@word1/handle, tenant:Tenant@word2/handle, resource:ResourceIdentity@word3/handle] }";
  lines = appendNativeRenderedText lines "  record_layout StandardAuditEnvelope { words = 5, fields = [actor:AuditActor@word0/handle, resource:ResourceIdentity@word1/handle, action:AuditAction@word2/handle, timestamp:Int@word3/immediate, provenance:AuditProvenance@word4/handle] }";
  lines
}

nativeAbiObjectLayoutLines : [Str]
nativeAbiObjectLayoutLines = {
  let mut lines = emptyRenderedTexts;
  lines = appendNativeRenderedText lines "  object_layout Principal { kind = record, header_words = 2, words = 3, roots = [2] }";
  lines = appendNativeRenderedText lines "  object_layout Tenant { kind = record, header_words = 2, words = 3, roots = [2] }";
  lines = appendNativeRenderedText lines "  object_layout ResourceIdentity { kind = record, header_words = 2, words = 4, roots = [2, 3] }";
  lines = appendNativeRenderedText lines "  object_layout AuditActor { kind = record, header_words = 2, words = 4, roots = [2, 3] }";
  lines = appendNativeRenderedText lines "  object_layout AuditAction { kind = record, header_words = 2, words = 4, roots = [2, 3] }";
  lines = appendNativeRenderedText lines "  object_layout AuditProvenance { kind = record, header_words = 2, words = 5, roots = [2, 3, 4] }";
  lines = appendNativeRenderedText lines "  object_layout SqliteConnection { kind = record, header_words = 2, words = 6, roots = [2, 3] }";
  lines = appendNativeRenderedText lines "  object_layout AuthSession { kind = record, header_words = 2, words = 6, roots = [2, 3, 4, 5] }";
  lines = appendNativeRenderedText lines "  object_layout StandardAuditEnvelope { kind = record, header_words = 2, words = 7, roots = [2, 3, 4, 6] }";
  lines
}

typeDeclAllNullary : HostedTypeDeclAst -> Bool
typeDeclAllNullary typeDecl = {
  for constructorDecl in typeDeclConstructors typeDecl {
    if hasHostedTypeValues (constructorDeclPayloadTypes constructorDecl) then return false else true
  };
  true
}

nativeLayoutStorageForType : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> HostedTypeAst -> Str
nativeLayoutStorageForType typeDecls recordDecls typ = match typ {
  HostedTypeName name ->
    if name == "Int" then "immediate" else if name == "Bool" then "immediate" else if name == "Str" then "handle" else if name == "Page" then "handle" else if name == "Redirect" then "handle" else if name == "View" then "handle" else if name == "Prompt" then "handle" else match lookupRecordDecl recordDecls name {
      FoundRecord recordDecl ->
        "handle",
      MissingRecord missingRecord ->
        match lookupTypeDecl typeDecls name {
          FoundTypeDecl typeDecl ->
            if typeDeclAllNullary typeDecl then "immediate" else "handle",
          MissingTypeDecl missingType ->
            "handle"
        }
    },
  HostedTypeApply name args ->
    "handle",
  HostedTypeVar name ->
    "handle",
  HostedTypeList itemType ->
    "handle",
  HostedTypeFunction input result ->
    "handle"
}

emitHostedRecordFieldLayout : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> Str -> HostedRecordFieldDeclAst -> Str
emitHostedRecordFieldLayout typeDecls recordDecls wordOffset fieldDecl = textConcat [recordFieldDeclName fieldDecl, ":", renderHostedType (recordFieldDeclType fieldDecl), "@word", wordOffset, "/", nativeLayoutStorageForType typeDecls recordDecls (recordFieldDeclType fieldDecl)]

emitHostedRecordFieldLayouts : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [HostedRecordFieldDeclAst] -> [Str]
emitHostedRecordFieldLayouts typeDecls recordDecls fields = {
  let mut rendered = emptyRenderedTexts;
  let mut wordOffset = "0";
  for fieldDecl in fields {
    rendered = appendNativeRenderedText rendered (emitHostedRecordFieldLayout typeDecls recordDecls wordOffset fieldDecl);
    wordOffset = incrementNativeNumber wordOffset;
    rendered
  };
  rendered
}

emitHostedRecordRootOffsets : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [HostedRecordFieldDeclAst] -> [Str]
emitHostedRecordRootOffsets typeDecls recordDecls fields = {
  let mut rendered = emptyRenderedTexts;
  let mut wordOffset = "0";
  for fieldDecl in fields {
    rendered = if nativeLayoutStorageForType typeDecls recordDecls (recordFieldDeclType fieldDecl) == "handle" then appendNativeRenderedText rendered (headerAdjustedOffset wordOffset) else rendered;
    wordOffset = incrementNativeNumber wordOffset;
    rendered
  };
  rendered
}

emitHostedRecordLayoutLines : HostedModuleAst -> [Str]
emitHostedRecordLayoutLines modl = {
  let typeDecls = effectiveModuleTypeDecls modl;
  let recordDecls = moduleRecordDeclarations modl;
  let mut rendered = emptyRenderedTexts;
  for recordDecl in recordDecls {
    rendered = appendNativeRenderedText rendered (textConcat ["  record_layout ", recordDeclName recordDecl, " { words = ", countHostedRecordFields (recordDeclFields recordDecl), ", fields = [", textJoin ", " (emitHostedRecordFieldLayouts typeDecls recordDecls (recordDeclFields recordDecl)), "] }"]);
    rendered
  };
  rendered
}

emitHostedRecordObjectLayoutLines : HostedModuleAst -> [Str]
emitHostedRecordObjectLayoutLines modl = {
  let typeDecls = effectiveModuleTypeDecls modl;
  let recordDecls = moduleRecordDeclarations modl;
  let mut rendered = emptyRenderedTexts;
  for recordDecl in recordDecls {
    let fieldCount = countHostedRecordFields (recordDeclFields recordDecl);
    rendered = appendNativeRenderedText rendered (textConcat ["  object_layout ", recordDeclName recordDecl, " { kind = record, header_words = 2, words = ", headerAdjustedOffset fieldCount, ", roots = [", textJoin ", " (emitHostedRecordRootOffsets typeDecls recordDecls (recordDeclFields recordDecl)), "] }"]);
    rendered
  };
  rendered
}

maxConstructorPayloadTypes : HostedTypeDeclAst -> [HostedTypeAst]
maxConstructorPayloadTypes typeDecl = {
  let mut payloadTypes = emptyHostedTypes;
  for constructorDecl in typeDeclConstructors typeDecl {
    payloadTypes = maxHostedTypeList payloadTypes (constructorDeclPayloadTypes constructorDecl);
    payloadTypes
  };
  payloadTypes
}

emitHostedPayloadLayouts : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [HostedTypeAst] -> [Str]
emitHostedPayloadLayouts typeDecls recordDecls payloadTypes = {
  let mut rendered = emptyRenderedTexts;
  let mut wordOffset = "1";
  for payloadType in payloadTypes {
    rendered = appendNativeRenderedText rendered (textConcat ["$", decrementNativeNumber wordOffset, ":", renderHostedType payloadType, "@word", wordOffset, "/", nativeLayoutStorageForType typeDecls recordDecls payloadType]);
    wordOffset = incrementNativeNumber wordOffset;
    rendered
  };
  rendered
}

emitHostedConstructorLayout : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> HostedConstructorDeclAst -> Str
emitHostedConstructorLayout typeDecls recordDecls constructorDecl = {
  let payloadTypes = constructorDeclPayloadTypes constructorDecl;
  let payloadWords = countHostedTypes payloadTypes;
  let totalWords = incrementNativeNumber payloadWords;
  textConcat [constructorDeclName constructorDecl, "{tag_word=0, payload_words=", payloadWords, ", words=", totalWords, ", payloads=[", textJoin ", " (emitHostedPayloadLayouts typeDecls recordDecls payloadTypes), "]}"]
}

emitHostedVariantLayoutLines : HostedModuleAst -> [Str]
emitHostedVariantLayoutLines modl = {
  let typeDecls = effectiveModuleTypeDecls modl;
  let emittedTypeDecls = nativeEmittedTypeDecls modl;
  let recordDecls = moduleRecordDeclarations modl;
  let mut rendered = emptyRenderedTexts;
  for typeDecl in emittedTypeDecls {
    let maxPayloadTypes = maxConstructorPayloadTypes typeDecl;
    let maxPayloadWords = countHostedTypes maxPayloadTypes;
    let mut constructorLayouts = emptyRenderedTexts;
    for constructorDecl in typeDeclConstructors typeDecl {
      constructorLayouts = appendNativeRenderedText constructorLayouts (emitHostedConstructorLayout typeDecls recordDecls constructorDecl);
      constructorLayouts
    };
    rendered = appendNativeRenderedText rendered (textConcat ["  variant_layout ", typeDeclName typeDecl, " { tag_word = 0, max_payload_words = ", maxPayloadWords, ", words = ", incrementNativeNumber maxPayloadWords, ", constructors = [", textJoin ", " constructorLayouts, "] }"]);
    rendered
  };
  rendered
}

emitHostedVariantRootOffsets : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [HostedTypeAst] -> [Str]
emitHostedVariantRootOffsets typeDecls recordDecls payloadTypes = {
  let mut rendered = emptyRenderedTexts;
  let mut wordOffset = "1";
  for payloadType in payloadTypes {
    rendered = if nativeLayoutStorageForType typeDecls recordDecls payloadType == "handle" then appendNativeRenderedText rendered (headerAdjustedOffset wordOffset) else rendered;
    wordOffset = incrementNativeNumber wordOffset;
    rendered
  };
  rendered
}

emitHostedVariantObjectLayoutLines : HostedModuleAst -> [Str]
emitHostedVariantObjectLayoutLines modl = {
  let typeDecls = effectiveModuleTypeDecls modl;
  let emittedTypeDecls = nativeEmittedTypeDecls modl;
  let recordDecls = moduleRecordDeclarations modl;
  let mut rendered = emptyRenderedTexts;
  for typeDecl in emittedTypeDecls {
    for constructorDecl in typeDeclConstructors typeDecl {
      let payloadTypes = constructorDeclPayloadTypes constructorDecl;
      let totalWords = incrementNativeNumber (countHostedTypes payloadTypes);
      rendered = appendNativeRenderedText rendered (textConcat ["  object_layout ", typeDeclName typeDecl, ".", constructorDeclName constructorDecl, " { kind = variant, header_words = 2, words = ", headerAdjustedOffset totalWords, ", roots = [", textJoin ", " (emitHostedVariantRootOffsets typeDecls recordDecls payloadTypes), "] }"]);
      rendered
    };
    rendered
  };
  rendered
}

nativeAbiLines : HostedModuleAst -> [Str]
nativeAbiLines modl = {
  let mut lines = emptyRenderedTexts;
  lines = appendNativeRenderedText lines "abi {";
  lines = appendNativeRenderedText lines "  version clasp-native-v1";
  lines = appendNativeRenderedText lines "  word_bytes 8";
  lines = appendNativeRenderedText lines "  memory_strategy reference_counting";
  lines = appendNativeRenderedText lines "  allocation { immediate = stack, handle = heap, global = static }";
  lines = appendNativeRenderedText lines "  ownership_rules [caller_owns_returns, callee_borrows_arguments, aggregates_retain_handle_fields, globals_are_static_roots]";
  lines = appendNativeRenderedText lines "  root_discovery_rules [static_globals, stack_handle_slots, heap_object_layouts]";
  lines = appendNativeRenderedText lines "  lifetime_invariants [layout_and_retain_headers, declared_root_offsets_only, release_children_before_free, borrowed_handles_do_not_retain]";
  lines = appendNativeRenderedText lines "  builtin_layout Int { storage = immediate, words = 1 }";
  lines = appendNativeRenderedText lines "  builtin_layout Bool { storage = immediate, words = 1 }";
  lines = appendNativeRenderedText lines "  builtin_layout Str { storage = handle, words = 1 }";
  lines = appendNativeRenderedText lines "  builtin_layout List { storage = handle, words = 1 }";
  lines = appendNativeRenderedText lines "  builtin_layout Page { storage = handle, words = 1 }";
  lines = appendNativeRenderedText lines "  builtin_layout Redirect { storage = handle, words = 1 }";
  lines = appendNativeRenderedText lines "  builtin_layout View { storage = handle, words = 1 }";
  lines = appendNativeRenderedText lines "  builtin_layout Prompt { storage = handle, words = 1 }";
  lines = append lines nativeAbiRecordLayoutLines;
  lines = append lines (emitHostedRecordLayoutLines modl);
  lines = append lines (emitHostedVariantLayoutLines modl);
  lines = append lines nativeAbiObjectLayoutLines;
  lines = append lines (emitHostedRecordObjectLayoutLines modl);
  lines = append lines (emitHostedVariantObjectLayoutLines modl);
  lines = appendNativeRenderedText lines "}";
  lines
}

nativeRuntimeLines : HostedModuleAst -> [Str]
nativeRuntimeLines modl = {
  let moduleName = moduleNameOf modl;
  let runtimeBindings = emitNativeRuntimeBindingTexts modl;
  let codecTypes = collectModuleRuntimeCodecTypes modl;
  let mut lines = emptyRenderedTexts;
  lines = appendNativeRenderedText lines "runtime {";
  lines = appendNativeRenderedText lines "  profile compiler_backend_minimal";
  lines = appendNativeRenderedText lines "  artifacts [\"runtime/clasp_runtime.h\", \"runtime/clasp_runtime.rs\"]";
  lines = appendNativeRenderedText lines "  memory_symbols [clasp_rt_init, clasp_rt_register_static_root, clasp_rt_alloc_object, clasp_rt_retain, clasp_rt_release, clasp_rt_string_from_utf8, clasp_rt_bytes_new, clasp_rt_string_list_new, clasp_rt_result_ok_string, clasp_rt_result_err_string, clasp_rt_json_from_string, clasp_rt_json_to_string, clasp_rt_binary_from_json, clasp_rt_json_from_binary, clasp_rt_transport_frame, clasp_rt_transport_unframe]";
  lines = appendNativeRenderedText lines (textConcat ["  bindings [", textJoin ", " runtimeBindings, "]"]);
  lines = appendNativeRenderedText lines (textConcat ["  json_codecs [", textJoin ", " (emitNativeJsonCodecTextsFromTypes codecTypes), "]"]);
  lines = appendNativeRenderedText lines (textConcat ["  binary_codecs [", textJoin ", " (emitNativeBinaryCodecTextsFromTypes codecTypes), "]"]);
  lines = appendNativeRenderedText lines (textConcat ["  boundaries [", textJoin ", " (emitHostedBoundaryTexts moduleName modl), "]"]);
  lines = appendNativeRenderedText lines (textConcat ["  service_transports [", textJoin ", " (emitHostedServiceTransportTexts modl), "]"]);
  lines = appendNativeRenderedText lines "}";
  lines
}

emitNativeHeaderSection : HostedModuleAst -> [LowerDeclText] -> Str
emitNativeHeaderSection modl decls = {
  let moduleName = moduleNameOf modl;
  let mut lines = emptyRenderedTexts;
  lines = appendNativeRenderedText lines "format clasp-native-ir-v1";
  lines = appendNativeRenderedText lines (textConcat ["module ", moduleName]);
  lines = appendNativeRenderedText lines (textConcat ["exports [", textJoin ", " (collectNativeExportNames modl decls), "]"]);
  lines = appendNativeRenderedText lines (textConcat ["entrypoints [", textJoin ", " (append (emitNativeConstructorEntrypoints moduleName modl) (emitNativeEntrypoints moduleName decls)), "]"]);
  textJoin "\n" lines
}

emitNativeAbiSection : HostedModuleAst -> Str
emitNativeAbiSection modl = textJoin "\n" (nativeAbiLines modl)

emitNativeRuntimeSection : HostedModuleAst -> Str
emitNativeRuntimeSection modl = textJoin "\n" (nativeRuntimeLines modl)

emitNativeDeclSection : [LowerDeclText] -> Str
emitNativeDeclSection decls = textJoin "\n\n" (renderNativeDecls decls)

emitNativeModule : HostedModuleAst -> [LowerDeclText] -> Str
emitNativeModule modl decls = {
  let mut sections = emptyRenderedTexts;
  let allDeclLines = append (emitNativeConstructorDecls modl) (renderNativeDecls decls);
  sections = appendNativeRenderedText sections (emitNativeHeaderSection modl decls);
  sections = appendNativeRenderedText sections (emitNativeAbiSection modl);
  sections = appendNativeRenderedText sections (emitNativeRuntimeSection modl);
  sections = appendNativeRenderedText sections (textJoin "\n\n" allDeclLines);
  textConcat [textJoin "\n\n" sections, "\n\n"]
}

emitNativeEntrypointJson : Str -> LowerDeclText -> Str
emitNativeEntrypointJson moduleName decl = match decl {
  LowerConst name body ->
    jsonObject [jsonFieldText "name" name, jsonFieldText "symbol" (nativeEntrypointSymbol moduleName name), jsonFieldText "kind" "global", jsonFieldRaw "arity" "0"],
  LowerFn name params body ->
    jsonObject [jsonFieldText "name" name, jsonFieldText "symbol" (nativeEntrypointSymbol moduleName name), jsonFieldText "kind" "function", jsonFieldRaw "arity" (renderNativeArity params)]
}

emitNativeEntrypointJsons : Str -> [LowerDeclText] -> [Str]
emitNativeEntrypointJsons moduleName decls = {
  let mut rendered = emptyRenderedTexts;
  for decl in decls {
    rendered = appendNativeRenderedText rendered (emitNativeEntrypointJson moduleName decl);
    rendered
  };
  rendered
}


emitNativeCompatibilityFingerprint : HostedModuleAst -> [LowerDeclText] -> Str
emitNativeCompatibilityFingerprint modl decls =
  textConcat ["native-compat:", textFingerprint64Hex (emitNativeCompatibilitySurfaceImage modl decls)]

emitNativeAbiImage : HostedModuleAst -> Str
emitNativeAbiImage modl =
  jsonObject [
    jsonFieldText "version" "clasp-native-v1",
    jsonFieldRaw "wordBytes" "8",
    jsonFieldText "memoryStrategy" "reference_counting",
    jsonFieldRaw "allocation" emitNativeAbiAllocationImage,
    jsonFieldArray "ownershipRules" (emitNativeJsonStringList ["caller_owns_returns", "callee_borrows_arguments", "aggregates_retain_handle_fields", "globals_are_static_roots"]),
    jsonFieldArray "rootDiscoveryRules" (emitNativeJsonStringList ["static_globals", "stack_handle_slots", "heap_object_layouts"]),
    jsonFieldArray "lifetimeInvariants" (emitNativeJsonStringList ["layout_and_retain_headers", "declared_root_offsets_only", "release_children_before_free", "borrowed_handles_do_not_retain"]),
    jsonFieldArray "builtinLayouts" emitNativeBuiltinLayoutImages,
    jsonFieldArray "recordLayouts" (append emitNativeStaticRecordLayoutImages (emitHostedRecordLayoutImages modl)),
    jsonFieldArray "variantLayouts" (emitHostedVariantLayoutImages modl),
    jsonFieldArray "objectLayouts" (append (append emitNativeStaticObjectLayoutImages (emitHostedRecordObjectLayoutImages modl)) (emitHostedVariantObjectLayoutImages modl))
  ]

emitNativeRuntimeImage : HostedModuleAst -> Str
emitNativeRuntimeImage modl = {
  let moduleName = moduleNameOf modl;
  let runtimeBindingImages = emitNativeRuntimeBindingImages modl;
  let codecTypes = collectModuleRuntimeCodecTypes modl;
  jsonObject [
    jsonFieldText "profile" "compiler_backend_minimal",
    jsonFieldArray "artifacts" (emitNativeJsonStringList ["runtime/clasp_runtime.h", "runtime/clasp_runtime.rs"]),
    jsonFieldArray "memorySymbols" (emitNativeJsonStringList ["clasp_rt_init", "clasp_rt_register_static_root", "clasp_rt_alloc_object", "clasp_rt_retain", "clasp_rt_release", "clasp_rt_string_from_utf8", "clasp_rt_bytes_new", "clasp_rt_string_list_new", "clasp_rt_result_ok_string", "clasp_rt_result_err_string", "clasp_rt_json_from_string", "clasp_rt_json_to_string", "clasp_rt_binary_from_json", "clasp_rt_json_from_binary", "clasp_rt_transport_frame", "clasp_rt_transport_unframe"]),
    jsonFieldArray "bindings" runtimeBindingImages,
    jsonFieldArray "jsonCodecs" (emitNativeJsonCodecImagesFromTypes codecTypes),
    jsonFieldArray "binaryCodecs" (emitNativeBinaryCodecImagesFromTypes codecTypes),
    jsonFieldArray "boundaries" (emitHostedBoundaryImages moduleName modl),
    jsonFieldArray "serviceTransports" (emitHostedServiceTransportImages modl),
    jsonFieldRaw "metadata" (emitHostedRuntimeMetadataImage modl)
  ]
}

emitNativeCompatibilityImage : HostedModuleAst -> [LowerDeclText] -> Str
emitNativeCompatibilityImage modl decls = {
  let fingerprint = emitNativeCompatibilityFingerprint modl decls;
  jsonObject [
    jsonFieldText "kind" "clasp-native-compatibility-v1",
    jsonFieldText "interfaceFingerprint" fingerprint,
    jsonFieldArray "acceptedPreviousFingerprints" [encode fingerprint],
    jsonFieldRaw "migration" (jsonObject [
      jsonFieldText "kind" "clasp-native-migration-v1",
      jsonFieldText "strategy" "exact-interface-only",
      jsonFieldRaw "stateType" (emitNativeMigrationStateTypeValue modl),
      jsonFieldRaw "snapshotSymbol" (emitNativeMigrationSnapshotSymbolValue modl),
      jsonFieldRaw "handoffSymbol" (emitNativeMigrationHandoffSymbolValue modl)
    ])
  ]
}

emitNativeModuleImageModuleName : HostedModuleAst -> Str
emitNativeModuleImageModuleName modl = moduleNameOf modl

emitNativeModuleImageExports : HostedModuleAst -> [LowerDeclText] -> Str
emitNativeModuleImageExports modl decls = {
  let ignored = decls;
  jsonArray (emitNativeJsonStringList (collectNativeExportNamesFromModule modl))
}

emitNativeModuleImageEntrypoints : HostedModuleAst -> [LowerDeclText] -> Str
emitNativeModuleImageEntrypoints modl decls = {
  let ignored = decls;
  let moduleName = moduleNameOf modl;
  jsonArray (append (emitNativeConstructorEntrypointJsons moduleName modl) (emitNativeEntrypointJsonsFromModule moduleName modl))
}

emitNativeModuleImageConstructorDecls : HostedModuleAst -> Str
emitNativeModuleImageConstructorDecls modl = jsonArray (emitNativeConstructorDeclJsons modl)


nativeImagePlanFieldSeparator : Str
nativeImagePlanFieldSeparator = "\n-- CLASP_NATIVE_IMAGE_PLAN_FIELD --\n"

emitNativeModuleImagePlanText : HostedModuleAst -> Str
emitNativeModuleImagePlanText modl =
  textJoin
    nativeImagePlanFieldSeparator
    [
      emitNativeModuleImageModuleName modl,
      emitNativeModuleImageExports modl emptyLowerDecls,
      emitNativeModuleImageEntrypoints modl emptyLowerDecls,
      emitNativeAbiImage modl,
      emitNativeRuntimeImage modl,
      emitNativeCompatibilityImage modl emptyLowerDecls,
      emitNativeModuleImageConstructorDecls modl,
      emitNativeModuleImageDeclNames modl
    ]

emitNativeModuleImageBuildPlanText : HostedModuleAst -> [HostedModuleAst] -> Str
emitNativeModuleImageBuildPlanText mergedModule sourceModules =
  textJoin
    nativeImagePlanFieldSeparator
    [
      emitNativeModuleImageModuleName mergedModule,
      emitNativeModuleImageExports mergedModule emptyLowerDecls,
      emitNativeModuleImageEntrypoints mergedModule emptyLowerDecls,
      emitNativeAbiImage mergedModule,
      emitNativeRuntimeImage mergedModule,
      emitNativeCompatibilityImage mergedModule emptyLowerDecls,
      emitNativeModuleImageConstructorDecls mergedModule,
      emitNativeProjectDeclModulePlanText mergedModule sourceModules
    ]

emitNativeModuleImage : HostedModuleAst -> [LowerDeclText] -> Str
emitNativeModuleImage modl decls = {
  jsonObject [
    jsonFieldText "format" "clasp-native-image-v1",
    jsonFieldText "irFormat" "clasp-native-ir-v1",
    jsonFieldText "module" (emitNativeModuleImageModuleName modl),
    jsonFieldRaw "exports" (emitNativeModuleImageExports modl decls),
    jsonFieldRaw "entrypoints" (emitNativeModuleImageEntrypoints modl decls),
    jsonFieldRaw "abi" (emitNativeAbiImage modl),
    jsonFieldRaw "runtime" (emitNativeRuntimeImage modl),
    jsonFieldRaw "compatibility" (emitNativeCompatibilityImage modl decls),
    jsonFieldRaw "decls" (emitNativeModuleImageDecls modl decls)
  ]
}

-- CLASP_PROJECT_MODULE --
module Compiler.Emit.NativeDecls

import Compiler.Ast
import Compiler.Checker
import Compiler.Json
import Compiler.Lower
import Compiler.Emit.NativeJson
import Compiler.Emit.NativeSurface

appendNativeDeclRenderedText : [Str] -> Str -> [Str]
appendNativeDeclRenderedText values value = append values [value]

collectHostedDeclNames : HostedModuleAst -> [Str]
collectHostedDeclNames modl = {
  let mut names = emptyRenderedTexts;
  for decl in moduleDeclarations modl {
    names = appendNativeDeclRenderedText names (declName decl);
    names
  };
  names
}

emitNativeModuleImageDeclNames : HostedModuleAst -> Str
emitNativeModuleImageDeclNames modl = textJoin "\n" (collectHostedDeclNames modl)

emitNativeTypeDeclFingerprintText : HostedTypeDeclAst -> Str
emitNativeTypeDeclFingerprintText typeDecl = {
  let mut constructorTexts = emptyRenderedTexts;
  for constructorDecl in typeDeclConstructors typeDecl {
    let payloadTexts = emitNativeJsonStringList (renderHostedTypeList (constructorDeclPayloadTypes constructorDecl));
    constructorTexts = appendNativeDeclRenderedText constructorTexts (textConcat [constructorDeclName constructorDecl, "(", textJoin "," payloadTexts, ")"]);
    constructorTexts
  };
  textConcat [typeDeclName typeDecl, "=", textJoin "|" constructorTexts]
}

emitNativeRecordFieldFingerprintText : HostedRecordFieldDeclAst -> Str
emitNativeRecordFieldFingerprintText field = textConcat [recordFieldDeclName field, ":", renderType (typeFromHostedTypeAst (recordFieldDeclType field))]

emitNativeRecordDeclFingerprintText : HostedRecordDeclAst -> Str
emitNativeRecordDeclFingerprintText recordDecl = {
  let mut fieldTexts = emptyRenderedTexts;
  for field in recordDeclFields recordDecl {
    fieldTexts = appendNativeDeclRenderedText fieldTexts (emitNativeRecordFieldFingerprintText field);
    fieldTexts
  };
  textConcat [recordDeclName recordDecl, "{", textJoin "," fieldTexts, "}"]
}

emitNativeForeignDeclFingerprintText : HostedForeignDeclAst -> Str
emitNativeForeignDeclFingerprintText foreignDecl = textConcat [foreignDeclName foreignDecl, ":", renderType (typeFromHostedTypeAst (foreignDeclTypeAst foreignDecl))]

emitNativeTypeBindingFingerprintText : TypeBinding -> Str
emitNativeTypeBindingFingerprintText binding = match binding {
  TypeBinding name bindingType ->
    textConcat [name, ":", renderType bindingType]
}

emitNativeDeclInterfaceFingerprintText : HostedDeclAst -> Str
emitNativeDeclInterfaceFingerprintText decl = match decl {
  HostedDeclAst name annotation params body ->
    if hasAnnotationAst annotation then {
      textConcat [name, ":", renderAnnotationAst annotation, "(", textJoin "," params, ")"]
    } else {
      textConcat [name, ":unannotated:", expressionSummary body]
    }
}

emitNativeProjectDeclContextFingerprint : HostedModuleAst -> Str
emitNativeProjectDeclContextFingerprint modl = {
  let bindingParts =
    if moduleDeclarationsFullyAnnotated modl then
      map emitNativeTypeBindingFingerprintText (collectAnnotatedBindings modl)
    else
      map emitNativeDeclInterfaceFingerprintText (moduleDeclarations modl);
  let typeDeclParts = map emitNativeTypeDeclFingerprintText (effectiveModuleTypeDecls modl);
  let recordDeclParts = map emitNativeRecordDeclFingerprintText (effectiveModuleRecordDecls modl);
  let foreignDeclParts = map emitNativeForeignDeclFingerprintText (moduleForeignDeclarations modl);
  let fingerprintParts =
    append
      (append bindingParts typeDeclParts)
      (append recordDeclParts foreignDeclParts);
  textFingerprint64Hex (textJoin "\n" fingerprintParts)
}

hostedDeclarationsFullyAnnotated : [HostedDeclAst] -> Bool
hostedDeclarationsFullyAnnotated declarations = {
  let mut fullyAnnotated = true;
  for decl in declarations {
    if hasAnnotationAst (declAnnotation decl) then {
      fullyAnnotated
    } else {
      fullyAnnotated = false;
      fullyAnnotated
    }
  };
  fullyAnnotated
}

emitNativeDeclLowerEnvForDeclarations : HostedModuleAst -> [HostedDeclAst] -> [HostedTypeDeclAst] -> [TypeBinding]
emitNativeDeclLowerEnvForDeclarations mergedModule declarations typeDecls = {
  let recordDecls = effectiveModuleRecordDecls mergedModule;
  let initialEnv =
    append
      baseEnv
      (append
        (collectConstructorBindings typeDecls)
        (append (collectForeignBindings mergedModule) (collectAnnotatedBindings mergedModule)));
  if moduleDeclarationsFullyAnnotated mergedModule then
    initialEnv
  else if hostedDeclarationsFullyAnnotated declarations then
    initialEnv
  else
    resolveInferModuleBindings typeDecls recordDecls initialEnv declarations
}

emitNativeDeclJsonsFromDeclarations : HostedModuleAst -> [HostedDeclAst] -> [Str] -> [Str]
emitNativeDeclJsonsFromDeclarations mergedModule declarations selectedNames = {
  let typeDecls = effectiveModuleTypeDecls mergedModule;
  let recordDecls = effectiveModuleRecordDecls mergedModule;
  let env = emitNativeDeclLowerEnvForDeclarations mergedModule declarations typeDecls;
  let mut rendered = emptyRenderedTexts;
  for decl in declarations {
    if containsText selectedNames (declName decl) then {
      let loweredDecl = lowerDecl typeDecls recordDecls env decl;
      let declJson = emitNativeDeclJson loweredDecl;
      rendered = appendNativeDeclRenderedText rendered declJson;
      rendered
    } else {
      rendered
    }
  };
  rendered
}

emitNativeDeclJsonsFromAllDeclarations : HostedModuleAst -> [HostedDeclAst] -> [Str]
emitNativeDeclJsonsFromAllDeclarations mergedModule declarations = {
  let typeDecls = effectiveModuleTypeDecls mergedModule;
  let recordDecls = effectiveModuleRecordDecls mergedModule;
  let env = emitNativeDeclLowerEnvForDeclarations mergedModule declarations typeDecls;
  let mut rendered = emptyRenderedTexts;
  for decl in declarations {
    let loweredDecl = lowerDecl typeDecls recordDecls env decl;
    let declJson = emitNativeDeclJson loweredDecl;
    rendered = appendNativeDeclRenderedText rendered declJson;
    rendered
  };
  rendered
}

emitNativeDeclJsonsForNamedDecls : HostedModuleAst -> [Str] -> [Str]
emitNativeDeclJsonsForNamedDecls modl selectedNames = emitNativeDeclJsonsFromDeclarations modl (moduleDeclarations modl) selectedNames

emitNativeModuleImageDecls : HostedModuleAst -> [LowerDeclText] -> Str
emitNativeModuleImageDecls modl decls =
  jsonArray (append (emitNativeConstructorDeclJsons modl) (emitNativeDeclJsons decls))

emitNativeModuleImageNamedDecls : HostedModuleAst -> [Str] -> Str
emitNativeModuleImageNamedDecls modl selectedNames = jsonArray (emitNativeDeclJsonsForNamedDecls modl selectedNames)

emitNativeSourceModuleImageDecls : HostedModuleAst -> HostedModuleAst -> Str
emitNativeSourceModuleImageDecls mergedModule sourceModule = jsonArray (emitNativeDeclJsonsFromAllDeclarations mergedModule (moduleDeclarations sourceModule))

-- CLASP_PROJECT_MODULE --
module Compiler.Emit.NativeJson

import Compiler.Ast
import Compiler.Checker
import Compiler.Json
import Compiler.Lower

appendNativeJsonText : [Str] -> Str -> [Str]
appendNativeJsonText values value = append values [value]

keepNoNativeJsonText : Str -> Bool
keepNoNativeJsonText value = false

emptyNativeJsonTexts : [Str]
emptyNativeJsonTexts = filter keepNoNativeJsonText [""]

emitNativeJsonStringList : [Str] -> [Str]
emitNativeJsonStringList values = {
  let mut rendered = emptyNativeJsonTexts;
  for value in values {
    rendered = appendNativeJsonText rendered (encode value);
    rendered
  };
  rendered
}

emitNativeJsonExprList : [LowerExprText] -> [Str]
emitNativeJsonExprList exprs = {
  let mut rendered = emptyNativeJsonTexts;
  for expr in exprs {
    rendered = appendNativeJsonText rendered (emitNativeExprJson expr);
    rendered
  };
  rendered
}

emitNativeJsonRecordFieldList : [LowerRecordFieldText] -> [Str]
emitNativeJsonRecordFieldList fields = {
  let mut rendered = emptyNativeJsonTexts;
  for field in fields {
    rendered = appendNativeJsonText rendered (emitNativeRecordFieldJson field);
    rendered
  };
  rendered
}

emitNativeJsonMatchBranchList : [LowerMatchBranchText] -> [Str]
emitNativeJsonMatchBranchList branches = {
  let mut rendered = emptyNativeJsonTexts;
  for branch in branches {
    rendered = appendNativeJsonText rendered (emitNativeMatchBranchJson branch);
    rendered
  };
  rendered
}

emitNativeCompareOpJson : LowerExprText -> LowerExprText -> Str -> Str
emitNativeCompareOpJson left right kindName =
  jsonObject [jsonFieldText "kind" "compare", jsonFieldText "op" kindName, jsonFieldRaw "left" (emitNativeExprJson left), jsonFieldRaw "right" (emitNativeExprJson right)]

emitNativeExprJson : LowerExprText -> Str
emitNativeExprJson expr = match expr {
  LowerName name ->
    jsonObject [jsonFieldText "kind" "local", jsonFieldText "name" name],
  LowerLiteral value ->
    jsonObject [jsonFieldText "kind" "string", jsonFieldText "value" value],
  LowerInt value ->
    jsonObject [jsonFieldText "kind" "int", jsonFieldRaw "value" value],
  LowerBool value ->
    jsonObject [jsonFieldText "kind" "bool", jsonFieldRaw "value" (if value then "true" else "false")],
  LowerArray values ->
    jsonObject [jsonFieldText "kind" "list", jsonFieldArray "items" (emitNativeJsonExprList values)],
  LowerListAppend left right ->
    jsonObject [jsonFieldText "kind" "intrinsic", jsonFieldText "name" "list.append", jsonFieldRaw "left" (emitNativeExprJson left), jsonFieldRaw "right" (emitNativeExprJson right)],
  LowerListPrepend value values ->
    jsonObject [jsonFieldText "kind" "intrinsic", jsonFieldText "name" "list.prepend", jsonFieldRaw "value" (emitNativeExprJson value), jsonFieldRaw "values" (emitNativeExprJson values)],
  LowerListReverse values ->
    jsonObject [jsonFieldText "kind" "intrinsic", jsonFieldText "name" "list.reverse", jsonFieldRaw "values" (emitNativeExprJson values)],
  LowerLength value ->
    jsonObject [jsonFieldText "kind" "intrinsic", jsonFieldText "name" "length", jsonFieldRaw "value" (emitNativeExprJson value)],
  LowerListMap callee values ->
    jsonObject [jsonFieldText "kind" "intrinsic", jsonFieldText "name" "list.map", jsonFieldText "callee" callee, jsonFieldRaw "values" (emitNativeExprJson values)],
  LowerListFilter callee values ->
    jsonObject [jsonFieldText "kind" "intrinsic", jsonFieldText "name" "list.filter", jsonFieldText "callee" callee, jsonFieldRaw "values" (emitNativeExprJson values)],
  LowerListAny callee values ->
    jsonObject [jsonFieldText "kind" "intrinsic", jsonFieldText "name" "list.any", jsonFieldText "callee" callee, jsonFieldRaw "values" (emitNativeExprJson values)],
  LowerListAll callee values ->
    jsonObject [jsonFieldText "kind" "intrinsic", jsonFieldText "name" "list.all", jsonFieldText "callee" callee, jsonFieldRaw "values" (emitNativeExprJson values)],
  LowerListFold callee initial values ->
    jsonObject [jsonFieldText "kind" "intrinsic", jsonFieldText "name" "list.fold", jsonFieldText "callee" callee, jsonFieldRaw "initial" (emitNativeExprJson initial), jsonFieldRaw "values" (emitNativeExprJson values)],
  LowerViewAppend left right ->
    jsonObject [jsonFieldText "kind" "intrinsic", jsonFieldText "name" "view.append", jsonFieldRaw "left" (emitNativeExprJson left), jsonFieldRaw "right" (emitNativeExprJson right)],
  LowerEncode value ->
    jsonObject [jsonFieldText "kind" "intrinsic", jsonFieldText "name" "encode", jsonFieldRaw "value" (emitNativeExprJson value)],
  LowerDecode targetType value ->
    jsonObject [jsonFieldText "kind" "intrinsic", jsonFieldText "name" "decode", jsonFieldText "type" (renderType targetType), jsonFieldRaw "value" (emitNativeExprJson value)],
  LowerIf condition thenBranch elseBranch ->
    jsonObject [jsonFieldText "kind" "if", jsonFieldRaw "condition" (emitNativeExprJson condition), jsonFieldRaw "thenBranch" (emitNativeExprJson thenBranch), jsonFieldRaw "elseBranch" (emitNativeExprJson elseBranch)],
  LowerEqual left right ->
    emitNativeCompareOpJson left right "eq",
  LowerNotEqual left right ->
    emitNativeCompareOpJson left right "ne",
  LowerLessThan left right ->
    emitNativeCompareOpJson left right "lt",
  LowerLessThanOrEqual left right ->
    emitNativeCompareOpJson left right "le",
  LowerGreaterThan left right ->
    emitNativeCompareOpJson left right "gt",
  LowerGreaterThanOrEqual left right ->
    emitNativeCompareOpJson left right "ge",
  LowerInvoke callee args ->
    jsonObject [jsonFieldText "kind" "call", jsonFieldRaw "callee" (jsonObject [jsonFieldText "kind" "local", jsonFieldText "name" callee]), jsonFieldArray "args" (emitNativeJsonExprList args)],
  LowerConstructor constructorName args ->
    jsonObject [jsonFieldText "kind" "construct", jsonFieldText "name" constructorName, jsonFieldArray "args" (emitNativeJsonExprList args)],
  LowerMatch subject branches ->
    jsonObject [jsonFieldText "kind" "match", jsonFieldRaw "scrutinee" (emitNativeExprJson subject), jsonFieldArray "branches" (emitNativeJsonMatchBranchList branches)],
  LowerRecord recordName fields ->
    jsonObject [jsonFieldText "kind" "record", jsonFieldText "recordName" recordName, jsonFieldArray "fields" (emitNativeJsonRecordFieldList fields)],
  LowerFieldAccess recordName subject fieldName ->
    jsonObject [jsonFieldText "kind" "field_access", jsonFieldText "recordName" recordName, jsonFieldRaw "target" (emitNativeExprJson subject), jsonFieldText "fieldName" fieldName],
  LowerLet binder value body ->
    jsonObject [jsonFieldText "kind" "let", jsonFieldText "mutability" "immutable", jsonFieldText "name" binder, jsonFieldRaw "value" (emitNativeExprJson value), jsonFieldRaw "body" (emitNativeExprJson body)],
  LowerMutableLet binder value body ->
    jsonObject [jsonFieldText "kind" "let", jsonFieldText "mutability" "mutable", jsonFieldText "name" binder, jsonFieldRaw "value" (emitNativeExprJson value), jsonFieldRaw "body" (emitNativeExprJson body)],
  LowerAssign binder value body ->
    jsonObject [jsonFieldText "kind" "assign", jsonFieldText "name" binder, jsonFieldRaw "value" (emitNativeExprJson value), jsonFieldRaw "body" (emitNativeExprJson body)],
  LowerFor binder iterable loopBody body ->
    jsonObject [jsonFieldText "kind" "for_each", jsonFieldText "name" binder, jsonFieldRaw "iterable" (emitNativeExprJson iterable), jsonFieldRaw "loopBody" (emitNativeExprJson loopBody), jsonFieldRaw "body" (emitNativeExprJson body)],
  LowerReturn value ->
    jsonObject [jsonFieldText "kind" "return", jsonFieldRaw "value" (emitNativeExprJson value)]
}

emitNativeRecordFieldJson : LowerRecordFieldText -> Str
emitNativeRecordFieldJson field = match field {
  LowerRecordFieldText name value ->
    jsonObject [jsonFieldText "name" name, jsonFieldRaw "value" (emitNativeExprJson value)]
}

emitNativeMatchBranchJson : LowerMatchBranchText -> Str
emitNativeMatchBranchJson branch = match branch {
  LowerMatchBranchText constructorName binders body ->
    jsonObject [jsonFieldText "tag" constructorName, jsonFieldArray "binders" (emitNativeJsonStringList binders), jsonFieldRaw "body" (emitNativeExprJson body)]
}

emitNativeDeclJson : LowerDeclText -> Str
emitNativeDeclJson decl = match decl {
  LowerConst name body ->
    jsonObject [jsonFieldText "kind" "global", jsonFieldText "name" name, jsonFieldRaw "body" (emitNativeExprJson body)],
  LowerFn name params body ->
    jsonObject [jsonFieldText "kind" "function", jsonFieldText "name" name, jsonFieldArray "params" (emitNativeJsonStringList params), jsonFieldRaw "body" (emitNativeExprJson body)]
}

emitNativeDeclJsons : [LowerDeclText] -> [Str]
emitNativeDeclJsons decls = {
  let mut rendered = emptyNativeJsonTexts;
  for decl in decls {
    rendered = appendNativeJsonText rendered (emitNativeDeclJson decl);
    rendered
  };
  rendered
}

-- CLASP_PROJECT_MODULE --
module Compiler.Emit.NativeSurface

import Compiler.Ast
import Compiler.Checker
import Compiler.Emit.NativeJson
import Compiler.Json
import Compiler.Lower

appendNativeSurfaceText : [Str] -> Str -> [Str]
appendNativeSurfaceText values value = append values [value]

keepNoNativeSurfaceText : Str -> Bool
keepNoNativeSurfaceText value = false

emptyNativeSurfaceTexts : [Str]
emptyNativeSurfaceTexts = filter keepNoNativeSurfaceText [""]

incrementNativeSurfaceNumber : Str -> Str
incrementNativeSurfaceNumber value = { if value == "0" then "1" else if value == "1" then "2" else if value == "2" then "3" else if value == "3" then "4" else if value == "4" then "5" else if value == "5" then "6" else if value == "6" then "7" else if value == "7" then "8" else if value == "8" then "9" else if value == "9" then "10" else if value == "10" then "11" else if value == "11" then "12" else if value == "12" then "13" else if value == "13" then "14" else if value == "14" then "15" else if value == "15" then "16" else if value == "16" then "17" else if value == "17" then "18" else if value == "18" then "19" else if value == "19" then "20" else if value == "20" then "21" else if value == "21" then "22" else if value == "22" then "23" else if value == "23" then "24" else if value == "24" then "25" else if value == "25" then "26" else if value == "26" then "27" else if value == "27" then "28" else if value == "28" then "29" else if value == "29" then "30" else if value == "30" then "31" else if value == "31" then "32" else if value == "32" then "33" else if value == "33" then "34" else if value == "34" then "35" else if value == "35" then "36" else if value == "36" then "37" else if value == "37" then "38" else if value == "38" then "39" else if value == "39" then "40" else value }

renderNativeSurfaceArity : [Str] -> Str
renderNativeSurfaceArity params = {
  let mut count = "0";
  for param in params {
    let ignored = param;
    count = incrementNativeSurfaceNumber count;
    count
  };
  count
}

countHostedSurfaceTypes : [HostedTypeAst] -> Str
countHostedSurfaceTypes values = {
  let mut count = "0";
  for value in values {
    let ignored = value;
    count = incrementNativeSurfaceNumber count;
    count
  };
  count
}

hasHostedSurfaceTypes : [HostedTypeAst] -> Bool
hasHostedSurfaceTypes values = {
  for value in values {
    return true
  };
  false
}

nativeSurfaceEmittedTypeDecls : HostedModuleAst -> [HostedTypeDeclAst]
nativeSurfaceEmittedTypeDecls modl = if moduleUsesBuiltinResult modl then effectiveModuleTypeDecls modl else moduleTypeDeclarations modl

nativeModuleSymbolPrefix : Str -> Str
nativeModuleSymbolPrefix moduleName = textConcat ["clasp_native__", textJoin "__" (textSplit moduleName ".")]

nativeEntrypointSymbol : Str -> Str -> Str
nativeEntrypointSymbol moduleName declName = textConcat [nativeModuleSymbolPrefix moduleName, "__", declName]

emitNativeEntrypoint : Str -> LowerDeclText -> Str
emitNativeEntrypoint moduleName decl = match decl {
  LowerConst name body ->
    textConcat [name, "{symbol=", nativeEntrypointSymbol moduleName name, ", kind=global, arity=0}"],
  LowerFn name params body ->
    textConcat [name, "{symbol=", nativeEntrypointSymbol moduleName name, ", kind=function, arity=", renderNativeSurfaceArity params, "}"]
}

emitNativeEntrypoints : Str -> [LowerDeclText] -> [Str]
emitNativeEntrypoints moduleName decls = {
  let mut rendered = emptyNativeSurfaceTexts;
  for decl in decls {
    rendered = appendNativeSurfaceText rendered (emitNativeEntrypoint moduleName decl);
    rendered
  };
  rendered
}

emitNativeConstructorParams : [HostedTypeAst] -> [Str]
emitNativeConstructorParams payloadTypes = {
  let mut rendered = emptyNativeSurfaceTexts;
  let mut index = "0";
  for payloadType in payloadTypes {
    let ignored = payloadType;
    rendered = appendNativeSurfaceText rendered (textConcat ["$", index]);
    index = incrementNativeSurfaceNumber index;
    rendered
  };
  rendered
}

emitNativeConstructorArgExprs : [Str] -> [Str]
emitNativeConstructorArgExprs params = {
  let mut rendered = emptyNativeSurfaceTexts;
  for param in params {
    rendered = appendNativeSurfaceText rendered (textConcat ["local(", param, ")"]);
    rendered
  };
  rendered
}

emitNativeConstructorDecl : HostedConstructorDeclAst -> Str
emitNativeConstructorDecl constructorDecl = {
  let params = emitNativeConstructorParams (constructorDeclPayloadTypes constructorDecl);
  if hasHostedSurfaceTypes (constructorDeclPayloadTypes constructorDecl) then textConcat ["function ", constructorDeclName constructorDecl, "(", textJoin ", " params, ") = construct ", constructorDeclName constructorDecl, "(", textJoin ", " (emitNativeConstructorArgExprs params), ")"] else textConcat ["global ", constructorDeclName constructorDecl, " = construct ", constructorDeclName constructorDecl, "()"]
}

emitNativeConstructorDecls : HostedModuleAst -> [Str]
emitNativeConstructorDecls modl = {
  let mut rendered = emptyNativeSurfaceTexts;
  for typeDecl in nativeSurfaceEmittedTypeDecls modl {
    for constructorDecl in typeDeclConstructors typeDecl {
      rendered = appendNativeSurfaceText rendered (emitNativeConstructorDecl constructorDecl);
      rendered
    };
    rendered
  };
  rendered
}

emitNativeConstructorEntrypoint : Str -> HostedConstructorDeclAst -> Str
emitNativeConstructorEntrypoint moduleName constructorDecl = {
  let payloadTypes = constructorDeclPayloadTypes constructorDecl;
  if hasHostedSurfaceTypes payloadTypes then textConcat [constructorDeclName constructorDecl, "{symbol=", nativeEntrypointSymbol moduleName (constructorDeclName constructorDecl), ", kind=function, arity=", countHostedSurfaceTypes payloadTypes, "}"] else textConcat [constructorDeclName constructorDecl, "{symbol=", nativeEntrypointSymbol moduleName (constructorDeclName constructorDecl), ", kind=global, arity=0}"]
}

emitNativeConstructorEntrypoints : Str -> HostedModuleAst -> [Str]
emitNativeConstructorEntrypoints moduleName modl = {
  let mut rendered = emptyNativeSurfaceTexts;
  for typeDecl in nativeSurfaceEmittedTypeDecls modl {
    for constructorDecl in typeDeclConstructors typeDecl {
      rendered = appendNativeSurfaceText rendered (emitNativeConstructorEntrypoint moduleName constructorDecl);
      rendered
    };
    rendered
  };
  rendered
}

hostedDeclName : HostedDeclAst -> Str
hostedDeclName decl = declName decl

hostedDeclArity : HostedDeclAst -> Str
hostedDeclArity decl = renderNativeSurfaceArity (declParams decl)

emitNativeEntrypointJsonFromDeclAst : Str -> HostedDeclAst -> Str
emitNativeEntrypointJsonFromDeclAst moduleName decl =
  if hasLowerParams decl then
    jsonObject [jsonFieldText "name" (declName decl), jsonFieldText "symbol" (nativeEntrypointSymbol moduleName (declName decl)), jsonFieldText "kind" "function", jsonFieldRaw "arity" (hostedDeclArity decl)]
  else
    jsonObject [jsonFieldText "name" (declName decl), jsonFieldText "symbol" (nativeEntrypointSymbol moduleName (declName decl)), jsonFieldText "kind" "global", jsonFieldRaw "arity" "0"]

emitNativeEntrypointJsonsFromModule : Str -> HostedModuleAst -> [Str]
emitNativeEntrypointJsonsFromModule moduleName modl = {
  let mut rendered = emptyNativeSurfaceTexts;
  for decl in moduleDeclarations modl {
    rendered = appendNativeSurfaceText rendered (emitNativeEntrypointJsonFromDeclAst moduleName decl);
    rendered
  };
  rendered
}

collectNativeExportNamesFromModule : HostedModuleAst -> [Str]
collectNativeExportNamesFromModule modl = {
  let mut names = emptyNativeSurfaceTexts;
  for typeDecl in nativeSurfaceEmittedTypeDecls modl {
    for constructorDecl in typeDeclConstructors typeDecl {
      names = appendNativeSurfaceText names (constructorDeclName constructorDecl);
      names
    };
    names
  };
  for decl in moduleDeclarations modl {
    names = appendNativeSurfaceText names (hostedDeclName decl);
    names
  };
  names
}

collectNativeExportNames : HostedModuleAst -> [LowerDeclText] -> [Str]
collectNativeExportNames modl decls = {
  let ignored = decls;
  collectNativeExportNamesFromModule modl
}

emitNativeConstructorBodyJson : HostedConstructorDeclAst -> Str
emitNativeConstructorBodyJson constructorDecl = {
  let params = emitNativeConstructorParams (constructorDeclPayloadTypes constructorDecl);
  let mut args = emptyNativeSurfaceTexts;
  for param in params {
    args = appendNativeSurfaceText args (jsonObject [jsonFieldText "kind" "local", jsonFieldText "name" param]);
    args
  };
  jsonObject [jsonFieldText "kind" "construct", jsonFieldText "name" (constructorDeclName constructorDecl), jsonFieldArray "args" args]
}

emitNativeConstructorDeclJson : HostedConstructorDeclAst -> Str
emitNativeConstructorDeclJson constructorDecl = {
  let params = emitNativeConstructorParams (constructorDeclPayloadTypes constructorDecl);
  let bodyJson = emitNativeConstructorBodyJson constructorDecl;
  if hasHostedSurfaceTypes (constructorDeclPayloadTypes constructorDecl) then jsonObject [jsonFieldText "kind" "function", jsonFieldText "name" (constructorDeclName constructorDecl), jsonFieldArray "params" (emitNativeJsonStringList params), jsonFieldRaw "body" bodyJson] else jsonObject [jsonFieldText "kind" "global", jsonFieldText "name" (constructorDeclName constructorDecl), jsonFieldRaw "body" bodyJson]
}

emitNativeConstructorDeclJsons : HostedModuleAst -> [Str]
emitNativeConstructorDeclJsons modl = {
  let mut rendered = emptyNativeSurfaceTexts;
  for typeDecl in nativeSurfaceEmittedTypeDecls modl {
    for constructorDecl in typeDeclConstructors typeDecl {
      rendered = appendNativeSurfaceText rendered (emitNativeConstructorDeclJson constructorDecl);
      rendered
    };
    rendered
  };
  rendered
}

emitNativeConstructorEntrypointJson : Str -> HostedConstructorDeclAst -> Str
emitNativeConstructorEntrypointJson moduleName constructorDecl = {
  let payloadTypes = constructorDeclPayloadTypes constructorDecl;
  jsonObject [jsonFieldText "name" (constructorDeclName constructorDecl), jsonFieldText "symbol" (nativeEntrypointSymbol moduleName (constructorDeclName constructorDecl)), jsonFieldText "kind" (if hasHostedSurfaceTypes payloadTypes then "function" else "global"), jsonFieldRaw "arity" (if hasHostedSurfaceTypes payloadTypes then countHostedSurfaceTypes payloadTypes else "0")]
}

emitNativeConstructorEntrypointJsons : Str -> HostedModuleAst -> [Str]
emitNativeConstructorEntrypointJsons moduleName modl = {
  let mut rendered = emptyNativeSurfaceTexts;
  for typeDecl in nativeSurfaceEmittedTypeDecls modl {
    for constructorDecl in typeDeclConstructors typeDecl {
      rendered = appendNativeSurfaceText rendered (emitNativeConstructorEntrypointJson moduleName constructorDecl);
      rendered
    };
    rendered
  };
  rendered
}

-- CLASP_PROJECT_MODULE --
module Compiler.Emit.NativeMetadata

import Compiler.Ast
import Compiler.Checker
import Compiler.Emit.NativeDecls
import Compiler.Emit.NativeJson
import Compiler.Emit.NativeSurface
import Compiler.Json

appendNativeMetadataText : [Str] -> Str -> [Str]
appendNativeMetadataText values value = append values [value]

nativeCodecSuffixForType : TypeText -> Str
nativeCodecSuffixForType typ = match typ {
  TInt ->
    "Int",
  TStr ->
    "Str",
  TBool ->
    "Bool",
  TList itemType ->
    textConcat ["List_", nativeCodecSuffixForType itemType],
  TNamed name ->
    name,
  TApply name args ->
    textConcat [name, "_Generic"],
  TFunction input result ->
    "Unsupported",
  TVar label ->
    textConcat ["Var_", label],
  TUnknown label ->
    label
}

workflowCodecSuffix : HostedWorkflowDeclAst -> Str
workflowCodecSuffix workflowDecl = nativeCodecSuffixForType (typeFromHostedTypeAst (workflowDeclStateTypeAst workflowDecl))

workflowHandoffSymbol : Str -> HostedWorkflowDeclAst -> Str
workflowHandoffSymbol moduleName workflowDecl = textConcat [nativeModuleSymbolPrefix moduleName, "__", workflowDeclName workflowDecl, "__handoff"]

emitHostedWorkflowBoundaryImage : Str -> HostedWorkflowDeclAst -> Str
emitHostedWorkflowBoundaryImage moduleName workflowDecl =
  jsonObject [
    jsonFieldText "kind" "workflow",
    jsonFieldText "name" (workflowDeclName workflowDecl),
    jsonFieldText "id" (workflowDeclIdentity workflowDecl),
    jsonFieldText "state" (renderHostedType (workflowDeclStateTypeAst workflowDecl)),
    jsonFieldText "checkpoint" (textConcat ["$encode_", workflowCodecSuffix workflowDecl]),
    jsonFieldText "restore" (textConcat ["$decode_", workflowCodecSuffix workflowDecl]),
    jsonFieldText "handoff" (workflowHandoffSymbol moduleName workflowDecl)
  ]

emitHostedWorkflowBoundaryImages : Str -> HostedModuleAst -> [Str]
emitHostedWorkflowBoundaryImages moduleName modl = {
  let mut rendered = emptyRenderedTexts;
  for workflowDecl in moduleWorkflowDeclarations modl {
    rendered = appendNativeMetadataText rendered (emitHostedWorkflowBoundaryImage moduleName workflowDecl);
    rendered
  };
  rendered
}

emitHostedWorkflowBoundaryText : Str -> HostedWorkflowDeclAst -> Str
emitHostedWorkflowBoundaryText moduleName workflowDecl =
  textConcat [
    "workflow ",
    workflowDeclName workflowDecl,
    "{id=",
    workflowDeclIdentity workflowDecl,
    ", state=",
    renderHostedType (workflowDeclStateTypeAst workflowDecl),
    ", checkpoint=$encode_",
    workflowCodecSuffix workflowDecl,
    ", restore=$decode_",
    workflowCodecSuffix workflowDecl,
    ", handoff=",
    workflowHandoffSymbol moduleName workflowDecl,
    "}"
  ]

emitHostedWorkflowBoundaryTexts : Str -> HostedModuleAst -> [Str]
emitHostedWorkflowBoundaryTexts moduleName modl = {
  let mut rendered = emptyRenderedTexts;
  for workflowDecl in moduleWorkflowDeclarations modl {
    rendered = appendNativeMetadataText rendered (emitHostedWorkflowBoundaryText moduleName workflowDecl);
    rendered
  };
  rendered
}

routeBoundaryKind : Str -> Str
routeBoundaryKind responseType = if responseType == "Page" then "page" else if responseType == "Redirect" then "redirect" else "json"

routeUsesServiceTransport : HostedRouteDeclAst -> Bool
routeUsesServiceTransport routeDecl = routeBoundaryKind (routeDeclResponseType routeDecl) == "json"

emitHostedRouteBoundaryImage : HostedRouteDeclAst -> Str
emitHostedRouteBoundaryImage routeDecl =
  jsonObject [
    jsonFieldText "kind" "route",
    jsonFieldText "name" (routeDeclName routeDecl),
    jsonFieldText "id" (routeDeclIdentity routeDecl),
    jsonFieldText "method" (routeDeclMethod routeDecl),
    jsonFieldText "path" (routeDeclPath routeDecl),
    jsonFieldText "request" (routeDeclRequestType routeDecl),
    jsonFieldText "response" (routeDeclResponseType routeDecl),
    jsonFieldText "handler" (routeDeclHandlerName routeDecl),
    jsonFieldText "responseKind" (routeBoundaryKind (routeDeclResponseType routeDecl)),
    jsonFieldText "encode" (textConcat ["$encode_", routeDeclResponseType routeDecl]),
    jsonFieldText "decode" (textConcat ["$decode_", routeDeclRequestType routeDecl])
  ]

emitHostedRouteBoundaryImages : HostedModuleAst -> [Str]
emitHostedRouteBoundaryImages modl = {
  let mut rendered = emptyRenderedTexts;
  for routeDecl in moduleRouteDeclarations modl {
    rendered = appendNativeMetadataText rendered (emitHostedRouteBoundaryImage routeDecl);
    rendered
  };
  rendered
}

emitHostedRouteBoundaryText : HostedRouteDeclAst -> Str
emitHostedRouteBoundaryText routeDecl =
  textConcat [
    "route ",
    routeDeclName routeDecl,
    "{id=",
    routeDeclIdentity routeDecl,
    ", method=",
    routeDeclMethod routeDecl,
    ", path=",
    encode (routeDeclPath routeDecl),
    ", request=",
    routeDeclRequestType routeDecl,
    ", response=",
    routeDeclResponseType routeDecl,
    ", response_kind=",
    routeBoundaryKind (routeDeclResponseType routeDecl),
    ", encode=$encode_",
    routeDeclResponseType routeDecl,
    ", decode=$decode_",
    routeDeclRequestType routeDecl,
    "}"
  ]

emitHostedRouteBoundaryTexts : HostedModuleAst -> [Str]
emitHostedRouteBoundaryTexts modl = {
  let mut rendered = emptyRenderedTexts;
  for routeDecl in moduleRouteDeclarations modl {
    rendered = appendNativeMetadataText rendered (emitHostedRouteBoundaryText routeDecl);
    rendered
  };
  rendered
}

emitHostedHookBoundaryImage : HostedHookDeclAst -> Str
emitHostedHookBoundaryImage hookDecl =
  jsonObject [
    jsonFieldText "kind" "hook",
    jsonFieldText "name" (hookDeclName hookDecl),
    jsonFieldText "id" (textConcat ["hook:", hookDeclName hookDecl]),
    jsonFieldText "event" (hookDeclEvent hookDecl),
    jsonFieldText "request" (hookDeclRequestType hookDecl),
    jsonFieldText "response" (hookDeclResponseType hookDecl),
    jsonFieldText "handler" (hookDeclHandlerName hookDecl),
    jsonFieldText "encode" (textConcat ["$encode_", hookDeclResponseType hookDecl]),
    jsonFieldText "decode" (textConcat ["$decode_", hookDeclRequestType hookDecl])
  ]

emitHostedHookBoundaryImages : HostedModuleAst -> [Str]
emitHostedHookBoundaryImages modl = {
  let mut rendered = emptyRenderedTexts;
  for hookDecl in moduleHookDeclarations modl {
    rendered = appendNativeMetadataText rendered (emitHostedHookBoundaryImage hookDecl);
    rendered
  };
  rendered
}

emitHostedHookBoundaryText : HostedHookDeclAst -> Str
emitHostedHookBoundaryText hookDecl =
  textConcat [
    "hook ",
    hookDeclName hookDecl,
    "{id=hook:",
    hookDeclName hookDecl,
    ", event=",
    encode (hookDeclEvent hookDecl),
    ", request=",
    hookDeclRequestType hookDecl,
    ", response=",
    hookDeclResponseType hookDecl,
    ", handler=",
    hookDeclHandlerName hookDecl,
    ", encode=$encode_",
    hookDeclResponseType hookDecl,
    ", decode=$decode_",
    hookDeclRequestType hookDecl,
    "}"
  ]

emitHostedHookBoundaryTexts : HostedModuleAst -> [Str]
emitHostedHookBoundaryTexts modl = {
  let mut rendered = emptyRenderedTexts;
  for hookDecl in moduleHookDeclarations modl {
    rendered = appendNativeMetadataText rendered (emitHostedHookBoundaryText hookDecl);
    rendered
  };
  rendered
}

emitHostedToolServerBoundaryImage : HostedToolServerDeclAst -> Str
emitHostedToolServerBoundaryImage toolServerDecl =
  jsonObject [
    jsonFieldText "kind" "toolserver",
    jsonFieldText "name" (toolServerDeclName toolServerDecl),
    jsonFieldText "id" (textConcat ["toolserver:", toolServerDeclName toolServerDecl]),
    jsonFieldText "protocol" (toolServerDeclProtocol toolServerDecl),
    jsonFieldText "location" (toolServerDeclLocation toolServerDecl),
    jsonFieldText "policy" (toolServerDeclPolicyName toolServerDecl)
  ]

emitHostedToolServerBoundaryImages : HostedModuleAst -> [Str]
emitHostedToolServerBoundaryImages modl = {
  let mut rendered = emptyRenderedTexts;
  for toolServerDecl in moduleToolServerDeclarations modl {
    rendered = appendNativeMetadataText rendered (emitHostedToolServerBoundaryImage toolServerDecl);
    rendered
  };
  rendered
}

emitHostedToolServerBoundaryText : HostedToolServerDeclAst -> Str
emitHostedToolServerBoundaryText toolServerDecl =
  textConcat [
    "toolserver ",
    toolServerDeclName toolServerDecl,
    "{id=toolserver:",
    toolServerDeclName toolServerDecl,
    ", protocol=",
    toolServerDeclProtocol toolServerDecl,
    ", location=",
    encode (toolServerDeclLocation toolServerDecl),
    ", policy=",
    toolServerDeclPolicyName toolServerDecl,
    "}"
  ]

emitHostedToolServerBoundaryTexts : HostedModuleAst -> [Str]
emitHostedToolServerBoundaryTexts modl = {
  let mut rendered = emptyRenderedTexts;
  for toolServerDecl in moduleToolServerDeclarations modl {
    rendered = appendNativeMetadataText rendered (emitHostedToolServerBoundaryText toolServerDecl);
    rendered
  };
  rendered
}

emitHostedToolBoundaryImage : HostedToolDeclAst -> Str
emitHostedToolBoundaryImage toolDecl =
  jsonObject [
    jsonFieldText "kind" "tool",
    jsonFieldText "name" (toolDeclName toolDecl),
    jsonFieldText "id" (textConcat ["tool:", toolDeclName toolDecl]),
    jsonFieldText "server" (toolDeclServerName toolDecl),
    jsonFieldText "operation" (toolDeclOperation toolDecl),
    jsonFieldText "request" (toolDeclRequestType toolDecl),
    jsonFieldText "response" (toolDeclResponseType toolDecl),
    jsonFieldText "encode" (textConcat ["$encode_", toolDeclResponseType toolDecl]),
    jsonFieldText "decode" (textConcat ["$decode_", toolDeclRequestType toolDecl])
  ]

emitHostedToolBoundaryImages : HostedModuleAst -> [Str]
emitHostedToolBoundaryImages modl = {
  let mut rendered = emptyRenderedTexts;
  for toolDecl in moduleToolDeclarations modl {
    rendered = appendNativeMetadataText rendered (emitHostedToolBoundaryImage toolDecl);
    rendered
  };
  rendered
}

emitHostedToolBoundaryText : HostedToolDeclAst -> Str
emitHostedToolBoundaryText toolDecl =
  textConcat [
    "tool ",
    toolDeclName toolDecl,
    "{id=tool:",
    toolDeclName toolDecl,
    ", server=",
    toolDeclServerName toolDecl,
    ", operation=",
    encode (toolDeclOperation toolDecl),
    ", request=",
    toolDeclRequestType toolDecl,
    ", response=",
    toolDeclResponseType toolDecl,
    ", encode=$encode_",
    toolDeclResponseType toolDecl,
    ", decode=$decode_",
    toolDeclRequestType toolDecl,
    "}"
  ]

emitHostedToolBoundaryTexts : HostedModuleAst -> [Str]
emitHostedToolBoundaryTexts modl = {
  let mut rendered = emptyRenderedTexts;
  for toolDecl in moduleToolDeclarations modl {
    rendered = appendNativeMetadataText rendered (emitHostedToolBoundaryText toolDecl);
    rendered
  };
  rendered
}

emitHostedBoundaryImages : Str -> HostedModuleAst -> [Str]
emitHostedBoundaryImages moduleName modl =
  append
    (append
      (append
        (append (emitHostedRouteBoundaryImages modl) (emitHostedHookBoundaryImages modl))
        (emitHostedToolServerBoundaryImages modl))
      (emitHostedToolBoundaryImages modl))
    (emitHostedWorkflowBoundaryImages moduleName modl)

emitHostedBoundaryTexts : Str -> HostedModuleAst -> [Str]
emitHostedBoundaryTexts moduleName modl =
  append
    (append
      (append
        (append (emitHostedRouteBoundaryTexts modl) (emitHostedHookBoundaryTexts modl))
        (emitHostedToolServerBoundaryTexts modl))
      (emitHostedToolBoundaryTexts modl))
    (emitHostedWorkflowBoundaryTexts moduleName modl)

jsonOptionalTextField : Str -> Str -> JsonField
jsonOptionalTextField name value = if value == "" then jsonFieldRaw name "null" else jsonFieldText name value

emitHostedGuideEntryImages : [HostedGuideEntryAst] -> [JsonField]
emitHostedGuideEntryImages entries = {
  let mut rendered = emptyJsonFields;
  for entry in entries {
    rendered = append rendered [jsonFieldText (guideEntryName entry) (guideEntryValue entry)];
    rendered
  };
  rendered
}

emitHostedGuideMetadataImages : HostedModuleAst -> [Str]
emitHostedGuideMetadataImages modl = {
  let mut rendered = emptyRenderedTexts;
  for guideDecl in moduleGuideDeclarations modl {
    rendered =
      appendNativeMetadataText rendered
        (jsonObject [
          jsonFieldText "name" (guideDeclName guideDecl),
          jsonFieldText "id" (textConcat ["guide:", guideDeclName guideDecl]),
          jsonOptionalTextField "extends" (guideDeclExtends guideDecl),
          jsonFieldRaw "entries" (jsonObject (emitHostedGuideEntryImages (guideDeclEntries guideDecl)))
        ]);
    rendered
  };
  rendered
}

emitHostedPolicyPermissionImages : HostedPolicyPermissionKindAst -> [HostedPolicyPermissionAst] -> [Str]
emitHostedPolicyPermissionImages targetKind permissions = {
  let mut rendered = emptyRenderedTexts;
  for permission in permissions {
    if renderHostedPolicyPermissionKind (policyPermissionKind permission) == renderHostedPolicyPermissionKind targetKind then {
      rendered = appendNativeMetadataText rendered (encode (policyPermissionValue permission));
      rendered
    } else {
      rendered
    }
  };
  rendered
}

emitHostedPolicyMetadataImages : HostedModuleAst -> [Str]
emitHostedPolicyMetadataImages modl = {
  let mut rendered = emptyRenderedTexts;
  for policyDecl in modulePolicyDeclarations modl {
    rendered =
      appendNativeMetadataText rendered
        (jsonObject [
          jsonFieldText "name" (policyDeclName policyDecl),
          jsonFieldText "id" (textConcat ["policy:", policyDeclName policyDecl]),
          jsonFieldArray "allowedClassifications" (emitNativeJsonStringList (policyDeclAllowedClassifications policyDecl)),
          jsonFieldArray "file" (emitHostedPolicyPermissionImages HostedPolicyPermissionFile (policyDeclPermissions policyDecl)),
          jsonFieldArray "network" (emitHostedPolicyPermissionImages HostedPolicyPermissionNetwork (policyDeclPermissions policyDecl)),
          jsonFieldArray "process" (emitHostedPolicyPermissionImages HostedPolicyPermissionProcess (policyDeclPermissions policyDecl)),
          jsonFieldArray "secret" (emitHostedPolicyPermissionImages HostedPolicyPermissionSecret (policyDeclPermissions policyDecl))
        ]);
    rendered
  };
  rendered
}

emitHostedAgentRoleMetadataImages : HostedModuleAst -> [Str]
emitHostedAgentRoleMetadataImages modl = {
  let mut rendered = emptyRenderedTexts;
  for roleDecl in moduleAgentRoleDeclarations modl {
    rendered =
      appendNativeMetadataText rendered
        (jsonObject [
          jsonFieldText "name" (agentRoleDeclName roleDecl),
          jsonFieldText "id" (textConcat ["agent-role:", agentRoleDeclName roleDecl]),
          jsonOptionalTextField "guideName" (agentRoleDeclGuideName roleDecl),
          jsonOptionalTextField "policyName" (agentRoleDeclPolicyName roleDecl),
          jsonOptionalTextField "approvalPolicy" (agentRoleDeclApprovalPolicy roleDecl),
          jsonOptionalTextField "sandboxPolicy" (agentRoleDeclSandboxPolicy roleDecl)
        ]);
    rendered
  };
  rendered
}

emitHostedAgentMetadataImages : HostedModuleAst -> [Str]
emitHostedAgentMetadataImages modl = {
  let mut rendered = emptyRenderedTexts;
  for agentDecl in moduleAgentDeclarations modl {
    rendered =
      appendNativeMetadataText rendered
        (jsonObject [
          jsonFieldText "name" (agentDeclName agentDecl),
          jsonFieldText "id" (textConcat ["agent:", agentDeclName agentDecl]),
          jsonOptionalTextField "roleName" (agentDeclRoleName agentDecl)
        ]);
    rendered
  };
  rendered
}

emitHostedRuntimeMetadataImage : HostedModuleAst -> Str
emitHostedRuntimeMetadataImage modl =
  jsonObject [
    jsonFieldArray "guides" (emitHostedGuideMetadataImages modl),
    jsonFieldArray "policies" (emitHostedPolicyMetadataImages modl),
    jsonFieldArray "agentRoles" (emitHostedAgentRoleMetadataImages modl),
    jsonFieldArray "agents" (emitHostedAgentMetadataImages modl)
  ]

emitHostedRouteServiceTransportImage : HostedRouteDeclAst -> Str
emitHostedRouteServiceTransportImage routeDecl =
  jsonObject [
    jsonFieldText "kind" "route",
    jsonFieldText "name" (routeDeclName routeDecl),
    jsonFieldText "id" (routeDeclIdentity routeDecl),
    jsonFieldText "mode" "request_response",
    jsonFieldText "request" (routeDeclRequestType routeDecl),
    jsonFieldText "requestEncode" (textConcat ["$encode_binary_", routeDeclRequestType routeDecl]),
    jsonFieldText "requestDecode" (textConcat ["$decode_binary_", routeDeclRequestType routeDecl]),
    jsonFieldText "response" (routeDeclResponseType routeDecl),
    jsonFieldText "responseEncode" (textConcat ["$encode_binary_", routeDeclResponseType routeDecl]),
    jsonFieldText "responseDecode" (textConcat ["$decode_binary_", routeDeclResponseType routeDecl]),
    jsonFieldText "framing" "length_prefixed"
  ]

emitHostedRouteServiceTransportImages : HostedModuleAst -> [Str]
emitHostedRouteServiceTransportImages modl = {
  let mut rendered = emptyRenderedTexts;
  for routeDecl in moduleRouteDeclarations modl {
    rendered = if routeUsesServiceTransport routeDecl then appendNativeMetadataText rendered (emitHostedRouteServiceTransportImage routeDecl) else rendered;
    rendered
  };
  rendered
}

emitHostedRouteServiceTransportText : HostedRouteDeclAst -> Str
emitHostedRouteServiceTransportText routeDecl =
  textConcat [
    "route ",
    routeDeclName routeDecl,
    "{id=",
    routeDeclIdentity routeDecl,
    ", mode=request_response, request=",
    routeDeclRequestType routeDecl,
    ", request_encode=$encode_binary_",
    routeDeclRequestType routeDecl,
    ", request_decode=$decode_binary_",
    routeDeclRequestType routeDecl,
    ", response=",
    routeDeclResponseType routeDecl,
    ", response_encode=$encode_binary_",
    routeDeclResponseType routeDecl,
    ", response_decode=$decode_binary_",
    routeDeclResponseType routeDecl,
    ", framing=length_prefixed}"
  ]

emitHostedRouteServiceTransportTexts : HostedModuleAst -> [Str]
emitHostedRouteServiceTransportTexts modl = {
  let mut rendered = emptyRenderedTexts;
  for routeDecl in moduleRouteDeclarations modl {
    rendered = if routeUsesServiceTransport routeDecl then appendNativeMetadataText rendered (emitHostedRouteServiceTransportText routeDecl) else rendered;
    rendered
  };
  rendered
}

emitHostedHookServiceTransportImage : HostedHookDeclAst -> Str
emitHostedHookServiceTransportImage hookDecl =
  jsonObject [
    jsonFieldText "kind" "hook",
    jsonFieldText "name" (hookDeclName hookDecl),
    jsonFieldText "id" (textConcat ["hook:", hookDeclName hookDecl]),
    jsonFieldText "mode" "event",
    jsonFieldText "request" (hookDeclRequestType hookDecl),
    jsonFieldText "requestEncode" (textConcat ["$encode_binary_", hookDeclRequestType hookDecl]),
    jsonFieldText "requestDecode" (textConcat ["$decode_binary_", hookDeclRequestType hookDecl]),
    jsonFieldText "response" (hookDeclResponseType hookDecl),
    jsonFieldText "responseEncode" (textConcat ["$encode_binary_", hookDeclResponseType hookDecl]),
    jsonFieldText "responseDecode" (textConcat ["$decode_binary_", hookDeclResponseType hookDecl]),
    jsonFieldText "framing" "length_prefixed"
  ]

emitHostedHookServiceTransportImages : HostedModuleAst -> [Str]
emitHostedHookServiceTransportImages modl = {
  let mut rendered = emptyRenderedTexts;
  for hookDecl in moduleHookDeclarations modl {
    rendered = appendNativeMetadataText rendered (emitHostedHookServiceTransportImage hookDecl);
    rendered
  };
  rendered
}

emitHostedHookServiceTransportText : HostedHookDeclAst -> Str
emitHostedHookServiceTransportText hookDecl =
  textConcat [
    "hook ",
    hookDeclName hookDecl,
    "{id=hook:",
    hookDeclName hookDecl,
    ", mode=event, request=",
    hookDeclRequestType hookDecl,
    ", request_encode=$encode_binary_",
    hookDeclRequestType hookDecl,
    ", request_decode=$decode_binary_",
    hookDeclRequestType hookDecl,
    ", response=",
    hookDeclResponseType hookDecl,
    ", response_encode=$encode_binary_",
    hookDeclResponseType hookDecl,
    ", response_decode=$decode_binary_",
    hookDeclResponseType hookDecl,
    ", framing=length_prefixed}"
  ]

emitHostedHookServiceTransportTexts : HostedModuleAst -> [Str]
emitHostedHookServiceTransportTexts modl = {
  let mut rendered = emptyRenderedTexts;
  for hookDecl in moduleHookDeclarations modl {
    rendered = appendNativeMetadataText rendered (emitHostedHookServiceTransportText hookDecl);
    rendered
  };
  rendered
}

emitHostedToolServiceTransportImage : HostedToolDeclAst -> Str
emitHostedToolServiceTransportImage toolDecl =
  jsonObject [
    jsonFieldText "kind" "tool",
    jsonFieldText "name" (toolDeclName toolDecl),
    jsonFieldText "id" (textConcat ["tool:", toolDeclName toolDecl]),
    jsonFieldText "mode" "rpc",
    jsonFieldText "request" (toolDeclRequestType toolDecl),
    jsonFieldText "requestEncode" (textConcat ["$encode_binary_", toolDeclRequestType toolDecl]),
    jsonFieldText "requestDecode" (textConcat ["$decode_binary_", toolDeclRequestType toolDecl]),
    jsonFieldText "response" (toolDeclResponseType toolDecl),
    jsonFieldText "responseEncode" (textConcat ["$encode_binary_", toolDeclResponseType toolDecl]),
    jsonFieldText "responseDecode" (textConcat ["$decode_binary_", toolDeclResponseType toolDecl]),
    jsonFieldText "framing" "length_prefixed"
  ]

emitHostedToolServiceTransportImages : HostedModuleAst -> [Str]
emitHostedToolServiceTransportImages modl = {
  let mut rendered = emptyRenderedTexts;
  for toolDecl in moduleToolDeclarations modl {
    rendered = appendNativeMetadataText rendered (emitHostedToolServiceTransportImage toolDecl);
    rendered
  };
  rendered
}

emitHostedToolServiceTransportText : HostedToolDeclAst -> Str
emitHostedToolServiceTransportText toolDecl =
  textConcat [
    "tool ",
    toolDeclName toolDecl,
    "{id=tool:",
    toolDeclName toolDecl,
    ", mode=rpc, request=",
    toolDeclRequestType toolDecl,
    ", request_encode=$encode_binary_",
    toolDeclRequestType toolDecl,
    ", request_decode=$decode_binary_",
    toolDeclRequestType toolDecl,
    ", response=",
    toolDeclResponseType toolDecl,
    ", response_encode=$encode_binary_",
    toolDeclResponseType toolDecl,
    ", response_decode=$decode_binary_",
    toolDeclResponseType toolDecl,
    ", framing=length_prefixed}"
  ]

emitHostedToolServiceTransportTexts : HostedModuleAst -> [Str]
emitHostedToolServiceTransportTexts modl = {
  let mut rendered = emptyRenderedTexts;
  for toolDecl in moduleToolDeclarations modl {
    rendered = appendNativeMetadataText rendered (emitHostedToolServiceTransportText toolDecl);
    rendered
  };
  rendered
}

emitHostedServiceTransportImages : HostedModuleAst -> [Str]
emitHostedServiceTransportImages modl =
  append
    (append (emitHostedRouteServiceTransportImages modl) (emitHostedHookServiceTransportImages modl))
    (emitHostedToolServiceTransportImages modl)

emitHostedServiceTransportTexts : HostedModuleAst -> [Str]
emitHostedServiceTransportTexts modl =
  append
    (append (emitHostedRouteServiceTransportTexts modl) (emitHostedHookServiceTransportTexts modl))
    (emitHostedToolServiceTransportTexts modl)

firstWorkflowDecl : HostedModuleAst -> HostedWorkflowDeclAst
firstWorkflowDecl modl = {
  for workflowDecl in moduleWorkflowDeclarations modl {
    return workflowDecl
  };
  hostedWorkflowDeclAst "" "" (HostedTypeName "")
}

hasExactlyOneWorkflowDecl : HostedModuleAst -> Bool
hasExactlyOneWorkflowDecl modl = {
  let mut seenOne = false;
  for workflowDecl in moduleWorkflowDeclarations modl {
    if seenOne then return false else {
      seenOne = true;
      seenOne
    }
  };
  seenOne
}

emitNativeMigrationStateTypeValue : HostedModuleAst -> Str
emitNativeMigrationStateTypeValue modl = if hasExactlyOneWorkflowDecl modl then encode (renderHostedType (workflowDeclStateTypeAst (firstWorkflowDecl modl))) else "null"

emitNativeMigrationSnapshotSymbolValue : HostedModuleAst -> Str
emitNativeMigrationSnapshotSymbolValue modl = if hasExactlyOneWorkflowDecl modl then encode (textConcat ["$encode_", workflowCodecSuffix (firstWorkflowDecl modl)]) else "null"

emitNativeMigrationHandoffSymbolValue : HostedModuleAst -> Str
emitNativeMigrationHandoffSymbolValue modl = if hasExactlyOneWorkflowDecl modl then encode (workflowHandoffSymbol (moduleNameOf modl) (firstWorkflowDecl modl)) else "null"

emitNativeProjectionFieldFingerprintText : HostedProjectionFieldDeclAst -> Str
emitNativeProjectionFieldFingerprintText field = projectionFieldDeclName field

emitNativeProjectionDeclFingerprintText : HostedProjectionDeclAst -> Str
emitNativeProjectionDeclFingerprintText decl = {
  let mut fields = emptyRenderedTexts;
  for field in projectionDeclFields decl {
    fields = appendNativeMetadataText fields (emitNativeProjectionFieldFingerprintText field);
    fields
  };
  textConcat [
    projectionDeclName decl,
    ":",
    projectionDeclSourceRecordName decl,
    ":",
    projectionDeclPolicyName decl,
    ":{",
    textJoin "," fields,
    "}"
  ]
}

emitNativeVerifierDeclFingerprintText : HostedVerifierDeclAst -> Str
emitNativeVerifierDeclFingerprintText decl = textConcat [verifierDeclName decl, ":", verifierDeclToolName decl]

emitNativeMergeGateDeclFingerprintText : HostedMergeGateDeclAst -> Str
emitNativeMergeGateDeclFingerprintText decl =
  textConcat [mergeGateDeclName decl, ":{", textJoin "," (mergeGateDeclVerifierNames decl), "}"]

emitNativeImportFingerprintText : Str -> Str
emitNativeImportFingerprintText importName = textConcat ["import:", importName]

emitNativeGuideMetadataFingerprintText : Str -> Str
emitNativeGuideMetadataFingerprintText guideImage = textConcat ["guide:", guideImage]

emitNativePolicyMetadataFingerprintText : Str -> Str
emitNativePolicyMetadataFingerprintText policyImage = textConcat ["policy:", policyImage]

emitNativeAgentRoleMetadataFingerprintText : Str -> Str
emitNativeAgentRoleMetadataFingerprintText roleImage = textConcat ["agentRole:", roleImage]

emitNativeAgentMetadataFingerprintText : Str -> Str
emitNativeAgentMetadataFingerprintText agentImage = textConcat ["agent:", agentImage]

emitNativeBoundaryFingerprintText : Str -> Str
emitNativeBoundaryFingerprintText boundaryText = textConcat ["boundary:", boundaryText]

emitNativeServiceTransportFingerprintText : Str -> Str
emitNativeServiceTransportFingerprintText serviceTransportText = textConcat ["service:", serviceTransportText]

emitNativeSourceModuleInterfaceFingerprint : HostedModuleAst -> Str
emitNativeSourceModuleInterfaceFingerprint modl = {
  let moduleName = moduleNameOf modl;
  let moduleParts = [moduleName];
  let importParts = map emitNativeImportFingerprintText (moduleImports modl);
  let declParts = map emitNativeDeclInterfaceFingerprintText (moduleDeclarations modl);
  let typeDeclParts = map emitNativeTypeDeclFingerprintText (moduleTypeDeclarations modl);
  let recordDeclParts = map emitNativeRecordDeclFingerprintText (moduleRecordDeclarations modl);
  let foreignDeclParts = map emitNativeForeignDeclFingerprintText (moduleForeignDeclarations modl);
  let guideParts = map emitNativeGuideMetadataFingerprintText (emitHostedGuideMetadataImages modl);
  let policyParts = map emitNativePolicyMetadataFingerprintText (emitHostedPolicyMetadataImages modl);
  let projectionParts = map emitNativeProjectionDeclFingerprintText (moduleProjectionDeclarations modl);
  let roleParts = map emitNativeAgentRoleMetadataFingerprintText (emitHostedAgentRoleMetadataImages modl);
  let agentParts = map emitNativeAgentMetadataFingerprintText (emitHostedAgentMetadataImages modl);
  let boundaryParts = map emitNativeBoundaryFingerprintText (emitHostedBoundaryTexts moduleName modl);
  let serviceParts = map emitNativeServiceTransportFingerprintText (emitHostedServiceTransportTexts modl);
  let verifierParts = map emitNativeVerifierDeclFingerprintText (moduleVerifierDeclarations modl);
  let mergeGateParts = map emitNativeMergeGateDeclFingerprintText (moduleMergeGateDeclarations modl);
  let fingerprintParts =
    append
      (append
        (append
          (append moduleParts importParts)
          (append declParts typeDeclParts))
        (append
          (append recordDeclParts foreignDeclParts)
          (append guideParts policyParts)))
      (append
        (append
          (append projectionParts roleParts)
          (append agentParts boundaryParts))
        (append serviceParts (append verifierParts mergeGateParts)));
  textFingerprint64Hex (textJoin "\n" fingerprintParts)
}

nativeImageDeclPlanFieldSeparator : Str
nativeImageDeclPlanFieldSeparator = "\n-- CLASP_NATIVE_IMAGE_DECL_PLAN_FIELD --\n"

nativeImageDeclModuleSeparator : Str
nativeImageDeclModuleSeparator = "\n-- CLASP_NATIVE_IMAGE_DECL_MODULE --\n"

nativeImageDeclModuleFieldSeparator : Str
nativeImageDeclModuleFieldSeparator = "\n-- CLASP_NATIVE_IMAGE_DECL_MODULE_FIELD --\n"

emitNativeDeclModulePlanEntryText : HostedModuleAst -> Str
emitNativeDeclModulePlanEntryText sourceModule =
  textJoin
    nativeImageDeclModuleFieldSeparator
    [
      moduleNameOf sourceModule,
      emitNativeModuleImageDeclNames sourceModule,
      emitNativeSourceModuleInterfaceFingerprint sourceModule
    ]

emitNativeDeclModulePlanEntriesText : [HostedModuleAst] -> Str
emitNativeDeclModulePlanEntriesText sourceModules = {
  let mut entries = emptyRenderedTexts;
  for sourceModule in sourceModules {
    let entryText = emitNativeDeclModulePlanEntryText sourceModule;
    entries = appendNativeMetadataText entries entryText;
    entries
  };
  textJoin nativeImageDeclModuleSeparator entries
}

emitNativeProjectDeclModulePlanText : HostedModuleAst -> [HostedModuleAst] -> Str
emitNativeProjectDeclModulePlanText mergedModule sourceModules =
  textJoin
    nativeImageDeclPlanFieldSeparator
    [
      emitNativeProjectDeclContextFingerprint mergedModule,
      emitNativeDeclModulePlanEntriesText sourceModules
    ]

