module Compiler.CheckedCore

import Compiler.Ast
import Compiler.Checker
import Compiler.Json

type CheckedCoreArtifactResult = CheckedCoreArtifactOk [CheckedCoreDeclArtifact] | CheckedCoreArtifactError Str
type CheckedCoreDeclArtifact = CheckedCoreDeclArtifact Str TypeText [CheckedCoreParamArtifact] CheckedCoreExprArtifact
type CheckedCoreParamArtifact = CheckedCoreParamArtifact Str TypeText
type CheckedCoreExprArtifact = CheckedCoreVarArtifact TypeText Str | CheckedCoreIntArtifact Str | CheckedCoreStringArtifact Str | CheckedCoreBoolArtifact Bool | CheckedCoreListArtifact TypeText [CheckedCoreExprArtifact] | CheckedCoreIfArtifact TypeText CheckedCoreExprArtifact CheckedCoreExprArtifact CheckedCoreExprArtifact | CheckedCoreReturnArtifact TypeText CheckedCoreExprArtifact | CheckedCoreEqualArtifact CheckedCoreExprArtifact CheckedCoreExprArtifact | CheckedCoreNotEqualArtifact CheckedCoreExprArtifact CheckedCoreExprArtifact | CheckedCoreLessThanArtifact CheckedCoreExprArtifact CheckedCoreExprArtifact | CheckedCoreLessThanOrEqualArtifact CheckedCoreExprArtifact CheckedCoreExprArtifact | CheckedCoreGreaterThanArtifact CheckedCoreExprArtifact CheckedCoreExprArtifact | CheckedCoreGreaterThanOrEqualArtifact CheckedCoreExprArtifact CheckedCoreExprArtifact | CheckedCoreLetArtifact TypeText Str CheckedCoreExprArtifact CheckedCoreExprArtifact | CheckedCoreMutableLetArtifact TypeText Str CheckedCoreExprArtifact CheckedCoreExprArtifact | CheckedCoreAssignArtifact TypeText Str CheckedCoreExprArtifact CheckedCoreExprArtifact | CheckedCoreForArtifact TypeText Str CheckedCoreExprArtifact CheckedCoreExprArtifact CheckedCoreExprArtifact | CheckedCoreCallArtifact TypeText Str TypeText [CheckedCoreExprArtifact] | CheckedCoreMatchArtifact TypeText CheckedCoreExprArtifact [CheckedCoreMatchBranchArtifact] | CheckedCoreRecordArtifact TypeText Str [CheckedCoreRecordFieldArtifact] | CheckedCoreFieldAccessArtifact TypeText CheckedCoreExprArtifact Str
type CheckedCoreRecordFieldArtifact = CheckedCoreRecordFieldArtifact Str CheckedCoreExprArtifact
type CheckedCoreMatchBranchArtifact = CheckedCoreMatchBranchArtifact CheckedCorePatternArtifact CheckedCoreExprArtifact
type CheckedCorePatternArtifact = CheckedCoreConstructorPatternArtifact Str [CheckedCorePatternBinderArtifact]
type CheckedCorePatternBinderArtifact = CheckedCorePatternBinderArtifact Str TypeText

type CheckedCoreExprBuildResult = CheckedCoreExprBuilt CheckedCoreExprArtifact | CheckedCoreExprBuildError Str
type CheckedCoreExprListBuildResult = CheckedCoreExprListBuilt [CheckedCoreExprArtifact] | CheckedCoreExprListBuildError Str
type CheckedCoreRecordFieldListBuildResult = CheckedCoreRecordFieldListBuilt [CheckedCoreRecordFieldArtifact] | CheckedCoreRecordFieldListBuildError Str
type CheckedCoreMatchBranchListBuildResult = CheckedCoreMatchBranchListBuilt [CheckedCoreMatchBranchArtifact] | CheckedCoreMatchBranchListBuildError Str
type CheckedCoreDeclBuildResult = CheckedCoreDeclBuilt CheckedCoreDeclArtifact | CheckedCoreDeclBuildError Str
type CheckedCoreDeclListBuildResult = CheckedCoreDeclListBuilt [CheckedCoreDeclArtifact] | CheckedCoreDeclListBuildError Str
type CheckedCoreMatchBranchBuildResult = CheckedCoreMatchBranchBuilt CheckedCoreMatchBranchArtifact | CheckedCoreMatchBranchBuildError Str

keepNoCheckedCoreParamArtifact : CheckedCoreParamArtifact -> Bool
keepNoCheckedCoreParamArtifact value = false

emptyCheckedCoreParamArtifacts : [CheckedCoreParamArtifact]
emptyCheckedCoreParamArtifacts = filter keepNoCheckedCoreParamArtifact [CheckedCoreParamArtifact "" (TUnknown "")]

keepNoCheckedCorePatternBinderArtifact : CheckedCorePatternBinderArtifact -> Bool
keepNoCheckedCorePatternBinderArtifact value = false

emptyCheckedCorePatternBinderArtifacts : [CheckedCorePatternBinderArtifact]
emptyCheckedCorePatternBinderArtifacts = filter keepNoCheckedCorePatternBinderArtifact [CheckedCorePatternBinderArtifact "" (TUnknown "")]

keepNoCheckedCoreExprArtifact : CheckedCoreExprArtifact -> Bool
keepNoCheckedCoreExprArtifact value = false

emptyCheckedCoreExprArtifacts : [CheckedCoreExprArtifact]
emptyCheckedCoreExprArtifacts = filter keepNoCheckedCoreExprArtifact [CheckedCoreStringArtifact ""]

keepNoCheckedCoreRecordFieldArtifact : CheckedCoreRecordFieldArtifact -> Bool
keepNoCheckedCoreRecordFieldArtifact value = false

emptyCheckedCoreRecordFieldArtifacts : [CheckedCoreRecordFieldArtifact]
emptyCheckedCoreRecordFieldArtifacts = filter keepNoCheckedCoreRecordFieldArtifact [CheckedCoreRecordFieldArtifact "" (CheckedCoreStringArtifact "")]

keepNoCheckedCoreMatchBranchArtifact : CheckedCoreMatchBranchArtifact -> Bool
keepNoCheckedCoreMatchBranchArtifact value = false

emptyCheckedCoreMatchBranchArtifacts : [CheckedCoreMatchBranchArtifact]
emptyCheckedCoreMatchBranchArtifacts = filter keepNoCheckedCoreMatchBranchArtifact [CheckedCoreMatchBranchArtifact (CheckedCoreConstructorPatternArtifact "" emptyCheckedCorePatternBinderArtifacts) (CheckedCoreStringArtifact "")]

keepNoCheckedCoreDeclArtifact : CheckedCoreDeclArtifact -> Bool
keepNoCheckedCoreDeclArtifact value = false

emptyCheckedCoreDeclArtifacts : [CheckedCoreDeclArtifact]
emptyCheckedCoreDeclArtifacts = filter keepNoCheckedCoreDeclArtifact [CheckedCoreDeclArtifact "" (TUnknown "") emptyCheckedCoreParamArtifacts (CheckedCoreStringArtifact "")]

keepNoCheckedCoreRenderedText : Str -> Bool
keepNoCheckedCoreRenderedText value = false

emptyCheckedCoreRenderedTexts : [Str]
emptyCheckedCoreRenderedTexts = filter keepNoCheckedCoreRenderedText [""]

appendCheckedCoreExprArtifact : [CheckedCoreExprArtifact] -> CheckedCoreExprArtifact -> [CheckedCoreExprArtifact]
appendCheckedCoreExprArtifact values value = append values [value]

appendCheckedCoreRecordFieldArtifact : [CheckedCoreRecordFieldArtifact] -> CheckedCoreRecordFieldArtifact -> [CheckedCoreRecordFieldArtifact]
appendCheckedCoreRecordFieldArtifact values value = append values [value]

appendCheckedCoreMatchBranchArtifact : [CheckedCoreMatchBranchArtifact] -> CheckedCoreMatchBranchArtifact -> [CheckedCoreMatchBranchArtifact]
appendCheckedCoreMatchBranchArtifact values value = append values [value]

appendCheckedCoreDeclArtifact : [CheckedCoreDeclArtifact] -> CheckedCoreDeclArtifact -> [CheckedCoreDeclArtifact]
appendCheckedCoreDeclArtifact values value = append values [value]

checkedCoreNameType : [TypeBinding] -> [TypeBinding] -> Str -> TypeText
checkedCoreNameType env localEnv name = match lookupTypeBinding (append localEnv env) name {
  FoundType bindingType ->
    bindingType,
  MissingType missing ->
    TUnknown missing
}

checkedCoreExtendLocalEnv : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [TypeBinding] -> [TypeBinding] -> ReturnContext -> Str -> HostedExprAst -> [TypeBinding]
checkedCoreExtendLocalEnv typeDecls recordDecls env localEnv fnContext binder value = match inferExpr typeDecls recordDecls env localEnv fnContext value {
  InferredExpr valueType ->
    appendTypeBinding localEnv (TypeBinding binder valueType),
  InferExprError message ->
    localEnv
}

checkedCoreExtendLoopLocalEnv : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [TypeBinding] -> [TypeBinding] -> ReturnContext -> Str -> HostedExprAst -> [TypeBinding]
checkedCoreExtendLoopLocalEnv typeDecls recordDecls env localEnv fnContext binder iterable = match inferExpr typeDecls recordDecls env localEnv fnContext iterable {
  InferredExpr iterableType ->
    match iterableType {
      TList itemType ->
        appendTypeBinding localEnv (TypeBinding binder itemType),
      TStr ->
        appendTypeBinding localEnv (TypeBinding binder TStr),
      TInt ->
        localEnv,
      TBool ->
        localEnv,
      TFunction inputType resultType ->
        localEnv,
      TNamed label ->
        localEnv,
      TApply label args ->
        localEnv,
      TVar label ->
        localEnv,
      TUnknown label ->
        localEnv
    },
  InferExprError message ->
    localEnv
}

checkedCoreFunctionLocalEnv : HostedDeclAst -> [TypeBinding]
checkedCoreFunctionLocalEnv decl = if hasAnnotationAst (declAnnotation decl) then {
  let declaredType = instantiateGenericType (textConcat ["decl:", declName decl]) (typeFromHostedTypeAst (annotationTypeAst (declAnnotation decl)));
  match bindFunctionParams decl declaredType {
    BindingParams localEnv expectedBodyType ->
      localEnv,
    BindingParamError message ->
      emptyTypeBindings
  }
} else {
  emptyTypeBindings
}

checkedCoreFunctionContext : HostedDeclAst -> ReturnContext
checkedCoreFunctionContext decl = if hasAnnotationAst (declAnnotation decl) then {
  let declaredType = instantiateGenericType (textConcat ["decl:", declName decl]) (typeFromHostedTypeAst (annotationTypeAst (declAnnotation decl)));
  match bindFunctionParams decl declaredType {
    BindingParams localEnv expectedBodyType ->
      InsideFunction expectedBodyType,
    BindingParamError message ->
      OutsideFunction
  }
} else {
  OutsideFunction
}

checkedCoreParamArtifacts : HostedDeclAst -> [CheckedCoreParamArtifact]
checkedCoreParamArtifacts decl = if hasAnnotationAst (declAnnotation decl) then {
  let declaredType = instantiateGenericType (textConcat ["decl:", declName decl]) (typeFromHostedTypeAst (annotationTypeAst (declAnnotation decl)));
  match bindFunctionParams decl declaredType {
    BindingParams localEnv expectedBodyType ->
      checkedCoreParamArtifactsFromBindings localEnv,
    BindingParamError message ->
      emptyCheckedCoreParamArtifacts
  }
} else {
  emptyCheckedCoreParamArtifacts
}

checkedCoreParamArtifactsFromBindings : [TypeBinding] -> [CheckedCoreParamArtifact]
checkedCoreParamArtifactsFromBindings bindings = {
  let mut params = emptyCheckedCoreParamArtifacts;
  for binding in bindings {
    params = match binding {
      TypeBinding name bindingType ->
        append params [CheckedCoreParamArtifact name bindingType]
    };
    params
  };
  params
}

checkedCorePatternBinderArtifacts : [TypeBinding] -> [CheckedCorePatternBinderArtifact]
checkedCorePatternBinderArtifacts bindings = {
  let mut binders = emptyCheckedCorePatternBinderArtifacts;
  for binding in bindings {
    binders = match binding {
      TypeBinding name bindingType ->
        append binders [CheckedCorePatternBinderArtifact name bindingType]
    };
    binders
  };
  binders
}

checkedCoreExprList : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [TypeBinding] -> [TypeBinding] -> ReturnContext -> [HostedExprAst] -> CheckedCoreExprListBuildResult
checkedCoreExprList typeDecls recordDecls env localEnv fnContext values = {
  let mut state = CheckedCoreExprListBuilt emptyCheckedCoreExprArtifacts;
  for value in values {
    state = match state {
      CheckedCoreExprListBuildError message ->
        CheckedCoreExprListBuildError message,
      CheckedCoreExprListBuilt artifacts ->
        match checkedCoreExpr typeDecls recordDecls env localEnv fnContext value {
          CheckedCoreExprBuilt artifact ->
            CheckedCoreExprListBuilt (appendCheckedCoreExprArtifact artifacts artifact),
          CheckedCoreExprBuildError message ->
            CheckedCoreExprListBuildError message
        }
    };
    state
  };
  state
}

checkedCoreRecordFieldList : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [TypeBinding] -> [TypeBinding] -> ReturnContext -> [HostedRecordFieldExprAst] -> CheckedCoreRecordFieldListBuildResult
checkedCoreRecordFieldList typeDecls recordDecls env localEnv fnContext fields = {
  let mut state = CheckedCoreRecordFieldListBuilt emptyCheckedCoreRecordFieldArtifacts;
  for field in fields {
    state = match state {
      CheckedCoreRecordFieldListBuildError message ->
        CheckedCoreRecordFieldListBuildError message,
      CheckedCoreRecordFieldListBuilt artifacts ->
        match checkedCoreExpr typeDecls recordDecls env localEnv fnContext (recordExprFieldValue field) {
          CheckedCoreExprBuilt artifact ->
            CheckedCoreRecordFieldListBuilt (appendCheckedCoreRecordFieldArtifact artifacts (CheckedCoreRecordFieldArtifact (recordExprFieldName field) artifact)),
          CheckedCoreExprBuildError message ->
            CheckedCoreRecordFieldListBuildError message
        }
    };
    state
  };
  state
}

checkedCoreMatchBranch : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [TypeBinding] -> [TypeBinding] -> ReturnContext -> HostedTypeDeclAst -> TypeText -> HostedMatchBranchAst -> CheckedCoreMatchBranchBuildResult
checkedCoreMatchBranch typeDecls recordDecls env localEnv fnContext typeDecl subjectType branch = {
  let pattern = branchPatternAst branch;
  match bindPattern typeDecl subjectType pattern {
    PatternBindError message ->
      CheckedCoreMatchBranchBuildError message,
    BoundPattern bindings ->
      match checkedCoreExpr typeDecls recordDecls env (append bindings localEnv) fnContext (branchBodyExpr branch) {
        CheckedCoreExprBuilt bodyArtifact ->
          CheckedCoreMatchBranchBuilt (CheckedCoreMatchBranchArtifact (CheckedCoreConstructorPatternArtifact (patternConstructorName pattern) (checkedCorePatternBinderArtifacts bindings)) bodyArtifact),
        CheckedCoreExprBuildError message ->
          CheckedCoreMatchBranchBuildError message
      }
  }
}

checkedCoreMatchBranchList : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [TypeBinding] -> [TypeBinding] -> ReturnContext -> HostedTypeDeclAst -> TypeText -> [HostedMatchBranchAst] -> CheckedCoreMatchBranchListBuildResult
checkedCoreMatchBranchList typeDecls recordDecls env localEnv fnContext typeDecl subjectType branches = {
  let mut state = CheckedCoreMatchBranchListBuilt emptyCheckedCoreMatchBranchArtifacts;
  for branch in branches {
    state = match state {
      CheckedCoreMatchBranchListBuildError message ->
        CheckedCoreMatchBranchListBuildError message,
      CheckedCoreMatchBranchListBuilt artifacts ->
        match checkedCoreMatchBranch typeDecls recordDecls env localEnv fnContext typeDecl subjectType branch {
          CheckedCoreMatchBranchBuilt artifact ->
            CheckedCoreMatchBranchListBuilt (appendCheckedCoreMatchBranchArtifact artifacts artifact),
          CheckedCoreMatchBranchBuildError message ->
            CheckedCoreMatchBranchListBuildError message
        }
    };
    state
  };
  state
}

checkedCoreCallArtifact : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [TypeBinding] -> [TypeBinding] -> ReturnContext -> TypeText -> Str -> [HostedExprAst] -> CheckedCoreExprBuildResult
checkedCoreCallArtifact typeDecls recordDecls env localEnv fnContext resultType callee args = match checkedCoreExprList typeDecls recordDecls env localEnv fnContext args {
  CheckedCoreExprListBuilt argArtifacts ->
    CheckedCoreExprBuilt (CheckedCoreCallArtifact resultType callee (checkedCoreNameType env localEnv callee) argArtifacts),
  CheckedCoreExprListBuildError message ->
    CheckedCoreExprBuildError message
}

checkedCoreExpr : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [TypeBinding] -> [TypeBinding] -> ReturnContext -> HostedExprAst -> CheckedCoreExprBuildResult
checkedCoreExpr typeDecls recordDecls env localEnv fnContext expr = match inferExpr typeDecls recordDecls env localEnv fnContext expr {
  InferExprError message ->
    CheckedCoreExprBuildError message,
  InferredExpr exprType ->
    checkedCoreExprWithType typeDecls recordDecls env localEnv fnContext expr exprType
}

checkedCoreExprWithType : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [TypeBinding] -> [TypeBinding] -> ReturnContext -> HostedExprAst -> TypeText -> CheckedCoreExprBuildResult
checkedCoreExprWithType typeDecls recordDecls env localEnv fnContext expr exprType = match expr {
  HostedName name ->
    CheckedCoreExprBuilt (CheckedCoreVarArtifact exprType name),
  HostedString value ->
    CheckedCoreExprBuilt (CheckedCoreStringArtifact value),
  HostedInt value ->
    CheckedCoreExprBuilt (CheckedCoreIntArtifact value),
  HostedBool value ->
    CheckedCoreExprBuilt (CheckedCoreBoolArtifact value),
  HostedList values ->
    match checkedCoreExprList typeDecls recordDecls env localEnv fnContext values {
      CheckedCoreExprListBuilt artifacts ->
        CheckedCoreExprBuilt (CheckedCoreListArtifact exprType artifacts),
      CheckedCoreExprListBuildError message ->
        CheckedCoreExprBuildError message
    },
  HostedCall callee args ->
    checkedCoreCallArtifact typeDecls recordDecls env localEnv fnContext exprType callee args,
  HostedConstructor constructorName args ->
    checkedCoreCallArtifact typeDecls recordDecls env localEnv fnContext exprType constructorName args,
  HostedMatch subject branches ->
    match inferExpr typeDecls recordDecls env localEnv fnContext subject {
      InferExprError message ->
        CheckedCoreExprBuildError message,
      InferredExpr subjectType ->
        match subjectType {
          TNamed typeName ->
            match lookupTypeDecl typeDecls typeName {
              MissingTypeDecl missing ->
                CheckedCoreExprBuildError (textConcat ["Unknown match type `", missing, "`."]),
              FoundTypeDecl typeDecl ->
                match checkedCoreExpr typeDecls recordDecls env localEnv fnContext subject {
                  CheckedCoreExprBuildError message ->
                    CheckedCoreExprBuildError message,
                  CheckedCoreExprBuilt subjectArtifact ->
                    match checkedCoreMatchBranchList typeDecls recordDecls env localEnv fnContext typeDecl subjectType branches {
                      CheckedCoreMatchBranchListBuilt branchArtifacts ->
                        CheckedCoreExprBuilt (CheckedCoreMatchArtifact exprType subjectArtifact branchArtifacts),
                      CheckedCoreMatchBranchListBuildError message ->
                        CheckedCoreExprBuildError message
                    }
                }
            },
          TApply typeName args ->
            match lookupTypeDecl typeDecls typeName {
              MissingTypeDecl missing ->
                CheckedCoreExprBuildError (textConcat ["Unknown match type `", missing, "`."]),
              FoundTypeDecl typeDecl ->
                match checkedCoreExpr typeDecls recordDecls env localEnv fnContext subject {
                  CheckedCoreExprBuildError message ->
                    CheckedCoreExprBuildError message,
                  CheckedCoreExprBuilt subjectArtifact ->
                    match checkedCoreMatchBranchList typeDecls recordDecls env localEnv fnContext typeDecl subjectType branches {
                      CheckedCoreMatchBranchListBuilt branchArtifacts ->
                        CheckedCoreExprBuilt (CheckedCoreMatchArtifact exprType subjectArtifact branchArtifacts),
                      CheckedCoreMatchBranchListBuildError message ->
                        CheckedCoreExprBuildError message
                    }
                }
            },
          TInt ->
            CheckedCoreExprBuildError "`match` requires a named type.",
          TStr ->
            CheckedCoreExprBuildError "`match` requires a named type.",
          TBool ->
            CheckedCoreExprBuildError "`match` requires a named type.",
          TList itemType ->
            CheckedCoreExprBuildError "`match` requires a named type.",
          TFunction inputType resultType ->
            CheckedCoreExprBuildError "`match` requires a named type.",
          TVar label ->
            CheckedCoreExprBuildError "`match` requires a known type.",
          TUnknown label ->
            CheckedCoreExprBuildError "`match` requires a known type."
        }
    },
  HostedRecord recordName fields ->
    match checkedCoreRecordFieldList typeDecls recordDecls env localEnv fnContext fields {
      CheckedCoreRecordFieldListBuilt fieldArtifacts ->
        CheckedCoreExprBuilt (CheckedCoreRecordArtifact exprType recordName fieldArtifacts),
      CheckedCoreRecordFieldListBuildError message ->
        CheckedCoreExprBuildError message
    },
  HostedFieldAccess subject fieldName ->
    match checkedCoreExpr typeDecls recordDecls env localEnv fnContext subject {
      CheckedCoreExprBuilt subjectArtifact ->
        CheckedCoreExprBuilt (CheckedCoreFieldAccessArtifact exprType subjectArtifact fieldName),
      CheckedCoreExprBuildError message ->
        CheckedCoreExprBuildError message
    },
  HostedLet binder value body ->
    match checkedCoreExpr typeDecls recordDecls env localEnv fnContext value {
      CheckedCoreExprBuildError message ->
        CheckedCoreExprBuildError message,
      CheckedCoreExprBuilt valueArtifact ->
        match checkedCoreExpr typeDecls recordDecls env (checkedCoreExtendLocalEnv typeDecls recordDecls env localEnv fnContext binder value) fnContext body {
          CheckedCoreExprBuilt bodyArtifact ->
            CheckedCoreExprBuilt (CheckedCoreLetArtifact exprType binder valueArtifact bodyArtifact),
          CheckedCoreExprBuildError message ->
            CheckedCoreExprBuildError message
        }
    },
  HostedMutableLet binder value body ->
    match checkedCoreExpr typeDecls recordDecls env localEnv fnContext value {
      CheckedCoreExprBuildError message ->
        CheckedCoreExprBuildError message,
      CheckedCoreExprBuilt valueArtifact ->
        match checkedCoreExpr typeDecls recordDecls env (checkedCoreExtendLocalEnv typeDecls recordDecls env localEnv fnContext binder value) fnContext body {
          CheckedCoreExprBuilt bodyArtifact ->
            CheckedCoreExprBuilt (CheckedCoreMutableLetArtifact exprType binder valueArtifact bodyArtifact),
          CheckedCoreExprBuildError message ->
            CheckedCoreExprBuildError message
        }
    },
  HostedAssign binder value body ->
    match checkedCoreExpr typeDecls recordDecls env localEnv fnContext value {
      CheckedCoreExprBuildError message ->
        CheckedCoreExprBuildError message,
      CheckedCoreExprBuilt valueArtifact ->
        match checkedCoreExpr typeDecls recordDecls env localEnv fnContext body {
          CheckedCoreExprBuilt bodyArtifact ->
            CheckedCoreExprBuilt (CheckedCoreAssignArtifact exprType binder valueArtifact bodyArtifact),
          CheckedCoreExprBuildError message ->
            CheckedCoreExprBuildError message
        }
    },
  HostedFor binder iterable loopBody body ->
    match checkedCoreExpr typeDecls recordDecls env localEnv fnContext iterable {
      CheckedCoreExprBuildError message ->
        CheckedCoreExprBuildError message,
      CheckedCoreExprBuilt iterableArtifact ->
        match checkedCoreExpr typeDecls recordDecls env (checkedCoreExtendLoopLocalEnv typeDecls recordDecls env localEnv fnContext binder iterable) fnContext loopBody {
          CheckedCoreExprBuildError message ->
            CheckedCoreExprBuildError message,
          CheckedCoreExprBuilt loopBodyArtifact ->
            match checkedCoreExpr typeDecls recordDecls env localEnv fnContext body {
              CheckedCoreExprBuilt bodyArtifact ->
                CheckedCoreExprBuilt (CheckedCoreForArtifact exprType binder iterableArtifact loopBodyArtifact bodyArtifact),
              CheckedCoreExprBuildError message ->
                CheckedCoreExprBuildError message
            }
        }
    },
  HostedReturn value ->
    match checkedCoreExpr typeDecls recordDecls env localEnv fnContext value {
      CheckedCoreExprBuilt valueArtifact ->
        CheckedCoreExprBuilt (CheckedCoreReturnArtifact exprType valueArtifact),
      CheckedCoreExprBuildError message ->
        CheckedCoreExprBuildError message
    },
  HostedIf condition thenBranch elseBranch ->
    match checkedCoreExpr typeDecls recordDecls env localEnv fnContext condition {
      CheckedCoreExprBuildError message ->
        CheckedCoreExprBuildError message,
      CheckedCoreExprBuilt conditionArtifact ->
        match checkedCoreExpr typeDecls recordDecls env localEnv fnContext thenBranch {
          CheckedCoreExprBuildError message ->
            CheckedCoreExprBuildError message,
          CheckedCoreExprBuilt thenArtifact ->
            match checkedCoreExpr typeDecls recordDecls env localEnv fnContext elseBranch {
              CheckedCoreExprBuilt elseArtifact ->
                CheckedCoreExprBuilt (CheckedCoreIfArtifact exprType conditionArtifact thenArtifact elseArtifact),
              CheckedCoreExprBuildError message ->
                CheckedCoreExprBuildError message
            }
        }
    },
  HostedEqual left right ->
    match checkedCoreExpr typeDecls recordDecls env localEnv fnContext left {
      CheckedCoreExprBuildError message ->
        CheckedCoreExprBuildError message,
      CheckedCoreExprBuilt leftArtifact ->
        match checkedCoreExpr typeDecls recordDecls env localEnv fnContext right {
          CheckedCoreExprBuilt rightArtifact ->
            CheckedCoreExprBuilt (CheckedCoreEqualArtifact leftArtifact rightArtifact),
          CheckedCoreExprBuildError message ->
            CheckedCoreExprBuildError message
        }
    },
  HostedNotEqual left right ->
    match checkedCoreExpr typeDecls recordDecls env localEnv fnContext left {
      CheckedCoreExprBuildError message ->
        CheckedCoreExprBuildError message,
      CheckedCoreExprBuilt leftArtifact ->
        match checkedCoreExpr typeDecls recordDecls env localEnv fnContext right {
          CheckedCoreExprBuilt rightArtifact ->
            CheckedCoreExprBuilt (CheckedCoreNotEqualArtifact leftArtifact rightArtifact),
          CheckedCoreExprBuildError message ->
            CheckedCoreExprBuildError message
        }
    },
  HostedLessThan left right ->
    match checkedCoreExpr typeDecls recordDecls env localEnv fnContext left {
      CheckedCoreExprBuildError message ->
        CheckedCoreExprBuildError message,
      CheckedCoreExprBuilt leftArtifact ->
        match checkedCoreExpr typeDecls recordDecls env localEnv fnContext right {
          CheckedCoreExprBuilt rightArtifact ->
            CheckedCoreExprBuilt (CheckedCoreLessThanArtifact leftArtifact rightArtifact),
          CheckedCoreExprBuildError message ->
            CheckedCoreExprBuildError message
        }
    },
  HostedLessThanOrEqual left right ->
    match checkedCoreExpr typeDecls recordDecls env localEnv fnContext left {
      CheckedCoreExprBuildError message ->
        CheckedCoreExprBuildError message,
      CheckedCoreExprBuilt leftArtifact ->
        match checkedCoreExpr typeDecls recordDecls env localEnv fnContext right {
          CheckedCoreExprBuilt rightArtifact ->
            CheckedCoreExprBuilt (CheckedCoreLessThanOrEqualArtifact leftArtifact rightArtifact),
          CheckedCoreExprBuildError message ->
            CheckedCoreExprBuildError message
        }
    },
  HostedGreaterThan left right ->
    match checkedCoreExpr typeDecls recordDecls env localEnv fnContext left {
      CheckedCoreExprBuildError message ->
        CheckedCoreExprBuildError message,
      CheckedCoreExprBuilt leftArtifact ->
        match checkedCoreExpr typeDecls recordDecls env localEnv fnContext right {
          CheckedCoreExprBuilt rightArtifact ->
            CheckedCoreExprBuilt (CheckedCoreGreaterThanArtifact leftArtifact rightArtifact),
          CheckedCoreExprBuildError message ->
            CheckedCoreExprBuildError message
        }
    },
  HostedGreaterThanOrEqual left right ->
    match checkedCoreExpr typeDecls recordDecls env localEnv fnContext left {
      CheckedCoreExprBuildError message ->
        CheckedCoreExprBuildError message,
      CheckedCoreExprBuilt leftArtifact ->
        match checkedCoreExpr typeDecls recordDecls env localEnv fnContext right {
          CheckedCoreExprBuilt rightArtifact ->
            CheckedCoreExprBuilt (CheckedCoreGreaterThanOrEqualArtifact leftArtifact rightArtifact),
          CheckedCoreExprBuildError message ->
            CheckedCoreExprBuildError message
        }
    }
}

checkedCoreDecl : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [TypeBinding] -> HostedDeclAst -> CheckedCoreDeclBuildResult
checkedCoreDecl typeDecls recordDecls env decl = match inferDecl typeDecls recordDecls env decl {
  InferDeclError message ->
    CheckedCoreDeclBuildError message,
  InferredDecl binding ->
    match binding {
      TypeBinding bindingName bindingType ->
        match checkedCoreExpr typeDecls recordDecls env (checkedCoreFunctionLocalEnv decl) (checkedCoreFunctionContext decl) (declBody decl) {
          CheckedCoreExprBuilt bodyArtifact ->
            CheckedCoreDeclBuilt (CheckedCoreDeclArtifact (declName decl) bindingType (checkedCoreParamArtifacts decl) bodyArtifact),
          CheckedCoreExprBuildError message ->
            CheckedCoreDeclBuildError message
        }
    }
}

checkedCoreDecls : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [TypeBinding] -> [HostedDeclAst] -> CheckedCoreDeclListBuildResult
checkedCoreDecls typeDecls recordDecls env decls = {
  let mut state = CheckedCoreDeclListBuilt emptyCheckedCoreDeclArtifacts;
  for decl in decls {
    state = match state {
      CheckedCoreDeclListBuildError message ->
        CheckedCoreDeclListBuildError message,
      CheckedCoreDeclListBuilt artifacts ->
        match checkedCoreDecl typeDecls recordDecls env decl {
          CheckedCoreDeclBuilt artifact ->
            CheckedCoreDeclListBuilt (appendCheckedCoreDeclArtifact artifacts artifact),
          CheckedCoreDeclBuildError message ->
            CheckedCoreDeclListBuildError message
        }
    };
    state
  };
  state
}

checkedCoreArtifactResult : HostedModuleAst -> CheckedCoreArtifactResult
checkedCoreArtifactResult modl = match inferModuleBindings modl {
  InferModuleError message ->
    CheckedCoreArtifactError message,
  InferredModule env -> {
    let typeDecls = effectiveModuleTypeDecls modl;
    let recordDecls = effectiveModuleRecordDecls modl;
    match checkedCoreDecls typeDecls recordDecls env (moduleDeclarations modl) {
      CheckedCoreDeclListBuilt artifacts ->
        CheckedCoreArtifactOk artifacts,
      CheckedCoreDeclListBuildError message ->
        CheckedCoreArtifactError message
    }
  }
}

renderTaggedObject0 : Str -> Str
renderTaggedObject0 tag = jsonObject [jsonFieldText "$tag" tag]

renderTaggedObject1 : Str -> Str -> Str
renderTaggedObject1 tag value0 = jsonObject [jsonFieldText "$tag" tag, jsonFieldRaw "$0" value0]

renderTaggedObject2 : Str -> Str -> Str -> Str
renderTaggedObject2 tag value0 value1 = jsonObject [jsonFieldText "$tag" tag, jsonFieldRaw "$0" value0, jsonFieldRaw "$1" value1]

renderTaggedObject3 : Str -> Str -> Str -> Str -> Str
renderTaggedObject3 tag value0 value1 value2 = jsonObject [jsonFieldText "$tag" tag, jsonFieldRaw "$0" value0, jsonFieldRaw "$1" value1, jsonFieldRaw "$2" value2]

renderTaggedObject4 : Str -> Str -> Str -> Str -> Str -> Str
renderTaggedObject4 tag value0 value1 value2 value3 = jsonObject [jsonFieldText "$tag" tag, jsonFieldRaw "$0" value0, jsonFieldRaw "$1" value1, jsonFieldRaw "$2" value2, jsonFieldRaw "$3" value3]

renderTaggedObject5 : Str -> Str -> Str -> Str -> Str -> Str -> Str
renderTaggedObject5 tag value0 value1 value2 value3 value4 = jsonObject [jsonFieldText "$tag" tag, jsonFieldRaw "$0" value0, jsonFieldRaw "$1" value1, jsonFieldRaw "$2" value2, jsonFieldRaw "$3" value3, jsonFieldRaw "$4" value4]

renderCheckedCoreTypeJsonList : [TypeText] -> [Str]
renderCheckedCoreTypeJsonList values = {
  let mut rendered = emptyCheckedCoreRenderedTexts;
  for value in values {
    rendered = append rendered [renderCheckedCoreTypeJson value];
    rendered
  };
  rendered
}

renderCheckedCoreTypeJson : TypeText -> Str
renderCheckedCoreTypeJson value = match value {
  TInt ->
    renderTaggedObject0 "TInt",
  TStr ->
    renderTaggedObject0 "TStr",
  TBool ->
    renderTaggedObject0 "TBool",
  TList itemType ->
    renderTaggedObject1 "TList" (renderCheckedCoreTypeJson itemType),
  TFunction inputType resultType ->
    renderTaggedObject2 "TFunction" (renderCheckedCoreTypeJson inputType) (renderCheckedCoreTypeJson resultType),
  TNamed label ->
    renderTaggedObject1 "TNamed" (encode label),
  TApply label args ->
    renderTaggedObject2 "TApply" (encode label) (renderJsonArray (renderCheckedCoreTypeJsonList args)),
  TVar label ->
    renderTaggedObject1 "TVar" (encode label),
  TUnknown label ->
    renderTaggedObject1 "TUnknown" (encode label)
}

renderCheckedCoreParamJson : CheckedCoreParamArtifact -> Str
renderCheckedCoreParamJson param = match param {
  CheckedCoreParamArtifact name paramType ->
    renderTaggedObject2 "CheckedCoreParamArtifact" (encode name) (renderCheckedCoreTypeJson paramType)
}

renderCheckedCoreParamJsonList : [CheckedCoreParamArtifact] -> [Str]
renderCheckedCoreParamJsonList values = {
  let mut rendered = emptyCheckedCoreRenderedTexts;
  for value in values {
    rendered = append rendered [renderCheckedCoreParamJson value];
    rendered
  };
  rendered
}

renderCheckedCorePatternBinderJson : CheckedCorePatternBinderArtifact -> Str
renderCheckedCorePatternBinderJson binder = match binder {
  CheckedCorePatternBinderArtifact name binderType ->
    renderTaggedObject2 "CheckedCorePatternBinderArtifact" (encode name) (renderCheckedCoreTypeJson binderType)
}

renderCheckedCorePatternBinderJsonList : [CheckedCorePatternBinderArtifact] -> [Str]
renderCheckedCorePatternBinderJsonList values = {
  let mut rendered = emptyCheckedCoreRenderedTexts;
  for value in values {
    rendered = append rendered [renderCheckedCorePatternBinderJson value];
    rendered
  };
  rendered
}

renderCheckedCorePatternJson : CheckedCorePatternArtifact -> Str
renderCheckedCorePatternJson pattern = match pattern {
  CheckedCoreConstructorPatternArtifact constructorName binders ->
    renderTaggedObject2 "CheckedCoreConstructorPatternArtifact" (encode constructorName) (renderJsonArray (renderCheckedCorePatternBinderJsonList binders))
}

renderCheckedCoreRecordFieldJson : CheckedCoreRecordFieldArtifact -> Str
renderCheckedCoreRecordFieldJson field = match field {
  CheckedCoreRecordFieldArtifact name value ->
    renderTaggedObject2 "CheckedCoreRecordFieldArtifact" (encode name) (renderCheckedCoreExprJson value)
}

renderCheckedCoreRecordFieldJsonList : [CheckedCoreRecordFieldArtifact] -> [Str]
renderCheckedCoreRecordFieldJsonList values = {
  let mut rendered = emptyCheckedCoreRenderedTexts;
  for value in values {
    rendered = append rendered [renderCheckedCoreRecordFieldJson value];
    rendered
  };
  rendered
}

renderCheckedCoreMatchBranchJson : CheckedCoreMatchBranchArtifact -> Str
renderCheckedCoreMatchBranchJson branch = match branch {
  CheckedCoreMatchBranchArtifact pattern body ->
    renderTaggedObject2 "CheckedCoreMatchBranchArtifact" (renderCheckedCorePatternJson pattern) (renderCheckedCoreExprJson body)
}

renderCheckedCoreMatchBranchJsonList : [CheckedCoreMatchBranchArtifact] -> [Str]
renderCheckedCoreMatchBranchJsonList values = {
  let mut rendered = emptyCheckedCoreRenderedTexts;
  for value in values {
    rendered = append rendered [renderCheckedCoreMatchBranchJson value];
    rendered
  };
  rendered
}

renderCheckedCoreExprJsonList : [CheckedCoreExprArtifact] -> [Str]
renderCheckedCoreExprJsonList values = {
  let mut rendered = emptyCheckedCoreRenderedTexts;
  for value in values {
    rendered = append rendered [renderCheckedCoreExprJson value];
    rendered
  };
  rendered
}

renderCheckedCoreExprJson : CheckedCoreExprArtifact -> Str
renderCheckedCoreExprJson expr = match expr {
  CheckedCoreVarArtifact exprType name ->
    renderTaggedObject2 "CheckedCoreVarArtifact" (renderCheckedCoreTypeJson exprType) (encode name),
  CheckedCoreIntArtifact value ->
    renderTaggedObject1 "CheckedCoreIntArtifact" (encode value),
  CheckedCoreStringArtifact value ->
    renderTaggedObject1 "CheckedCoreStringArtifact" (encode value),
  CheckedCoreBoolArtifact value ->
    renderTaggedObject1 "CheckedCoreBoolArtifact" (if value then "true" else "false"),
  CheckedCoreListArtifact exprType values ->
    renderTaggedObject2 "CheckedCoreListArtifact" (renderCheckedCoreTypeJson exprType) (renderJsonArray (renderCheckedCoreExprJsonList values)),
  CheckedCoreIfArtifact exprType condition thenBranch elseBranch ->
    renderTaggedObject4 "CheckedCoreIfArtifact" (renderCheckedCoreTypeJson exprType) (renderCheckedCoreExprJson condition) (renderCheckedCoreExprJson thenBranch) (renderCheckedCoreExprJson elseBranch),
  CheckedCoreReturnArtifact exprType value ->
    renderTaggedObject2 "CheckedCoreReturnArtifact" (renderCheckedCoreTypeJson exprType) (renderCheckedCoreExprJson value),
  CheckedCoreEqualArtifact left right ->
    renderTaggedObject2 "CheckedCoreEqualArtifact" (renderCheckedCoreExprJson left) (renderCheckedCoreExprJson right),
  CheckedCoreNotEqualArtifact left right ->
    renderTaggedObject2 "CheckedCoreNotEqualArtifact" (renderCheckedCoreExprJson left) (renderCheckedCoreExprJson right),
  CheckedCoreLessThanArtifact left right ->
    renderTaggedObject2 "CheckedCoreLessThanArtifact" (renderCheckedCoreExprJson left) (renderCheckedCoreExprJson right),
  CheckedCoreLessThanOrEqualArtifact left right ->
    renderTaggedObject2 "CheckedCoreLessThanOrEqualArtifact" (renderCheckedCoreExprJson left) (renderCheckedCoreExprJson right),
  CheckedCoreGreaterThanArtifact left right ->
    renderTaggedObject2 "CheckedCoreGreaterThanArtifact" (renderCheckedCoreExprJson left) (renderCheckedCoreExprJson right),
  CheckedCoreGreaterThanOrEqualArtifact left right ->
    renderTaggedObject2 "CheckedCoreGreaterThanOrEqualArtifact" (renderCheckedCoreExprJson left) (renderCheckedCoreExprJson right),
  CheckedCoreLetArtifact exprType binder value body ->
    renderTaggedObject4 "CheckedCoreLetArtifact" (renderCheckedCoreTypeJson exprType) (encode binder) (renderCheckedCoreExprJson value) (renderCheckedCoreExprJson body),
  CheckedCoreMutableLetArtifact exprType binder value body ->
    renderTaggedObject4 "CheckedCoreMutableLetArtifact" (renderCheckedCoreTypeJson exprType) (encode binder) (renderCheckedCoreExprJson value) (renderCheckedCoreExprJson body),
  CheckedCoreAssignArtifact exprType binder value body ->
    renderTaggedObject4 "CheckedCoreAssignArtifact" (renderCheckedCoreTypeJson exprType) (encode binder) (renderCheckedCoreExprJson value) (renderCheckedCoreExprJson body),
  CheckedCoreForArtifact exprType binder iterable loopBody body ->
    renderTaggedObject5 "CheckedCoreForArtifact" (renderCheckedCoreTypeJson exprType) (encode binder) (renderCheckedCoreExprJson iterable) (renderCheckedCoreExprJson loopBody) (renderCheckedCoreExprJson body),
  CheckedCoreCallArtifact exprType calleeName calleeType args ->
    renderTaggedObject4 "CheckedCoreCallArtifact" (renderCheckedCoreTypeJson exprType) (encode calleeName) (renderCheckedCoreTypeJson calleeType) (renderJsonArray (renderCheckedCoreExprJsonList args)),
  CheckedCoreMatchArtifact exprType subject branches ->
    renderTaggedObject3 "CheckedCoreMatchArtifact" (renderCheckedCoreTypeJson exprType) (renderCheckedCoreExprJson subject) (renderJsonArray (renderCheckedCoreMatchBranchJsonList branches)),
  CheckedCoreRecordArtifact exprType recordName fields ->
    renderTaggedObject3 "CheckedCoreRecordArtifact" (renderCheckedCoreTypeJson exprType) (encode recordName) (renderJsonArray (renderCheckedCoreRecordFieldJsonList fields)),
  CheckedCoreFieldAccessArtifact exprType subject fieldName ->
    renderTaggedObject3 "CheckedCoreFieldAccessArtifact" (renderCheckedCoreTypeJson exprType) (renderCheckedCoreExprJson subject) (encode fieldName)
}

renderCheckedCoreDeclJson : CheckedCoreDeclArtifact -> Str
renderCheckedCoreDeclJson decl = match decl {
  CheckedCoreDeclArtifact name declType params body ->
    renderTaggedObject4 "CheckedCoreDeclArtifact" (encode name) (renderCheckedCoreTypeJson declType) (renderJsonArray (renderCheckedCoreParamJsonList params)) (renderCheckedCoreExprJson body)
}

renderCheckedCoreDeclJsonList : [CheckedCoreDeclArtifact] -> [Str]
renderCheckedCoreDeclJsonList values = {
  let mut rendered = emptyCheckedCoreRenderedTexts;
  for value in values {
    rendered = append rendered [renderCheckedCoreDeclJson value];
    rendered
  };
  rendered
}

renderCheckedCoreArtifactResultJson : CheckedCoreArtifactResult -> Str
renderCheckedCoreArtifactResultJson result = match result {
  CheckedCoreArtifactOk decls ->
    renderTaggedObject1 "CheckedCoreArtifactOk" (renderJsonArray (renderCheckedCoreDeclJsonList decls)),
  CheckedCoreArtifactError message ->
    renderTaggedObject1 "CheckedCoreArtifactError" (encode message)
}

checkedCoreSourceJson : Str -> Str
checkedCoreSourceJson source = renderCheckedCoreArtifactResultJson (checkedCoreArtifactResult (parseModuleAst source))

-- CLASP_PROJECT_MODULE --
module Compiler.Json

type JsonField = JsonFieldRaw Str Str | JsonFieldText Str Str | JsonFieldArray Str [Str]

keepNoJsonRenderedText : Str -> Bool
keepNoJsonRenderedText value = false

emptyJsonRenderedTexts : [Str]
emptyJsonRenderedTexts = filter keepNoJsonRenderedText [""]

keepNoJsonField : JsonField -> Bool
keepNoJsonField field = false

emptyJsonFields : [JsonField]
emptyJsonFields = filter keepNoJsonField [JsonFieldRaw "" ""]

appendRenderedJson : [Str] -> Str -> [Str]
appendRenderedJson values value = append values [value]

renderJsonArray : [Str] -> Str
renderJsonArray values = textConcat ["[", textJoin ", " values, "]"]

renderJsonField : JsonField -> Str
renderJsonField field = match field {
  JsonFieldRaw name value ->
    textConcat [encode name, ": ", value],
  JsonFieldText name value ->
    textConcat [encode name, ": ", encode value],
  JsonFieldArray name values ->
    textConcat [encode name, ": ", renderJsonArray values]
}

renderJsonFields : [JsonField] -> [Str]
renderJsonFields fields = {
  let mut rendered = emptyJsonRenderedTexts;
  for field in fields {
    rendered = appendRenderedJson rendered (renderJsonField field);
    rendered
  };
  rendered
}

renderJsonObject : [JsonField] -> Str
renderJsonObject fields = textConcat ["{", textJoin ", " (renderJsonFields fields), "}"]

jsonObject : [JsonField] -> Str
jsonObject fields = renderJsonObject fields

jsonArray : [Str] -> Str
jsonArray values = renderJsonArray values

jsonFieldRaw : Str -> Str -> JsonField
jsonFieldRaw name value = JsonFieldRaw name value

jsonFieldText : Str -> Str -> JsonField
jsonFieldText name value = JsonFieldText name value

jsonFieldArray : Str -> [Str] -> JsonField
jsonFieldArray name values = JsonFieldArray name values

-- CLASP_PROJECT_MODULE --
module Compiler.Emit.JavaScript

import Compiler.Ast
import Compiler.Lower

appendJsRenderedText : [Str] -> Str -> [Str]
appendJsRenderedText values value = append values [value]

hasJsValues : [Str] -> Bool
hasJsValues values = {
  for value in values {
    return true
  };
  false
}

hasReturnInExprs : [LowerExprText] -> Bool
hasReturnInExprs exprs = {
  for expr in exprs {
    if emitExprContainsReturn expr then return true else false
  };
  false
}

jsBuiltinPreludeName : Str -> Bool
jsBuiltinPreludeName name = if name == "textConcat" then true else if name == "textJoin" then true else if name == "textSplit" then true else if name == "textChars" then true else if name == "textFingerprint64Hex" then true else if name == "textPrefix" then true else if name == "textSplitFirst" then true else if name == "dictEmpty" then true else if name == "dictSet" then true else if name == "dictGet" then true else if name == "dictHas" then true else if name == "dictRemove" then true else if name == "dictKeys" then true else if name == "dictValues" then true else if name == "pathJoin" then true else if name == "pathDirname" then true else if name == "pathBasename" then true else if name == "fileExists" then true else if name == "readFile" then true else if name == "runCommandJson" then true else false

exprsNeedBuiltinPrelude : [LowerExprText] -> Bool
exprsNeedBuiltinPrelude exprs = {
  for expr in exprs {
    if exprNeedsBuiltinPrelude expr then return true else false
  };
  false
}

recordFieldsNeedBuiltinPrelude : [LowerRecordFieldText] -> Bool
recordFieldsNeedBuiltinPrelude fields = {
  for field in fields {
    match field {
      LowerRecordFieldText name value ->
        if exprNeedsBuiltinPrelude value then return true else false
    }
  };
  false
}

branchesNeedBuiltinPrelude : [LowerMatchBranchText] -> Bool
branchesNeedBuiltinPrelude branches = {
  for branch in branches {
    match branch {
      LowerMatchBranchText constructorName binders body ->
        if exprNeedsBuiltinPrelude body then return true else false
    }
  };
  false
}

exprNeedsBuiltinPrelude : LowerExprText -> Bool
exprNeedsBuiltinPrelude expr = match expr {
  LowerName name ->
    false,
  LowerLiteral value ->
    false,
  LowerInt value ->
    false,
  LowerBool value ->
    false,
  LowerArray values ->
    exprsNeedBuiltinPrelude values,
  LowerListAppend left right ->
    if exprNeedsBuiltinPrelude left then true else exprNeedsBuiltinPrelude right,
  LowerListPrepend value values ->
    if exprNeedsBuiltinPrelude value then true else exprNeedsBuiltinPrelude values,
  LowerListReverse values ->
    exprNeedsBuiltinPrelude values,
  LowerLength value ->
    exprNeedsBuiltinPrelude value,
  LowerListMap callee values ->
    exprNeedsBuiltinPrelude values,
  LowerListFilter callee values ->
    exprNeedsBuiltinPrelude values,
  LowerListAny callee values ->
    exprNeedsBuiltinPrelude values,
  LowerListAll callee values ->
    exprNeedsBuiltinPrelude values,
  LowerListFold callee initial values ->
    if exprNeedsBuiltinPrelude initial then true else exprNeedsBuiltinPrelude values,
  LowerViewAppend left right ->
    if exprNeedsBuiltinPrelude left then true else exprNeedsBuiltinPrelude right,
  LowerEncode value ->
    exprNeedsBuiltinPrelude value,
  LowerDecode targetType value ->
    exprNeedsBuiltinPrelude value,
  LowerInvoke callee args ->
    if jsBuiltinPreludeName callee then true else exprsNeedBuiltinPrelude args,
  LowerConstructor constructorName args ->
    exprsNeedBuiltinPrelude args,
  LowerMatch subject branches ->
    if exprNeedsBuiltinPrelude subject then true else branchesNeedBuiltinPrelude branches,
  LowerRecord recordName fields ->
    recordFieldsNeedBuiltinPrelude fields,
  LowerFieldAccess recordName subject fieldName ->
    exprNeedsBuiltinPrelude subject,
  LowerLet binder value body ->
    if exprNeedsBuiltinPrelude value then true else exprNeedsBuiltinPrelude body,
  LowerMutableLet binder value body ->
    if exprNeedsBuiltinPrelude value then true else exprNeedsBuiltinPrelude body,
  LowerAssign binder value body ->
    if exprNeedsBuiltinPrelude value then true else exprNeedsBuiltinPrelude body,
  LowerFor binder iterable loopBody body ->
    if exprNeedsBuiltinPrelude iterable then true else if exprNeedsBuiltinPrelude loopBody then true else exprNeedsBuiltinPrelude body,
  LowerReturn value ->
    exprNeedsBuiltinPrelude value,
  LowerIf condition thenBranch elseBranch ->
    if exprNeedsBuiltinPrelude condition then true else if exprNeedsBuiltinPrelude thenBranch then true else exprNeedsBuiltinPrelude elseBranch,
  LowerEqual left right ->
    if exprNeedsBuiltinPrelude left then true else exprNeedsBuiltinPrelude right,
  LowerNotEqual left right ->
    if exprNeedsBuiltinPrelude left then true else exprNeedsBuiltinPrelude right,
  LowerLessThan left right ->
    if exprNeedsBuiltinPrelude left then true else exprNeedsBuiltinPrelude right,
  LowerLessThanOrEqual left right ->
    if exprNeedsBuiltinPrelude left then true else exprNeedsBuiltinPrelude right,
  LowerGreaterThan left right ->
    if exprNeedsBuiltinPrelude left then true else exprNeedsBuiltinPrelude right,
  LowerGreaterThanOrEqual left right ->
    if exprNeedsBuiltinPrelude left then true else exprNeedsBuiltinPrelude right
}

hasReturnInRecordFields : [LowerRecordFieldText] -> Bool
hasReturnInRecordFields fields = {
  for field in fields {
    match field {
      LowerRecordFieldText name value ->
        if emitExprContainsReturn value then return true else false
    }
  };
  false
}

hasReturnInMatchBranches : [LowerMatchBranchText] -> Bool
hasReturnInMatchBranches branches = {
  for branch in branches {
    match branch {
      LowerMatchBranchText constructorName binders body ->
        if emitExprContainsReturn body then return true else false
    }
  };
  false
}

emitExprContainsReturn : LowerExprText -> Bool
emitExprContainsReturn expr = match expr {
  LowerName name ->
    false,
  LowerLiteral value ->
    false,
  LowerInt value ->
    false,
  LowerBool value ->
    false,
  LowerArray values ->
    hasReturnInExprs values,
  LowerListAppend left right ->
    if emitExprContainsReturn left then true else emitExprContainsReturn right,
  LowerListPrepend value values ->
    if emitExprContainsReturn value then true else emitExprContainsReturn values,
  LowerListReverse values ->
    emitExprContainsReturn values,
  LowerLength value ->
    emitExprContainsReturn value,
  LowerListMap callee values ->
    emitExprContainsReturn values,
  LowerListFilter callee values ->
    emitExprContainsReturn values,
  LowerListAny callee values ->
    emitExprContainsReturn values,
  LowerListAll callee values ->
    emitExprContainsReturn values,
  LowerListFold callee initial values ->
    if emitExprContainsReturn initial then true else emitExprContainsReturn values,
  LowerViewAppend left right ->
    if emitExprContainsReturn left then true else emitExprContainsReturn right,
  LowerEncode value ->
    emitExprContainsReturn value,
  LowerDecode targetType value ->
    emitExprContainsReturn value,
  LowerInvoke callee args ->
    hasReturnInExprs args,
  LowerConstructor constructorName args ->
    hasReturnInExprs args,
  LowerMatch subject branches ->
    if emitExprContainsReturn subject then true else hasReturnInMatchBranches branches,
  LowerRecord recordName fields ->
    hasReturnInRecordFields fields,
  LowerFieldAccess recordName subject fieldName ->
    emitExprContainsReturn subject,
  LowerLet binder value body ->
    if emitExprContainsReturn value then true else emitExprContainsReturn body,
  LowerMutableLet binder value body ->
    if emitExprContainsReturn value then true else emitExprContainsReturn body,
  LowerAssign binder value body ->
    if emitExprContainsReturn value then true else emitExprContainsReturn body,
  LowerFor binder iterable loopBody body ->
    if emitExprContainsReturn iterable then true else if emitExprContainsReturn loopBody then true else emitExprContainsReturn body,
  LowerReturn value ->
    true,
  LowerIf condition thenBranch elseBranch ->
    if emitExprContainsReturn condition then true else if emitExprContainsReturn thenBranch then true else emitExprContainsReturn elseBranch,
  LowerEqual left right ->
    if emitExprContainsReturn left then true else emitExprContainsReturn right,
  LowerNotEqual left right ->
    if emitExprContainsReturn left then true else emitExprContainsReturn right,
  LowerLessThan left right ->
    if emitExprContainsReturn left then true else emitExprContainsReturn right,
  LowerLessThanOrEqual left right ->
    if emitExprContainsReturn left then true else emitExprContainsReturn right,
  LowerGreaterThan left right ->
    if emitExprContainsReturn left then true else emitExprContainsReturn right,
  LowerGreaterThanOrEqual left right ->
    if emitExprContainsReturn left then true else emitExprContainsReturn right
}

emitExprs : [LowerExprText] -> [Str]
emitExprs exprs = {
  let mut rendered = emptyRenderedTexts;
  for expr in exprs {
    rendered = appendJsRenderedText rendered (emitExpr expr);
    rendered
  };
  rendered
}

emitRecordFields : [LowerRecordFieldText] -> [Str]
emitRecordFields fields = {
  let mut rendered = emptyRenderedTexts;
  for field in fields {
    rendered = appendJsRenderedText rendered (emitRecordField field);
    rendered
  };
  rendered
}

emitRecordField : LowerRecordFieldText -> Str
emitRecordField field = match field {
  LowerRecordFieldText name value ->
    textConcat [name, ": ", emitExpr value]
}

emitMatchBranchLines : LowerMatchBranchText -> [Str]
emitMatchBranchLines branch = match branch {
  LowerMatchBranchText constructorName binders body ->
    if hasJsValues binders then [textConcat ["  if (__match[0] === \"", constructorName, "\") {"], textConcat ["    const [_, ", textJoin ", " binders, "] = __match;"], textConcat ["    return ", emitExpr body, ";"], "  }"] else [textConcat ["  if (__match[0] === \"", constructorName, "\") {"], textConcat ["    return ", emitExpr body, ";"], "  }"]
}

emitMatchBranchBlocks : [LowerMatchBranchText] -> [Str]
emitMatchBranchBlocks branches = {
  let mut rendered = emptyRenderedTexts;
  for branch in branches {
    rendered = append rendered (emitMatchBranchLines branch);
    rendered
  };
  rendered
}

emitExpr : LowerExprText -> Str
emitExpr expr = match expr {
  LowerName name ->
    name,
  LowerLiteral value ->
    encode value,
  LowerInt value ->
    value,
  LowerBool value ->
    if value then "true" else "false",
  LowerArray values ->
    textConcat ["[", textJoin ", " (emitExprs values), "]"],
  LowerListAppend left right ->
    textConcat ["(", emitExpr left, ").concat(", emitExpr right, ")"],
  LowerListPrepend value values ->
    textConcat ["[", emitExpr value, "].concat(", emitExpr values, ")"],
  LowerListReverse values ->
    textConcat ["(() => { const __values = ", emitExpr values, "; return Object.freeze([...__values].reverse()); })()"],
  LowerLength value ->
    textConcat ["(", emitExpr value, ").length"],
  LowerListMap callee values ->
    textConcat ["Object.freeze((", emitExpr values, ").map(($item) => ", callee, "($item)))"],
  LowerListFilter callee values ->
    textConcat ["Object.freeze((", emitExpr values, ").filter(($item) => ", callee, "($item)))"],
  LowerListAny callee values ->
    textConcat ["(", emitExpr values, ").some(($item) => ", callee, "($item))"],
  LowerListAll callee values ->
    textConcat ["(", emitExpr values, ").every(($item) => ", callee, "($item))"],
  LowerListFold callee initial values ->
    textJoin "\n" ["(() => {", textConcat ["  let __acc = ", emitExpr initial, ";"], textConcat ["  for (const __item of ", emitExpr values, ") {"], textConcat ["    __acc = ", callee, "(__acc, __item);"], "  }", "  return __acc;", "})()"],
  LowerViewAppend left right ->
    textConcat ["Object.freeze({ $kind: \"append\", left: ", emitExpr left, ", right: ", emitExpr right, " })"],
  LowerEncode value ->
    textConcat ["JSON.stringify(", emitExpr value, ")"],
  LowerDecode targetType value ->
    textConcat ["JSON.parse(", emitExpr value, ")"],
  LowerIf condition thenBranch elseBranch ->
    textJoin "\n" ["(() => {", textConcat ["  if (", emitExpr condition, ") {"], textConcat ["    return ", emitExpr thenBranch, ";"], "  }", textConcat ["  return ", emitExpr elseBranch, ";"], "})()"],
  LowerEqual left right ->
    textConcat ["(", emitExpr left, " === ", emitExpr right, ")"],
  LowerNotEqual left right ->
    textConcat ["(", emitExpr left, " !== ", emitExpr right, ")"],
  LowerLessThan left right ->
    textConcat ["(", emitExpr left, " < ", emitExpr right, ")"],
  LowerLessThanOrEqual left right ->
    textConcat ["(", emitExpr left, " <= ", emitExpr right, ")"],
  LowerGreaterThan left right ->
    textConcat ["(", emitExpr left, " > ", emitExpr right, ")"],
  LowerGreaterThanOrEqual left right ->
    textConcat ["(", emitExpr left, " >= ", emitExpr right, ")"],
  LowerInvoke callee args ->
    textConcat [callee, "(", textJoin ", " (emitExprs args), ")"],
  LowerConstructor constructorName args -> {
    let renderedArgs = emitExprs args;
    if hasJsValues renderedArgs then textConcat ["[\"", constructorName, "\", ", textJoin ", " renderedArgs, "]"] else textConcat ["[\"", constructorName, "\"]"]
  },
  LowerMatch subject branches ->
    textJoin "\n" (append ["(() => {", textConcat ["  const __match = ", emitExpr subject, ";"]] (append (emitMatchBranchBlocks branches) ["  return undefined;", "})()"])),
  LowerRecord recordName fields ->
    textConcat ["{ ", textJoin ", " (emitRecordFields fields), " }"],
  LowerFieldAccess recordName subject fieldName ->
    textConcat ["(", emitExpr subject, ").", fieldName],
  LowerLet binder value body ->
    textJoin "\n" ["(() => {", textConcat ["  const ", binder, " = ", emitExpr value, ";"], textConcat ["  return ", emitExpr body, ";"], "})()"],
  LowerMutableLet binder value body ->
    textJoin "\n" ["(() => {", textConcat ["  let ", binder, " = ", emitExpr value, ";"], textConcat ["  return ", emitExpr body, ";"], "})()"],
  LowerAssign binder value body ->
    textJoin "\n" ["(() => {", textConcat ["  ", binder, " = ", emitExpr value, ";"], textConcat ["  return ", emitExpr body, ";"], "})()"],
  LowerFor binder iterable loopBody body ->
    textJoin "\n" ["(() => {", textConcat ["  for (const ", binder, " of ", emitExpr iterable, ") {"], textConcat ["    ", emitExpr loopBody, ";"], "  }", textConcat ["  return ", emitExpr body, ";"], "})()"],
  LowerReturn value ->
    textJoin "\n" ["(() => {", textConcat ["  throw $claspEarlyReturn(", emitExpr value, ");"], "})()"]
}

emitDecl : LowerDeclText -> Str
emitDecl decl = match decl {
  LowerConst name body ->
    textConcat ["export const ", name, " = ", emitExpr body, ";"],
  LowerFn name params body ->
    if emitExprContainsReturn body then textJoin "\n" [textConcat ["export function ", name, "(", textJoin ", " params, ") {"], "  try {", textConcat ["    return ", emitExpr body, ";"], "  } catch (error) {", "    if (error && error.$claspEarlyReturn === true) {", "      return error.value;", "    }", "    throw error;", "  }", "}"] else textConcat ["export function ", name, "(", textJoin ", " params, ") { return ", emitExpr body, "; }"]
}

moduleHasReturn : [LowerDeclText] -> Bool
moduleHasReturn decls = {
  for decl in decls {
    match decl {
      LowerConst name body ->
        if emitExprContainsReturn body then return true else false,
      LowerFn name params body ->
        if emitExprContainsReturn body then return true else false
    }
  };
  false
}

emitEarlyReturnPrelude : [LowerDeclText] -> [Str]
emitEarlyReturnPrelude decls = if moduleHasReturn decls then ["function $claspEarlyReturn(value) {", "  return { $claspEarlyReturn: true, value };", "}"] else emptyRenderedTexts

moduleNeedsBuiltinPrelude : [LowerDeclText] -> Bool
moduleNeedsBuiltinPrelude decls = {
  for decl in decls {
    match decl {
      LowerConst name body ->
        if exprNeedsBuiltinPrelude body then return true else false,
      LowerFn name params body ->
        if exprNeedsBuiltinPrelude body then return true else false
    }
  };
  false
}

builtinPreludeLines : [Str]
builtinPreludeLines =
  [
    "function $claspNormalizePathSegments(parts, path = \"parts\") {",
    "  if (!Array.isArray(parts)) {",
    "    throw new Error(`${path} expected a list of strings`);",
    "  }",
    "  return parts.map((part, index) => {",
    "    if (typeof part !== \"string\") {",
    "      throw new Error(`${path}[${index}] expected a string`);",
    "    }",
    "    return part;",
    "  });",
    "}",
    "function $claspNormalizePath(value) {",
    "  if (typeof value !== \"string\") {",
    "    throw new Error(`path expected a string`);",
    "  }",
    "  const trimmed = value.replace(/\\\\+/g, \"/\");",
    "  const collapsed = trimmed.replace(/\\/+/g, \"/\");",
    "  return collapsed === \"\" ? \".\" : collapsed;",
    "}",
    "function $claspHostRuntime(name) {",
    "  const runtime = globalThis.__claspRuntime;",
    "  if (!runtime || !(name in runtime)) {",
    "    throw new Error(`Missing Clasp runtime binding: ${name}`);",
    "  }",
    "  return runtime[name];",
    "}",
    "const $claspBuiltinRuntime = Object.freeze({",
    "  textConcat(parts) {",
    "    return $claspNormalizePathSegments(parts, \"parts\").join(\"\");",
    "  },",
    "  textJoin(separator, parts) {",
    "    if (typeof separator !== \"string\") {",
    "      throw new Error(`separator expected a string`);",
    "    }",
    "    return $claspNormalizePathSegments(parts, \"parts\").join(separator);",
    "  },",
    "  textSplit(value, separator) {",
    "    if (typeof value !== \"string\") {",
    "      throw new Error(`value expected a string`);",
    "    }",
    "    if (typeof separator !== \"string\") {",
    "      throw new Error(`separator expected a string`);",
    "    }",
    "    return Object.freeze(value.split(separator));",
    "  },",
    "  textChars(value) {",
    "    if (typeof value !== \"string\") {",
    "      throw new Error(`value expected a string`);",
    "    }",
    "    return Object.freeze(Array.from(value));",
    "  },",
    "  textFingerprint64Hex(value) {",
    "    if (typeof value !== \"string\") {",
    "      throw new Error(`value expected a string`);",
    "    }",
    "    const bytes = new TextEncoder().encode(value);",
    "    let hash = 14695981039346656037n;",
    "    const prime = 1099511628211n;",
    "    const mask = 0xffffffffffffffffn;",
    "    for (const byte of bytes) {",
    "      hash = (hash ^ BigInt(byte)) * prime;",
    "      hash &= mask;",
    "    }",
    "    return hash.toString(16).padStart(16, \"0\");",
    "  },",
    "  textPrefix(value, prefix) {",
    "    if (typeof value !== \"string\") {",
    "      throw new Error(`value expected a string`);",
    "    }",
    "    if (typeof prefix !== \"string\") {",
    "      throw new Error(`prefix expected a string`);",
    "    }",
    "    return value.startsWith(prefix)",
    "      ? [\"Ok\", value.slice(prefix.length)]",
    "      : [\"Err\", value];",
    "  },",
    "  textSplitFirst(value, separator) {",
    "    if (typeof value !== \"string\") {",
    "      throw new Error(`value expected a string`);",
    "    }",
    "    if (typeof separator !== \"string\") {",
    "      throw new Error(`separator expected a string`);",
    "    }",
    "    const index = value.indexOf(separator);",
    "    return index < 0",
    "      ? [\"Err\", value]",
    "      : [\"Ok\", value.slice(0, index) + \"\\n\" + value.slice(index + separator.length)];",
    "  },",
    "  dictEmpty() {",
    "    return Object.freeze({});",
    "  },",
    "  dictSet(key, value, dict) {",
    "    if (typeof key !== \"string\") {",
    "      throw new Error(`key expected a string`);",
    "    }",
    "    const objectValue = $claspExpectObject(dict, \"dict\");",
    "    return Object.freeze({ ...objectValue, [key]: $claspSnapshotValue(value) });",
    "  },",
    "  dictGet(key, dict) {",
    "    if (typeof key !== \"string\") {",
    "      throw new Error(`key expected a string`);",
    "    }",
    "    const objectValue = $claspExpectObject(dict, \"dict\");",
    "    return Object.prototype.hasOwnProperty.call(objectValue, key)",
    "      ? Object.freeze({ $tag: \"Ok\", $0: $claspSnapshotValue(objectValue[key]) })",
    "      : Object.freeze({ $tag: \"Err\", $0: `Missing dict key: ${key}` });",
    "  },",
    "  dictHas(key, dict) {",
    "    if (typeof key !== \"string\") {",
    "      throw new Error(`key expected a string`);",
    "    }",
    "    const objectValue = $claspExpectObject(dict, \"dict\");",
    "    return Object.prototype.hasOwnProperty.call(objectValue, key);",
    "  },",
    "  dictRemove(key, dict) {",
    "    if (typeof key !== \"string\") {",
    "      throw new Error(`key expected a string`);",
    "    }",
    "    const objectValue = $claspExpectObject(dict, \"dict\");",
    "    const next = { ...objectValue };",
    "    delete next[key];",
    "    return Object.freeze(next);",
    "  },",
    "  dictKeys(dict) {",
    "    return Object.freeze(Object.keys($claspExpectObject(dict, \"dict\")));",
    "  },",
    "  dictValues(dict) {",
    "    return Object.freeze(Object.values($claspExpectObject(dict, \"dict\")).map((value) => $claspSnapshotValue(value)));",
    "  },",
    "  pathJoin(parts) {",
    "    const normalized = $claspNormalizePathSegments(parts, \"parts\")",
    "      .filter((part) => part !== \"\")",
    "      .join(\"/\");",
    "    return $claspNormalizePath(normalized);",
    "  },",
    "  pathDirname(path) {",
    "    const normalized = $claspNormalizePath(path);",
    "    if (normalized === \"/\") {",
    "      return \"/\";",
    "    }",
    "    const trimmed = normalized.endsWith(\"/\") && normalized.length > 1 ? normalized.slice(0, -1) : normalized;",
    "    const index = trimmed.lastIndexOf(\"/\");",
    "    if (index < 0) {",
    "      return \".\";",
    "    }",
    "    if (index === 0) {",
    "      return \"/\";",
    "    }",
    "    return trimmed.slice(0, index);",
    "  },",
    "  pathBasename(path) {",
    "    const normalized = $claspNormalizePath(path);",
    "    if (normalized === \"/\") {",
    "      return \"/\";",
    "    }",
    "    const trimmed = normalized.endsWith(\"/\") && normalized.length > 1 ? normalized.slice(0, -1) : normalized;",
    "    const index = trimmed.lastIndexOf(\"/\");",
    "    return index < 0 ? trimmed : trimmed.slice(index + 1);",
    "  }",
    "});",
    "function textConcat($0) { return $claspBuiltinRuntime.textConcat($0); }",
    "function textJoin($0, $1) { return $claspBuiltinRuntime.textJoin($0, $1); }",
    "function textSplit($0, $1) { return $claspBuiltinRuntime.textSplit($0, $1); }",
    "function textChars($0) { return $claspBuiltinRuntime.textChars($0); }",
    "function textFingerprint64Hex($0) { return $claspBuiltinRuntime.textFingerprint64Hex($0); }",
    "function textPrefix($0, $1) { return $claspBuiltinRuntime.textPrefix($0, $1); }",
    "function textSplitFirst($0, $1) { return $claspBuiltinRuntime.textSplitFirst($0, $1); }",
    "const dictEmpty = $claspBuiltinRuntime.dictEmpty();",
    "function dictSet($0, $1, $2) { return $claspBuiltinRuntime.dictSet($0, $1, $2); }",
    "function dictGet($0, $1) { return $claspBuiltinRuntime.dictGet($0, $1); }",
    "function dictHas($0, $1) { return $claspBuiltinRuntime.dictHas($0, $1); }",
    "function dictRemove($0, $1) { return $claspBuiltinRuntime.dictRemove($0, $1); }",
    "function dictKeys($0) { return $claspBuiltinRuntime.dictKeys($0); }",
    "function dictValues($0) { return $claspBuiltinRuntime.dictValues($0); }",
    "function pathJoin($0) { return $claspBuiltinRuntime.pathJoin($0); }",
    "function pathDirname($0) { return $claspBuiltinRuntime.pathDirname($0); }",
    "function pathBasename($0) { return $claspBuiltinRuntime.pathBasename($0); }",
    "function fileExists($0) { return $claspHostRuntime(\"fileExists\")($0); }",
    "function readFile($0) { return $claspHostRuntime(\"readFile\")($0); }",
    "function runCommandJson($0, $1) { return $claspHostRuntime(\"runCommandJson\")($0, $1); }"
  ]

emitBuiltinPrelude : [LowerDeclText] -> [Str]
emitBuiltinPrelude decls = if moduleNeedsBuiltinPrelude decls then builtinPreludeLines else emptyRenderedTexts

defaultForeignParamNames : [Str]
defaultForeignParamNames = ["arg0", "arg1", "arg2", "arg3", "arg4", "arg5"]

hasForeignDecls : [HostedForeignDeclAst] -> Bool
hasForeignDecls foreignDecls = {
  for foreignDecl in foreignDecls {
    return true
  };
  false
}

emitForeignParamsFromType : HostedTypeAst -> [Str] -> [Str]
emitForeignParamsFromType typ availableNames = match typ {
  HostedTypeFunction input result ->
    append [firstText availableNames] (emitForeignParamsFromType result (remainingTexts availableNames)),
  HostedTypeName name ->
    emptyRenderedTexts,
  HostedTypeApply name args ->
    emptyRenderedTexts,
  HostedTypeVar name ->
    emptyRenderedTexts,
  HostedTypeList itemType ->
    emptyRenderedTexts
}

emitForeignParams : HostedForeignDeclAst -> [Str]
emitForeignParams foreignDecl = emitForeignParamsFromType (foreignDeclTypeAst foreignDecl) defaultForeignParamNames

emitForeignReturnType : HostedTypeAst -> HostedTypeAst
emitForeignReturnType typ = match typ {
  HostedTypeFunction input result ->
    emitForeignReturnType result,
  HostedTypeName name ->
    typ,
  HostedTypeApply name args ->
    typ,
  HostedTypeVar name ->
    typ,
  HostedTypeList itemType ->
    typ
}

packageBindingIdentifier : HostedForeignDeclAst -> Str
packageBindingIdentifier foreignDecl = textConcat ["$claspPackageBinding_", foreignDeclName foreignDecl]

emitHostedPackageImportKind : HostedPackageImportKindAst -> Str
emitHostedPackageImportKind kind = match kind {
  HostedPackageImportNpm ->
    "npm",
  HostedPackageImportTypeScript ->
    "typescript"
}

emitForeignSourceLiteral : HostedForeignDeclAst -> Str
emitForeignSourceLiteral foreignDecl = match foreignDeclSource foreignDecl {
  HostedForeignPackageImport kind specifier declarationPath ->
    textConcat ["{ kind: \"", emitHostedPackageImportKind kind, "\", specifier: \"", specifier, "\" }"],
  HostedForeignRuntime ->
    "null"
}

emitForeignDeclarationLiteral : HostedForeignDeclAst -> Str
emitForeignDeclarationLiteral foreignDecl = match foreignDeclSource foreignDecl {
  HostedForeignPackageImport kind specifier declarationPath ->
    if foreignDeclSignature foreignDecl == "" then textConcat ["{ path: \"", declarationPath, "\", signature: null }"] else textConcat ["{ path: \"", declarationPath, "\", signature: \"", foreignDeclSignature foreignDecl, "\" }"],
  HostedForeignRuntime ->
    "null"
}

emitIdentityHostCodec : HostedTypeAst -> Str -> Str
emitIdentityHostCodec typ mode = if mode == "from" then textConcat ["{ type: \"", renderHostedType typ, "\", fromHost(value, path = \"value\") { return value; }, toHost(value, path = \"value\") { return value; } }"] else textConcat ["{ type: \"", renderHostedType typ, "\", fromHost(value, path = \"result\") { return value; }, toHost(value, path = \"result\") { return value; } }"]

emitForeignParamCodecsFromType : HostedTypeAst -> [Str]
emitForeignParamCodecsFromType typ = match typ {
  HostedTypeFunction input result ->
    append [emitIdentityHostCodec input "from"] (emitForeignParamCodecsFromType result),
  HostedTypeName name ->
    emptyRenderedTexts,
  HostedTypeApply name args ->
    emptyRenderedTexts,
  HostedTypeVar name ->
    emptyRenderedTexts,
  HostedTypeList itemType ->
    emptyRenderedTexts
}

hasPackageForeignDecl : [HostedForeignDeclAst] -> Bool
hasPackageForeignDecl foreignDecls = {
  for foreignDecl in foreignDecls {
    match foreignDeclSource foreignDecl {
      HostedForeignPackageImport kind specifier declarationPath ->
        return true,
      HostedForeignRuntime ->
        false
    }
  };
  false
}

hasRuntimeForeignDecl : [HostedForeignDeclAst] -> Bool
hasRuntimeForeignDecl foreignDecls = {
  for foreignDecl in foreignDecls {
    match foreignDeclSource foreignDecl {
      HostedForeignPackageImport kind specifier declarationPath ->
        false,
      HostedForeignRuntime ->
        return true
    }
  };
  false
}

emitPackageForeignImport : HostedForeignDeclAst -> Str
emitPackageForeignImport foreignDecl = match foreignDeclSource foreignDecl {
  HostedForeignPackageImport kind specifier declarationPath ->
    textConcat ["import { ", foreignDeclRuntimeName foreignDecl, " as ", packageBindingIdentifier foreignDecl, " } from \"", specifier, "\";"],
  HostedForeignRuntime ->
    ""
}

emitPackageForeignImports : [HostedForeignDeclAst] -> [Str]
emitPackageForeignImports foreignDecls = {
  let mut rendered = emptyRenderedTexts;
  for foreignDecl in foreignDecls {
    match foreignDeclSource foreignDecl {
      HostedForeignPackageImport kind specifier declarationPath -> {
        rendered = appendJsRenderedText rendered (emitPackageForeignImport foreignDecl);
        rendered
      },
      HostedForeignRuntime ->
        rendered
    }
  };
  rendered
}

emitHostBindingEntry : HostedForeignDeclAst -> Str
emitHostBindingEntry foreignDecl = textJoin "\n" ["  {", textConcat ["    name: \"", foreignDeclName foreignDecl, "\","], textConcat ["    runtimeName: \"", foreignDeclRuntimeName foreignDecl, "\","], textConcat ["    source: ", emitForeignSourceLiteral foreignDecl, ","], textConcat ["    declaration: ", emitForeignDeclarationLiteral foreignDecl, ","], textConcat ["    params: [", textJoin ", " (emitForeignParamCodecsFromType (foreignDeclTypeAst foreignDecl)), "],"], textConcat ["    returns: ", emitIdentityHostCodec (emitForeignReturnType (foreignDeclTypeAst foreignDecl)) "result"], "  },"]

emitHostBindingEntries : [HostedForeignDeclAst] -> [Str]
emitHostBindingEntries foreignDecls = {
  let mut rendered = emptyRenderedTexts;
  for foreignDecl in foreignDecls {
    rendered = appendJsRenderedText rendered (emitHostBindingEntry foreignDecl);
    rendered
  };
  rendered
}

emitPackageImportEntry : HostedForeignDeclAst -> Str
emitPackageImportEntry foreignDecl = match foreignDeclSource foreignDecl {
  HostedForeignPackageImport kind specifier declarationPath ->
    textConcat ["  { name: \"", foreignDeclName foreignDecl, "\", runtimeName: \"", foreignDeclRuntimeName foreignDecl, "\", kind: \"", emitHostedPackageImportKind kind, "\", specifier: \"", specifier, "\", declaration: ", emitForeignDeclarationLiteral foreignDecl, " },"],
  HostedForeignRuntime ->
    ""
}

emitPackageImportEntries : [HostedForeignDeclAst] -> [Str]
emitPackageImportEntries foreignDecls = {
  let mut rendered = emptyRenderedTexts;
  for foreignDecl in foreignDecls {
    match foreignDeclSource foreignDecl {
      HostedForeignPackageImport kind specifier declarationPath -> {
        rendered = appendJsRenderedText rendered (emitPackageImportEntry foreignDecl);
        rendered
      },
      HostedForeignRuntime ->
        rendered
    }
  };
  rendered
}

emitPackageBindingEntry : HostedForeignDeclAst -> [Str]
emitPackageBindingEntry foreignDecl = match foreignDeclSource foreignDecl {
  HostedForeignPackageImport kind specifier declarationPath ->
    [textConcat ["  \"", foreignDeclName foreignDecl, "\": ", packageBindingIdentifier foreignDecl, ","], textConcat ["  \"", foreignDeclRuntimeName foreignDecl, "\": ", packageBindingIdentifier foreignDecl, ","]],
  HostedForeignRuntime ->
    emptyRenderedTexts
}

emitPackageBindingEntries : [HostedForeignDeclAst] -> [Str]
emitPackageBindingEntries foreignDecls = {
  let mut rendered = emptyRenderedTexts;
  for foreignDecl in foreignDecls {
    rendered = append rendered (emitPackageBindingEntry foreignDecl);
    rendered
  };
  rendered
}

emitHostBindingPrelude : [HostedForeignDeclAst] -> [Str]
emitHostBindingPrelude foreignDecls = if hasForeignDecls foreignDecls then ["function $claspRuntime(name) {", "  const runtime = globalThis.__claspRuntime;", "  if (!runtime || !(name in runtime)) {", "    throw new Error(`Missing Clasp runtime binding: ${name}`);", "  }", "  return runtime[name];", "}", "function $claspHostBinding(name) {", "  const binding = $claspHostBindingMap[name];", "  if (!binding) {", "    throw new Error(`Missing Clasp host binding manifest: ${name}`);", "  }", "  return binding;", "}", "function $claspCallHostBinding(name, args) {", "  const binding = $claspHostBinding(name);", "  const runtime = $claspRuntime(binding.runtimeName);", "  const hostArgs = binding.params.map((param, index) => param.toHost(args[index]));", "  return binding.returns.fromHost(runtime(...hostArgs));", "}", "function $claspAdaptHostBinding(binding, implementation) {", "  return (...args) => {", "    const preparedArgs = binding.params.map((param, index) => {", "      const path = `arguments[${index}]`;", "      return param.toHost(param.fromHost(args[index], path), path);", "    });", "    return binding.returns.toHost(binding.returns.fromHost(implementation(...preparedArgs), \"result\"), \"result\");", "  };", "}"] else emptyRenderedTexts

emitHostBindingExports : [HostedForeignDeclAst] -> [Str]
emitHostBindingExports foreignDecls = if hasForeignDecls foreignDecls then ["export const __claspHostBindings = ["] else emptyRenderedTexts

emitPackageImportExports : [HostedForeignDeclAst] -> [Str]
emitPackageImportExports foreignDecls = if hasForeignDecls foreignDecls then ["];", "export const __claspPackageImports = ["] else emptyRenderedTexts

emitPackageBindingPrelude : [HostedForeignDeclAst] -> [Str]
emitPackageBindingPrelude foreignDecls = if hasForeignDecls foreignDecls then ["];", "const __claspPackageBindings = Object.freeze({"] else emptyRenderedTexts

emitPackageBindingSupport : [HostedForeignDeclAst] -> [Str]
emitPackageBindingSupport foreignDecls = if hasForeignDecls foreignDecls then ["});", "const $claspHostBindingMap = Object.fromEntries(__claspHostBindings.map((binding) => [binding.name, binding]));", "export function __claspAdaptHostBindings(implementations = {}) {", "  const runtimeBindings = {};", "  for (const binding of __claspHostBindings) {", "    const byName = implementations[binding.name];", "    const byRuntimeName = implementations[binding.runtimeName];", "    const implementation = typeof byName === \"function\" ? byName : byRuntimeName;", "    if (typeof implementation === \"function\") {", "      runtimeBindings[binding.runtimeName] = $claspAdaptHostBinding(binding, implementation);", "    }", "  }", "  return runtimeBindings;", "}", "export function __claspPackageHostBindings() {", "  return __claspAdaptHostBindings(__claspPackageBindings);", "}"] else emptyRenderedTexts

emitForeignBindings : [HostedForeignDeclAst] -> [Str]
emitForeignBindings foreignDecls = {
  let mut rendered = emptyRenderedTexts;
  for foreignDecl in foreignDecls {
    let params = emitForeignParams foreignDecl;
    let bindingLine = if firstText params == "" then textConcat ["export const ", foreignDeclName foreignDecl, " = () => $claspCallHostBinding(\"", foreignDeclName foreignDecl, "\", []);"] else textConcat ["export function ", foreignDeclName foreignDecl, "(", textJoin ", " params, ") { return $claspCallHostBinding(\"", foreignDeclName foreignDecl, "\", [", textJoin ", " params, "]); }"];
    rendered = appendJsRenderedText rendered bindingLine;
    rendered
  };
  rendered
}

emitJsString : Str -> Str
emitJsString value = encode value

emitOptionalJsString : Str -> Str
emitOptionalJsString value = if value == "" then "null" else emitJsString value

hasGuideDeclarations : [HostedGuideDeclAst] -> Bool
hasGuideDeclarations decls = {
  for decl in decls {
    return true
  };
  false
}

hasPolicyDeclarations : [HostedPolicyDeclAst] -> Bool
hasPolicyDeclarations decls = {
  for decl in decls {
    return true
  };
  false
}

hasAgentRoleDeclarations : [HostedAgentRoleDeclAst] -> Bool
hasAgentRoleDeclarations decls = {
  for decl in decls {
    return true
  };
  false
}

hasAgentDeclarations : [HostedAgentDeclAst] -> Bool
hasAgentDeclarations decls = {
  for decl in decls {
    return true
  };
  false
}

hasHookDeclarations : [HostedHookDeclAst] -> Bool
hasHookDeclarations decls = {
  for decl in decls {
    return true
  };
  false
}

hasToolServerDeclarations : [HostedToolServerDeclAst] -> Bool
hasToolServerDeclarations decls = {
  for decl in decls {
    return true
  };
  false
}

hasToolDeclarations : [HostedToolDeclAst] -> Bool
hasToolDeclarations decls = {
  for decl in decls {
    return true
  };
  false
}

hasVerifierDeclarations : [HostedVerifierDeclAst] -> Bool
hasVerifierDeclarations decls = {
  for decl in decls {
    return true
  };
  false
}

hasMergeGateDeclarations : [HostedMergeGateDeclAst] -> Bool
hasMergeGateDeclarations decls = {
  for decl in decls {
    return true
  };
  false
}

renderGuideEntryObjectLines : [HostedGuideEntryAst] -> [Str]
renderGuideEntryObjectLines entries = {
  let mut rendered = emptyRenderedTexts;
  for entry in entries {
    rendered = appendJsRenderedText rendered (textConcat ["      ", emitJsString (guideEntryName entry), ": ", emitJsString (guideEntryValue entry), ","]);
    rendered
  };
  rendered
}

emitGuides : [HostedGuideDeclAst] -> [Str]
emitGuides guides = if hasGuideDeclarations guides then {
  let mut rendered = ["export const __claspGuides = Object.freeze(["];
  for guideDecl in guides {
    rendered = append rendered ["  Object.freeze({", textConcat ["    name: ", emitJsString (guideDeclName guideDecl), ","], textConcat ["    id: ", emitJsString (textConcat ["guide:", guideDeclName guideDecl]), ","], textConcat ["    extends: ", emitOptionalJsString (guideDeclExtends guideDecl), ","], "    entries: Object.freeze({"];
    rendered = append rendered (renderGuideEntryObjectLines (guideDeclEntries guideDecl));
    rendered = append rendered ["    })", "  }),"];
    rendered
  };
  append rendered ["]);", ""]
} else ["export const __claspGuides = Object.freeze([]);", ""]

emitPolicyPermissionValues : HostedPolicyPermissionKindAst -> [HostedPolicyPermissionAst] -> [Str]
emitPolicyPermissionValues targetKind permissions = {
  let mut rendered = emptyRenderedTexts;
  for permission in permissions {
    if renderHostedPolicyPermissionKind (policyPermissionKind permission) == renderHostedPolicyPermissionKind targetKind then {
      rendered = appendRenderedText rendered (emitJsString (policyPermissionValue permission));
      rendered
    } else {
      rendered
    }
  };
  rendered
}

emitJsStringValues : [Str] -> [Str]
emitJsStringValues values = {
  let mut rendered = emptyRenderedTexts;
  for value in values {
    rendered = appendRenderedText rendered (emitJsString value);
    rendered
  };
  rendered
}

emitTypeSchemaDecodeExpr : HostedTypeAst -> Str -> Str -> Str
emitTypeSchemaDecodeExpr typ valueRef pathRef = match typ {
  HostedTypeName name ->
    if name == "Str" then textConcat ["$claspExpectString(", valueRef, ", ", pathRef, ")"] else if name == "Int" then textConcat ["$claspExpectInt(", valueRef, ", ", pathRef, ")"] else if name == "Bool" then textConcat ["$claspExpectBool(", valueRef, ", ", pathRef, ")"] else if name == "Prompt" then textConcat ["$claspExpectPrompt(", valueRef, ", ", pathRef, ")"] else textConcat ["((__claspSchemas[", emitJsString name, "] ?? { fromHost(value) { return value; } }).fromHost(", valueRef, ", ", pathRef, "))"],
  HostedTypeApply name args ->
    textConcat ["((__claspSchemas[", emitJsString name, "] ?? { fromHost(value) { return value; } }).fromHost(", valueRef, ", ", pathRef, "))"],
  HostedTypeVar name ->
    valueRef,
  HostedTypeList itemType ->
    textConcat ["Object.freeze($claspExpectArray(", valueRef, ", ", pathRef, ").map((item) => ", emitTypeSchemaDecodeExpr itemType "item" pathRef, "))"],
  HostedTypeFunction input result ->
    valueRef
}

emitSchemaFieldNames : [HostedRecordFieldDeclAst] -> [Str]
emitSchemaFieldNames fields = {
  let mut rendered = emptyRenderedTexts;
  for field in fields {
    rendered = appendRenderedText rendered (emitJsString (recordFieldDeclName field));
    rendered
  };
  rendered
}

emitSchemaFieldLines : [HostedRecordFieldDeclAst] -> [Str]
emitSchemaFieldLines fields = {
  let mut rendered = emptyRenderedTexts;
  for field in fields {
    let fieldName = recordFieldDeclName field;
    rendered = appendRenderedText rendered (textConcat ["      ", fieldName, ": ", emitTypeSchemaDecodeExpr (recordFieldDeclType field) (textConcat ["objectValue.", fieldName]) (textConcat ["`${path}.", fieldName, "`"]), ","]);
    rendered
  };
  rendered
}

emitRecordSchema : HostedRecordDeclAst -> [Str]
emitRecordSchema decl = {
  let schemaName = recordDeclName decl;
  let schemaConstName = textConcat ["$claspSchema_", schemaName];
  let header = [textConcat ["const ", schemaConstName, " = {"], "  kind: \"clasp-schema-contract\",", "  version: 1,", textConcat ["  name: ", emitJsString schemaName, ","], textConcat ["  schema: Object.freeze({ kind: \"record\", name: ", emitJsString schemaName, ", fields: Object.freeze([", textJoin ", " (emitSchemaFieldNames (recordDeclFields decl)), "]) }),"], "  seed: null,", "  fromHost(value, path = \"value\") {", "    const objectValue = $claspExpectObject(value, path);", "    return Object.freeze({"];
  let footer = [ "    });", "  },", "  toHost(value, path = \"value\") { return this.fromHost(value, path); },", "  decodeJson(jsonText) { return this.fromHost(JSON.parse(jsonText), \"value\"); },", "  encodeJson(value) { return JSON.stringify(this.toHost(value, \"value\")); },", "  stream(initial = null) { return $claspCreateSchemaStream(this, initial); }", "};", "" ];
  append header (append (emitSchemaFieldLines (recordDeclFields decl)) footer)
}

emitSchemas : [HostedRecordDeclAst] -> [Str]
emitSchemas recordDecls = {
  let mut rendered = emptyRenderedTexts;
  for recordDecl in recordDecls {
    rendered = append rendered (emitRecordSchema recordDecl);
    rendered
  };
  let mut entries = emptyRenderedTexts;
  for recordDecl in recordDecls {
    let recordName = recordDeclName recordDecl;
    entries = appendRenderedText entries (textConcat [recordName, ": $claspSchema_", recordName]);
    entries
  };
  append rendered [textConcat ["export const __claspSchemas = Object.freeze({ ", textJoin ", " entries, " });"], "for (const schemaContract of Object.values(__claspSchemas)) {", "  schemaContract.binary = $claspCreateSchemaBinaryCodec(schemaContract);", "  schemaContract.encodeBinary = function (value) { return this.binary.encode(value); };", "  schemaContract.decodeBinary = function (payload, path = \"value\") { return this.binary.decode(payload, path); };", "  schemaContract.encodeFramedBinary = function (value) { return this.binary.frame(value); };", "  schemaContract.decodeFramedBinary = function (frame, path = \"value\") { return this.binary.unframe(frame, path); };", "  Object.freeze(schemaContract);", "}", ""]
}

emitExportsRegistry : HostedModuleAst -> [Str]
emitExportsRegistry modl = {
  let mut entries = emptyRenderedTexts;
  for exportName in declNames modl {
    entries = appendRenderedText entries (textConcat [exportName, ": ", exportName]);
    entries
  };
  [textConcat ["const __claspExports = Object.freeze({ ", textJoin ", " entries, " });"], ""]
}

emitSelfHostedRuntimePrelude : [Str]
emitSelfHostedRuntimePrelude = {
  let core = [ "function $claspSnapshotValue(value) {", "  if (typeof globalThis.structuredClone === \"function\") {", "    return globalThis.structuredClone(value);", "  }", "  return value === undefined ? undefined : JSON.parse(JSON.stringify(value));", "}", "", "function $claspExpectObject(value, path = \"value\") {", "  if (typeof value !== \"object\" || value === null || Array.isArray(value)) {", "    throw new Error(`${path} expected an object`);", "  }", "  return value;", "}", "", "function $claspExpectArray(value, path = \"value\") {", "  if (!Array.isArray(value)) {", "    throw new Error(`${path} expected an array`);", "  }", "  return value;", "}", "", "function $claspExpectString(value, path = \"value\") {", "  if (typeof value !== \"string\") {", "    throw new Error(`${path} expected a string`);", "  }", "  return value;", "}", "", "function $claspExpectInt(value, path = \"value\") {", "  if (!Number.isInteger(value)) {", "    throw new Error(`${path} expected an integer`);", "  }", "  return value;", "}", "", "function $claspExpectBool(value, path = \"value\") {", "  if (typeof value !== \"boolean\") {", "    throw new Error(`${path} expected a boolean`);", "  }", "  return value;", "}", "", "const $claspBinaryMagic = Object.freeze([67, 76, 66, 49]);", "const $claspTextEncoder = typeof TextEncoder === \"undefined\" ? null : new TextEncoder();", "const $claspTextDecoder = typeof TextDecoder === \"undefined\" ? null : new TextDecoder();", "", "function $claspEncodeUtf8Text(value) {", "  if ($claspTextEncoder === null) {", "    throw new Error(\"This runtime does not provide TextEncoder for binary Clasp codecs\");", "  }", "  return $claspTextEncoder.encode($claspExpectString(value, \"value\"));", "}", "", "function $claspDecodeUtf8Text(bytes, path = \"value\") {", "  if ($claspTextDecoder === null) {", "    throw new Error(\"This runtime does not provide TextDecoder for binary Clasp codecs\");", "  }", "  return $claspTextDecoder.decode($claspNormalizeBinaryBytes(bytes, path));", "}", "", "function $claspNormalizeBinaryBytes(value, path = \"value\") {", "  if (value instanceof Uint8Array) {", "    return value;", "  }", "  if (value instanceof ArrayBuffer) {", "    return new Uint8Array(value);", "  }", "  if (ArrayBuffer.isView(value)) {", "    return new Uint8Array(value.buffer, value.byteOffset, value.byteLength);", "  }", "  throw new Error(`${path} expected binary bytes`);", "}", "", "function $claspWriteUint32(target, offset, value) {", "  new DataView(target.buffer, target.byteOffset, target.byteLength).setUint32(offset, value, true);", "}", "", "function $claspReadUint32(source, offset, path = \"value\") {", "  if (offset + 4 > source.byteLength) {", "    throw new Error(`${path} truncated binary payload`);", "  }", "  return new DataView(source.buffer, source.byteOffset, source.byteLength).getUint32(offset, true);", "}", "", "function $claspFrameBinaryPayload(payload) {", "  const bytes = $claspNormalizeBinaryBytes(payload, \"payload\");", "  const frame = new Uint8Array(4 + bytes.byteLength);", "  $claspWriteUint32(frame, 0, bytes.byteLength);", "  frame.set(bytes, 4);", "  return frame;", "}", "", "function $claspUnframeBinaryPayload(frame, path = \"value\") {", "  const bytes = $claspNormalizeBinaryBytes(frame, path);", "  const expectedLength = $claspReadUint32(bytes, 0, path);", "  const payload = bytes.slice(4);", "  if (payload.byteLength !== expectedLength) {", "    throw new Error(`${path} expected ${expectedLength} framed bytes but received ${payload.byteLength}`);", "  }", "  return payload;", "}", "", "function $claspEncodeSchemaBinaryPayload(schemaContract, value) {", "  const normalizedValue = schemaContract.toHost(schemaContract.fromHost(value, \"value\"), \"value\");", "  const fingerprint = String(schemaContract.schema?.schemaFingerprint ?? schemaContract.type ?? schemaContract.name ?? \"value\");", "  const fingerprintBytes = $claspEncodeUtf8Text(fingerprint);", "  const payloadBytes = $claspEncodeUtf8Text(JSON.stringify(normalizedValue));", "  const buffer = new Uint8Array(12 + fingerprintBytes.byteLength + payloadBytes.byteLength);", "  buffer.set($claspBinaryMagic, 0);", "  $claspWriteUint32(buffer, 4, fingerprintBytes.byteLength);", "  $claspWriteUint32(buffer, 8, payloadBytes.byteLength);", "  buffer.set(fingerprintBytes, 12);", "  buffer.set(payloadBytes, 12 + fingerprintBytes.byteLength);", "  return buffer;", "}", "", "function $claspDecodeSchemaBinaryPayload(schemaContract, payload, path = \"value\") {", "  const bytes = $claspNormalizeBinaryBytes(payload, path);", "  if (bytes.byteLength < 12) {", "    throw new Error(`${path} expected a Clasp binary payload`);", "  }", "  for (let index = 0; index < $claspBinaryMagic.length; index += 1) {", "    if (bytes[index] !== $claspBinaryMagic[index]) {", "      throw new Error(`${path} expected a Clasp binary payload`);", "    }", "  }", "  const fingerprintLength = $claspReadUint32(bytes, 4, path);", "  const payloadLength = $claspReadUint32(bytes, 8, path);", "  const payloadOffset = 12 + fingerprintLength;", "  if (payloadOffset + payloadLength !== bytes.byteLength) {", "    throw new Error(`${path} has an invalid Clasp binary payload length`);", "  }", "  const fingerprint = $claspDecodeUtf8Text(bytes.slice(12, payloadOffset), `${path}.fingerprint`);", "  const expectedFingerprint = String(schemaContract.schema?.schemaFingerprint ?? schemaContract.type ?? schemaContract.name ?? \"value\");", "  if (fingerprint !== expectedFingerprint) {", "    throw new Error(`${path} expected schema fingerprint ${expectedFingerprint} but received ${fingerprint}`);", "  }", "  const payloadText = $claspDecodeUtf8Text(bytes.slice(payloadOffset), `${path}.payload`);", "  return schemaContract.toHost(schemaContract.fromHost(JSON.parse(payloadText), path), path);", "}", "", "function $claspCreateSchemaBinaryCodec(schemaContract) {", "  return Object.freeze({", "    type: schemaContract.type ?? schemaContract.name ?? null,", "    schemaFingerprint: String(schemaContract.schema?.schemaFingerprint ?? schemaContract.type ?? schemaContract.name ?? \"value\"),", "    framing: \"length_prefixed\",", "    encode(value) { return $claspEncodeSchemaBinaryPayload(schemaContract, value); },", "    decode(bytes, path = \"value\") { return $claspDecodeSchemaBinaryPayload(schemaContract, bytes, path); },", "    frame(value) { return $claspFrameBinaryPayload(this.encode(value)); },", "    unframe(frame, path = \"value\") { return this.decode($claspUnframeBinaryPayload(frame, path), path); }", "  });", "}", "", "function $claspCreateSchemaStream(contract, initial = null) {", "  return Object.freeze({ kind: \"clasp-schema-stream\", schema: contract, initial });", "}" ];
  let prompts = [ "", "function $claspPromptMessage(role, content) {", "  return Object.freeze({", "    $kind: \"prompt\",", "    messages: Object.freeze([Object.freeze({", "      role: $claspExpectString(role, \"prompt.role\"),", "      content: $claspExpectString(content, \"prompt.content\")", "    })])", "  });", "}", "", "function $claspExpectPrompt(value, path = \"value\") {", "  const objectValue = $claspExpectObject(value, path);", "  if (objectValue.$kind !== \"prompt\") {", "    throw new Error(`${path} expected a Prompt value`);", "  }", "  const messages = $claspExpectArray(objectValue.messages, `${path}.messages`).map((message, index) => {", "    const messagePath = `${path}.messages[${index}]`;", "    const messageObject = $claspExpectObject(message, messagePath);", "    return Object.freeze({", "      role: $claspExpectString(messageObject.role, `${messagePath}.role`),", "      content: $claspExpectString(messageObject.content, `${messagePath}.content`)", "    });", "  });", "  return Object.freeze({ $kind: \"prompt\", messages: Object.freeze(messages) });", "}", "", "function systemPrompt(content) { return $claspPromptMessage(\"system\", content); }", "function assistantPrompt(content) { return $claspPromptMessage(\"assistant\", content); }", "function userPrompt(content) { return $claspPromptMessage(\"user\", content); }", "", "function appendPrompt(left, right) {", "  const leftPrompt = $claspExpectPrompt(left, \"left\");", "  const rightPrompt = $claspExpectPrompt(right, \"right\");", "  return Object.freeze({", "    $kind: \"prompt\",", "    messages: Object.freeze([...leftPrompt.messages, ...rightPrompt.messages].map((message) => Object.freeze({ role: message.role, content: message.content })))", "  });", "}", "", "function promptText(value) {", "  const prompt = $claspExpectPrompt(value, \"value\");", "  return prompt.messages.map((message) => `${message.role}: ${message.content}`).join(\"\\n\\n\");", "}" ];
  let traces = [ "", "function $claspCreateTraceCollector(seed = []) {", "  const entries = Array.isArray(seed) ? seed.map((entry) => $claspSnapshotValue(entry)) : [];", "  return Object.freeze({", "    kind: \"clasp-trace-collector\",", "    version: 1,", "    record(entry) {", "      const snapshot = $claspSnapshotValue(entry);", "      entries.push(snapshot);", "      return snapshot;", "    },", "    entries() {", "      return $claspSnapshotValue(entries);", "    },", "    clear() {", "      entries.length = 0;", "      return this.entries();", "    }", "  });", "}", "", "function $claspMaybeRecordTrace(options = null, kind, name, action) {", "  const collector = options && typeof options === \"object\" && options.collector && typeof options.collector.record === \"function\"", "    ? options.collector", "    : null;", "  if (collector) {", "    collector.record(Object.freeze({ kind, name, action, status: \"ok\" }));", "  }", "}" ];
  append core (append prompts traces)
}

emitPolicies : [HostedPolicyDeclAst] -> [Str]
emitPolicies policies = if hasPolicyDeclarations policies then {
  let mut rendered = ["export const __claspPolicies = Object.freeze(["];
  for policyDecl in policies {
    rendered = append rendered ["  $claspCreatePolicyRuntime({", textConcat ["    name: ", emitJsString (policyDeclName policyDecl), ","], textConcat ["    id: ", emitJsString (textConcat ["policy:", policyDeclName policyDecl]), ","], textConcat ["    allowedClassifications: Object.freeze([", textJoin ", " (emitJsStringValues (policyDeclAllowedClassifications policyDecl)), "]),"], textConcat ["    file: Object.freeze([", textJoin ", " (emitPolicyPermissionValues HostedPolicyPermissionFile (policyDeclPermissions policyDecl)), "]),"], textConcat ["    network: Object.freeze([", textJoin ", " (emitPolicyPermissionValues HostedPolicyPermissionNetwork (policyDeclPermissions policyDecl)), "]),"], textConcat ["    process: Object.freeze([", textJoin ", " (emitPolicyPermissionValues HostedPolicyPermissionProcess (policyDeclPermissions policyDecl)), "]),"], textConcat ["    secret: Object.freeze([", textJoin ", " (emitPolicyPermissionValues HostedPolicyPermissionSecret (policyDeclPermissions policyDecl)), "])"], "  }),"];
    rendered
  };
  append rendered ["]);", "const $claspPolicyMap = Object.freeze(Object.fromEntries(__claspPolicies.map((policy) => [policy.name, policy])));", ""]
} else ["export const __claspPolicies = Object.freeze([]);", "const $claspPolicyMap = Object.freeze({});", ""]

emitGuideHelpers : [Str]
emitGuideHelpers =
  [
    "const $claspGuideMap = Object.freeze(Object.fromEntries(__claspGuides.map((guide) => [guide.name, guide])));",
    ""
  ]

emitAgentRoles : [HostedAgentRoleDeclAst] -> [Str]
emitAgentRoles roles = if hasAgentRoleDeclarations roles then {
  let mut rendered = ["const __claspAgentRoleSpecs = Object.freeze(["];
  for roleDecl in roles {
    rendered = append rendered ["  Object.freeze({", textConcat ["    name: ", emitJsString (agentRoleDeclName roleDecl), ","], textConcat ["    id: ", emitJsString (textConcat ["agent-role:", agentRoleDeclName roleDecl]), ","], textConcat ["    guideName: ", emitOptionalJsString (agentRoleDeclGuideName roleDecl), ","], textConcat ["    policyName: ", emitOptionalJsString (agentRoleDeclPolicyName roleDecl), ","], textConcat ["    approvalPolicy: ", emitOptionalJsString (agentRoleDeclApprovalPolicy roleDecl), ","], textConcat ["    sandboxPolicy: ", emitOptionalJsString (agentRoleDeclSandboxPolicy roleDecl)], "  }),"];
    rendered
  };
  append rendered ["]);", "export const __claspAgentRoles = Object.freeze(__claspAgentRoleSpecs.map((role) => Object.freeze({", "  ...role,", "  guide: typeof role.guideName === \"string\" && role.guideName !== \"\" ? $claspGuideMap[role.guideName] ?? null : null,", "  policy: typeof role.policyName === \"string\" && role.policyName !== \"\" ? $claspPolicyMap[role.policyName] ?? null : null,", "  instructions: $claspResolveGuideInstructions(role.guideName, $claspGuideMap)", "})));", "const $claspAgentRoleMap = Object.freeze(Object.fromEntries(__claspAgentRoles.map((role) => [role.name, role])));", ""]
} else ["export const __claspAgentRoles = Object.freeze([]);", "const $claspAgentRoleMap = Object.freeze({});", ""]

emitAgents : [HostedAgentDeclAst] -> [Str]
emitAgents agents = if hasAgentDeclarations agents then {
  let mut rendered = ["const __claspAgentSpecs = Object.freeze(["];
  for agentDecl in agents {
    rendered = append rendered ["  Object.freeze({", textConcat ["    name: ", emitJsString (agentDeclName agentDecl), ","], textConcat ["    id: ", emitJsString (textConcat ["agent:", agentDeclName agentDecl]), ","], textConcat ["    roleName: ", emitOptionalJsString (agentDeclRoleName agentDecl)], "  }),"];
    rendered
  };
  append rendered ["]);", "export const __claspAgents = Object.freeze(__claspAgentSpecs.map((agent) => {", "  const role = typeof agent.roleName === \"string\" && agent.roleName !== \"\" ? $claspAgentRoleMap[agent.roleName] ?? null : null;", "  return Object.freeze({", "    ...agent,", "    role,", "    policy: role?.policy ?? null,", "    instructions: role?.instructions ?? Object.freeze({})", "  });", "}));", ""]
} else ["export const __claspAgents = Object.freeze([]);", ""]

emitHooks : [HostedHookDeclAst] -> [Str]
emitHooks hooks = if hasHookDeclarations hooks then {
  let mut rendered = ["export const __claspHooks = Object.freeze(["];
  for hookDecl in hooks {
    rendered = append rendered ["  Object.freeze({", textConcat ["    name: ", emitJsString (hookDeclName hookDecl), ","], textConcat ["    id: ", emitJsString (textConcat ["hook:", hookDeclName hookDecl]), ","], textConcat ["    event: ", emitJsString (hookDeclEvent hookDecl), ","], textConcat ["    requestType: ", emitOptionalJsString (hookDeclRequestType hookDecl), ","], textConcat ["    responseType: ", emitOptionalJsString (hookDeclResponseType hookDecl), ","], textConcat ["    handlerName: ", emitOptionalJsString (hookDeclHandlerName hookDecl), ","], "    invoke(value, options = null) {", "      const handler = __claspExports[this.handlerName] ?? null;", "      if (typeof handler !== \"function\") {", "        throw new Error(`Missing Clasp hook handler: ${String(this.handlerName)}`);", "      }", "      return handler(value);", "    }", "  }),"];
    rendered
  };
  append rendered ["]);", ""]
} else emptyRenderedTexts

emitToolServers : [HostedToolServerDeclAst] -> [Str]
emitToolServers servers = if hasToolServerDeclarations servers then {
  let mut rendered = ["export const __claspToolServers = Object.freeze(["];
  for serverDecl in servers {
    rendered = append rendered ["  Object.freeze({", textConcat ["    kind: ", emitJsString "toolServer", ","], textConcat ["    name: ", emitJsString (toolServerDeclName serverDecl), ","], textConcat ["    id: ", emitJsString (textConcat ["toolserver:", toolServerDeclName serverDecl]), ","], textConcat ["    protocol: ", emitOptionalJsString (toolServerDeclProtocol serverDecl), ","], textConcat ["    location: ", emitOptionalJsString (toolServerDeclLocation serverDecl), ","], textConcat ["    policyName: ", emitOptionalJsString (toolServerDeclPolicyName serverDecl)], "  }),"];
    rendered
  };
  append rendered ["]);", "const $claspToolServerMap = Object.freeze(Object.fromEntries(__claspToolServers.map((server) => [server.name, server])));", ""]
} else ["export const __claspToolServers = Object.freeze([]);", "const $claspToolServerMap = Object.freeze({});", ""]

emitTools : [HostedToolDeclAst] -> [Str]
emitTools tools = if hasToolDeclarations tools then {
  let mut rendered = ["export const __claspTools = Object.freeze(["];
  for toolDecl in tools {
    rendered = append rendered ["  Object.freeze({", textConcat ["    name: ", emitJsString (toolDeclName toolDecl), ","], textConcat ["    id: ", emitJsString (textConcat ["tool:", toolDeclName toolDecl]), ","], textConcat ["    serverName: ", emitOptionalJsString (toolDeclServerName toolDecl), ","], textConcat ["    operation: ", emitOptionalJsString (toolDeclOperation toolDecl), ","], textConcat ["    requestType: ", emitOptionalJsString (toolDeclRequestType toolDecl), ","], textConcat ["    requestSchema: (__claspSchemas[", emitJsString (toolDeclRequestType toolDecl), "] ?? null),"], textConcat ["    responseType: ", emitOptionalJsString (toolDeclResponseType toolDecl), ","], textConcat ["    responseSchema: (__claspSchemas[", emitJsString (toolDeclResponseType toolDecl), "] ?? null),"], "    prepare(value, id = null, options = null) { return this.prepareCall(value, id, options); },", "    prepareCall(value, id = null, options = null) {", "      const params = this.requestSchema ? this.requestSchema.toHost(this.requestSchema.fromHost(value, \"params\"), \"params\") : value;", "      $claspMaybeRecordTrace(options, \"tool\", this.name, \"prepare_call\");", "      return Object.freeze({ jsonrpc: \"2.0\", id: id ?? this.name, method: this.operation, params });", "    },", "    evaluateResult(payload, options = null) {", "      const result = this.responseSchema ? this.responseSchema.toHost(this.responseSchema.fromHost(payload, \"result\"), \"result\") : payload;", "      $claspMaybeRecordTrace(options, \"tool\", this.name, \"parse_result\");", "      return Object.freeze({ result, output: result });", "    },", "    parseResult(payload, options = null) { return this.evaluateResult(payload, options).result; },", "    decodeResultEnvelope(value, path = \"response\") {", "      const objectValue = $claspExpectObject(value, path);", "      return Object.freeze({", "        jsonrpc: typeof objectValue.jsonrpc === \"string\" ? objectValue.jsonrpc : \"2.0\",", "        id: objectValue.id ?? null,", "        result: this.parseResult(objectValue.result)", "      });", "    },", "    parseResultEnvelope(jsonText) { return this.decodeResultEnvelope(JSON.parse(jsonText)); }", "  }),"];
    rendered
  };
  append rendered ["]);", "export const __claspToolCallContracts = Object.freeze(__claspTools.map((tool) => Object.freeze({", "  kind: \"clasp-tool-call-contract\",", "  version: 1,", "  name: tool.name,", "  toolName: tool.name,", "  toolId: tool.id,", "  serverName: tool.serverName,", "  serverProtocol: ($claspToolServerMap[tool.serverName] ?? null)?.protocol ?? null,", "  operation: tool.operation,", "  requestType: tool.requestType,", "  requestSchema: tool.requestSchema,", "  responseType: tool.responseType,", "  responseSchema: tool.responseSchema,", "  prepare(value, id = null, options = null) { return tool.prepare(value, id, options); },", "  evaluateResult(payload, options = null) { return tool.evaluateResult(payload, options); },", "  parse(payload, options = null) { return tool.parseResult(payload, options); },", "  decodeResultEnvelope(value, path = \"response\") { return tool.decodeResultEnvelope(value, path); },", "  parseResultEnvelope(jsonText) { return tool.parseResultEnvelope(jsonText); }", "})));", "const $claspToolCallContractMap = Object.freeze(Object.fromEntries(__claspToolCallContracts.map((tool) => [tool.name, tool])));", ""]
} else ["export const __claspTools = Object.freeze([]);", "export const __claspToolCallContracts = Object.freeze([]);", "const $claspToolCallContractMap = Object.freeze({});", ""]

emitVerifiers : [HostedVerifierDeclAst] -> [Str]
emitVerifiers verifiers = if hasVerifierDeclarations verifiers then {
  let mut rendered = ["export const __claspVerifiers = Object.freeze(["];
  for verifierDecl in verifiers {
    rendered = append rendered ["  Object.freeze({", textConcat ["    name: ", emitJsString (verifierDeclName verifierDecl), ","], textConcat ["    id: ", emitJsString (textConcat ["verifier:", verifierDeclName verifierDecl]), ","], textConcat ["    toolName: ", emitOptionalJsString (verifierDeclToolName verifierDecl), ","], "    prepareRun(value, id = null, options = null) {", "      const tool = $claspToolCallContractMap[this.toolName] ?? null;", "      if (tool === null) {", "        throw new Error(`Unknown Clasp tool contract: ${String(this.toolName)}`);", "      }", "      return tool.prepare(value, id, options);", "    },", "    parseResult(payload, options = null) {", "      const tool = $claspToolCallContractMap[this.toolName] ?? null;", "      if (tool === null) {", "        throw new Error(`Unknown Clasp tool contract: ${String(this.toolName)}`);", "      }", "      return tool.parse(payload, options);", "    }", "  }),"];
    rendered
  };
  append rendered ["]);", "const $claspVerifierMap = Object.freeze(Object.fromEntries(__claspVerifiers.map((verifier) => [verifier.name, verifier])));", ""]
} else ["export const __claspVerifiers = Object.freeze([]);", "const $claspVerifierMap = Object.freeze({});", ""]

emitMergeGates : [HostedMergeGateDeclAst] -> [Str]
emitMergeGates mergeGates = if hasMergeGateDeclarations mergeGates then {
  let mut rendered = ["export const __claspMergeGates = Object.freeze(["];
  for mergeGateDecl in mergeGates {
    let mut verifierNames = emptyRenderedTexts;
    for verifierName in mergeGateDeclVerifierNames mergeGateDecl {
      verifierNames = appendRenderedText verifierNames (emitJsString verifierName);
      verifierNames
    };
    rendered = append rendered ["  Object.freeze({", textConcat ["    name: ", emitJsString (mergeGateDeclName mergeGateDecl), ","], textConcat ["    id: ", emitJsString (textConcat ["mergegate:", mergeGateDeclName mergeGateDecl]), ","], textConcat ["    verifierNames: Object.freeze([", textJoin ", " verifierNames, "]),"], "    plan(value, idSeed = this.name) {", "      return this.verifierNames.map((name, index) => {", "        const verifier = $claspVerifierMap[name] ?? null;", "        if (verifier === null) {", "          throw new Error(`Unknown Clasp verifier: ${String(name)}`);", "        }", "        return verifier.prepareRun(value, `${idSeed}:${index}`);", "      });", "    }", "  }),"];
    rendered
  };
  append rendered ["]);", ""]
} else emptyRenderedTexts

emitFrontendModuleBindings : HostedModuleAst -> [Str]
emitFrontendModuleBindings modl =
  [
    "export const __claspTraceCollector = Object.freeze({",
    "  version: 1,",
    "  create(seed = []) { return $claspCreateTraceCollector(seed); }",
    "});",
    "",
    "export const __claspModule = Object.freeze({",
    textConcat ["  name: ", emitJsString (moduleNameOf modl), ","],
    "  version: 1",
    "});",
    "",
    "export const __claspBindings = Object.freeze({",
    "  kind: \"clasp-generated-bindings\",",
    "  version: 1,",
    "  module: __claspModule,",
    "  schemas: __claspSchemas,",
    "  traces: __claspTraceCollector",
    "});",
    ""
  ]

emitFrontendModule : HostedModuleAst -> [LowerDeclText] -> Str
emitFrontendModule modl decls = {
  let mut rendered = ["// Generated by compiler-selfhost"];
  let foreignDecls = moduleForeignDeclarations modl;
  rendered = append rendered (emitPackageForeignImports foreignDecls);
  rendered = append rendered (emitBuiltinPrelude decls);
  rendered = append rendered emitSelfHostedRuntimePrelude;
  rendered = append rendered (emitHostBindingPrelude foreignDecls);
  rendered = append rendered (emitHostBindingExports foreignDecls);
  rendered = if hasForeignDecls foreignDecls then append rendered (emitHostBindingEntries foreignDecls) else rendered;
  rendered = append rendered (emitPackageImportExports foreignDecls);
  rendered = if hasForeignDecls foreignDecls then append rendered (emitPackageImportEntries foreignDecls) else rendered;
  rendered = append rendered (emitPackageBindingPrelude foreignDecls);
  rendered = if hasForeignDecls foreignDecls then append rendered (emitPackageBindingEntries foreignDecls) else rendered;
  rendered = append rendered (emitPackageBindingSupport foreignDecls);
  rendered = append rendered (emitEarlyReturnPrelude decls);
  rendered = append rendered (emitForeignBindings (moduleForeignDeclarations modl));
  for decl in decls {
    rendered = appendJsRenderedText rendered (emitDecl decl);
    rendered
  };
  rendered = append rendered (emitExportsRegistry modl);
  rendered = append rendered (emitSchemas (moduleRecordDeclarations modl));
  rendered = append rendered (emitFrontendModuleBindings modl);
  textJoin "\n" rendered
}

-- CLASP_PROJECT_MODULE --
module Compiler.Lower

import Compiler.Ast
import Compiler.Checker

type LowerExprText = LowerName Str | LowerLiteral Str | LowerInt Str | LowerBool Bool | LowerArray [LowerExprText] | LowerListAppend LowerExprText LowerExprText | LowerListPrepend LowerExprText LowerExprText | LowerListReverse LowerExprText | LowerLength LowerExprText | LowerListMap Str LowerExprText | LowerListFilter Str LowerExprText | LowerListAny Str LowerExprText | LowerListAll Str LowerExprText | LowerListFold Str LowerExprText LowerExprText | LowerViewAppend LowerExprText LowerExprText | LowerEncode LowerExprText | LowerDecode TypeText LowerExprText | LowerInvoke Str [LowerExprText] | LowerConstructor Str [LowerExprText] | LowerMatch LowerExprText [LowerMatchBranchText] | LowerRecord Str [LowerRecordFieldText] | LowerFieldAccess Str LowerExprText Str | LowerLet Str LowerExprText LowerExprText | LowerMutableLet Str LowerExprText LowerExprText | LowerAssign Str LowerExprText LowerExprText | LowerFor Str LowerExprText LowerExprText LowerExprText | LowerReturn LowerExprText | LowerIf LowerExprText LowerExprText LowerExprText | LowerEqual LowerExprText LowerExprText | LowerNotEqual LowerExprText LowerExprText | LowerLessThan LowerExprText LowerExprText | LowerLessThanOrEqual LowerExprText LowerExprText | LowerGreaterThan LowerExprText LowerExprText | LowerGreaterThanOrEqual LowerExprText LowerExprText
type LowerRecordFieldText = LowerRecordFieldText Str LowerExprText
type LowerMatchBranchText = LowerMatchBranchText Str [Str] LowerExprText
type LowerDeclText = LowerConst Str LowerExprText | LowerFn Str [Str] LowerExprText

keepNoLowerExpr : LowerExprText -> Bool
keepNoLowerExpr value = false

emptyLowerExprs : [LowerExprText]
emptyLowerExprs = filter keepNoLowerExpr [LowerName ""]

keepNoLowerRecordField : LowerRecordFieldText -> Bool
keepNoLowerRecordField value = false

emptyLowerRecordFields : [LowerRecordFieldText]
emptyLowerRecordFields = filter keepNoLowerRecordField [LowerRecordFieldText "" (LowerName "")]

keepNoLowerMatchBranch : LowerMatchBranchText -> Bool
keepNoLowerMatchBranch value = false

emptyLowerMatchBranches : [LowerMatchBranchText]
emptyLowerMatchBranches = filter keepNoLowerMatchBranch [LowerMatchBranchText "" emptyRenderedTexts (LowerName "")]

keepNoLowerDecl : LowerDeclText -> Bool
keepNoLowerDecl value = false

emptyLowerDecls : [LowerDeclText]
emptyLowerDecls = filter keepNoLowerDecl [LowerConst "" (LowerName "")]

appendLowerRenderedText : [Str] -> Str -> [Str]
appendLowerRenderedText values value = append values [value]

appendLowerExpr : [LowerExprText] -> LowerExprText -> [LowerExprText]
appendLowerExpr values value = append values [value]

appendLowerRecordField : [LowerRecordFieldText] -> LowerRecordFieldText -> [LowerRecordFieldText]
appendLowerRecordField values value = append values [value]

appendLowerMatchBranch : [LowerMatchBranchText] -> LowerMatchBranchText -> [LowerMatchBranchText]
appendLowerMatchBranch values value = append values [value]

appendLowerDecl : [LowerDeclText] -> LowerDeclText -> [LowerDeclText]
appendLowerDecl values value = append values [value]

hasLowerParams : HostedDeclAst -> Bool
hasLowerParams decl = {
  for paramName in declParams decl {
    return true
  };
  false
}

fallbackLowerEnv : HostedModuleAst -> [HostedTypeDeclAst] -> [TypeBinding]
fallbackLowerEnv modl typeDecls = append baseEnv (append (collectConstructorBindings typeDecls) (append (collectForeignBindings modl) (collectAnnotatedBindings modl)))

lowerModuleEnv : HostedModuleAst -> [HostedTypeDeclAst] -> [TypeBinding]
lowerModuleEnv modl typeDecls =
  if moduleDeclarationsFullyAnnotated modl then
    fallbackLowerEnv modl typeDecls
  else
    match inferModuleBindings modl {
      InferredModule env ->
        env,
      InferModuleError message ->
        fallbackLowerEnv modl typeDecls
    }

unknownLowerType : TypeText
unknownLowerType = TUnknown "<lower>"

inferredExprType : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [TypeBinding] -> [TypeBinding] -> ReturnContext -> HostedExprAst -> TypeText
inferredExprType typeDecls recordDecls env localEnv fnContext expr = match inferExpr typeDecls recordDecls env localEnv fnContext expr {
  InferredExpr exprType ->
    exprType,
  InferExprError message ->
    unknownLowerType
}

recordNameForType : TypeText -> Str
recordNameForType typ = match typ {
  TNamed recordName ->
    recordName,
  TApply recordName args ->
    recordName,
  TInt ->
    "",
  TStr ->
    "",
  TBool ->
    "",
  TList itemType ->
    "",
  TFunction inputType resultType ->
    "",
  TVar label ->
    "",
  TUnknown label ->
    ""
}

extendLowerLocalEnv : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [TypeBinding] -> [TypeBinding] -> ReturnContext -> Str -> HostedExprAst -> [TypeBinding]
extendLowerLocalEnv typeDecls recordDecls env localEnv fnContext binder value = match inferExpr typeDecls recordDecls env localEnv fnContext value {
  InferredExpr valueType ->
    appendTypeBinding localEnv (TypeBinding binder valueType),
  InferExprError message ->
    localEnv
}

extendLowerLoopLocalEnv : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [TypeBinding] -> [TypeBinding] -> ReturnContext -> Str -> HostedExprAst -> [TypeBinding]
extendLowerLoopLocalEnv typeDecls recordDecls env localEnv fnContext binder iterable = match inferExpr typeDecls recordDecls env localEnv fnContext iterable {
  InferredExpr iterableType ->
    match iterableType {
      TList itemType ->
        appendTypeBinding localEnv (TypeBinding binder itemType),
      TStr ->
        appendTypeBinding localEnv (TypeBinding binder TStr),
      TInt ->
        localEnv,
      TBool ->
        localEnv,
      TFunction inputType resultType ->
        localEnv,
      TNamed label ->
        localEnv,
      TApply label args ->
        localEnv,
      TVar label ->
        localEnv,
      TUnknown label ->
        localEnv
    },
  InferExprError message ->
    localEnv
}

lowerExprs : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [TypeBinding] -> [TypeBinding] -> ReturnContext -> [HostedExprAst] -> [LowerExprText]
lowerExprs typeDecls recordDecls env localEnv fnContext values = {
  let mut lowered = emptyLowerExprs;
  for value in values {
    lowered = appendLowerExpr lowered (lowerExpr typeDecls recordDecls env localEnv fnContext value);
    lowered
  };
  lowered
}

lowerRecordFields : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [TypeBinding] -> [TypeBinding] -> ReturnContext -> [HostedRecordFieldExprAst] -> [LowerRecordFieldText]
lowerRecordFields typeDecls recordDecls env localEnv fnContext fields = {
  let mut lowered = emptyLowerRecordFields;
  for field in fields {
    lowered = appendLowerRecordField lowered (LowerRecordFieldText (recordExprFieldName field) (lowerExpr typeDecls recordDecls env localEnv fnContext (recordExprFieldValue field)));
    lowered
  };
  lowered
}

lowerMatchBranches : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [TypeBinding] -> [TypeBinding] -> ReturnContext -> [HostedMatchBranchAst] -> [LowerMatchBranchText]
lowerMatchBranches typeDecls recordDecls env localEnv fnContext branches = {
  let mut lowered = emptyLowerMatchBranches;
  for branch in branches {
    let branchPattern = branchPatternAst branch;
    lowered = appendLowerMatchBranch lowered (LowerMatchBranchText (patternConstructorName branchPattern) (patternBinders branchPattern) (lowerExpr typeDecls recordDecls env localEnv fnContext (branchBodyExpr branch)));
    lowered
  };
  lowered
}

lowerAppendExpr : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [TypeBinding] -> [TypeBinding] -> ReturnContext -> [HostedExprAst] -> LowerExprText
lowerAppendExpr typeDecls recordDecls env localEnv fnContext args = {
  let left = firstHostedExpr args;
  let remaining = remainingHostedExprs args;
  let right = firstHostedExpr remaining;
  let extra = firstHostedExpr (remainingHostedExprs remaining);
  if expressionSummary left == "" then {
    LowerInvoke "append" (lowerExprs typeDecls recordDecls env localEnv fnContext args)
  } else if expressionSummary right == "" then {
    LowerInvoke "append" (lowerExprs typeDecls recordDecls env localEnv fnContext args)
  } else if expressionSummary extra == "" then {
    match inferredExprType typeDecls recordDecls env localEnv fnContext left {
      TNamed label ->
        if label == "View" then LowerViewAppend (lowerExpr typeDecls recordDecls env localEnv fnContext left) (lowerExpr typeDecls recordDecls env localEnv fnContext right) else LowerListAppend (lowerExpr typeDecls recordDecls env localEnv fnContext left) (lowerExpr typeDecls recordDecls env localEnv fnContext right),
      TApply label args ->
        LowerListAppend (lowerExpr typeDecls recordDecls env localEnv fnContext left) (lowerExpr typeDecls recordDecls env localEnv fnContext right),
      TInt ->
        LowerListAppend (lowerExpr typeDecls recordDecls env localEnv fnContext left) (lowerExpr typeDecls recordDecls env localEnv fnContext right),
      TStr ->
        LowerListAppend (lowerExpr typeDecls recordDecls env localEnv fnContext left) (lowerExpr typeDecls recordDecls env localEnv fnContext right),
      TBool ->
        LowerListAppend (lowerExpr typeDecls recordDecls env localEnv fnContext left) (lowerExpr typeDecls recordDecls env localEnv fnContext right),
      TList itemType ->
        LowerListAppend (lowerExpr typeDecls recordDecls env localEnv fnContext left) (lowerExpr typeDecls recordDecls env localEnv fnContext right),
      TFunction inputType resultType ->
        LowerListAppend (lowerExpr typeDecls recordDecls env localEnv fnContext left) (lowerExpr typeDecls recordDecls env localEnv fnContext right),
      TVar label ->
        LowerListAppend (lowerExpr typeDecls recordDecls env localEnv fnContext left) (lowerExpr typeDecls recordDecls env localEnv fnContext right),
      TUnknown label ->
        LowerListAppend (lowerExpr typeDecls recordDecls env localEnv fnContext left) (lowerExpr typeDecls recordDecls env localEnv fnContext right)
    }
  } else {
    LowerInvoke "append" (lowerExprs typeDecls recordDecls env localEnv fnContext args)
  }
}

lowerPrependExpr : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [TypeBinding] -> [TypeBinding] -> ReturnContext -> [HostedExprAst] -> LowerExprText
lowerPrependExpr typeDecls recordDecls env localEnv fnContext args = {
  let value = firstHostedExpr args;
  let remaining = remainingHostedExprs args;
  let values = firstHostedExpr remaining;
  let extra = firstHostedExpr (remainingHostedExprs remaining);
  if expressionSummary value == "" then {
    LowerInvoke "prepend" (lowerExprs typeDecls recordDecls env localEnv fnContext args)
  } else if expressionSummary values == "" then {
    LowerInvoke "prepend" (lowerExprs typeDecls recordDecls env localEnv fnContext args)
  } else if expressionSummary extra == "" then {
    LowerListPrepend (lowerExpr typeDecls recordDecls env localEnv fnContext value) (lowerExpr typeDecls recordDecls env localEnv fnContext values)
  } else {
    LowerInvoke "prepend" (lowerExprs typeDecls recordDecls env localEnv fnContext args)
  }
}

lowerReverseExpr : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [TypeBinding] -> [TypeBinding] -> ReturnContext -> [HostedExprAst] -> LowerExprText
lowerReverseExpr typeDecls recordDecls env localEnv fnContext args = {
  let values = firstHostedExpr args;
  let extra = firstHostedExpr (remainingHostedExprs args);
  if expressionSummary values == "" then {
    LowerInvoke "reverse" (lowerExprs typeDecls recordDecls env localEnv fnContext args)
  } else if expressionSummary extra == "" then {
    LowerListReverse (lowerExpr typeDecls recordDecls env localEnv fnContext values)
  } else {
    LowerInvoke "reverse" (lowerExprs typeDecls recordDecls env localEnv fnContext args)
  }
}

lowerLengthExpr : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [TypeBinding] -> [TypeBinding] -> ReturnContext -> [HostedExprAst] -> LowerExprText
lowerLengthExpr typeDecls recordDecls env localEnv fnContext args = {
  let value = firstHostedExpr args;
  let extra = firstHostedExpr (remainingHostedExprs args);
  if expressionSummary value == "" then {
    LowerInvoke "length" (lowerExprs typeDecls recordDecls env localEnv fnContext args)
  } else if expressionSummary extra == "" then {
    LowerLength (lowerExpr typeDecls recordDecls env localEnv fnContext value)
  } else {
    LowerInvoke "length" (lowerExprs typeDecls recordDecls env localEnv fnContext args)
  }
}

lowerMapExpr : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [TypeBinding] -> [TypeBinding] -> ReturnContext -> [HostedExprAst] -> LowerExprText
lowerMapExpr typeDecls recordDecls env localEnv fnContext args = {
  let functionExpr = firstHostedExpr args;
  let valuesExpr = firstHostedExpr (remainingHostedExprs args);
  let extraExpr = firstHostedExpr (remainingHostedExprs (remainingHostedExprs args));
  if expressionSummary functionExpr == "" then {
    LowerInvoke "map" (lowerExprs typeDecls recordDecls env localEnv fnContext args)
  } else if expressionSummary valuesExpr == "" then {
    LowerInvoke "map" (lowerExprs typeDecls recordDecls env localEnv fnContext args)
  } else if expressionSummary extraExpr == "" then {
    match functionExpr {
      HostedName functionName ->
        LowerListMap functionName (lowerExpr typeDecls recordDecls env localEnv fnContext valuesExpr),
      HostedString value ->
        LowerInvoke "map" (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedInt value ->
        LowerInvoke "map" (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedBool value ->
        LowerInvoke "map" (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedList values ->
        LowerInvoke "map" (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedCall callee values ->
        LowerInvoke "map" (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedConstructor constructorName values ->
        LowerInvoke "map" (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedMatch subject branches ->
