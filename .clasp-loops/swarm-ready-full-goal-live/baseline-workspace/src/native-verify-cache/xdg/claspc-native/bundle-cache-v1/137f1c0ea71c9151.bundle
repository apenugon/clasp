appendTypeDecl : [HostedTypeDeclAst] -> HostedTypeDeclAst -> [HostedTypeDeclAst]
appendTypeDecl values value = append values [value]

appendRecordDecl : [HostedRecordDeclAst] -> HostedRecordDeclAst -> [HostedRecordDeclAst]
appendRecordDecl values value = append values [value]

appendForeignDecl : [HostedForeignDeclAst] -> HostedForeignDeclAst -> [HostedForeignDeclAst]
appendForeignDecl values value = append values [value]

applyForeignSignature : HostedForeignDeclAst -> Str -> Str -> HostedForeignDeclAst
applyForeignSignature foreignDecl targetName signature = if foreignDeclName foreignDecl == targetName then hostedForeignDeclAst (foreignDeclName foreignDecl) (foreignDeclUnsafeInterop foreignDecl) (foreignDeclTypeAst foreignDecl) (foreignDeclRuntimeName foreignDecl) (foreignDeclSource foreignDecl) signature else foreignDecl

applyForeignSignatureList : [HostedForeignDeclAst] -> Str -> Str -> [HostedForeignDeclAst]
applyForeignSignatureList foreignDecls targetName signature = {
  let mut updated = emptyHostedForeignDecls;
  for foreignDecl in foreignDecls {
    updated = appendForeignDecl updated (applyForeignSignature foreignDecl targetName signature);
    updated
  };
  updated
}

appendDecl : [HostedDeclAst] -> HostedDeclAst -> [HostedDeclAst]
appendDecl values value = append values [value]

appendGuideDecl : [HostedGuideDeclAst] -> HostedGuideDeclAst -> [HostedGuideDeclAst]
appendGuideDecl values value = append values [value]

appendPolicyDecl : [HostedPolicyDeclAst] -> HostedPolicyDeclAst -> [HostedPolicyDeclAst]
appendPolicyDecl values value = append values [value]

