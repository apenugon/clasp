recordUpdateLowerTempName : Str
recordUpdateLowerTempName = "__clasp_record_update_subject__"

lowerRecordUpdateExpr : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [TypeBinding] -> [TypeBinding] -> ReturnContext -> [HostedExprAst] -> LowerExprText
lowerRecordUpdateExpr typeDecls recordDecls env localEnv fnContext args = {
  let subjectExpr = firstHostedExpr args;
  let overrideExpr = firstHostedExpr (remainingHostedExprs args);
  let extraExpr = firstHostedExpr (remainingHostedExprs (remainingHostedExprs args));
  if expressionSummary subjectExpr == "" then {
    LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args)
  } else if expressionSummary overrideExpr == "" then {
    LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args)
  } else if expressionSummary extraExpr == "" then {
    match overrideExpr {
      HostedRecord overrideName fields ->
        if overrideName == recordUpdatePlaceholderName then {
          match inferredExprType typeDecls recordDecls env localEnv fnContext subjectExpr {
            TNamed recordName ->
              match lookupRecordDecl recordDecls recordName {
                FoundRecord recordDecl -> {
                  let mut loweredFields = emptyLowerRecordFields;
                  for fieldDecl in recordDeclFields recordDecl {
                    let fieldName = recordFieldDeclName fieldDecl;
                    let loweredValue = match lookupRecordExprField fields fieldName {
                      FoundRecordExprField exprField ->
                        lowerExpr typeDecls recordDecls env localEnv fnContext (recordExprFieldValue exprField),
                      MissingRecordExprField missingField ->
                        LowerFieldAccess recordName (LowerName recordUpdateLowerTempName) fieldName
                    };
                    loweredFields = appendLowerRecordField loweredFields (LowerRecordFieldText fieldName loweredValue);
                    loweredFields
                  };
                  LowerLet recordUpdateLowerTempName (lowerExpr typeDecls recordDecls env localEnv fnContext subjectExpr) (LowerRecord recordName loweredFields)
                },
                MissingRecord missing ->
                  LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args)
              },
            TApply recordName typeArgs ->
              match lookupRecordDecl recordDecls recordName {
                FoundRecord recordDecl -> {
                  let mut loweredFields = emptyLowerRecordFields;
                  for fieldDecl in recordDeclFields recordDecl {
                    let fieldName = recordFieldDeclName fieldDecl;
                    let loweredValue = match lookupRecordExprField fields fieldName {
                      FoundRecordExprField exprField ->
                        lowerExpr typeDecls recordDecls env localEnv fnContext (recordExprFieldValue exprField),
                      MissingRecordExprField missingField ->
                        LowerFieldAccess recordName (LowerName recordUpdateLowerTempName) fieldName
                    };
                    loweredFields = appendLowerRecordField loweredFields (LowerRecordFieldText fieldName loweredValue);
                    loweredFields
                  };
                  LowerLet recordUpdateLowerTempName (lowerExpr typeDecls recordDecls env localEnv fnContext subjectExpr) (LowerRecord recordName loweredFields)
                },
                MissingRecord missing ->
                  LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args)
              },
            TInt ->
              LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
            TStr ->
              LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
            TBool ->
              LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
            TList itemType ->
              LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
            TFunction inputType resultType ->
              LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
            TVar label ->
              LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
            TUnknown label ->
              LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args)
          }
        } else {
          LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args)
        },
      HostedName name ->
        LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedString value ->
        LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedInt value ->
        LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedBool value ->
        LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedList values ->
        LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedCall callee values ->
        LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedConstructor constructorName values ->
        LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedMatch subject branches ->
        LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedFieldAccess subject fieldName ->
        LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedLet binder value body ->
        LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedMutableLet binder value body ->
        LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedAssign binder value body ->
        LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedFor binder iterable loopBody body ->
        LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedReturn value ->
        LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedIf condition thenBranch elseBranch ->
        LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedEqual left right ->
        LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedNotEqual left right ->
        LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedLessThan left right ->
        LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedLessThanOrEqual left right ->
        LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedGreaterThan left right ->
        LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
      HostedGreaterThanOrEqual left right ->
        LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args)
    }
  } else {
    LowerInvoke recordUpdateBuiltinName (lowerExprs typeDecls recordDecls env localEnv fnContext args)
  }
}

lowerExpr : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [TypeBinding] -> [TypeBinding] -> ReturnContext -> HostedExprAst -> LowerExprText
lowerExpr typeDecls recordDecls env localEnv fnContext expr = match expr {
  HostedName name ->
    LowerName name,
  HostedString value ->
    LowerLiteral value,
  HostedInt value ->
    LowerInt value,
  HostedBool value ->
    LowerBool value,
  HostedList values ->
    LowerArray (lowerExprs typeDecls recordDecls env localEnv fnContext values),
  HostedCall callee args ->
    if callee == "append" then lowerAppendExpr typeDecls recordDecls env localEnv fnContext args else if callee == "prepend" then lowerPrependExpr typeDecls recordDecls env localEnv fnContext args else if callee == "reverse" then lowerReverseExpr typeDecls recordDecls env localEnv fnContext args else if callee == "length" then lowerLengthExpr typeDecls recordDecls env localEnv fnContext args else if callee == "map" then lowerMapExpr typeDecls recordDecls env localEnv fnContext args else if callee == "filter" then lowerFilterExpr typeDecls recordDecls env localEnv fnContext args else if callee == "any" then lowerAnyExpr typeDecls recordDecls env localEnv fnContext args else if callee == "all" then lowerAllExpr typeDecls recordDecls env localEnv fnContext args else if callee == "fold" then lowerFoldExpr typeDecls recordDecls env localEnv fnContext args else if callee == "decode" then lowerDecodeExpr typeDecls recordDecls env localEnv fnContext args else if callee == "encode" then lowerEncodeExpr typeDecls recordDecls env localEnv fnContext args else if callee == recordUpdateBuiltinName then lowerRecordUpdateExpr typeDecls recordDecls env localEnv fnContext args else LowerInvoke callee (lowerExprs typeDecls recordDecls env localEnv fnContext args),
  HostedConstructor constructorName args ->
    LowerConstructor constructorName (lowerExprs typeDecls recordDecls env localEnv fnContext args),
  HostedMatch subject branches ->
    LowerMatch (lowerExpr typeDecls recordDecls env localEnv fnContext subject) (lowerMatchBranches typeDecls recordDecls env localEnv fnContext branches),
  HostedRecord recordName fields ->
    LowerRecord recordName (lowerRecordFields typeDecls recordDecls env localEnv fnContext fields),
  HostedFieldAccess subject fieldName ->
    LowerFieldAccess (recordNameForType (inferredExprType typeDecls recordDecls env localEnv fnContext subject)) (lowerExpr typeDecls recordDecls env localEnv fnContext subject) fieldName,
  HostedLet binder value body ->
    LowerLet binder (lowerExpr typeDecls recordDecls env localEnv fnContext value) (lowerExpr typeDecls recordDecls env (extendLowerLocalEnv typeDecls recordDecls env localEnv fnContext binder value) fnContext body),
  HostedMutableLet binder value body ->
    LowerMutableLet binder (lowerExpr typeDecls recordDecls env localEnv fnContext value) (lowerExpr typeDecls recordDecls env (extendLowerLocalEnv typeDecls recordDecls env localEnv fnContext binder value) fnContext body),
  HostedAssign binder value body ->
    LowerAssign binder (lowerExpr typeDecls recordDecls env localEnv fnContext value) (lowerExpr typeDecls recordDecls env localEnv fnContext body),
  HostedFor binder iterable loopBody body ->
    LowerFor binder (lowerExpr typeDecls recordDecls env localEnv fnContext iterable) (lowerExpr typeDecls recordDecls env (extendLowerLoopLocalEnv typeDecls recordDecls env localEnv fnContext binder iterable) fnContext loopBody) (lowerExpr typeDecls recordDecls env localEnv fnContext body),
  HostedReturn value ->
    LowerReturn (lowerExpr typeDecls recordDecls env localEnv fnContext value),
  HostedIf condition thenBranch elseBranch ->
    LowerIf (lowerExpr typeDecls recordDecls env localEnv fnContext condition) (lowerExpr typeDecls recordDecls env localEnv fnContext thenBranch) (lowerExpr typeDecls recordDecls env localEnv fnContext elseBranch),
  HostedEqual left right ->
    LowerEqual (lowerExpr typeDecls recordDecls env localEnv fnContext left) (lowerExpr typeDecls recordDecls env localEnv fnContext right),
  HostedNotEqual left right ->
    LowerNotEqual (lowerExpr typeDecls recordDecls env localEnv fnContext left) (lowerExpr typeDecls recordDecls env localEnv fnContext right),
  HostedLessThan left right ->
    LowerLessThan (lowerExpr typeDecls recordDecls env localEnv fnContext left) (lowerExpr typeDecls recordDecls env localEnv fnContext right),
  HostedLessThanOrEqual left right ->
    LowerLessThanOrEqual (lowerExpr typeDecls recordDecls env localEnv fnContext left) (lowerExpr typeDecls recordDecls env localEnv fnContext right),
  HostedGreaterThan left right ->
    LowerGreaterThan (lowerExpr typeDecls recordDecls env localEnv fnContext left) (lowerExpr typeDecls recordDecls env localEnv fnContext right),
  HostedGreaterThanOrEqual left right ->
    LowerGreaterThanOrEqual (lowerExpr typeDecls recordDecls env localEnv fnContext left) (lowerExpr typeDecls recordDecls env localEnv fnContext right)
}

lowerFunctionLocalEnv : HostedDeclAst -> [TypeBinding]
lowerFunctionLocalEnv decl = if hasAnnotationAst (declAnnotation decl) then {
  let declaredType = instantiateGenericType (textConcat ["decl:", declName decl]) (typeFromHostedTypeAst (annotationTypeAst (declAnnotation decl)));
  match bindFunctionParams decl declaredType {
    BindingParams localEnv expectedBodyType ->
      localEnv,
    BindingParamError message ->
      emptyTypeBindings
  }
} else {
  emptyTypeBindings
}

lowerFunctionFnContext : HostedDeclAst -> ReturnContext
lowerFunctionFnContext decl = if hasAnnotationAst (declAnnotation decl) then {
  let declaredType = instantiateGenericType (textConcat ["decl:", declName decl]) (typeFromHostedTypeAst (annotationTypeAst (declAnnotation decl)));
  match bindFunctionParams decl declaredType {
    BindingParams localEnv expectedBodyType ->
      InsideFunction expectedBodyType,
    BindingParamError message ->
      OutsideFunction
  }
} else {
  OutsideFunction
}

lowerDecl : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [TypeBinding] -> HostedDeclAst -> LowerDeclText
lowerDecl typeDecls recordDecls env decl = if hasLowerParams decl then LowerFn (declName decl) (declParams decl) (lowerExpr typeDecls recordDecls env (lowerFunctionLocalEnv decl) (lowerFunctionFnContext decl) (declBody decl)) else LowerConst (declName decl) (lowerExpr typeDecls recordDecls env emptyTypeBindings OutsideFunction (declBody decl))

lowerModule : HostedModuleAst -> [LowerDeclText]
lowerModule modl = {
  let typeDecls = effectiveModuleTypeDecls modl;
  let recordDecls = effectiveModuleRecordDecls modl;
  let env = lowerModuleEnv modl typeDecls;
  let mut lowered = emptyLowerDecls;
  for decl in moduleDeclarations modl {
    lowered = appendLowerDecl lowered (lowerDecl typeDecls recordDecls env decl);
    lowered
  };
  lowered
}

renderLowerExprs : [LowerExprText] -> [Str]
renderLowerExprs values = {
  let mut rendered = emptyRenderedTexts;
  for value in values {
    rendered = appendLowerRenderedText rendered (renderLowerExpr value);
    rendered
  };
  rendered
}

renderLowerRecordFields : [LowerRecordFieldText] -> [Str]
renderLowerRecordFields fields = {
  let mut rendered = emptyRenderedTexts;
  for field in fields {
    rendered = appendLowerRenderedText rendered (renderLowerRecordField field);
    rendered
  };
  rendered
}

renderLowerRecordField : LowerRecordFieldText -> Str
renderLowerRecordField field = match field {
  LowerRecordFieldText name value ->
    textConcat [name, " = ", renderLowerExpr value]
}

renderLowerMatchBranch : LowerMatchBranchText -> Str
renderLowerMatchBranch branch = match branch {
  LowerMatchBranchText constructorName binders body ->
    textConcat [constructorName, "(", textJoin ", " binders, ") -> ", renderLowerExpr body]
}

renderLowerMatchBranches : [LowerMatchBranchText] -> [Str]
renderLowerMatchBranches branches = {
  let mut rendered = emptyRenderedTexts;
  for branch in branches {
    rendered = appendLowerRenderedText rendered (renderLowerMatchBranch branch);
    rendered
  };
  rendered
}

renderLowerExpr : LowerExprText -> Str
renderLowerExpr expr = match expr {
  LowerName name ->
    textConcat ["name:", name],
  LowerLiteral value ->
    textConcat ["literal:", value],
  LowerInt value ->
    textConcat ["int:", value],
  LowerBool value ->
    textConcat ["bool:", if value then "true" else "false"],
  LowerArray values ->
    textConcat ["list:[", textJoin ", " (renderLowerExprs values), "]"],
  LowerListAppend left right ->
    textConcat ["list.append(", renderLowerExpr left, ", ", renderLowerExpr right, ")"],
  LowerListPrepend value values ->
    textConcat ["list.prepend(", renderLowerExpr value, ", ", renderLowerExpr values, ")"],
  LowerListReverse values ->
    textConcat ["list.reverse(", renderLowerExpr values, ")"],
  LowerLength value ->
    textConcat ["length(", renderLowerExpr value, ")"],
  LowerListMap callee values ->
    textConcat ["list.map(", callee, ", ", renderLowerExpr values, ")"],
  LowerListFilter callee values ->
    textConcat ["list.filter(", callee, ", ", renderLowerExpr values, ")"],
  LowerListAny callee values ->
    textConcat ["list.any(", callee, ", ", renderLowerExpr values, ")"],
  LowerListAll callee values ->
    textConcat ["list.all(", callee, ", ", renderLowerExpr values, ")"],
  LowerListFold callee initial values ->
    textConcat ["list.fold(", callee, ", ", renderLowerExpr initial, ", ", renderLowerExpr values, ")"],
  LowerViewAppend left right ->
    textConcat ["view.append(", renderLowerExpr left, ", ", renderLowerExpr right, ")"],
  LowerEncode value ->
    textConcat ["encode(", renderLowerExpr value, ")"],
  LowerDecode targetType value ->
    textConcat ["decode(", renderType targetType, ", ", renderLowerExpr value, ")"],
  LowerInvoke callee args ->
    textConcat ["call ", callee, "(", textJoin ", " (renderLowerExprs args), ")"],
  LowerConstructor constructorName args ->
    textConcat ["ctor ", constructorName, "(", textJoin ", " (renderLowerExprs args), ")"],
  LowerMatch subject branches ->
    textConcat ["match ", renderLowerExpr subject, " [", textJoin ", " (renderLowerMatchBranches branches), "]"],
  LowerRecord recordName fields ->
    textConcat ["record ", recordName, " {", textJoin ", " (renderLowerRecordFields fields), "}"],
  LowerFieldAccess recordName subject fieldName ->
    if recordName == "" then textConcat ["field(", renderLowerExpr subject, ", ", fieldName, ")"] else textConcat ["field(", recordName, ", ", renderLowerExpr subject, ", ", fieldName, ")"],
  LowerLet binder value body ->
    textConcat ["let ", binder, " = ", renderLowerExpr value, " in ", renderLowerExpr body],
  LowerMutableLet binder value body ->
    textConcat ["let mut ", binder, " = ", renderLowerExpr value, " in ", renderLowerExpr body],
  LowerAssign binder value body ->
    textConcat ["assign ", binder, " = ", renderLowerExpr value, " then ", renderLowerExpr body],
  LowerFor binder iterable loopBody body ->
    textConcat ["for ", binder, " in ", renderLowerExpr iterable, " do ", renderLowerExpr loopBody, " then ", renderLowerExpr body],
  LowerReturn value ->
    textConcat ["return ", renderLowerExpr value],
  LowerIf condition thenBranch elseBranch ->
    textConcat ["if ", renderLowerExpr condition, " then ", renderLowerExpr thenBranch, " else ", renderLowerExpr elseBranch],
  LowerEqual left right ->
    textConcat ["eq(", renderLowerExpr left, ", ", renderLowerExpr right, ")"],
  LowerNotEqual left right ->
    textConcat ["ne(", renderLowerExpr left, ", ", renderLowerExpr right, ")"],
  LowerLessThan left right ->
    textConcat ["lt(", renderLowerExpr left, ", ", renderLowerExpr right, ")"],
  LowerLessThanOrEqual left right ->
    textConcat ["le(", renderLowerExpr left, ", ", renderLowerExpr right, ")"],
  LowerGreaterThan left right ->
    textConcat ["gt(", renderLowerExpr left, ", ", renderLowerExpr right, ")"],
  LowerGreaterThanOrEqual left right ->
    textConcat ["ge(", renderLowerExpr left, ", ", renderLowerExpr right, ")"]
}

renderLowerDecl : LowerDeclText -> Str
renderLowerDecl decl = match decl {
  LowerConst name body ->
    textConcat ["const ", name, " = ", renderLowerExpr body],
  LowerFn name params body ->
    textConcat ["function ", name, "(", textJoin ", " params, ") = ", renderLowerExpr body]
}

renderLowerModuleSummary : [LowerDeclText] -> Str
renderLowerModuleSummary decls = {
  let mut rendered = emptyRenderedTexts;
  for decl in decls {
    rendered = appendLowerRenderedText rendered (renderLowerDecl decl);
    rendered
  };
  textJoin "\n" rendered
}

renderLowerDeclByName : [LowerDeclText] -> Str -> Str
renderLowerDeclByName decls targetName = {
  let mut rendered = textConcat ["<missing:", targetName, ">"];
  for decl in decls {
    rendered = if lowerDeclName decl == targetName then renderLowerDecl decl else rendered;
    rendered
  };
  rendered
}

lowerDeclName : LowerDeclText -> Str
lowerDeclName decl = match decl {
  LowerConst name body ->
    name,
  LowerFn name params body ->
    name
}

-- CLASP_PROJECT_MODULE --
module Compiler.Project

import Compiler.Ast

type HostedProjectModuleLookupResult = FoundHostedProjectModule HostedModuleAst | MissingHostedProjectModule Str
type HostedProjectModulesResult = HostedProjectModules [HostedModuleAst] | HostedProjectModulesError Str
type HostedResolvedProjectResult = HostedResolvedProjectOk HostedModuleAst [HostedModuleAst] | HostedResolvedProjectError Str
type HostedProjectBundleResult = HostedProjectBundleOk HostedModuleAst | HostedProjectBundleError Str

keepNoHostedModule : HostedModuleAst -> Bool
keepNoHostedModule modl = false

emptyHostedModules : [HostedModuleAst]
emptyHostedModules = filter keepNoHostedModule [hostedModuleAst "" emptyRenderedTexts emptyHostedTypeDecls emptyHostedRecordDecls emptyHostedForeignDecls emptyHostedDecls emptyHostedGuideDecls emptyHostedPolicyDecls emptyHostedProjectionDecls emptyHostedAgentRoleDecls emptyHostedAgentDecls emptyHostedWorkflowDecls emptyHostedRouteDecls emptyHostedHookDecls emptyHostedToolServerDecls emptyHostedToolDecls emptyHostedVerifierDecls emptyHostedMergeGateDecls ""]

sourceModule : Str -> HostedModuleAst
sourceModule source = synthesizeModuleProjections (parseModuleAst source)

lookupRecordDeclByName : [HostedRecordDeclAst] -> Str -> HostedRecordDeclAst
lookupRecordDeclByName recordDeclarations targetName = {
  for recordDecl in recordDeclarations {
    if recordDeclName recordDecl == targetName then {
      return recordDecl
    } else {
      recordDecl
    }
  };
  hostedRecordDeclAst targetName emptyHostedRecordFieldDecls
}

projectRecordFields : HostedRecordDeclAst -> [HostedProjectionFieldDeclAst] -> [HostedRecordFieldDeclAst]
projectRecordFields sourceRecord projectionFields = {
  let mut projectedFieldsReversed = emptyHostedRecordFieldDecls;
  for projectionField in projectionFields {
    let targetName = projectionFieldDeclName projectionField;
    for recordField in recordDeclFields sourceRecord {
      if recordFieldDeclName recordField == targetName then {
        projectedFieldsReversed = prepend recordField projectedFieldsReversed;
        projectedFieldsReversed
      } else {
        projectedFieldsReversed
      }
    };
    projectedFieldsReversed
  };
  reverse projectedFieldsReversed
}

synthesizeProjectionRecordDecl : [HostedRecordDeclAst] -> HostedProjectionDeclAst -> HostedRecordDeclAst
synthesizeProjectionRecordDecl recordDeclarations projectionDecl = {
  let sourceRecord = lookupRecordDeclByName recordDeclarations (projectionDeclSourceRecordName projectionDecl);
  hostedRecordDeclAst (projectionDeclName projectionDecl) (projectRecordFields sourceRecord (projectionDeclFields projectionDecl))
}

appendProjectionRecordDecls : [HostedRecordDeclAst] -> [HostedProjectionDeclAst] -> [HostedRecordDeclAst]
appendProjectionRecordDecls recordDeclarations projectionDeclarations = {
  let mut allRecordDeclarations = recordDeclarations;
  for projectionDecl in projectionDeclarations {
    allRecordDeclarations = append allRecordDeclarations [synthesizeProjectionRecordDecl allRecordDeclarations projectionDecl];
    allRecordDeclarations
  };
  allRecordDeclarations
}

synthesizeModuleProjections : HostedModuleAst -> HostedModuleAst
synthesizeModuleProjections modl = {
  let projectionDeclarations = moduleProjectionDeclarations modl;
  let recordDeclarations = appendProjectionRecordDecls (moduleRecordDeclarations modl) projectionDeclarations;
  hostedModuleAst (moduleNameOf modl) (moduleImports modl) (moduleTypeDeclarations modl) recordDeclarations (moduleForeignDeclarations modl) (moduleDeclarations modl) (moduleGuideDeclarations modl) (modulePolicyDeclarations modl) projectionDeclarations (moduleAgentRoleDeclarations modl) (moduleAgentDeclarations modl) (moduleWorkflowDeclarations modl) (moduleRouteDeclarations modl) (moduleHookDeclarations modl) (moduleToolServerDeclarations modl) (moduleToolDeclarations modl) (moduleVerifierDeclarations modl) (moduleMergeGateDeclarations modl) (moduleMainExprSummary modl)
}

frontendOnlyCompileError : Str
frontendOnlyCompileError = "// compiler-selfhost frontend-only compile error: backend declarations must use nativeSourceText or nativeProjectText."

backendDeclarationKeyword : Str -> Bool
backendDeclarationKeyword keyword = if keyword == "route" then true else if keyword == "guide" then true else if keyword == "policy" then true else if keyword == "role" then true else if keyword == "agent" then true else if keyword == "workflow" then true else if keyword == "hook" then true else if keyword == "toolserver" then true else if keyword == "tool" then true else if keyword == "verifier" then true else if keyword == "mergegate" then true else false

sourceDeclaresBackendSurface : Str -> Bool
sourceDeclaresBackendSurface source = {
  for line in textSplit source "\n" {
    let trimmed = trimSpaces line;
    let keyword = firstText (splitWords trimmed);
    if backendDeclarationKeyword keyword then return true else false
  };
  false
}

projectBundleSeparator : Str
projectBundleSeparator = "\n-- CLASP_PROJECT_MODULE --\n"

parseProjectModules : Str -> [HostedModuleAst]
parseProjectModules bundle = {
  let mut modulesReversed = emptyHostedModules;
  for source in textSplit bundle projectBundleSeparator {
    let trimmed = trimSpaces source;
    if trimmed == "" then {
      modulesReversed
    } else {
      modulesReversed = prepend (sourceModule trimmed) modulesReversed;
      modulesReversed
    }
  };
  reverse modulesReversed
}

lookupProjectModule : [HostedModuleAst] -> Str -> HostedProjectModuleLookupResult
lookupProjectModule modules targetName = {
  for modl in modules {
    if moduleNameOf modl == targetName then {
      return FoundHostedProjectModule modl
    } else {
      MissingHostedProjectModule targetName
    }
  };
  MissingHostedProjectModule targetName
}

containsProjectModule : [HostedModuleAst] -> Str -> Bool
containsProjectModule modules targetName = {
  for modl in modules {
    if moduleNameOf modl == targetName then return true else false
  };
  false
}

hasProjectModules : [HostedModuleAst] -> Bool
hasProjectModules modules = {
  for modl in modules {
    return true
  };
  false
}

appendUniqueProjectModules : [HostedModuleAst] -> [HostedModuleAst] -> [HostedModuleAst]
appendUniqueProjectModules modules additions = {
  let mut combinedReversed = reverse modules;
  for modl in additions {
    let name = moduleNameOf modl;
    if containsProjectModule combinedReversed name then {
      combinedReversed
    } else {
      combinedReversed = prepend modl combinedReversed;
      combinedReversed
    }
  };
  reverse combinedReversed
}

collectProjectImportNames : [HostedModuleAst] -> [Str]
collectProjectImportNames modules = {
  let mut importedNamesReversed = emptyRenderedTexts;
  for modl in modules {
    for importName in moduleImports modl {
      if containsText importedNamesReversed importName then {
        importedNamesReversed
      } else {
        importedNamesReversed = prepend importName importedNamesReversed;
        importedNamesReversed
      }
    };
    importedNamesReversed
  };
  reverse importedNamesReversed
}

collectProjectImports : [HostedModuleAst] -> [Str] -> [Str] -> HostedProjectModulesResult
collectProjectImports modules seen dependencyNames = {
  let dependencyName = firstText dependencyNames;
  let remainingDependencyNames = remainingTexts dependencyNames;
  if dependencyName == "" then {
    HostedProjectModules emptyHostedModules
  } else if containsText seen dependencyName then {
    collectProjectImports modules seen remainingDependencyNames
  } else {
    match lookupProjectModule modules dependencyName {
      FoundHostedProjectModule imported ->
        match collectProjectImports modules (prepend dependencyName seen) (moduleImports imported) {
          HostedProjectModules nestedImports ->
            match collectProjectImports modules (prepend dependencyName seen) remainingDependencyNames {
              HostedProjectModules remainingImports ->
                HostedProjectModules (appendUniqueProjectModules (appendUniqueProjectModules nestedImports [imported]) remainingImports),
              HostedProjectModulesError message ->
                HostedProjectModulesError message
            },
          HostedProjectModulesError message ->
            HostedProjectModulesError message
        },
      MissingHostedProjectModule missing ->
        HostedProjectModulesError (textConcat ["Missing imported module `", missing, "`."])
    }
  }
}

mergeProjectModules : HostedModuleAst -> [HostedModuleAst] -> HostedModuleAst
mergeProjectModules entry importedModules = {
  let mut typeDeclarationsReversed = emptyHostedTypeDecls;
  let mut recordDeclarationsReversed = emptyHostedRecordDecls;
  let mut foreignDeclarationsReversed = emptyHostedForeignDecls;
  let mut declarationsReversed = emptyHostedDecls;
  let mut guideDeclarationsReversed = emptyHostedGuideDecls;
  let mut policyDeclarationsReversed = emptyHostedPolicyDecls;
  let mut projectionDeclarationsReversed = emptyHostedProjectionDecls;
  let mut agentRoleDeclarationsReversed = emptyHostedAgentRoleDecls;
  let mut agentDeclarationsReversed = emptyHostedAgentDecls;
  let mut workflowDeclarationsReversed = emptyHostedWorkflowDecls;
  let mut routeDeclarationsReversed = emptyHostedRouteDecls;
  let mut hookDeclarationsReversed = emptyHostedHookDecls;
  let mut toolServerDeclarationsReversed = emptyHostedToolServerDecls;
  let mut toolDeclarationsReversed = emptyHostedToolDecls;
  let mut verifierDeclarationsReversed = emptyHostedVerifierDecls;
  let mut mergeGateDeclarationsReversed = emptyHostedMergeGateDecls;
  for modl in append importedModules [entry] {
    for typeDeclaration in moduleTypeDeclarations modl {
      typeDeclarationsReversed = prepend typeDeclaration typeDeclarationsReversed;
      typeDeclarationsReversed
    };
    for recordDeclaration in moduleRecordDeclarations modl {
      recordDeclarationsReversed = prepend recordDeclaration recordDeclarationsReversed;
      recordDeclarationsReversed
    };
    for foreignDeclaration in moduleForeignDeclarations modl {
      foreignDeclarationsReversed = prepend foreignDeclaration foreignDeclarationsReversed;
      foreignDeclarationsReversed
    };
    for declaration in moduleDeclarations modl {
      declarationsReversed = prepend declaration declarationsReversed;
      declarationsReversed
    };
    for guideDeclaration in moduleGuideDeclarations modl {
      guideDeclarationsReversed = prepend guideDeclaration guideDeclarationsReversed;
      guideDeclarationsReversed
    };
    for policyDeclaration in modulePolicyDeclarations modl {
      policyDeclarationsReversed = prepend policyDeclaration policyDeclarationsReversed;
      policyDeclarationsReversed
    };
    for projectionDeclaration in moduleProjectionDeclarations modl {
      projectionDeclarationsReversed = prepend projectionDeclaration projectionDeclarationsReversed;
      projectionDeclarationsReversed
    };
    for agentRoleDeclaration in moduleAgentRoleDeclarations modl {
      agentRoleDeclarationsReversed = prepend agentRoleDeclaration agentRoleDeclarationsReversed;
      agentRoleDeclarationsReversed
    };
    for agentDeclaration in moduleAgentDeclarations modl {
      agentDeclarationsReversed = prepend agentDeclaration agentDeclarationsReversed;
      agentDeclarationsReversed
    };
    for workflowDeclaration in moduleWorkflowDeclarations modl {
      workflowDeclarationsReversed = prepend workflowDeclaration workflowDeclarationsReversed;
      workflowDeclarationsReversed
    };
    for routeDeclaration in moduleRouteDeclarations modl {
      routeDeclarationsReversed = prepend routeDeclaration routeDeclarationsReversed;
      routeDeclarationsReversed
    };
    for hookDeclaration in moduleHookDeclarations modl {
      hookDeclarationsReversed = prepend hookDeclaration hookDeclarationsReversed;
      hookDeclarationsReversed
    };
    for toolServerDeclaration in moduleToolServerDeclarations modl {
      toolServerDeclarationsReversed = prepend toolServerDeclaration toolServerDeclarationsReversed;
      toolServerDeclarationsReversed
    };
    for toolDeclaration in moduleToolDeclarations modl {
      toolDeclarationsReversed = prepend toolDeclaration toolDeclarationsReversed;
      toolDeclarationsReversed
    };
    for verifierDeclaration in moduleVerifierDeclarations modl {
      verifierDeclarationsReversed = prepend verifierDeclaration verifierDeclarationsReversed;
      verifierDeclarationsReversed
    };
    for mergeGateDeclaration in moduleMergeGateDeclarations modl {
      mergeGateDeclarationsReversed = prepend mergeGateDeclaration mergeGateDeclarationsReversed;
      mergeGateDeclarationsReversed
    };
    declarationsReversed
  };
  let typeDeclarations = reverse typeDeclarationsReversed;
  let recordDeclarations = reverse recordDeclarationsReversed;
  let foreignDeclarations = reverse foreignDeclarationsReversed;
  let declarations = reverse declarationsReversed;
  let guideDeclarations = reverse guideDeclarationsReversed;
  let policyDeclarations = reverse policyDeclarationsReversed;
  let projectionDeclarations = reverse projectionDeclarationsReversed;
  let agentRoleDeclarations = reverse agentRoleDeclarationsReversed;
  let agentDeclarations = reverse agentDeclarationsReversed;
  let workflowDeclarations = reverse workflowDeclarationsReversed;
  let routeDeclarations = reverse routeDeclarationsReversed;
  let hookDeclarations = reverse hookDeclarationsReversed;
  let toolServerDeclarations = reverse toolServerDeclarationsReversed;
  let toolDeclarations = reverse toolDeclarationsReversed;
  let verifierDeclarations = reverse verifierDeclarationsReversed;
  let mergeGateDeclarations = reverse mergeGateDeclarationsReversed;
  hostedModuleAst (moduleNameOf entry) [] typeDeclarations recordDeclarations foreignDeclarations declarations guideDeclarations policyDeclarations projectionDeclarations agentRoleDeclarations agentDeclarations workflowDeclarations routeDeclarations hookDeclarations toolServerDeclarations toolDeclarations verifierDeclarations mergeGateDeclarations (moduleMainExprSummary entry)
}

orderedProjectModules : HostedModuleAst -> [HostedModuleAst] -> [HostedModuleAst]
orderedProjectModules entry importedModules = append importedModules [entry]

projectImportedModules : [HostedModuleAst] -> Str -> [HostedModuleAst]
projectImportedModules sourceModules entryModuleName = {
  let mut importedModules = emptyHostedModules;
  for modl in sourceModules {
    if moduleNameOf modl == entryModuleName then {
      importedModules
    } else {
      importedModules = append importedModules [modl];
      importedModules
    }
  };
  importedModules
}

projectCheckScopeModule : HostedModuleAst -> [HostedModuleAst] -> HostedModuleAst
projectCheckScopeModule entry importedModules = {
  let mut typeDeclarationsReversed = emptyHostedTypeDecls;
  let mut recordDeclarationsReversed = emptyHostedRecordDecls;
  let mut foreignDeclarationsReversed = emptyHostedForeignDecls;
  for modl in append importedModules [entry] {
    for typeDeclaration in moduleTypeDeclarations modl {
      typeDeclarationsReversed = prepend typeDeclaration typeDeclarationsReversed;
      typeDeclarationsReversed
    };
    for recordDeclaration in moduleRecordDeclarations modl {
      recordDeclarationsReversed = prepend recordDeclaration recordDeclarationsReversed;
      recordDeclarationsReversed
    };
    for foreignDeclaration in moduleForeignDeclarations modl {
      foreignDeclarationsReversed = prepend foreignDeclaration foreignDeclarationsReversed;
      foreignDeclarationsReversed
    };
    foreignDeclarationsReversed
  };
  hostedModuleAst (moduleNameOf entry) (moduleImports entry) (reverse typeDeclarationsReversed) (reverse recordDeclarationsReversed) (reverse foreignDeclarationsReversed) (moduleDeclarations entry) emptyHostedGuideDecls emptyHostedPolicyDecls emptyHostedProjectionDecls emptyHostedAgentRoleDecls emptyHostedAgentDecls emptyHostedWorkflowDecls emptyHostedRouteDecls emptyHostedHookDecls emptyHostedToolServerDecls emptyHostedToolDecls emptyHostedVerifierDecls emptyHostedMergeGateDecls (moduleMainExprSummary entry)
}

resolveProjectModules : Str -> HostedResolvedProjectResult
resolveProjectModules bundle = {
  let modules = parseProjectModules bundle;
  let importedNames = collectProjectImportNames modules;
  let mut entryModuleName = "";
  let mut entryModuleConflict = false;
  for modl in modules {
    let candidateName = moduleNameOf modl;
    if containsText importedNames candidateName then {
      entryModuleConflict
    } else if entryModuleName == "" then {
      entryModuleName = candidateName;
      entryModuleConflict
    } else {
      entryModuleConflict = true;
      entryModuleConflict
    }
  };
  if entryModuleConflict then {
    HostedResolvedProjectError "Expected exactly one project entry module."
  } else if entryModuleName == "" then {
    HostedResolvedProjectError "Missing project entry module."
  } else {
    match lookupProjectModule modules entryModuleName {
      FoundHostedProjectModule entry ->
        match collectProjectImports modules [entryModuleName] (moduleImports entry) {
          HostedProjectModules importedModules ->
            if hasProjectModules importedModules then HostedResolvedProjectOk (mergeProjectModules entry importedModules) (orderedProjectModules entry importedModules) else HostedResolvedProjectOk entry [entry],
          HostedProjectModulesError message ->
            HostedResolvedProjectError message
        },
      MissingHostedProjectModule missing ->
        HostedResolvedProjectError (textConcat ["Missing project entry module `", missing, "`."])
    }
  }
}

resolveProjectBundle : Str -> HostedProjectBundleResult
resolveProjectBundle bundle = match resolveProjectModules bundle {
  HostedResolvedProjectOk mergedModule sourceModules ->
    HostedProjectBundleOk mergedModule,
  HostedResolvedProjectError message ->
    HostedProjectBundleError message
}

-- CLASP_PROJECT_MODULE --
module Compiler.Driver.Native

import Compiler.Checker
import Compiler.Emit.Native
import Compiler.Json
import Compiler.Lower
import Compiler.Project

nativeDriverSourceLoweredDecls : Str -> [LowerDeclText]
nativeDriverSourceLoweredDecls source = lowerModule (sourceModule source)

nativeDriverSourceText : Str -> Str
nativeDriverSourceText source = emitNativeModule (sourceModule source) (nativeDriverSourceLoweredDecls source)

nativeDriverImageSourceText : Str -> Str
nativeDriverImageSourceText source = emitNativeModuleImage (sourceModule source) (nativeDriverSourceLoweredDecls source)

nativeDriverProjectBundleHasSeparator : Str -> Bool
nativeDriverProjectBundleHasSeparator bundle = if firstText (remainingTexts (textSplit bundle projectBundleSeparator)) == "" then false else true

nativeDriverProjectBundleIsSingleSourceModule : Str -> Bool
nativeDriverProjectBundleIsSingleSourceModule bundle = if nativeDriverProjectBundleHasSeparator bundle then false else true

nativeDriverProjectBundleSourceModule : Str -> HostedModuleAst
nativeDriverProjectBundleSourceModule bundle = sourceModule bundle

nativeDriverProjectText : Str -> Str
nativeDriverProjectText bundle = if nativeDriverProjectBundleIsSingleSourceModule bundle then emitNativeModule (nativeDriverProjectBundleSourceModule bundle) (lowerModule (nativeDriverProjectBundleSourceModule bundle)) else match resolveProjectBundle bundle {
  HostedProjectBundleOk modl ->
    emitNativeModule modl (lowerModule modl),
  HostedProjectBundleError message ->
    textConcat ["// compiler-selfhost project error: ", message]
}

nativeDriverImageProjectText : Str -> Str
nativeDriverImageProjectText bundle = if nativeDriverProjectBundleIsSingleSourceModule bundle then emitNativeModuleImage (nativeDriverProjectBundleSourceModule bundle) (lowerModule (nativeDriverProjectBundleSourceModule bundle)) else match resolveProjectBundle bundle {
  HostedProjectBundleOk modl ->
    emitNativeModuleImage modl (lowerModule modl),
  HostedProjectBundleError message ->
    jsonObject [jsonFieldText "format" "clasp-native-image-v1", jsonFieldText "error" message]
}

nativeDriverImageProjectPlanText : Str -> Str
nativeDriverImageProjectPlanText bundle = if nativeDriverProjectBundleIsSingleSourceModule bundle then emitNativeModuleImagePlanText (nativeDriverProjectBundleSourceModule bundle) else match resolveProjectBundle bundle {
  HostedProjectBundleOk modl ->
    emitNativeModuleImagePlanText modl,
  HostedProjectBundleError message ->
    textConcat ["ERROR:", message]
}

nativeDriverImageProjectBuildPlanText : Str -> Str
nativeDriverImageProjectBuildPlanText bundle = if nativeDriverProjectBundleIsSingleSourceModule bundle then emitNativeModuleImageBuildPlanText (nativeDriverProjectBundleSourceModule bundle) [nativeDriverProjectBundleSourceModule bundle] else match resolveProjectModules bundle {
  HostedResolvedProjectOk mergedModule sourceModules ->
    emitNativeModuleImageBuildPlanText mergedModule sourceModules,
  HostedResolvedProjectError message ->
    textConcat ["ERROR:", message]
}

nativeDriverImageSourceModuleInterfaceFingerprintText : Str -> Str
nativeDriverImageSourceModuleInterfaceFingerprintText source =
  emitNativeSourceModuleInterfaceFingerprint (sourceModule source)

nativeDriverImageProjectModuleText : Str -> Str
nativeDriverImageProjectModuleText bundle = if nativeDriverProjectBundleIsSingleSourceModule bundle then emitNativeModuleImageModuleName (nativeDriverProjectBundleSourceModule bundle) else match resolveProjectBundle bundle {
  HostedProjectBundleOk modl ->
    emitNativeModuleImageModuleName modl,
  HostedProjectBundleError message ->
    textConcat ["ERROR:", message]
}

nativeDriverImageProjectExportsText : Str -> Str
nativeDriverImageProjectExportsText bundle = if nativeDriverProjectBundleIsSingleSourceModule bundle then emitNativeModuleImageExports (nativeDriverProjectBundleSourceModule bundle) emptyLowerDecls else match resolveProjectBundle bundle {
  HostedProjectBundleOk modl ->
    emitNativeModuleImageExports modl emptyLowerDecls,
  HostedProjectBundleError message ->
    jsonArray [encode (textConcat ["ERROR:", message])]
}

nativeDriverImageProjectEntrypointsText : Str -> Str
nativeDriverImageProjectEntrypointsText bundle = if nativeDriverProjectBundleIsSingleSourceModule bundle then emitNativeModuleImageEntrypoints (nativeDriverProjectBundleSourceModule bundle) emptyLowerDecls else match resolveProjectBundle bundle {
  HostedProjectBundleOk modl ->
    emitNativeModuleImageEntrypoints modl emptyLowerDecls,
  HostedProjectBundleError message ->
    jsonArray [encode (textConcat ["ERROR:", message])]
}

nativeDriverImageProjectAbiText : Str -> Str
nativeDriverImageProjectAbiText bundle = if nativeDriverProjectBundleIsSingleSourceModule bundle then emitNativeAbiImage (nativeDriverProjectBundleSourceModule bundle) else match resolveProjectBundle bundle {
  HostedProjectBundleOk modl ->
    emitNativeAbiImage modl,
  HostedProjectBundleError message ->
    jsonObject [jsonFieldText "error" message]
}

nativeDriverImageProjectRuntimeText : Str -> Str
nativeDriverImageProjectRuntimeText bundle = if nativeDriverProjectBundleIsSingleSourceModule bundle then emitNativeRuntimeImage (nativeDriverProjectBundleSourceModule bundle) else match resolveProjectBundle bundle {
  HostedProjectBundleOk modl ->
    emitNativeRuntimeImage modl,
  HostedProjectBundleError message ->
    jsonObject [jsonFieldText "error" message]
}

nativeDriverImageProjectCompatibilityText : Str -> Str
nativeDriverImageProjectCompatibilityText bundle = if nativeDriverProjectBundleIsSingleSourceModule bundle then emitNativeCompatibilityImage (nativeDriverProjectBundleSourceModule bundle) emptyLowerDecls else match resolveProjectBundle bundle {
  HostedProjectBundleOk modl ->
    emitNativeCompatibilityImage modl emptyLowerDecls,
  HostedProjectBundleError message ->
    jsonObject [jsonFieldText "error" message]
}

nativeDriverImageProjectDeclsText : Str -> Str
nativeDriverImageProjectDeclsText bundle = if nativeDriverProjectBundleIsSingleSourceModule bundle then emitNativeModuleImageDecls (nativeDriverProjectBundleSourceModule bundle) (nativeDriverSourceLoweredDecls bundle) else match resolveProjectBundle bundle {
  HostedProjectBundleOk modl ->
    emitNativeModuleImageDecls modl (lowerModule modl),
  HostedProjectBundleError message ->
    jsonArray [encode (textConcat ["ERROR:", message])]
}

nativeDriverImageProjectConstructorDeclsText : Str -> Str
nativeDriverImageProjectConstructorDeclsText bundle = if nativeDriverProjectBundleIsSingleSourceModule bundle then emitNativeModuleImageConstructorDecls (nativeDriverProjectBundleSourceModule bundle) else match resolveProjectBundle bundle {
  HostedProjectBundleOk modl ->
    emitNativeModuleImageConstructorDecls modl,
  HostedProjectBundleError message ->
    jsonArray [encode (textConcat ["ERROR:", message])]
}

nativeDriverImageProjectDeclNamesText : Str -> Str
nativeDriverImageProjectDeclNamesText bundle = if nativeDriverProjectBundleIsSingleSourceModule bundle then emitNativeModuleImageDeclNames (nativeDriverProjectBundleSourceModule bundle) else match resolveProjectBundle bundle {
  HostedProjectBundleOk modl ->
    emitNativeModuleImageDeclNames modl,
  HostedProjectBundleError message ->
    textConcat ["ERROR:", message]
}

nativeDriverImageProjectDeclModulePlanText : Str -> Str
nativeDriverImageProjectDeclModulePlanText bundle = if nativeDriverProjectBundleIsSingleSourceModule bundle then emitNativeProjectDeclModulePlanText (nativeDriverProjectBundleSourceModule bundle) [nativeDriverProjectBundleSourceModule bundle] else match resolveProjectModules bundle {
  HostedResolvedProjectOk mergedModule sourceModules ->
    emitNativeProjectDeclModulePlanText mergedModule sourceModules,
  HostedResolvedProjectError message ->
    textConcat ["ERROR:", message]
}

nativeDriverImageProjectModuleDeclsText : Str -> Str -> Str
nativeDriverImageProjectModuleDeclsText bundle moduleName = if nativeDriverProjectBundleIsSingleSourceModule bundle then {
  let sourceModuleValue = nativeDriverProjectBundleSourceModule bundle;
  if moduleName == moduleNameOf sourceModuleValue then emitNativeSourceModuleImageDecls sourceModuleValue sourceModuleValue else jsonArray [encode (textConcat ["ERROR:", moduleName])]
} else match resolveProjectModules bundle {
  HostedResolvedProjectOk mergedModule sourceModules ->
    match lookupProjectModule sourceModules moduleName {
      FoundHostedProjectModule sourceModule ->
        emitNativeSourceModuleImageDecls mergedModule sourceModule,
      MissingHostedProjectModule missing ->
        jsonArray [encode (textConcat ["ERROR:", missing])]
    },
  HostedResolvedProjectError message ->
    jsonArray [encode (textConcat ["ERROR:", message])]
}

nativeDriverImageProjectNamedDeclsText : Str -> Str -> Str
nativeDriverImageProjectNamedDeclsText bundle namesText = if nativeDriverProjectBundleIsSingleSourceModule bundle then emitNativeModuleImageNamedDecls (nativeDriverProjectBundleSourceModule bundle) (if namesText == "" then [] else textSplit namesText "\n") else match resolveProjectBundle bundle {
  HostedProjectBundleOk modl ->
    emitNativeModuleImageNamedDecls modl (if namesText == "" then [] else textSplit namesText "\n"),
  HostedProjectBundleError message ->
    jsonArray [encode (textConcat ["ERROR:", message])]
}

-- CLASP_PROJECT_MODULE --
module Compiler.Emit.Native

import Compiler.Ast
import Compiler.Checker
import Compiler.Emit.NativeDecls
import Compiler.Emit.NativeJson
import Compiler.Emit.NativeMetadata
import Compiler.Emit.NativeSurface
import Compiler.CheckedCore
import Compiler.Json
import Compiler.Lower

appendNativeRenderedText : [Str] -> Str -> [Str]
appendNativeRenderedText values value = append values [value]

keepNoNativeTypeText : TypeText -> Bool
keepNoNativeTypeText value = false

emptyNativeTypeTexts : [TypeText]
emptyNativeTypeTexts = filter keepNoNativeTypeText [TUnknown ""]

emitNativeExprs : [LowerExprText] -> [Str]
emitNativeExprs exprs = {
  let mut rendered = emptyRenderedTexts;
  for expr in exprs {
    rendered = appendNativeRenderedText rendered (emitNativeExpr expr);
    rendered
  };
  rendered
}

emitNativeRecordFields : [LowerRecordFieldText] -> [Str]
emitNativeRecordFields fields = {
  let mut rendered = emptyRenderedTexts;
  for field in fields {
    rendered = appendNativeRenderedText rendered (emitNativeRecordField field);
    rendered
  };
  rendered
}

emitNativeRecordField : LowerRecordFieldText -> Str
emitNativeRecordField field = match field {
  LowerRecordFieldText name value ->
    textConcat [name, " = ", emitNativeExpr value]
}

emitNativeMatchBranch : LowerMatchBranchText -> Str
emitNativeMatchBranch branch = match branch {
  LowerMatchBranchText constructorName binders body ->
    textConcat [constructorName, "(", textJoin ", " binders, ") -> ", emitNativeExpr body]
}

emitNativeMatchBranches : [LowerMatchBranchText] -> [Str]
emitNativeMatchBranches branches = {
  let mut rendered = emptyRenderedTexts;
  for branch in branches {
    rendered = appendNativeRenderedText rendered (emitNativeMatchBranch branch);
    rendered
  };
  rendered
}

emitNativeExpr : LowerExprText -> Str
emitNativeExpr expr = match expr {
  LowerName name ->
    textConcat ["local(", name, ")"],
  LowerLiteral value ->
    textConcat ["string(\"", value, "\")"],
  LowerInt value ->
    textConcat ["int(", value, ")"],
  LowerBool value ->
    textConcat ["bool(", if value then "true" else "false", ")"],
  LowerArray values ->
    textConcat ["list([", textJoin ", " (emitNativeExprs values), "])"],
  LowerListAppend left right ->
    textConcat ["intrinsic.list.append(", emitNativeExpr left, ", ", emitNativeExpr right, ")"],
  LowerListPrepend value values ->
    textConcat ["intrinsic.list.prepend(", emitNativeExpr value, ", ", emitNativeExpr values, ")"],
  LowerListReverse values ->
    textConcat ["intrinsic.list.reverse(", emitNativeExpr values, ")"],
  LowerLength value ->
    textConcat ["intrinsic.length(", emitNativeExpr value, ")"],
  LowerListMap callee values ->
    textConcat ["intrinsic.list.map(", callee, ", ", emitNativeExpr values, ")"],
  LowerListFilter callee values ->
    textConcat ["intrinsic.list.filter(", callee, ", ", emitNativeExpr values, ")"],
  LowerListAny callee values ->
    textConcat ["intrinsic.list.any(", callee, ", ", emitNativeExpr values, ")"],
  LowerListAll callee values ->
    textConcat ["intrinsic.list.all(", callee, ", ", emitNativeExpr values, ")"],
  LowerListFold callee initial values ->
    textConcat ["intrinsic.list.fold(", callee, ", ", emitNativeExpr initial, ", ", emitNativeExpr values, ")"],
  LowerViewAppend left right ->
    textConcat ["intrinsic.view.append(", emitNativeExpr left, ", ", emitNativeExpr right, ")"],
  LowerEncode value ->
    textConcat ["intrinsic.encode(", emitNativeExpr value, ")"],
  LowerDecode targetType value ->
    textConcat ["intrinsic.decode(", renderType targetType, ", ", emitNativeExpr value, ")"],
  LowerIf condition thenBranch elseBranch ->
    textConcat ["if ", emitNativeExpr condition, " then ", emitNativeExpr thenBranch, " else ", emitNativeExpr elseBranch],
  LowerEqual left right ->
    textConcat ["compare.eq(", emitNativeExpr left, ", ", emitNativeExpr right, ")"],
  LowerNotEqual left right ->
    textConcat ["compare.ne(", emitNativeExpr left, ", ", emitNativeExpr right, ")"],
  LowerLessThan left right ->
    textConcat ["compare.lt(", emitNativeExpr left, ", ", emitNativeExpr right, ")"],
  LowerLessThanOrEqual left right ->
    textConcat ["compare.le(", emitNativeExpr left, ", ", emitNativeExpr right, ")"],
  LowerGreaterThan left right ->
    textConcat ["compare.gt(", emitNativeExpr left, ", ", emitNativeExpr right, ")"],
  LowerGreaterThanOrEqual left right ->
    textConcat ["compare.ge(", emitNativeExpr left, ", ", emitNativeExpr right, ")"],
  LowerInvoke callee args ->
    textConcat ["call(local(", callee, "), [", textJoin ", " (emitNativeExprs args), "])"],
  LowerConstructor constructorName args ->
    textConcat ["call(local(", constructorName, "), [", textJoin ", " (emitNativeExprs args), "])"],
  LowerMatch subject branches ->
    textConcat ["match ", emitNativeExpr subject, " [", textJoin ", " (emitNativeMatchBranches branches), "]"],
  LowerRecord recordName fields ->
    textConcat ["record ", recordName, " {", textJoin ", " (emitNativeRecordFields fields), "}"],
  LowerFieldAccess recordName subject fieldName ->
    if recordName == "" then textConcat ["field(", emitNativeExpr subject, ", ", fieldName, ")"] else textConcat ["field(", recordName, ", ", emitNativeExpr subject, ", ", fieldName, ")"],
  LowerLet binder value body ->
    textConcat ["let.immutable ", binder, " = ", emitNativeExpr value, " in ", emitNativeExpr body],
  LowerMutableLet binder value body ->
    textConcat ["let.mutable ", binder, " = ", emitNativeExpr value, " in ", emitNativeExpr body],
  LowerAssign binder value body ->
    textConcat ["assign ", binder, " = ", emitNativeExpr value, " then ", emitNativeExpr body],
  LowerFor binder iterable loopBody body ->
    textConcat ["for_each ", binder, " in ", emitNativeExpr iterable, " do ", emitNativeExpr loopBody, " then ", emitNativeExpr body],
  LowerReturn value ->
    textConcat ["return(", emitNativeExpr value, ")"]
}

emitNativeDecl : LowerDeclText -> Str
emitNativeDecl decl = match decl {
  LowerConst name body ->
    textConcat ["global ", name, " = ", emitNativeExpr body],
  LowerFn name params body ->
    textConcat ["function ", name, "(", textJoin ", " params, ") = ", emitNativeExpr body]
}

collectLowerDeclNames : [LowerDeclText] -> [Str]
collectLowerDeclNames decls = {
  let mut names = emptyRenderedTexts;
  for decl in decls {
    names = append names [nativeDeclName decl];
    names
  };
  names
}

incrementNativeNumber : Str -> Str
incrementNativeNumber value = { if value == "0" then "1" else if value == "1" then "2" else if value == "2" then "3" else if value == "3" then "4" else if value == "4" then "5" else if value == "5" then "6" else if value == "6" then "7" else if value == "7" then "8" else if value == "8" then "9" else if value == "9" then "10" else if value == "10" then "11" else if value == "11" then "12" else if value == "12" then "13" else if value == "13" then "14" else if value == "14" then "15" else if value == "15" then "16" else if value == "16" then "17" else if value == "17" then "18" else if value == "18" then "19" else if value == "19" then "20" else if value == "20" then "21" else if value == "21" then "22" else if value == "22" then "23" else if value == "23" then "24" else if value == "24" then "25" else if value == "25" then "26" else if value == "26" then "27" else if value == "27" then "28" else if value == "28" then "29" else if value == "29" then "30" else if value == "30" then "31" else if value == "31" then "32" else if value == "32" then "33" else if value == "33" then "34" else if value == "34" then "35" else if value == "35" then "36" else if value == "36" then "37" else if value == "37" then "38" else if value == "38" then "39" else if value == "39" then "40" else value }

decrementNativeNumber : Str -> Str
decrementNativeNumber value = { if value == "1" then "0" else if value == "2" then "1" else if value == "3" then "2" else if value == "4" then "3" else if value == "5" then "4" else if value == "6" then "5" else if value == "7" then "6" else if value == "8" then "7" else if value == "9" then "8" else if value == "10" then "9" else if value == "11" then "10" else if value == "12" then "11" else if value == "13" then "12" else if value == "14" then "13" else if value == "15" then "14" else if value == "16" then "15" else if value == "17" then "16" else if value == "18" then "17" else if value == "19" then "18" else if value == "20" then "19" else if value == "21" then "20" else if value == "22" then "21" else if value == "23" then "22" else if value == "24" then "23" else if value == "25" then "24" else if value == "26" then "25" else if value == "27" then "26" else if value == "28" then "27" else if value == "29" then "28" else if value == "30" then "29" else if value == "31" then "30" else if value == "32" then "31" else if value == "33" then "32" else if value == "34" then "33" else if value == "35" then "34" else if value == "36" then "35" else if value == "37" then "36" else if value == "38" then "37" else if value == "39" then "38" else if value == "40" then "39" else value }

renderNativeArity : [Str] -> Str
renderNativeArity params = {
  let mut count = "0";
  for param in params {
    let ignored = param;
    count = incrementNativeNumber count;
    count
  };
  count
}

countHostedTypes : [HostedTypeAst] -> Str
countHostedTypes values = {
  let mut count = "0";
  for value in values {
    let ignored = value;
    count = incrementNativeNumber count;
    count
  };
  count
}

countHostedRecordFields : [HostedRecordFieldDeclAst] -> Str
countHostedRecordFields fields = {
  let mut count = "0";
  for field in fields {
    let ignored = field;
    count = incrementNativeNumber count;
    count
  };
  count
}

hasHostedTypeValues : [HostedTypeAst] -> Bool
hasHostedTypeValues values = {
  for value in values {
    return true
  };
  false
}

maxHostedTypeList : [HostedTypeAst] -> [HostedTypeAst] -> [HostedTypeAst]
maxHostedTypeList left right = if hasHostedTypeValues left then { if hasHostedTypeValues right then maxHostedTypeList (remainingHostedTypes left) (remainingHostedTypes right) else left } else right

headerAdjustedOffset : Str -> Str
headerAdjustedOffset value = incrementNativeNumber (incrementNativeNumber value)

hostedTypeUsesNamedType : HostedTypeAst -> Str -> Bool
hostedTypeUsesNamedType typeAst targetName = match typeAst {
  HostedTypeName name ->
    name == targetName,
  HostedTypeApply name args ->
    if name == targetName then true else {
      for arg in args {
        if hostedTypeUsesNamedType arg targetName then return true else false
      };
      false
    },
  HostedTypeVar name ->
    false,
  HostedTypeList itemType ->
    hostedTypeUsesNamedType itemType targetName,
  HostedTypeFunction input result ->
    if hostedTypeUsesNamedType input targetName then true else hostedTypeUsesNamedType result targetName
}

recordDeclUsesNamedType : HostedRecordDeclAst -> Str -> Bool
recordDeclUsesNamedType recordDecl targetName = {
  for fieldDecl in recordDeclFields recordDecl {
    if hostedTypeUsesNamedType (recordFieldDeclType fieldDecl) targetName then return true else false
  };
  false
}

constructorDeclUsesNamedType : HostedConstructorDeclAst -> Str -> Bool
constructorDeclUsesNamedType constructorDecl targetName = {
  for payloadType in constructorDeclPayloadTypes constructorDecl {
    if hostedTypeUsesNamedType payloadType targetName then return true else false
  };
  false
}

typeDeclUsesNamedType : HostedTypeDeclAst -> Str -> Bool
typeDeclUsesNamedType typeDecl targetName = {
  if typeDeclName typeDecl == targetName then true else {
    for constructorDecl in typeDeclConstructors typeDecl {
      if constructorDeclUsesNamedType constructorDecl targetName then return true else false
    };
    false
  }
}

annotationUsesNamedType : HostedAnnotationAst -> Str -> Bool
annotationUsesNamedType annotation targetName = if hasAnnotationAst annotation then hostedTypeUsesNamedType (annotationTypeAst annotation) targetName else false

exprUsesBuiltinResultRuntime : HostedExprAst -> Bool
exprUsesBuiltinResultRuntime expr = match expr {
  HostedName name ->
    false,
  HostedString value ->
    false,
  HostedInt value ->
    false,
  HostedBool value ->
    false,
  HostedList values ->
    exprListUsesBuiltinResultRuntime values,
  HostedCall callee args ->
    if callee == "textPrefix" then true else if callee == "textSplitFirst" then true else if callee == "dictGet" then true else if callee == "readFile" then true else if callee == "runCommandJson" then true else if callee == "writeFile" then true else if callee == "appendFile" then true else if callee == "mkdirAll" then true else if callee == "envVar" then true else exprListUsesBuiltinResultRuntime args,
  HostedConstructor constructorName args ->
    exprListUsesBuiltinResultRuntime args,
  HostedMatch subject branches ->
    if exprUsesBuiltinResultRuntime subject then true else branchListUsesBuiltinResultRuntime branches,
  HostedRecord recordName fields ->
    recordFieldExprListUsesBuiltinResultRuntime fields,
  HostedFieldAccess subject fieldName ->
    exprUsesBuiltinResultRuntime subject,
  HostedLet binder value body ->
    if exprUsesBuiltinResultRuntime value then true else exprUsesBuiltinResultRuntime body,
  HostedMutableLet binder value body ->
    if exprUsesBuiltinResultRuntime value then true else exprUsesBuiltinResultRuntime body,
  HostedAssign binder value body ->
    if exprUsesBuiltinResultRuntime value then true else exprUsesBuiltinResultRuntime body,
  HostedFor binder iterable loopBody body ->
    if exprUsesBuiltinResultRuntime iterable then true else if exprUsesBuiltinResultRuntime loopBody then true else exprUsesBuiltinResultRuntime body,
  HostedReturn value ->
    exprUsesBuiltinResultRuntime value,
  HostedIf condition thenBranch elseBranch ->
    if exprUsesBuiltinResultRuntime condition then true else if exprUsesBuiltinResultRuntime thenBranch then true else exprUsesBuiltinResultRuntime elseBranch,
  HostedEqual left right ->
    if exprUsesBuiltinResultRuntime left then true else exprUsesBuiltinResultRuntime right,
  HostedNotEqual left right ->
    if exprUsesBuiltinResultRuntime left then true else exprUsesBuiltinResultRuntime right,
  HostedLessThan left right ->
    if exprUsesBuiltinResultRuntime left then true else exprUsesBuiltinResultRuntime right,
  HostedLessThanOrEqual left right ->
    if exprUsesBuiltinResultRuntime left then true else exprUsesBuiltinResultRuntime right,
  HostedGreaterThan left right ->
    if exprUsesBuiltinResultRuntime left then true else exprUsesBuiltinResultRuntime right,
  HostedGreaterThanOrEqual left right ->
    if exprUsesBuiltinResultRuntime left then true else exprUsesBuiltinResultRuntime right
}

exprListUsesBuiltinResultRuntime : [HostedExprAst] -> Bool
exprListUsesBuiltinResultRuntime exprs = {
  for expr in exprs {
    if exprUsesBuiltinResultRuntime expr then return true else false
  };
  false
}

recordFieldExprListUsesBuiltinResultRuntime : [HostedRecordFieldExprAst] -> Bool
recordFieldExprListUsesBuiltinResultRuntime fields = {
  for field in fields {
    if exprUsesBuiltinResultRuntime (recordExprFieldValue field) then return true else false
  };
  false
}

branchUsesBuiltinResultRuntime : HostedMatchBranchAst -> Bool
branchUsesBuiltinResultRuntime branch = exprUsesBuiltinResultRuntime (branchBodyExpr branch)

branchListUsesBuiltinResultRuntime : [HostedMatchBranchAst] -> Bool
branchListUsesBuiltinResultRuntime branches = {
  for branch in branches {
    if branchUsesBuiltinResultRuntime branch then return true else false
  };
  false
}

declUsesBuiltinResult : HostedDeclAst -> Bool
declUsesBuiltinResult decl = if annotationUsesNamedType (declAnnotation decl) resultBuiltinTypeName then true else exprUsesBuiltinResultRuntime (declBody decl)

foreignDeclUsesBuiltinResult : HostedForeignDeclAst -> Bool
foreignDeclUsesBuiltinResult foreignDecl = hostedTypeUsesNamedType (foreignDeclTypeAst foreignDecl) resultBuiltinTypeName

moduleDeclaresBuiltinResult : HostedModuleAst -> Bool
moduleDeclaresBuiltinResult modl = {
  for typeDecl in moduleTypeDeclarations modl {
    if typeDeclName typeDecl == resultBuiltinTypeName then return true else false
  };
  false
}

moduleUsesBuiltinResult : HostedModuleAst -> Bool
moduleUsesBuiltinResult modl = {
  if moduleDeclaresBuiltinResult modl then true else {
    for typeDecl in moduleTypeDeclarations modl {
      if typeDeclUsesNamedType typeDecl resultBuiltinTypeName then return true else false
    };
    for recordDecl in moduleRecordDeclarations modl {
      if recordDeclUsesNamedType recordDecl resultBuiltinTypeName then return true else false
    };
    for foreignDecl in moduleForeignDeclarations modl {
      if foreignDeclUsesBuiltinResult foreignDecl then return true else false
    };
    for decl in moduleDeclarations modl {
      if declUsesBuiltinResult decl then return true else false
    };
    false
  }
}

nativeEmittedTypeDecls : HostedModuleAst -> [HostedTypeDeclAst]
nativeEmittedTypeDecls modl = if moduleUsesBuiltinResult modl then effectiveModuleTypeDecls modl else moduleTypeDeclarations modl

renderTypeTextList : [TypeText] -> [Str]
renderTypeTextList types = {
  let mut rendered = emptyRenderedTexts;
  for typ in types {
    rendered = appendNativeRenderedText rendered (renderType typ);
    rendered
  };
  rendered
}

supportsRuntimeCodecType : TypeText -> Bool
supportsRuntimeCodecType typ = match typ {
  TInt ->
    true,
  TStr ->
    true,
  TBool ->
    true,
  TList itemType ->
    supportsRuntimeCodecType itemType,
  TNamed name ->
    true,
  TApply name args ->
    false,
  TFunction input result ->
    false,
  TVar label ->
    false,
  TUnknown label ->
    false
}

appendUniqueRuntimeCodecType : [TypeText] -> TypeText -> [TypeText]
appendUniqueRuntimeCodecType types typ = if supportsRuntimeCodecType typ then {
  if containsText (renderTypeTextList types) (renderType typ) then types else append types [typ]
} else {
  types
}

appendUniqueRuntimeCodecTypes : [TypeText] -> [TypeText] -> [TypeText]
appendUniqueRuntimeCodecTypes existing additions = {
  let mut merged = existing;
  for typ in additions {
    merged = appendUniqueRuntimeCodecType merged typ;
    merged
  };
  merged
}

collectRuntimeCodecTypesFromExprList : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [TypeBinding] -> [TypeBinding] -> ReturnContext -> [HostedExprAst] -> [TypeText]
collectRuntimeCodecTypesFromExprList typeDecls recordDecls env localEnv fnContext exprs = {
  let mut collected = emptyNativeTypeTexts;
  for expr in exprs {
    collected = appendUniqueRuntimeCodecTypes collected (collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext expr);
    collected
  };
  collected
}

collectRuntimeCodecTypesFromRecordFields : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [TypeBinding] -> [TypeBinding] -> ReturnContext -> [HostedRecordFieldExprAst] -> [TypeText]
collectRuntimeCodecTypesFromRecordFields typeDecls recordDecls env localEnv fnContext fields = {
  let mut collected = emptyNativeTypeTexts;
  for field in fields {
    collected = appendUniqueRuntimeCodecTypes collected (collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext (recordExprFieldValue field));
    collected
  };
  collected
}

collectRuntimeCodecTypesFromBranches : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [TypeBinding] -> [TypeBinding] -> ReturnContext -> [HostedMatchBranchAst] -> [TypeText]
collectRuntimeCodecTypesFromBranches typeDecls recordDecls env localEnv fnContext branches = {
  let mut collected = emptyNativeTypeTexts;
  for branch in branches {
    collected = appendUniqueRuntimeCodecTypes collected (collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext (branchBodyExpr branch));
    collected
  };
  collected
}

collectRuntimeCodecTypesFromExpr : [HostedTypeDeclAst] -> [HostedRecordDeclAst] -> [TypeBinding] -> [TypeBinding] -> ReturnContext -> HostedExprAst -> [TypeText]
collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext expr = match expr {
  HostedName name ->
    emptyNativeTypeTexts,
  HostedString value ->
    emptyNativeTypeTexts,
  HostedInt value ->
    emptyNativeTypeTexts,
  HostedBool value ->
    emptyNativeTypeTexts,
  HostedList values ->
    collectRuntimeCodecTypesFromExprList typeDecls recordDecls env localEnv fnContext values,
  HostedCall callee args -> {
    let argTypes = collectRuntimeCodecTypesFromExprList typeDecls recordDecls env localEnv fnContext args;
    if callee == "encode" then {
      appendUniqueRuntimeCodecType argTypes (inferredExprType typeDecls recordDecls env localEnv fnContext (firstHostedExpr args))
    } else {
      argTypes
    }
  },
  HostedConstructor constructorName args ->
    collectRuntimeCodecTypesFromExprList typeDecls recordDecls env localEnv fnContext args,
  HostedMatch subject branches -> {
    let subjectTypes = collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext subject;
    appendUniqueRuntimeCodecTypes subjectTypes (collectRuntimeCodecTypesFromBranches typeDecls recordDecls env localEnv fnContext branches)
  },
  HostedRecord recordName fields ->
    collectRuntimeCodecTypesFromRecordFields typeDecls recordDecls env localEnv fnContext fields,
  HostedFieldAccess subject fieldName ->
    collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext subject,
  HostedLet binder value body -> {
    let valueTypes = collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext value;
    let extendedLocalEnv = extendLowerLocalEnv typeDecls recordDecls env localEnv fnContext binder value;
    appendUniqueRuntimeCodecTypes valueTypes (collectRuntimeCodecTypesFromExpr typeDecls recordDecls env extendedLocalEnv fnContext body)
  },
  HostedMutableLet binder value body -> {
    let valueTypes = collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext value;
    let extendedLocalEnv = extendLowerLocalEnv typeDecls recordDecls env localEnv fnContext binder value;
    appendUniqueRuntimeCodecTypes valueTypes (collectRuntimeCodecTypesFromExpr typeDecls recordDecls env extendedLocalEnv fnContext body)
  },
  HostedAssign binder value body -> {
    let valueTypes = collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext value;
    appendUniqueRuntimeCodecTypes valueTypes (collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext body)
  },
  HostedFor binder iterable loopBody body -> {
    let iterableTypes = collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext iterable;
    let loopLocalEnv = extendLowerLoopLocalEnv typeDecls recordDecls env localEnv fnContext binder iterable;
    let loopTypes = collectRuntimeCodecTypesFromExpr typeDecls recordDecls env loopLocalEnv fnContext loopBody;
    appendUniqueRuntimeCodecTypes (appendUniqueRuntimeCodecTypes iterableTypes loopTypes) (collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext body)
  },
  HostedReturn value ->
    collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext value,
  HostedIf condition thenBranch elseBranch -> {
    let conditionTypes = collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext condition;
    let thenTypes = collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext thenBranch;
    appendUniqueRuntimeCodecTypes (appendUniqueRuntimeCodecTypes conditionTypes thenTypes) (collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext elseBranch)
  },
  HostedEqual left right -> {
    let leftTypes = collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext left;
    appendUniqueRuntimeCodecTypes leftTypes (collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext right)
  },
  HostedNotEqual left right -> {
    let leftTypes = collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext left;
    appendUniqueRuntimeCodecTypes leftTypes (collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext right)
  },
  HostedLessThan left right -> {
    let leftTypes = collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext left;
    appendUniqueRuntimeCodecTypes leftTypes (collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext right)
  },
  HostedLessThanOrEqual left right -> {
    let leftTypes = collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext left;
    appendUniqueRuntimeCodecTypes leftTypes (collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext right)
  },
  HostedGreaterThan left right -> {
    let leftTypes = collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext left;
    appendUniqueRuntimeCodecTypes leftTypes (collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext right)
  },
  HostedGreaterThanOrEqual left right -> {
    let leftTypes = collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext left;
    appendUniqueRuntimeCodecTypes leftTypes (collectRuntimeCodecTypesFromExpr typeDecls recordDecls env localEnv fnContext right)
  }
}

collectModuleRuntimeCodecTypes : HostedModuleAst -> [TypeText]
collectModuleRuntimeCodecTypes modl = {
  let typeDecls = effectiveModuleTypeDecls modl;
  let recordDecls = moduleRecordDeclarations modl;
  let env = lowerModuleEnv modl typeDecls;
  let mut collected = emptyNativeTypeTexts;
  for workflowDecl in moduleWorkflowDeclarations modl {
    collected = appendUniqueRuntimeCodecType collected (typeFromHostedTypeAst (workflowDeclStateTypeAst workflowDecl));
    collected
  };
  for routeDecl in moduleRouteDeclarations modl {
    collected = appendUniqueRuntimeCodecType collected (TNamed (routeDeclRequestType routeDecl));
    collected = appendUniqueRuntimeCodecType collected (TNamed (routeDeclResponseType routeDecl));
    collected
  };
  for hookDecl in moduleHookDeclarations modl {
    collected = appendUniqueRuntimeCodecType collected (TNamed (hookDeclRequestType hookDecl));
    collected = appendUniqueRuntimeCodecType collected (TNamed (hookDeclResponseType hookDecl));
    collected
  };
  for toolDecl in moduleToolDeclarations modl {
    collected = appendUniqueRuntimeCodecType collected (TNamed (toolDeclRequestType toolDecl));
    collected = appendUniqueRuntimeCodecType collected (TNamed (toolDeclResponseType toolDecl));
    collected
  };
  for decl in moduleDeclarations modl {
    let declCodecTypes = if hasLowerParams decl then collectRuntimeCodecTypesFromExpr typeDecls recordDecls env (lowerFunctionLocalEnv decl) (lowerFunctionFnContext decl) (declBody decl) else collectRuntimeCodecTypesFromExpr typeDecls recordDecls env emptyTypeBindings OutsideFunction (declBody decl);
    collected = appendUniqueRuntimeCodecTypes collected declCodecTypes;
    collected
  };
  collected
}

appendUniqueTextValue : [Str] -> Str -> [Str]
appendUniqueTextValue values value = if containsText values value then values else append values [value]

appendUniqueTextValues : [Str] -> [Str] -> [Str]
appendUniqueTextValues existing additions = {
  let mut merged = existing;
  for value in additions {
    merged = appendUniqueTextValue merged value;
    merged
  };
  merged
}

builtinRuntimeBindingName : Str -> Bool
builtinRuntimeBindingName name = if name == "textConcat" then true else if name == "textJoin" then true else if name == "textSplit" then true else if name == "textChars" then true else if name == "textFingerprint64Hex" then true else if name == "textPrefix" then true else if name == "textSplitFirst" then true else if name == "dictEmpty" then true else if name == "dictSet" then true else if name == "dictGet" then true else if name == "dictHas" then true else if name == "dictRemove" then true else if name == "dictKeys" then true else if name == "dictValues" then true else if name == "text" then true else if name == "element" then true else if name == "styled" then true else if name == "link" then true else if name == "form" then true else if name == "input" then true else if name == "submit" then true else if name == "systemPrompt" then true else if name == "assistantPrompt" then true else if name == "userPrompt" then true else if name == "appendPrompt" then true else if name == "promptText" then true else if name == "page" then true else if name == "redirect" then true else if name == "principal" then true else if name == "tenant" then true else if name == "resourceIdentity" then true else if name == "authSession" then true else if name == "argv" then true else if name == "timeUnixMs" then true else if name == "envVar" then true else if name == "pathJoin" then true else if name == "pathDirname" then true else if name == "pathBasename" then true else if name == "fileExists" then true else if name == "readFile" then true else if name == "runCommandJson" then true else if name == "writeFile" then true else if name == "appendFile" then true else if name == "mkdirAll" then true else false

collectRuntimeBindingNamesFromExprList : [HostedExprAst] -> [Str]
collectRuntimeBindingNamesFromExprList exprs = {
  let mut collected = emptyRenderedTexts;
  for expr in exprs {
    collected = appendUniqueTextValues collected (collectRuntimeBindingNamesFromExpr expr);
    collected
  };
  collected
}

collectRuntimeBindingNamesFromRecordFields : [HostedRecordFieldExprAst] -> [Str]
collectRuntimeBindingNamesFromRecordFields fields = {
  let mut collected = emptyRenderedTexts;
  for field in fields {
    collected = appendUniqueTextValues collected (collectRuntimeBindingNamesFromExpr (recordExprFieldValue field));
    collected
  };
  collected
}

collectRuntimeBindingNamesFromBranches : [HostedMatchBranchAst] -> [Str]
collectRuntimeBindingNamesFromBranches branches = {
  let mut collected = emptyRenderedTexts;
  for branch in branches {
    collected = appendUniqueTextValues collected (collectRuntimeBindingNamesFromExpr (branchBodyExpr branch));
    collected
  };
  collected
}

collectRuntimeBindingNamesFromExpr : HostedExprAst -> [Str]
collectRuntimeBindingNamesFromExpr expr = match expr {
  HostedName name ->
    if builtinRuntimeBindingName name then [name] else emptyRenderedTexts,
  HostedString value ->
    emptyRenderedTexts,
  HostedInt value ->
    emptyRenderedTexts,
  HostedBool value ->
    emptyRenderedTexts,
  HostedList values ->
    collectRuntimeBindingNamesFromExprList values,
  HostedCall callee args -> {
    let argNames = collectRuntimeBindingNamesFromExprList args;
    if builtinRuntimeBindingName callee then appendUniqueTextValue argNames callee else argNames
  },
  HostedConstructor constructorName args ->
    collectRuntimeBindingNamesFromExprList args,
  HostedMatch subject branches -> {
    let subjectNames = collectRuntimeBindingNamesFromExpr subject;
    appendUniqueTextValues subjectNames (collectRuntimeBindingNamesFromBranches branches)
  },
  HostedRecord recordName fields ->
    collectRuntimeBindingNamesFromRecordFields fields,
  HostedFieldAccess subject fieldName ->
    collectRuntimeBindingNamesFromExpr subject,
  HostedLet binder value body -> {
    let valueNames = collectRuntimeBindingNamesFromExpr value;
    appendUniqueTextValues valueNames (collectRuntimeBindingNamesFromExpr body)
  },
  HostedMutableLet binder value body -> {
    let valueNames = collectRuntimeBindingNamesFromExpr value;
    appendUniqueTextValues valueNames (collectRuntimeBindingNamesFromExpr body)
  },
  HostedAssign binder value body -> {
    let valueNames = collectRuntimeBindingNamesFromExpr value;
    appendUniqueTextValues valueNames (collectRuntimeBindingNamesFromExpr body)
  },
  HostedFor binder iterable loopBody body -> {
    let iterableNames = collectRuntimeBindingNamesFromExpr iterable;
    let loopNames = collectRuntimeBindingNamesFromExpr loopBody;
    appendUniqueTextValues (appendUniqueTextValues iterableNames loopNames) (collectRuntimeBindingNamesFromExpr body)
  },
  HostedReturn value ->
    collectRuntimeBindingNamesFromExpr value,
  HostedIf condition thenBranch elseBranch -> {
    let conditionNames = collectRuntimeBindingNamesFromExpr condition;
    let thenNames = collectRuntimeBindingNamesFromExpr thenBranch;
    appendUniqueTextValues (appendUniqueTextValues conditionNames thenNames) (collectRuntimeBindingNamesFromExpr elseBranch)
  },
  HostedEqual left right -> {
    let leftNames = collectRuntimeBindingNamesFromExpr left;
    appendUniqueTextValues leftNames (collectRuntimeBindingNamesFromExpr right)
  },
  HostedNotEqual left right -> {
    let leftNames = collectRuntimeBindingNamesFromExpr left;
    appendUniqueTextValues leftNames (collectRuntimeBindingNamesFromExpr right)
  },
  HostedLessThan left right -> {
    let leftNames = collectRuntimeBindingNamesFromExpr left;
    appendUniqueTextValues leftNames (collectRuntimeBindingNamesFromExpr right)
  },
  HostedLessThanOrEqual left right -> {
    let leftNames = collectRuntimeBindingNamesFromExpr left;
    appendUniqueTextValues leftNames (collectRuntimeBindingNamesFromExpr right)
  },
  HostedGreaterThan left right -> {
    let leftNames = collectRuntimeBindingNamesFromExpr left;
    appendUniqueTextValues leftNames (collectRuntimeBindingNamesFromExpr right)
  },
  HostedGreaterThanOrEqual left right -> {
    let leftNames = collectRuntimeBindingNamesFromExpr left;
    appendUniqueTextValues leftNames (collectRuntimeBindingNamesFromExpr right)
  }
}

collectModuleRuntimeBindingNames : HostedModuleAst -> [Str]
collectModuleRuntimeBindingNames modl = {
  let mut collected = emptyRenderedTexts;
  for decl in moduleDeclarations modl {
    collected = appendUniqueTextValues collected (collectRuntimeBindingNamesFromExpr (declBody decl));
    collected
  };
  collected
}

lowercaseRuntimeChar : Str -> Str
lowercaseRuntimeChar value = if value == "A" then "a" else if value == "B" then "b" else if value == "C" then "c" else if value == "D" then "d" else if value == "E" then "e" else if value == "F" then "f" else if value == "G" then "g" else if value == "H" then "h" else if value == "I" then "i" else if value == "J" then "j" else if value == "K" then "k" else if value == "L" then "l" else if value == "M" then "m" else if value == "N" then "n" else if value == "O" then "o" else if value == "P" then "p" else if value == "Q" then "q" else if value == "R" then "r" else if value == "S" then "s" else if value == "T" then "t" else if value == "U" then "u" else if value == "V" then "v" else if value == "W" then "w" else if value == "X" then "x" else if value == "Y" then "y" else if value == "Z" then "z" else value

dropLastChar : Str -> Str
dropLastChar value = {
  let mut result = "";
  let mut previous = "";
  let mut seenChar = false;
  for char in textChars value {
    if seenChar then {
      result = appendChar result previous;
      previous = char;
      result
    } else {
      previous = char;
      seenChar = true;
      result
    }
  };
  result
}

normalizeRuntimeName : Str -> Str
normalizeRuntimeName value = {
  let mut normalized = "";
  let mut seenText = false;
  for char in textChars value {
    if char == "_" then {
      if seenText then {
        if lastCharText normalized == "_" then normalized else {
          normalized = appendChar normalized "_";
          normalized
        }
      } else {
        normalized
      }
    } else if isUppercaseChar char then {
      if seenText then {
        if lastCharText normalized == "_" then {
          normalized = appendChar normalized (lowercaseRuntimeChar char);
          normalized
        } else {
          normalized = textConcat [normalized, "_", lowercaseRuntimeChar char];
          normalized
        }
      } else {
        normalized = appendChar normalized (lowercaseRuntimeChar char);
        seenText = true;
        normalized
      }
    } else {
      normalized = appendChar normalized char;
      seenText = true;
      normalized
    }
  };
  if lastCharText normalized == "_" then dropLastChar normalized else normalized
}

nativeRuntimeBindingSymbol : Str -> Str
nativeRuntimeBindingSymbol runtimeName = textConcat ["clasp_rt_", normalizeRuntimeName runtimeName]

emitRuntimeBindingImage : Str -> Str -> Str -> Str
emitRuntimeBindingImage name runtimeName bindingType =
  jsonObject [
    jsonFieldText "name" name,
    jsonFieldText "runtime" runtimeName,
    jsonFieldText "symbol" (nativeRuntimeBindingSymbol runtimeName),
    jsonFieldText "type" bindingType
  ]

emitBuiltinRuntimeBindingImage : Str -> Str
emitBuiltinRuntimeBindingImage name = if name == "textConcat" then emitRuntimeBindingImage "textConcat" "textConcat" "[Str] -> Str" else if name == "textJoin" then emitRuntimeBindingImage "textJoin" "textJoin" "Str -> [Str] -> Str" else if name == "textSplit" then emitRuntimeBindingImage "textSplit" "textSplit" "Str -> Str -> [Str]" else if name == "textChars" then emitRuntimeBindingImage "textChars" "textChars" "Str -> [Str]" else if name == "textFingerprint64Hex" then emitRuntimeBindingImage "textFingerprint64Hex" "textFingerprint64Hex" "Str -> Str" else if name == "textPrefix" then emitRuntimeBindingImage "textPrefix" "textPrefix" "Str -> Str -> Result Str" else if name == "textSplitFirst" then emitRuntimeBindingImage "textSplitFirst" "textSplitFirst" "Str -> Str -> Result Str" else if name == "dictEmpty" then emitRuntimeBindingImage "dictEmpty" "dictEmpty" "Dict Str a" else if name == "dictSet" then emitRuntimeBindingImage "dictSet" "dictSet" "Str -> a -> Dict Str a -> Dict Str a" else if name == "dictGet" then emitRuntimeBindingImage "dictGet" "dictGet" "Str -> Dict Str a -> Result a" else if name == "dictHas" then emitRuntimeBindingImage "dictHas" "dictHas" "Str -> Dict Str a -> Bool" else if name == "dictRemove" then emitRuntimeBindingImage "dictRemove" "dictRemove" "Str -> Dict Str a -> Dict Str a" else if name == "dictKeys" then emitRuntimeBindingImage "dictKeys" "dictKeys" "Dict Str a -> [Str]" else if name == "dictValues" then emitRuntimeBindingImage "dictValues" "dictValues" "Dict Str a -> [a]" else if name == "text" then emitRuntimeBindingImage "text" "viewText" "Str -> View" else if name == "element" then emitRuntimeBindingImage "element" "viewElement" "Str -> View -> View" else if name == "styled" then emitRuntimeBindingImage "styled" "viewStyled" "Str -> View -> View" else if name == "link" then emitRuntimeBindingImage "link" "viewLink" "Str -> View -> View" else if name == "form" then emitRuntimeBindingImage "form" "viewForm" "Str -> Str -> View -> View" else if name == "input" then emitRuntimeBindingImage "input" "viewInput" "Str -> Str -> Str -> View" else if name == "submit" then emitRuntimeBindingImage "submit" "viewSubmit" "Str -> View" else if name == "systemPrompt" then emitRuntimeBindingImage "systemPrompt" "systemPrompt" "Str -> Prompt" else if name == "assistantPrompt" then emitRuntimeBindingImage "assistantPrompt" "assistantPrompt" "Str -> Prompt" else if name == "userPrompt" then emitRuntimeBindingImage "userPrompt" "userPrompt" "Str -> Prompt" else if name == "appendPrompt" then emitRuntimeBindingImage "appendPrompt" "appendPrompt" "Prompt -> Prompt -> Prompt" else if name == "promptText" then emitRuntimeBindingImage "promptText" "promptText" "Prompt -> Str" else if name == "page" then emitRuntimeBindingImage "page" "page" "Str -> View -> Page" else if name == "redirect" then emitRuntimeBindingImage "redirect" "redirect" "Str -> Redirect" else if name == "principal" then emitRuntimeBindingImage "principal" "principal" "Str -> Principal" else if name == "tenant" then emitRuntimeBindingImage "tenant" "tenant" "Str -> Tenant" else if name == "resourceIdentity" then emitRuntimeBindingImage "resourceIdentity" "resourceIdentity" "Str -> Str -> ResourceIdentity" else if name == "authSession" then emitRuntimeBindingImage "authSession" "authSession" "Str -> Principal -> Tenant -> ResourceIdentity -> AuthSession" else if name == "argv" then emitRuntimeBindingImage "argv" "argv" "[Str]" else if name == "timeUnixMs" then emitRuntimeBindingImage "timeUnixMs" "timeUnixMs" "Int" else if name == "envVar" then emitRuntimeBindingImage "envVar" "envVar" "Str -> Result Str" else if name == "pathJoin" then emitRuntimeBindingImage "pathJoin" "pathJoin" "[Str] -> Str" else if name == "pathDirname" then emitRuntimeBindingImage "pathDirname" "pathDirname" "Str -> Str" else if name == "pathBasename" then emitRuntimeBindingImage "pathBasename" "pathBasename" "Str -> Str" else if name == "fileExists" then emitRuntimeBindingImage "fileExists" "fileExists" "Str -> Bool" else if name == "readFile" then emitRuntimeBindingImage "readFile" "readFile" "Str -> Result Str" else if name == "runCommandJson" then emitRuntimeBindingImage "runCommandJson" "runCommandJson" "Str -> [Str] -> Result Str" else if name == "writeFile" then emitRuntimeBindingImage "writeFile" "writeFile" "Str -> Str -> Result Str" else if name == "appendFile" then emitRuntimeBindingImage "appendFile" "appendFile" "Str -> Str -> Result Str" else if name == "mkdirAll" then emitRuntimeBindingImage "mkdirAll" "mkdirAll" "Str -> Result Str" else jsonObject emptyJsonFields

emitBuiltinRuntimeBindingText : Str -> Str
emitBuiltinRuntimeBindingText name = if name == "textConcat" then "textConcat{runtime=textConcat, symbol=clasp_rt_text_concat, type=[Str] -> Str}" else if name == "textJoin" then "textJoin{runtime=textJoin, symbol=clasp_rt_text_join, type=Str -> [Str] -> Str}" else if name == "textSplit" then "textSplit{runtime=textSplit, symbol=clasp_rt_text_split, type=Str -> Str -> [Str]}" else if name == "textChars" then "textChars{runtime=textChars, symbol=clasp_rt_text_chars, type=Str -> [Str]}" else if name == "textFingerprint64Hex" then "textFingerprint64Hex{runtime=textFingerprint64Hex, symbol=clasp_rt_text_fingerprint64_hex, type=Str -> Str}" else if name == "textPrefix" then "textPrefix{runtime=textPrefix, symbol=clasp_rt_text_prefix, type=Str -> Str -> Result Str}" else if name == "textSplitFirst" then "textSplitFirst{runtime=textSplitFirst, symbol=clasp_rt_text_split_first, type=Str -> Str -> Result Str}" else if name == "dictEmpty" then "dictEmpty{runtime=dictEmpty, symbol=clasp_rt_dict_empty, type=Dict Str a}" else if name == "dictSet" then "dictSet{runtime=dictSet, symbol=clasp_rt_dict_set, type=Str -> a -> Dict Str a -> Dict Str a}" else if name == "dictGet" then "dictGet{runtime=dictGet, symbol=clasp_rt_dict_get, type=Str -> Dict Str a -> Result a}" else if name == "dictHas" then "dictHas{runtime=dictHas, symbol=clasp_rt_dict_has, type=Str -> Dict Str a -> Bool}" else if name == "dictRemove" then "dictRemove{runtime=dictRemove, symbol=clasp_rt_dict_remove, type=Str -> Dict Str a -> Dict Str a}" else if name == "dictKeys" then "dictKeys{runtime=dictKeys, symbol=clasp_rt_dict_keys, type=Dict Str a -> [Str]}" else if name == "dictValues" then "dictValues{runtime=dictValues, symbol=clasp_rt_dict_values, type=Dict Str a -> [a]}" else if name == "text" then "text{runtime=viewText, symbol=clasp_rt_view_text, type=Str -> View}" else if name == "element" then "element{runtime=viewElement, symbol=clasp_rt_view_element, type=Str -> View -> View}" else if name == "styled" then "styled{runtime=viewStyled, symbol=clasp_rt_view_styled, type=Str -> View -> View}" else if name == "link" then "link{runtime=viewLink, symbol=clasp_rt_view_link, type=Str -> View -> View}" else if name == "form" then "form{runtime=viewForm, symbol=clasp_rt_view_form, type=Str -> Str -> View -> View}" else if name == "input" then "input{runtime=viewInput, symbol=clasp_rt_view_input, type=Str -> Str -> Str -> View}" else if name == "submit" then "submit{runtime=viewSubmit, symbol=clasp_rt_view_submit, type=Str -> View}" else if name == "systemPrompt" then "systemPrompt{runtime=systemPrompt, symbol=clasp_rt_system_prompt, type=Str -> Prompt}" else if name == "assistantPrompt" then "assistantPrompt{runtime=assistantPrompt, symbol=clasp_rt_assistant_prompt, type=Str -> Prompt}" else if name == "userPrompt" then "userPrompt{runtime=userPrompt, symbol=clasp_rt_user_prompt, type=Str -> Prompt}" else if name == "appendPrompt" then "appendPrompt{runtime=appendPrompt, symbol=clasp_rt_append_prompt, type=Prompt -> Prompt -> Prompt}" else if name == "promptText" then "promptText{runtime=promptText, symbol=clasp_rt_prompt_text, type=Prompt -> Str}" else if name == "page" then "page{runtime=page, symbol=clasp_rt_page, type=Str -> View -> Page}" else if name == "redirect" then "redirect{runtime=redirect, symbol=clasp_rt_redirect, type=Str -> Redirect}" else if name == "principal" then "principal{runtime=principal, symbol=clasp_rt_principal, type=Str -> Principal}" else if name == "tenant" then "tenant{runtime=tenant, symbol=clasp_rt_tenant, type=Str -> Tenant}" else if name == "resourceIdentity" then "resourceIdentity{runtime=resourceIdentity, symbol=clasp_rt_resource_identity, type=Str -> Str -> ResourceIdentity}" else if name == "authSession" then "authSession{runtime=authSession, symbol=clasp_rt_auth_session, type=Str -> Principal -> Tenant -> ResourceIdentity -> AuthSession}" else if name == "argv" then "argv{runtime=argv, symbol=clasp_rt_argv, type=[Str]}" else if name == "timeUnixMs" then "timeUnixMs{runtime=timeUnixMs, symbol=clasp_rt_time_unix_ms, type=Int}" else if name == "envVar" then "envVar{runtime=envVar, symbol=clasp_rt_env_var, type=Str -> Result Str}" else if name == "pathJoin" then "pathJoin{runtime=pathJoin, symbol=clasp_rt_path_join, type=[Str] -> Str}" else if name == "pathDirname" then "pathDirname{runtime=pathDirname, symbol=clasp_rt_path_dirname, type=Str -> Str}" else if name == "pathBasename" then "pathBasename{runtime=pathBasename, symbol=clasp_rt_path_basename, type=Str -> Str}" else if name == "fileExists" then "fileExists{runtime=fileExists, symbol=clasp_rt_file_exists, type=Str -> Bool}" else if name == "readFile" then "readFile{runtime=readFile, symbol=clasp_rt_read_file, type=Str -> Result Str}" else if name == "runCommandJson" then "runCommandJson{runtime=runCommandJson, symbol=clasp_rt_run_command_json, type=Str -> [Str] -> Result Str}" else if name == "writeFile" then "writeFile{runtime=writeFile, symbol=clasp_rt_write_file, type=Str -> Str -> Result Str}" else if name == "appendFile" then "appendFile{runtime=appendFile, symbol=clasp_rt_append_file, type=Str -> Str -> Result Str}" else if name == "mkdirAll" then "mkdirAll{runtime=mkdirAll, symbol=clasp_rt_mkdir_all, type=Str -> Result Str}" else ""

emitNativeRuntimeBindingImage : HostedForeignDeclAst -> Str
emitNativeRuntimeBindingImage foreignDecl =
  emitRuntimeBindingImage (foreignDeclName foreignDecl) (foreignDeclRuntimeName foreignDecl) (renderHostedType (foreignDeclTypeAst foreignDecl))

emitNativeRuntimeBindingText : HostedForeignDeclAst -> Str
emitNativeRuntimeBindingText foreignDecl =
  textConcat [foreignDeclName foreignDecl, "{runtime=", foreignDeclRuntimeName foreignDecl, ", symbol=", nativeRuntimeBindingSymbol (foreignDeclRuntimeName foreignDecl), ", type=", renderHostedType (foreignDeclTypeAst foreignDecl), "}"]

emitNativeBuiltinRuntimeBindingImages : [Str] -> [Str]
emitNativeBuiltinRuntimeBindingImages bindingNames = {
  let mut rendered = emptyRenderedTexts;
  for builtinName in ["textConcat", "textJoin", "textSplit", "textChars", "textFingerprint64Hex", "textPrefix", "textSplitFirst", "dictEmpty", "dictSet", "dictGet", "dictHas", "dictRemove", "dictKeys", "dictValues", "text", "element", "styled", "link", "form", "input", "submit", "systemPrompt", "assistantPrompt", "userPrompt", "appendPrompt", "promptText", "page", "redirect", "principal", "tenant", "resourceIdentity", "authSession", "argv", "timeUnixMs", "envVar", "pathJoin", "pathDirname", "pathBasename", "fileExists", "readFile", "runCommandJson", "writeFile", "appendFile", "mkdirAll"] {
    if containsText bindingNames builtinName then {
      rendered = appendNativeRenderedText rendered (emitBuiltinRuntimeBindingImage builtinName);
      rendered
    } else {
      rendered
    }
  };
  rendered
}

emitNativeBuiltinRuntimeBindingTexts : [Str] -> [Str]
emitNativeBuiltinRuntimeBindingTexts bindingNames = {
  let mut rendered = emptyRenderedTexts;
  for builtinName in ["textConcat", "textJoin", "textSplit", "textChars", "textFingerprint64Hex", "textPrefix", "textSplitFirst", "dictEmpty", "dictSet", "dictGet", "dictHas", "dictRemove", "dictKeys", "dictValues", "text", "element", "styled", "link", "form", "input", "submit", "systemPrompt", "assistantPrompt", "userPrompt", "appendPrompt", "promptText", "page", "redirect", "principal", "tenant", "resourceIdentity", "authSession", "argv", "timeUnixMs", "envVar", "pathJoin", "pathDirname", "pathBasename", "fileExists", "readFile", "runCommandJson", "writeFile", "appendFile", "mkdirAll"] {
    if containsText bindingNames builtinName then {
      rendered = appendNativeRenderedText rendered (emitBuiltinRuntimeBindingText builtinName);
      rendered
    } else {
      rendered
    }
  };
  rendered
}

emitNativeRuntimeBindingImages : HostedModuleAst -> [Str]
emitNativeRuntimeBindingImages modl = {
  let mut rendered = emitNativeBuiltinRuntimeBindingImages (collectModuleRuntimeBindingNames modl);
  for foreignDecl in moduleForeignDeclarations modl {
    rendered = appendNativeRenderedText rendered (emitNativeRuntimeBindingImage foreignDecl);
    rendered
  };
  rendered
}

emitNativeRuntimeBindingTexts : HostedModuleAst -> [Str]
emitNativeRuntimeBindingTexts modl = {
  let mut rendered = emitNativeBuiltinRuntimeBindingTexts (collectModuleRuntimeBindingNames modl);
  for foreignDecl in moduleForeignDeclarations modl {
    rendered = appendNativeRenderedText rendered (emitNativeRuntimeBindingText foreignDecl);
    rendered
  };
  rendered
}

nativeCodecSuffixForType : TypeText -> Str
nativeCodecSuffixForType typ = match typ {
  TInt ->
    "Int",
  TStr ->
    "Str",
  TBool ->
    "Bool",
  TList itemType ->
    textConcat ["List_", nativeCodecSuffixForType itemType],
  TNamed name ->
    name,
  TApply name args ->
    textConcat [name, "_Generic"],
  TFunction input result ->
    "Unsupported",
  TVar label ->
    textConcat ["Var_", label],
  TUnknown label ->
    label
}

emitNativeJsonCodecImage : TypeText -> Str
emitNativeJsonCodecImage typ = {
  let suffix = nativeCodecSuffixForType typ;
  jsonObject [jsonFieldText "type" (renderType typ), jsonFieldText "encode" (textConcat ["$encode_", suffix]), jsonFieldText "decode" (textConcat ["$decode_", suffix])]
}

emitNativeBinaryCodecImage : TypeText -> Str
emitNativeBinaryCodecImage typ = {
  let suffix = nativeCodecSuffixForType typ;
  jsonObject [jsonFieldText "type" (renderType typ), jsonFieldText "encode" (textConcat ["$encode_binary_", suffix]), jsonFieldText "decode" (textConcat ["$decode_binary_", suffix]), jsonFieldText "framing" "length_prefixed"]
}

emitNativeJsonCodecText : TypeText -> Str
emitNativeJsonCodecText typ = {
  let suffix = nativeCodecSuffixForType typ;
  textConcat [renderType typ, "{encode=$encode_", suffix, ", decode=$decode_", suffix, "}"]
}

emitNativeBinaryCodecText : TypeText -> Str
emitNativeBinaryCodecText typ = {
  let suffix = nativeCodecSuffixForType typ;
  textConcat [renderType typ, "{encode=$encode_binary_", suffix, ", decode=$decode_binary_", suffix, ", framing=length_prefixed}"]
}

emitNativeJsonCodecImagesFromTypes : [TypeText] -> [Str]
emitNativeJsonCodecImagesFromTypes codecTypes = {
  let mut rendered = emptyRenderedTexts;
  for codecType in codecTypes {
    rendered = appendNativeRenderedText rendered (emitNativeJsonCodecImage codecType);
    rendered
  };
  rendered
}

emitNativeJsonCodecTextsFromTypes : [TypeText] -> [Str]
emitNativeJsonCodecTextsFromTypes codecTypes = {
  let mut rendered = emptyRenderedTexts;
  for codecType in codecTypes {
    rendered = appendNativeRenderedText rendered (emitNativeJsonCodecText codecType);
    rendered
  };
  rendered
}

emitNativeBinaryCodecImagesFromTypes : [TypeText] -> [Str]
emitNativeBinaryCodecImagesFromTypes codecTypes = {
  let mut rendered = emptyRenderedTexts;
  for codecType in codecTypes {
    rendered = appendNativeRenderedText rendered (emitNativeBinaryCodecImage codecType);
    rendered
  };
  rendered
}

emitNativeBinaryCodecTextsFromTypes : [TypeText] -> [Str]
emitNativeBinaryCodecTextsFromTypes codecTypes = {
  let mut rendered = emptyRenderedTexts;
  for codecType in codecTypes {
    rendered = appendNativeRenderedText rendered (emitNativeBinaryCodecText codecType);
    rendered
  };
  rendered
}


emitNativeJsonNumberList : [Str] -> [Str]
emitNativeJsonNumberList values = values

emitNativeAbiAllocationImage : Str
emitNativeAbiAllocationImage =
  jsonObject [
    jsonFieldText "immediate" "stack",
    jsonFieldText "handle" "heap",
    jsonFieldText "global" "static"
  ]

emitNativeBuiltinLayoutImage : Str -> Str -> Str -> Str
emitNativeBuiltinLayoutImage name storage words =
  jsonObject [
    jsonFieldText "name" name,
    jsonFieldText "storage" storage,
    jsonFieldRaw "words" words
  ]

