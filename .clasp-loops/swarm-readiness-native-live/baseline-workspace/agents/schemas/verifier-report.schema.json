{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Clasp Verifier Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "verdict",
    "summary",
    "findings",
    "tests_run",
    "follow_up"
  ],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["pass", "fail"]
    },
    "summary": { "type": "string" },
    "findings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tests_run": {
      "type": "array",
      "items": { "type": "string" }
    },
    "follow_up": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
