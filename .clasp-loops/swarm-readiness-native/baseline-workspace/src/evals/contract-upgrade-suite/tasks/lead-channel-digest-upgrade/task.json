{
  "id": "lead-channel-digest-upgrade",
  "title": "Upgrade the lead summary flow to a LeadChannelDigest contract",
  "overview": "The lead follow-up slice needs a channel-oriented contract upgrade that should propagate through the API, workflow state, and downstream lookup request.",
  "requirements": [
    "Introduce a new record type named `LeadChannelDigest` with this exact schema: `company : Str`, `sourceChannel : Str`, `campaignTag : Str`, `owner : Str`.",
    "Update the downstream playbook lookup request so it carries `sourceChannel : Str` and `campaignTag : Str` instead of a single status string.",
    "Update the workflow state so it stores `digest : LeadChannelDigest`.",
    "Update the lead summary API route so it returns `LeadChannelDigest`.",
    "Keep the program compiling.",
    "Keep `main` working. After the change, `main` should evaluate to `\"inbound-high\"`."
  ],
  "fileHints": [
    "Main.clasp",
    "Shared/Lead.clasp"
  ],
  "oracleHints": [
    "Exact edit surfaces: `Main.clasp`, `Shared/Lead.clasp`.",
    "Relevant declarations: `LeadSummary`, `LeadPlaybookLookup`, `LeadFollowUpState`, `summarizeLeadApi`, `lookupLeadPlaybook`, `main`."
  ],
