module CompilerMain

import Compiler.Driver.Frontend
import Compiler.Driver.Native

checkSourceText : Str -> Str
checkSourceText source = frontendDriverCheckSourceText source

explainSourceText : Str -> Str
explainSourceText source = frontendDriverExplainSourceText source

compileSourceText : Str -> Str
compileSourceText source = frontendDriverCompileSourceText source

nativeSourceText : Str -> Str
nativeSourceText source = nativeDriverSourceText source

nativeImageSourceText : Str -> Str
nativeImageSourceText source = nativeDriverImageSourceText source

checkCoreSourceText : Str -> Str
checkCoreSourceText source = frontendDriverCheckCoreSourceText source

checkProjectText : Str -> Str
checkProjectText bundle = frontendDriverCheckProjectText bundle

checkProjectModuleSummaryText : Str -> Str -> Str
checkProjectModuleSummaryText bundle importedSummaryText = frontendDriverCheckProjectModuleSummaryText bundle importedSummaryText

explainProjectText : Str -> Str
explainProjectText bundle = frontendDriverExplainProjectText bundle

compileProjectText : Str -> Str
compileProjectText bundle = frontendDriverCompileProjectText bundle

nativeProjectText : Str -> Str
nativeProjectText bundle = nativeDriverProjectText bundle

nativeImageProjectText : Str -> Str
nativeImageProjectText bundle = nativeDriverImageProjectText bundle

nativeImageProjectPlanText : Str -> Str
nativeImageProjectPlanText bundle = nativeDriverImageProjectPlanText bundle

nativeImageProjectBuildPlanText : Str -> Str
nativeImageProjectBuildPlanText bundle = nativeDriverImageProjectBuildPlanText bundle

nativeImageSourceModuleInterfaceFingerprintText : Str -> Str
