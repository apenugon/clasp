nativeImageProjectModuleText : Str -> Str
nativeImageProjectModuleText bundle = nativeDriverImageProjectModuleText bundle

nativeImageProjectExportsText : Str -> Str
nativeImageProjectExportsText bundle = nativeDriverImageProjectExportsText bundle

nativeImageProjectEntrypointsText : Str -> Str
nativeImageProjectEntrypointsText bundle = nativeDriverImageProjectEntrypointsText bundle

nativeImageProjectAbiText : Str -> Str
nativeImageProjectAbiText bundle = nativeDriverImageProjectAbiText bundle

nativeImageProjectRuntimeText : Str -> Str
nativeImageProjectRuntimeText bundle = nativeDriverImageProjectRuntimeText bundle

nativeImageProjectCompatibilityText : Str -> Str
nativeImageProjectCompatibilityText bundle = nativeDriverImageProjectCompatibilityText bundle

nativeImageProjectDeclsText : Str -> Str
nativeImageProjectDeclsText bundle = nativeDriverImageProjectDeclsText bundle

nativeImageProjectConstructorDeclsText : Str -> Str
nativeImageProjectConstructorDeclsText bundle = nativeDriverImageProjectConstructorDeclsText bundle

nativeImageProjectDeclNamesText : Str -> Str
nativeImageProjectDeclNamesText bundle = nativeDriverImageProjectDeclNamesText bundle

nativeImageProjectDeclModulePlanText : Str -> Str
nativeImageProjectDeclModulePlanText bundle = nativeDriverImageProjectDeclModulePlanText bundle

nativeImageProjectModuleDeclsText : Str -> Str -> Str
