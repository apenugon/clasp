{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Clasp Backend Benchmark Result",
  "type": "object",
  "required": [
    "schemaVersion",
    "generatedAt",
    "compileBenchmarks",
    "runtimeBenchmarks"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "environment": {
      "type": "object"
    },
    "compileBenchmarks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["workload", "input", "jsBun", "native", "deltaMs", "nativeSpeedupVsJs"],
        "properties": {
          "workload": { "type": "string" },
          "input": { "type": "string" },
          "jsBun": { "type": "object" },
          "native": { "type": "object" },
          "deltaMs": { "type": "integer" },
          "nativeSpeedupVsJs": { "type": "number" }
        }
      }
    },
    "runtimeBenchmarks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["workload", "input", "jsBun", "native", "deltaMs", "nativeSpeedupVsJs"],
        "properties": {
          "workload": { "type": "string" },
          "input": { "type": "string" },
          "jsBun": { "type": "object" },
          "native": { "type": "object" },
          "deltaMs": { "type": "integer" },
          "nativeSpeedupVsJs": { "type": "number" }
        }
      }
    }
  },
  "additionalProperties": true
}
