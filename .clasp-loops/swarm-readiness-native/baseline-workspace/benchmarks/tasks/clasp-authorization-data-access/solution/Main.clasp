module Main

record Customer = {
  id : Str,
  company : Str,
  contactEmail : Str classified pii,
  plan : Str
}

policy SupportAccess = public, pii

projection SupportCustomer = Customer with SupportAccess {
  id,
  company,
  contactEmail,
  plan
}

guide SupportGuide = {
  scope: "Keep protected customer reads, writes, and field disclosures behind explicit policy proofs."
}

role SupportWorkerRole = guide: SupportGuide, policy: SupportAccess, approval: on_request, sandbox: workspace_write

agent supportWorker = SupportWorkerRole

readProofPolicy : Str
readProofPolicy = "SupportAccess"

writeProofPolicy : Str
writeProofPolicy = "SupportAccess"

disclosureProofPolicy : Str
disclosureProofPolicy = "SupportAccess"

disclosureField : Str
disclosureField = "contactEmail"

customerId : Str
customerId = "cust-42"
