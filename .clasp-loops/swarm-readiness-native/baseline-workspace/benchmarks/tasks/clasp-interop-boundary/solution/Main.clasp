module Main

record LeadRequest = {
  company : Str,
  budget : Int
}

record LeadVerdict = {
  accepted : Bool,
  reason : Str
}

record LeadInspection = {
  label : Str,
  verdict : LeadVerdict
}

foreign unsafe inspectLead : LeadRequest -> LeadInspection = "inspectLead" from typescript "./support/inspectLead.mjs" declaration "./support/inspectLead.d.ts"

assessLead : LeadRequest -> LeadInspection
assessLead request = inspectLead request

main : Str
main = "ok"
