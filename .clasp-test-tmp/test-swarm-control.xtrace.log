#!/usr/bin/env bash
set -euo pipefail

task_file="$1"
workspace="$2"
report_json="$3"
log_jsonl="$4"
task_id="$(basename "$task_file" .md)"

printf '\''base\n'\'' > "$workspace/feature.txt"

cat > "$report_json" <<JSON
