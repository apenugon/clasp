  [[ "$output" == *'\''batch=foundation'\''* ]]
  [[ "$output" == *'\''lane=01-foundation-a'\''* ]]
  [[ "$output" == *'\''lane=02-foundation-b'\''* ]]
  [[ "$output" != *'\''lane=03-follow-up'\''* ]]

  deadline=$((SECONDS + 20))
  while [[ -f .clasp-swarm/test-wave/01-foundation-a/pid || -f .clasp-swarm/test-wave/02-foundation-b/pid ]]; do
