module Main

import Process

record CapabilityStatus = {
  name : Str,
  status : Str,
  evidence : [Str],
  blocking_gaps : [Str],
  required_closure : [Str]
}
record VerifierReport = {
  verdict : Str,
  summary : Str,
  findings : [Str],
  tests_run : [Str],
  follow_up : [Str],
  capability_statuses : [CapabilityStatus]
}
record LoopState = {
  attempt : Int,
  phase : Str,
  verdict : Str,
  completed : Bool,
  builderRuns : Int,
  verifierRuns : Int,
  healthy : Bool,
  needsAttention : Bool,
  attentionReason : Str,
  final : Bool
}
record StepHandle = {
  prefix : Str,
  attempt : Int,
  reportPath : Str,
  stdoutPath : Str,
  stderrPath : Str,
  heartbeatPath : Str
}

stateRoot : Str
stateRoot = if textJoin "" argv == "" then "feedback-loop-state" else pathJoin argv

emptyTexts : [Str]
emptyTexts = []

emptyCapabilityStatuses : [CapabilityStatus]
emptyCapabilityStatuses = []

readEnvText : Str -> Str -> Str
readEnvText name fallback = match envVar name {
  Ok raw -> decode Str raw,
  Err message -> fallback
}

taskFile : Str
taskFile = readEnvText "CLASP_LOOP_TASK_FILE_JSON" "agents/tasks/0011-swarm-ready-full-goal.md"

workspaceRoot : Str
workspaceRoot = readEnvText "CLASP_LOOP_WORKSPACE_JSON" "."

defaultBaselineWorkspace : Str
defaultBaselineWorkspace = {
  let candidate = pathJoin [stateRoot, "baseline-workspace"] in
  if length candidate < 96 then
    candidate
  else
    pathJoin ["/tmp", "clasp-feedback-loop-baselines", textFingerprint64Hex stateRoot]
}

baselineWorkspace : Str
baselineWorkspace = readEnvText "CLASP_LOOP_BASELINE_WORKSPACE_JSON" defaultBaselineWorkspace

builderSchemaPath : Str
builderSchemaPath = readEnvText "CLASP_LOOP_BUILDER_SCHEMA_JSON" "agents/schemas/builder-report.schema.json"

verifierSchemaPath : Str
verifierSchemaPath = readEnvText "CLASP_LOOP_VERIFIER_SCHEMA_JSON" "agents/schemas/verifier-report.schema.json"

codexBin : Str
codexBin = readEnvText "CLASP_LOOP_CODEX_BIN_JSON" "codex"

codexModel : Str
codexModel = readEnvText "CLASP_LOOP_CODEX_MODEL_JSON" "gpt-5.4"

codexReasoning : Str
codexReasoning = readEnvText "CLASP_LOOP_CODEX_REASONING_JSON" "medium"

codexSandbox : Str
codexSandbox = readEnvText "CLASP_LOOP_CODEX_SANDBOX_JSON" "danger-full-access"

watchPollMs : Int
watchPollMs = match envVar "CLASP_LOOP_WATCH_POLL_MS_JSON" {
  Ok raw -> decode Int raw,
  Err message -> 1000
}

maxAttempts : Int
maxAttempts = match envVar "CLASP_LOOP_MAX_ATTEMPTS_JSON" {
  Ok raw -> decode Int raw,
  Err message -> 20
}

commandName : Str
commandName = match envVar "CLASP_LOOP_COMMAND" {
  Ok raw -> raw,
  Err message -> "run"
}

feedbackPath : Str
feedbackPath = pathJoin [stateRoot, "feedback.json"]

builderPolicyPath : Str
builderPolicyPath = pathJoin [stateRoot, "builder-policy.md"]

verifierPolicyPath : Str
verifierPolicyPath = pathJoin [stateRoot, "verifier-policy.md"]

loopStatePath : Str
loopStatePath = pathJoin [stateRoot, "state.json"]

baselineReadyPath : Str
baselineReadyPath = pathJoin [stateRoot, "baseline.ready"]

baselineArchivePath : Str
baselineArchivePath = pathJoin [stateRoot, "baseline.tar"]

baselineDiffPath : Int -> Str
baselineDiffPath attempt = pathJoin [stateRoot, textConcat ["changes-", encode attempt, ".diff"]]

builderReportPath : Int -> Str
builderReportPath attempt = pathJoin [stateRoot, textConcat ["builder-", encode attempt, ".json"]]

builderStdoutPath : Int -> Str
builderStdoutPath attempt = pathJoin [stateRoot, textConcat ["builder-", encode attempt, ".stdout.jsonl"]]

builderStderrPath : Int -> Str
builderStderrPath attempt = pathJoin [stateRoot, textConcat ["builder-", encode attempt, ".stderr.log"]]

verifierReportPath : Int -> Str
verifierReportPath attempt = pathJoin [stateRoot, textConcat ["verifier-", encode attempt, ".json"]]

verifierStdoutPath : Int -> Str
verifierStdoutPath attempt = pathJoin [stateRoot, textConcat ["verifier-", encode attempt, ".stdout.jsonl"]]

verifierStderrPath : Int -> Str
verifierStderrPath attempt = pathJoin [stateRoot, textConcat ["verifier-", encode attempt, ".stderr.log"]]

builderHeartbeatPath : Int -> Str
builderHeartbeatPath attempt = pathJoin [stateRoot, textConcat ["builder-", encode attempt, ".heartbeat.json"]]

verifierHeartbeatPath : Int -> Str
verifierHeartbeatPath attempt = pathJoin [stateRoot, textConcat ["verifier-", encode attempt, ".heartbeat.json"]]

processStdoutPath : Str -> Int -> Str
processStdoutPath prefix attempt =
  if prefix == "builder" then
    builderStdoutPath attempt
  else
    verifierStdoutPath attempt

processStderrPath : Str -> Int -> Str
processStderrPath prefix attempt =
  if prefix == "builder" then
    builderStderrPath attempt
  else
    verifierStderrPath attempt

processHeartbeatPath : Str -> Int -> Str
processHeartbeatPath prefix attempt =
  if prefix == "builder" then
    builderHeartbeatPath attempt
  else
    verifierHeartbeatPath attempt

processReportPath : Str -> Int -> Str
processReportPath prefix attempt =
  if prefix == "builder" then
    builderReportPath attempt
  else
    verifierReportPath attempt

stepHandle : Str -> Int -> StepHandle
stepHandle prefix attempt =
  StepHandle {
    prefix = prefix,
    attempt = attempt,
    reportPath = processReportPath prefix attempt,
    stdoutPath = processStdoutPath prefix attempt,
    stderrPath = processStderrPath prefix attempt,
    heartbeatPath = processHeartbeatPath prefix attempt
  }

runProcess : Str -> [Str] -> ProcessResult
runProcess cwd command = match runCommandJson cwd command {
  Ok raw ->
    decode ProcessResult raw,
  Err message ->
    ProcessResult {
      exitCode = 1,
      stdout = "",
      stderr = message
    }
}

readTextOrEmpty : Str -> Str
readTextOrEmpty path = match readFile path {
  Ok raw ->
    raw,
  Err message ->
    ""
}

watchedProcessOk : WatchedProcess -> Result WatchedProcess
watchedProcessOk process = Ok process

watchedProcessError : Str -> Result WatchedProcess
watchedProcessError message = Err message

successProcessResult : StepHandle -> ProcessResult
successProcessResult step =
  ProcessResult {
    exitCode = 0,
    stdout = readTextOrEmpty step.stdoutPath,
    stderr = readTextOrEmpty step.stderrPath
  }

failedProcessResult : Str -> ProcessResult
failedProcessResult message =
  ProcessResult {
    exitCode = 1,
    stdout = "",
    stderr = message
  }

processResultFromStep : StepHandle -> Int -> ProcessResult
processResultFromStep step exitCode =
  ProcessResult {
    exitCode = exitCode,
    stdout = readTextOrEmpty step.stdoutPath,
    stderr = readTextOrEmpty step.stderrPath
  }

spawnStep : StepHandle -> [Str] -> Result WatchedProcess
spawnStep step command =
  spawn (watchedCommandSpec workspaceRoot step.stdoutPath step.stderrPath step.heartbeatPath watchPollMs command)

reconcileStep : StepHandle -> Result WatchedProcess
reconcileStep step = reconcile step.heartbeatPath

awaitStep : StepHandle -> Result WatchedProcess
awaitStep step = await step.heartbeatPath watchPollMs

resumeStep : StepHandle -> ProcessResult
resumeStep step = match awaitStep step {
  Ok process ->
    processResultFromStep step process.exitCode,
  Err message ->
    failedProcessResult message
}

launchStepAndAwait : StepHandle -> [Str] -> LoopState -> ProcessResult
launchStepAndAwait step command runningState =
  match spawnStep step command {
    Err message ->
      failedProcessResult message,
    Ok process ->
      let stateError = writeLoopState runningState in
      if stateError != "" then
        failedProcessResult stateError
      else
        resumeStep step
  }

ensureStepReport : StepHandle -> [Str] -> LoopState -> LoopState -> ProcessResult
ensureStepReport step command launchingState runningState =
  if fileExists step.reportPath then
    successProcessResult step
  else if fileExists step.heartbeatPath then {
    let reconciled = reconcileStep step in
    let resumed = resumeStep step in
    if fileExists step.reportPath then
      successProcessResult step
    else
      launchStepAndAwait step command runningState
  } else {
    let launchingStateError = writeLoopState launchingState in
    if launchingStateError != "" then
      failedProcessResult launchingStateError
    else {
      let launched = launchStepAndAwait step command runningState in
      if fileExists step.reportPath then
        successProcessResult step
      else
        launched
    }
  }

readVerifierReport : Int -> VerifierReport
readVerifierReport attempt = match readFile (verifierReportPath attempt) {
  Ok raw ->
    decode VerifierReport raw,
  Err message ->
    VerifierReport {
      verdict = "fail",
      summary = textConcat ["missing verifier report: ", message],
      findings = [message],
      tests_run = emptyTexts,
      follow_up = ["leave a verifier report at the configured path"],
      capability_statuses = emptyCapabilityStatuses
    }
}

readFeedbackText : Int -> Str
readFeedbackText attempt = match readFile feedbackPath {
  Ok raw ->
    raw,
  Err message ->
    ""
}

syntheticFailureReport : Str -> Str -> VerifierReport
syntheticFailureReport summary detail =
  VerifierReport {
    verdict = "fail",
    summary = summary,
    findings = [detail],
    tests_run = emptyTexts,
    follow_up = ["Retry the failed step after inspecting its stderr artifact and persisted heartbeat."],
    capability_statuses = emptyCapabilityStatuses
  }

defaultBuilderPolicyText : Str
defaultBuilderPolicyText = textJoin "\n" [
  "Close whole blocking capability categories rather than single complaint lines.",
  "Prefer code/runtime/compiler/example/test changes over docs-only movement.",
  "Use the previous verifier report as the primary steering input for the next attempt.",
  "Do not broaden backend-native swarm/runtime work into JavaScript-emitter parity unless the frontend compile target actually requires it.",
  "Treat Compiler.Emit.JavaScript as the frontend/client emitter, not as a backend execution path."
]

defaultVerifierPolicyText : Str
defaultVerifierPolicyText = textJoin "\n" [
  "Judge the whole repository, not only the latest diff.",
  "Group failures by capability category.",
  "Do not fail merely because legacy helper scripts remain in the repo if the ordinary-program path is complete and not required.",
  "Do not demand JavaScript-emitter parity for backend-native swarm/runtime capabilities unless the task explicitly requires frontend/client support."
]

readPolicyText : Str -> Str -> Str
readPolicyText path fallback = match readFile path {
  Ok raw ->
    raw,
  Err message ->
    fallback
}

ensurePolicyFile : Str -> Str -> Str
ensurePolicyFile path fallback =
  if fileExists path then
    ""
  else
    match writeFile path fallback {
      Ok written ->
        "",
      Err message ->
        message
    }

ensurePolicies : Str
ensurePolicies = {
  let builderError = ensurePolicyFile builderPolicyPath defaultBuilderPolicyText in
  if builderError != "" then
    builderError
  else
    ensurePolicyFile verifierPolicyPath defaultVerifierPolicyText
}

capabilityChecklist : [Str]
capabilityChecklist = [
  "ordinary_program_execution: the live builder/verifier loop runs as a normal Clasp program via claspc run, invokes Codex directly from Clasp, and persists durable final state/status in ordinary runtime storage.",
  "durable_native_substrate: objective/run/task/event/artifact persistence, DAG edges, projected status, leases, approvals, merge-policy state, tool/process execution, and monitoring/state inspection are durably available.",
  "clasp_native_control_api: ordinary Clasp programs can use the orchestration substrate directly without requiring shell wrapper orchestration or external claspc swarm subprocesses as the primary model.",
  "orchestration_viability: builder/verifier/planner-style programs are realistically implementable in Clasp itself without obvious missing runtime/control-plane substrate.",
  "ergonomics: Dict state, empty lists, polymorphic collections, and record update/destructuring are usable enough for state-heavy orchestration code.",
  "verification_gate: scenario-level coverage exists for the ordinary-program loop path and new runtime/workflow/control-plane behavior, and bash scripts/verify-all.sh passes."
]

capabilityChecklistText : Str
capabilityChecklistText = textJoin "\n" [
  "- ordinary_program_execution: the live builder/verifier loop runs as a normal Clasp program via claspc run, invokes Codex directly from Clasp, and persists durable final state/status in ordinary runtime storage.",
  "- durable_native_substrate: objective/run/task/event/artifact persistence, DAG edges, projected status, leases, approvals, merge-policy state, tool/process execution, and monitoring/state inspection are durably available.",
  "- clasp_native_control_api: ordinary Clasp programs can use the orchestration substrate directly without requiring shell wrapper orchestration or external claspc swarm subprocesses as the primary model.",
  "- orchestration_viability: builder/verifier/planner-style programs are realistically implementable in Clasp itself without obvious missing runtime/control-plane substrate.",
  "- ergonomics: Dict state, empty lists, polymorphic collections, and record update/destructuring are usable enough for state-heavy orchestration code.",
  "- verification_gate: scenario-level coverage exists for the ordinary-program loop path and new runtime/workflow/control-plane behavior, and bash scripts/verify-all.sh passes."
]

builderEscalationText : Int -> Str
builderEscalationText attempt =
  if attempt < 3 then
    "Prefer closing at least one whole failing capability category this attempt, not just one complaint line."
  else
    textJoin "\n" [
      "You have already seen multiple verifier failures.",
      "Escalate to closing an entire blocking capability category even if that requires coordinated compiler/runtime/example/test/doc changes in one slice.",
      "Do not spend this attempt on docs-only, wrapper-only, or single-harness-only fixes unless the previous verifier report makes clear that such a fix is the only remaining blocker."
    ]

builderFeedbackSection : Int -> Str
builderFeedbackSection attempt =
  if readFeedbackText attempt == "" then
    "No previous verifier feedback is present yet."
  else
    textJoin "\n" [
      "Verifier feedback from the previous attempt:",
      readFeedbackText attempt
    ]

builderPolicySection : Int -> Str
builderPolicySection attempt =
  textJoin "\n" [
    textConcat ["Current builder policy from ", builderPolicyPath, ":"],
    readPolicyText builderPolicyPath defaultBuilderPolicyText
  ]

verifierPolicySection : Int -> Str
verifierPolicySection attempt =
  textJoin "\n" [
    textConcat ["Current verifier policy from ", verifierPolicyPath, ":"],
    readPolicyText verifierPolicyPath defaultVerifierPolicyText
  ]

loopState : Int -> Str -> Str -> Bool -> Int -> Int -> Bool -> Bool -> Str -> Bool -> LoopState
loopState attempt phase verdict completed builderRuns verifierRuns healthy needsAttention attentionReason final =
  LoopState {
    attempt = attempt,
    phase = phase,
    verdict = verdict,
    completed = completed,
    builderRuns = builderRuns,
    verifierRuns = verifierRuns,
    healthy = healthy,
    needsAttention = needsAttention,
    attentionReason = attentionReason,
    final = final
  }

emptyLoopState : LoopState
emptyLoopState = loopState 1 "needs-builder" "pending" false 0 0 true false "" false

writeLoopState : LoopState -> Str
writeLoopState state = match writeFile loopStatePath (encode state) {
  Ok written ->
    "",
  Err message ->
    message
}

readLoopState : LoopState
readLoopState = match readFile loopStatePath {
  Ok raw ->
    decode LoopState raw,
  Err message ->
    emptyLoopState
}

incrementAttempt : Int -> Int
incrementAttempt value =
  if value == 0 then
    1
  else if value == 1 then
    2
  else if value == 2 then
    3
  else if value == 3 then
    4
  else if value == 4 then
    5
  else if value == 5 then
    6
  else if value == 6 then
    7
  else if value == 7 then
    8
  else if value == 8 then
    9
  else if value == 9 then
    10
  else if value == 10 then
    11
  else if value == 11 then
    12
  else if value == 12 then
    13
  else if value == 13 then
    14
  else if value == 14 then
    15
  else if value == 15 then
    16
  else if value == 16 then
    17
  else if value == 17 then
    18
  else if value == 18 then
    19
  else if value == 19 then
    20
  else
    value

codexReasoningConfig : Str
codexReasoningConfig = textConcat ["model_reasoning_effort=\"", codexReasoning, "\""]

codexCommand : Str -> Str -> Str -> [Str]
codexCommand schemaPath reportPath prompt = [
  codexBin,
  "exec",
  "--json",
  "--cd",
  workspaceRoot,
  "-m",
  codexModel,
  "-c",
  codexReasoningConfig,
  "--skip-git-repo-check",
  "--sandbox",
  codexSandbox,
  "--ephemeral",
  "--output-schema",
  schemaPath,
  "-o",
  reportPath,
  prompt
]

baselineExcludeFlags : Str
baselineExcludeFlags =
  textConcat [
    "--exclude=.git ",
    "--exclude=*/.git ",
    "--exclude=.clasp-agents ",
    "--exclude=*/.clasp-agents ",
    "--exclude=.clasp-loops ",
    "--exclude=*/.clasp-loops ",
    "--exclude=.clasp-swarm ",
    "--exclude=*/.clasp-swarm ",
    "--exclude=.clasp-test-tmp ",
    "--exclude=*/.clasp-test-tmp ",
    "--exclude=.clasp-verify-tmp ",
    "--exclude=*/.clasp-verify-tmp ",
    "--exclude=dist ",
    "--exclude=*/dist ",
    "--exclude=dist-newstyle ",
    "--exclude=*/dist-newstyle ",
    "--exclude=result ",
    "--exclude=*/result ",
    "--exclude=runtime/target ",
    "--exclude=*/runtime/target ",
    "--exclude=node_modules ",
    "--exclude=*/node_modules ",
    "--exclude=__serve-native-export-host ",
    "--exclude=*/__serve-native-export-host ",
    "--exclude=exec-image ",
    "--exclude=*/exec-image ",
    "--exclude=feedback-loop-state ",
    "--exclude=*/feedback-loop-state ",
    "--exclude=swarm-native-state ",
    "--exclude=*/swarm-native-state ",
    "--exclude=help ",
    "--exclude=*/help ",
    "--exclude=src/native-verify-cache ",
    "--exclude=*/src/native-verify-cache "
  ]

refreshBaselineDiff : Int -> ProcessResult
refreshBaselineDiff attempt =
  runProcess workspaceRoot [
    "bash",
    "-lc",
    textConcat [
      "diff -ruN ",
      baselineExcludeFlags,
      baselineWorkspace,
      " ",
      workspaceRoot,
      " > ",
      baselineDiffPath attempt,
      "; status=$?; if [ \"$status\" -eq 0 ] || [ \"$status\" -eq 1 ]; then exit 0; else exit \"$status\"; fi"
    ]
  ]

builderPrompt : Int -> Str
builderPrompt attempt =
  textJoin "\n" [
    "You are the builder subagent for the Clasp repository.",
    "Read AGENTS.md first if it exists.",
    textConcat ["Read the task file at ", taskFile, "."],
    "Drive the repository toward the full task goal, not just the smallest local diff that would satisfy one verifier complaint.",
    "Work only in the current checkout.",
    "Keep changes coherent and scoped, but prefer closing an entire blocking capability category over a tiny local patch.",
    "Add or update tests for changed behavior.",
    "Run the narrowest checks that cover your changes before finishing.",
    "Do not run bash scripts/verify-all.sh; the verifier owns the repo-wide gate.",
    "Do not assume that a docs tweak or one wrapper fix is enough if the previous verifier report still shows a broader architectural blocker.",
    "Capability categories to close:",
    capabilityChecklistText,
    builderEscalationText attempt,
    builderPolicySection attempt,
    builderFeedbackSection attempt,
    "Return JSON matching the provided output schema.",
    "Include the required feedback object in your final JSON.",
    textConcat ["Attempt: ", encode attempt]
  ]

verifierPrompt : Int -> Str
verifierPrompt attempt =
  textJoin "\n" [
    "You are the verifier subagent for the Clasp repository.",
    "Read AGENTS.md first if it exists.",
    textConcat ["Read the task file at ", taskFile, "."],
    textConcat ["Review the changes since the baseline snapshot at ", baselineWorkspace, " using the focused diff artifact at ", baselineDiffPath attempt, "."],
    textConcat ["That artifact is generated from diff -ruN with the loop's transient/generated-directory exclusions. If you need to rerun the diff manually, use the same exclusions rather than diffing transient trees."],
    "Use the diff to understand what changed, but judge pass or fail against the full repository state and the full task acceptance criteria.",
    "Do not pass because the latest diff is locally good if the repository still falls short of the overall task goal.",
    "Before returning pass, explicitly verify every required capability listed in the task file and fail if any are missing, partial, or only scaffolded.",
    "Judge legacy shell wrapper scripts as supporting artifacts only. Fail on shell usage only if the required ordinary-program path is absent, incomplete, or still the primary required orchestration path.",
    "Do not fail solely because an internal native lane uses JSON-shaped values. Fail only if real orchestration logic is still forced back into shell/CLI glue or cannot be implemented cleanly as an ordinary Clasp program.",
    "Capability categories to judge:",
    capabilityChecklistText,
    builderPolicySection attempt,
    verifierPolicySection attempt,
    "Run the narrowest verification needed to decide pass or fail.",
    "Treat missing scenario-level coverage for runtime, workflow, trust-boundary, interop, or app-surface changes as a defect.",
    "Before returning pass, run bash scripts/verify-all.sh successfully in the current checkout.",
    "Return capability_statuses with one entry for every capability category above.",
    "Each capability_statuses entry must include name, status, evidence, blocking_gaps, and required_closure.",
    "Use status pass only when that whole category is convincingly closed in the current repository state; otherwise use fail.",
    "When failing, make follow_up and required_closure aim at closing whole blocking categories, not single complaint lines.",
    textConcat ["If repeated failures indicate a policy problem, you may edit ", builderPolicyPath, " and/or ", verifierPolicyPath, " directly so the next attempt runs with improved policy. Mention any policy edits you make in your report."],
    "Return JSON matching the provided output schema.",
    textConcat ["Attempt: ", encode attempt]
  ]

ensureBaseline : ProcessResult
ensureBaseline =
  if fileExists baselineReadyPath then
    ProcessResult { exitCode = 0, stdout = baselineWorkspace, stderr = "" }
  else {
    let removed = runProcess workspaceRoot ["rm", "-rf", baselineWorkspace, baselineArchivePath] in
    if removed.exitCode != 0 then
      removed
    else {
      let created = runProcess workspaceRoot ["mkdir", "-p", baselineWorkspace] in
      if created.exitCode != 0 then
        created
      else {
        let streamed = runProcess workspaceRoot [
          "bash",
          "-lc",
          textConcat [
            "tar -cf - ",
            baselineExcludeFlags,
            ". | tar -xf - -C ",
            baselineWorkspace
          ]
        ] in
        if streamed.exitCode != 0 then
          streamed
        else
          match writeFile baselineReadyPath "ready" {
            Ok written ->
              ProcessResult { exitCode = 0, stdout = baselineWorkspace, stderr = "" },
            Err message ->
              ProcessResult { exitCode = 1, stdout = "", stderr = message }
          }
      }
    }
  }

ensureLoopReady : Str
ensureLoopReady =
  if taskFile == "" then
    "config-error:missing-task-file"
  else if workspaceRoot == "" then
    "config-error:missing-workspace-root"
  else {
    match mkdirAll stateRoot {
      Err message ->
        textConcat ["state-root-error:", message],
      Ok created ->
        let baselineResult = ensureBaseline in
        if baselineResult.exitCode != 0 then
          textConcat ["baseline-error:", baselineResult.stderr]
        else {
          let policyError = ensurePolicies in
          if policyError != "" then
            textConcat ["policy-error:", policyError]
          else
            ""
        }
    }
  }

persistFailureAndContinue : Int -> VerifierReport -> Str
persistFailureAndContinue attempt report = {
  let isFinalAttempt = attempt == maxAttempts;
  let nextState =
    if isFinalAttempt then
      loopState attempt "failed" "fail" false attempt attempt false true report.summary true
    else
      loopState (incrementAttempt attempt) "needs-builder" "retry" false attempt attempt false true report.summary false;
  let stateError = writeLoopState nextState in
  if stateError != "" then
    textConcat ["state-error:", stateError]
  else
    match writeFile feedbackPath (encode report) {
      Ok written ->
        if isFinalAttempt then
          textConcat ["fail:", encode attempt]
        else
          runAttempt (incrementAttempt attempt),
      Err message ->
        textConcat ["feedback-error:", message]
    }
}

finishPass : Int -> VerifierReport -> Str
finishPass attempt report =
  match writeFile feedbackPath (encode report) {
    Err message ->
      textConcat ["feedback-error:", message],
    Ok written ->
      let stateError = writeLoopState (loopState attempt "completed" "pass" true attempt attempt true false "" true) in
      if stateError != "" then
        textConcat ["state-error:", stateError]
      else
        textConcat ["pass:", encode attempt]
  }

runVerifierPhase : Int -> Str
runVerifierPhase attempt =
  if attempt > maxAttempts then
    textConcat ["fail:", encode maxAttempts]
  else {
    let prepError = ensureLoopReady in
    if prepError != "" then
      prepError
    else {
      let diffResult = refreshBaselineDiff attempt in
      if diffResult.exitCode != 0 then
        textConcat ["diff-error:", diffResult.stderr]
      else {
      let verifierStep = stepHandle "verifier" attempt;
      let verifierRun =
        ensureStepReport
          verifierStep
          (codexCommand verifierSchemaPath verifierStep.reportPath (verifierPrompt attempt))
          (loopState attempt "verifier-launching" "pending" false attempt attempt true false "" false)
          (loopState attempt "verifier-running" "pending" false attempt attempt true false "" false) in
      if fileExists verifierStep.reportPath then {
        let report = readVerifierReport attempt in
        if report.verdict == "pass" then
          finishPass attempt report
        else
          persistFailureAndContinue attempt report
      } else
          persistFailureAndContinue
            attempt
            (syntheticFailureReport
              "verifier step failed before producing a durable report"
              verifierRun.stderr)
      }
    }
  }

runBuilderPhase : Int -> Str
runBuilderPhase attempt =
  if attempt > maxAttempts then
    textConcat ["fail:", encode maxAttempts]
  else {
    let prepError = ensureLoopReady in
    if prepError != "" then
      prepError
    else {
      let builderStep = stepHandle "builder" attempt in
      if fileExists builderStep.reportPath then
        runVerifierPhase attempt
      else {
        let builderRun =
          ensureStepReport
            builderStep
            (codexCommand builderSchemaPath builderStep.reportPath (builderPrompt attempt))
            (loopState attempt "builder-launching" "pending" false attempt 0 true false "" false)
            (loopState attempt "builder-running" "pending" false attempt 0 true false "" false) in
        if fileExists builderStep.reportPath then
          runVerifierPhase attempt
        else
          persistFailureAndContinue
            attempt
            (syntheticFailureReport
              "builder step failed before producing a durable report"
              builderRun.stderr)
      }
    }
  }

runAttempt : Int -> Str
runAttempt attempt = runBuilderPhase attempt

resumeLoop : LoopState -> Str
resumeLoop state =
  if state.final then
    if state.verdict == "pass" then
      textConcat ["pass:", encode state.attempt]
    else if state.verdict == "fail" then
      textConcat ["fail:", encode state.attempt]
    else
      runAttempt state.attempt
  else if state.phase == "builder-running" then
    runBuilderPhase state.attempt
  else if state.phase == "builder-launching" then
    runBuilderPhase state.attempt
  else if state.phase == "verifier-running" then
    runVerifierPhase state.attempt
  else if state.phase == "verifier-launching" then
    runVerifierPhase state.attempt
  else if state.attempt == 0 then
    runAttempt 1
  else
    runAttempt state.attempt

main : Str
main =
  if commandName == "status" then
    encode readLoopState
  else
    resumeLoop readLoopState

-- CLASP_PROJECT_MODULE --
module Process

foreign runCommandRaw : Str -> [Str] -> Result Str = "runCommandJson"
foreign spawnCommandRaw : Str -> Str -> Str -> Str -> Int -> [Str] -> Result Str = "spawnCommandJson"
foreign watchCommandRaw : Str -> Str -> Str -> Str -> Int -> [Str] -> Result Str = "watchCommandJson"
foreign reconcileWatchedProcessRaw : Str -> Result Str = "reconcileWatchedProcessJson"
foreign awaitWatchedProcessRaw : Str -> Int -> Result Str = "awaitWatchedProcessJson"

record ProcessResult = { exitCode : Int, stdout : Str, stderr : Str }

record WatchedProcess = {
  pid : Int,
  running : Bool,
  completed : Bool,
  exitCode : Int,
  stdoutPath : Str,
  stderrPath : Str,
  heartbeatPath : Str,
  updatedAtMs : Int
}

record CommandSpec = { cwd : Str, command : [Str] }

record WatchedCommandSpec = {
  cwd : Str,
  stdoutPath : Str,
  stderrPath : Str,
  heartbeatPath : Str,
  watchPollMs : Int,
  command : [Str]
}

processResultError : Str -> Result ProcessResult
processResultError message = Err message

watchedProcessError : Str -> Result WatchedProcess
watchedProcessError message = Err message

commandSpec : Str -> [Str] -> CommandSpec
commandSpec cwd command = CommandSpec { cwd = cwd, command = command }

watchedCommandSpec : Str -> Str -> Str -> Str -> Int -> [Str] -> WatchedCommandSpec
watchedCommandSpec cwd stdoutPath stderrPath heartbeatPath watchPollMs command =
  WatchedCommandSpec {
    cwd = cwd,
    stdoutPath = stdoutPath,
    stderrPath = stderrPath,
    heartbeatPath = heartbeatPath,
    watchPollMs = watchPollMs,
    command = command
  }

processResult : Result Str -> Result ProcessResult
processResult value = match value {
  Ok raw -> Ok (decode ProcessResult raw),
  Err message -> processResultError message
}

watchedProcessResult : Result Str -> Result WatchedProcess
watchedProcessResult value = match value {
  Ok raw -> Ok (decode WatchedProcess raw),
  Err message -> watchedProcessError message
}

run : CommandSpec -> Result ProcessResult
run spec = processResult (runCommandRaw spec.cwd spec.command)

spawn : WatchedCommandSpec -> Result WatchedProcess
spawn spec =
  watchedProcessResult (
    spawnCommandRaw
      spec.cwd
      spec.stdoutPath
      spec.stderrPath
      spec.heartbeatPath
      spec.watchPollMs
      spec.command
  )

watch : WatchedCommandSpec -> Result WatchedProcess
watch spec =
  watchedProcessResult (
    watchCommandRaw
      spec.cwd
      spec.stdoutPath
      spec.stderrPath
      spec.heartbeatPath
      spec.watchPollMs
      spec.command
  )

reconcile : Str -> Result WatchedProcess
reconcile heartbeatPath = watchedProcessResult (reconcileWatchedProcessRaw heartbeatPath)

await : Str -> Int -> Result WatchedProcess
await heartbeatPath watchPollMs =
  watchedProcessResult (awaitWatchedProcessRaw heartbeatPath watchPollMs)
