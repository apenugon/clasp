module Main

import Shared.User
import Shared.Render

main : Str
main = renderUser defaultUser

-- CLASP_PROJECT_MODULE --
module Shared.User

record User = { name : Str }

defaultUser : User
defaultUser = User { name = "operator" }

-- CLASP_PROJECT_MODULE --
module Shared.Render

import Shared.User

renderUser : User -> Str
renderUser user = user.name
