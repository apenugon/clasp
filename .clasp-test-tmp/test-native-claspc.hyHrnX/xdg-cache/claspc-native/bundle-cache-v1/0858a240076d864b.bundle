module Main

import Shared.Lead

foreign mockLeadSummaryModel : LeadIntake -> Str = "mockLeadSummaryModel"
foreign mockLeadOutreachModel : LeadOutreachRequest -> Str = "mockLeadOutreachModel"
foreign storeLead : LeadIntake -> LeadSummary -> Str = "storeLead"
foreign loadInbox : Empty -> Str = "loadInbox"
foreign loadPrimaryLead : Empty -> Str = "loadPrimaryLead"
foreign loadSecondaryLead : Empty -> Str = "loadSecondaryLead"
foreign reviewLead : LeadReview -> Str = "reviewLead"

policy LeadAssistOps = public permits {
  process "node"
}

toolserver LeadAssistTools = "mcp" "stdio://lead-assist-tools" with LeadAssistOps

tool lookupLeadPlaybook = LeadAssistTools "lookup_lead_playbook" LeadPlaybookLookup -> LeadPlaybook

summarizeLead : LeadIntake -> LeadSummary
summarizeLead intake = decode LeadSummary (mockLeadSummaryModel intake)

createLead : LeadIntake -> LeadRecord
createLead intake = decode LeadRecord (storeLead intake (summarizeLead intake))

inboxSnapshot : Empty -> InboxSnapshot
inboxSnapshot req = decode InboxSnapshot (loadInbox req)

primaryLead : Empty -> LeadRecord
primaryLead req = decode LeadRecord (loadPrimaryLead req)

secondaryLead : Empty -> LeadRecord
secondaryLead req = decode LeadRecord (loadSecondaryLead req)

reviewedLead : LeadReview -> LeadRecord
reviewedLead review = decode LeadRecord (reviewLead review)

leadPlaybookRequest : LeadRecord -> LeadPlaybookLookup
leadPlaybookRequest lead = LeadPlaybookLookup {
  segment = lead.segment,
  priority = lead.priority
}

leadPriorityLabel : LeadPriority -> Str
leadPriorityLabel priority = match priority {
  Low -> "low",
  Medium -> "medium",
  High -> "high"
}

leadSegmentLabel : LeadSegment -> Str
leadSegmentLabel segment = match segment {
  Startup -> "startup",
  Growth -> "growth",
  Enterprise -> "enterprise"
}

outreachPrompt : LeadRecord -> LeadPlaybook -> Prompt
outreachPrompt lead playbook = appendPrompt (appendPrompt (appendPrompt (appendPrompt (appendPrompt (appendPrompt (systemPrompt "You are the lead outreach assistant.") (assistantPrompt lead.company)) (assistantPrompt lead.summary)) (assistantPrompt (leadPriorityLabel lead.priority))) (assistantPrompt (leadSegmentLabel lead.segment))) (assistantPrompt playbook.guidance)) (userPrompt playbook.callToAction)

outreachPromptText : LeadRecord -> LeadPlaybook -> Str
outreachPromptText lead playbook = promptText (outreachPrompt lead playbook)

leadOutreachRequest : LeadRecord -> LeadPlaybook -> LeadOutreachRequest
leadOutreachRequest lead playbook = LeadOutreachRequest {
  leadId = lead.leadId,
  company = lead.company,
  contact = lead.contact,
  summary = lead.summary,
  priorityLabel = leadPriorityLabel lead.priority,
  segmentLabel = leadSegmentLabel lead.segment,
  channel = playbook.channel,
  guidance = playbook.guidance,
  callToAction = playbook.callToAction,
  promptText = outreachPromptText lead playbook
}

draftLeadOutreach : LeadRecord -> LeadPlaybook -> LeadOutreachDraft
draftLeadOutreach lead playbook = decode LeadOutreachDraft (mockLeadOutreachModel (leadOutreachRequest lead playbook))

workflow LeadFollowUpFlow = { state : LeadFollowUpState }

landingPage : Empty -> Page
landingPage req = renderLandingPage (inboxSnapshot req)

inboxPage : Empty -> Page
inboxPage req = renderInboxPage (inboxSnapshot req)

primaryLeadPage : Empty -> Page
primaryLeadPage req = renderLeadPage (primaryLead req)

secondaryLeadPage : Empty -> Page
secondaryLeadPage req = renderLeadPage (secondaryLead req)

createLeadPage : LeadIntake -> Page
createLeadPage intake = renderLeadPage (createLead intake)

reviewLeadPage : LeadReview -> Page
reviewLeadPage review = renderLeadPage (reviewedLead review)

route landingRoute = GET "/" Empty -> Page landingPage
route inboxRoute = GET "/inbox" Empty -> Page inboxPage
route primaryLeadRoute = GET "/lead/primary" Empty -> Page primaryLeadPage
route secondaryLeadRoute = GET "/lead/secondary" Empty -> Page secondaryLeadPage
route createLeadRoute = POST "/leads" LeadIntake -> Page createLeadPage
route reviewLeadRoute = POST "/review" LeadReview -> Page reviewLeadPage
route inboxSnapshotRoute = GET "/api/inbox" Empty -> InboxSnapshot inboxSnapshot
route primaryLeadRecordRoute = GET "/api/lead/primary" Empty -> LeadRecord primaryLead
route secondaryLeadRecordRoute = GET "/api/lead/secondary" Empty -> LeadRecord secondaryLead
route createLeadRecordRoute = POST "/api/leads" LeadIntake -> LeadRecord createLead
route reviewLeadRecordRoute = POST "/api/review" LeadReview -> LeadRecord reviewedLead

-- CLASP_PROJECT_MODULE --
module Shared.Lead

record Empty = {}

type LeadPriority = Low | Medium | High
type LeadSegment = Startup | Growth | Enterprise

type ReviewStatus = New | Reviewed

record LeadIntake = {
  company : Str,
  contact : Str,
  budget : Int,
  segment : LeadSegment
}

record LeadReview = {
  leadId : Str,
  note : Str
}

record LeadSummary = {
  summary : Str,
  priority : LeadPriority,
  segment : LeadSegment,
  followUpRequired : Bool
}

record LeadRecord = {
  leadId : Str,
  company : Str,
  contact : Str,
  summary : Str,
  priority : LeadPriority,
  segment : LeadSegment,
  followUpRequired : Bool,
  reviewStatus : ReviewStatus,
  reviewNote : Str
}

record LeadFollowUpState = {
  leadId : Str,
  company : Str,
  priority : LeadPriority,
  segment : LeadSegment,
  reviewStatus : ReviewStatus,
  reviewNote : Str,
  nextAction : Str,
  touchCount : Int
}

record InboxSnapshot = {
  headline : Str,
  primaryLeadLabel : Str,
  secondaryLeadLabel : Str
}

record LeadPlaybookLookup = {
  segment : LeadSegment,
  priority : LeadPriority
}

record LeadPlaybook = {
  channel : Str,
  guidance : Str,
  callToAction : Str
}

record LeadOutreachRequest = {
  leadId : Str,
  company : Str,
  contact : Str,
  summary : Str,
  priorityLabel : Str,
  segmentLabel : Str,
  channel : Str,
  guidance : Str,
  callToAction : Str,
  promptText : Str
}

record LeadOutreachDraft = {
  leadId : Str,
  channel : Str,
  subject : Str,
  message : Str,
  callToAction : Str
}

renderLandingPage : InboxSnapshot -> Page
renderLandingPage inbox = page "Lead inbox" (styled "lead_shell" (element "main" (append (element "h1" (text "Lead inbox")) (append (element "p" (text "Capture a lead, score it once, and review it on the server.")) (append intakeSection (append (element "h2" (text inbox.headline)) (append (inboxLinks inbox) (element "p" (link "/inbox" (text "Open the inbox page"))))))))))

renderInboxPage : InboxSnapshot -> Page
renderInboxPage inbox = page "Inbox" (styled "lead_shell" (element "main" (append (element "h1" (text inbox.headline)) (append (element "p" (text "Open a seeded lead or create a new one from the intake page.")) (append (inboxLinks inbox) (element "p" (link "/" (text "Back to intake"))))))))

renderLeadPage : LeadRecord -> Page
renderLeadPage lead = page lead.company (styled "lead_shell" (element "main" (append (element "h1" (text lead.company)) (append (element "p" (text lead.contact)) (append (priorityView lead.priority) (append (segmentView lead.segment) (append (element "p" (text lead.summary)) (append (reviewStatusView lead) (append (reviewForm lead) (element "p" (link "/inbox" (text "Back to inbox"))))))))))))

intakeForm : View
intakeForm = form "POST" "/leads" (element "section" (append (element "label" (append (text "Company") (input "company" "text" ""))) (append (element "label" (append (text "Contact") (input "contact" "text" ""))) (append (element "label" (append (text "Budget") (input "budget" "number" ""))) (append (element "label" (append (text "Segment") (input "segment" "text" ""))) (submit "Create lead"))))))

intakeSection : View
intakeSection = element "section" (append (element "h2" (text "New lead")) intakeForm)

inboxLinks : InboxSnapshot -> View
inboxLinks inbox = element "nav" (append (element "p" (link "/lead/primary" (text inbox.primaryLeadLabel))) (element "p" (link "/lead/secondary" (text inbox.secondaryLeadLabel))))

priorityView : LeadPriority -> View
priorityView priority = match priority {
  Low -> element "p" (text "Priority: low"),
  Medium -> element "p" (text "Priority: medium"),
  High -> element "p" (text "Priority: high")
}

segmentView : LeadSegment -> View
segmentView segment = match segment {
  Startup -> element "p" (text "Segment: startup"),
  Growth -> element "p" (text "Segment: growth"),
  Enterprise -> element "p" (text "Segment: enterprise")
}

reviewStatusView : LeadRecord -> View
reviewStatusView lead = match lead.reviewStatus {
  New -> element "section" (append (element "p" (text "Review status: new")) (element "p" (text "Add an internal note before handing this lead off."))),
  Reviewed -> element "section" (append (element "p" (text "Review status: reviewed")) (element "p" (text lead.reviewNote)))
}

reviewForm : LeadRecord -> View
reviewForm lead = form "POST" "/review" (element "section" (append (input "leadId" "hidden" lead.leadId) (append (element "label" (append (text "Review note") (input "note" "text" lead.reviewNote))) (submit "Save review"))))
